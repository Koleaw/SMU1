---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileMenu from '../components/MobileMenu.astro';
import { withBase } from '../utils/withBase';
import yandex from '../data/yandex.json';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/assets/images/placeholders/og-default.svg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Exo+2:wght@500;600;700&family=Manrope:wght@400&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/assets/brand/favicon.svg')} />
    <link rel="canonical" href={canonical.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(withBase(ogImage), Astro.site).toString()} />
    <!-- Yandex.Metrika counter -->
    <script
      is:inline
      define:vars={{
        metrikaCounterId: yandex.metrika.counterId,
        metrikaScriptSrc: yandex.metrika.scriptSrc
      }}
    >
      (function(m, e, t, r, i, k, a) {
        m[i] = m[i] || function() {
          (m[i].a = m[i].a || []).push(arguments);
        };
        m[i].l = 1 * new Date();
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return;
          }
        }
        k = e.createElement(t), a = e.getElementsByTagName(t)[0], k.async = 1, k.src = r, a.parentNode.insertBefore(k, a);
      })(window, document, 'script', metrikaScriptSrc, 'ym');

      ym(metrikaCounterId, 'init', {
        ssr: true,
        webvisor: true,
        clickmap: true,
        ecommerce: 'dataLayer',
        referrer: document.referrer,
        url: location.href,
        accurateTrackBounce: true,
        trackLinks: true
      });
    </script>
    <!-- /Yandex.Metrika counter -->
  </head>
  <body>
    <noscript><div><img src={`https://mc.yandex.ru/watch/${yandex.metrika.counterId}`} style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <Header />
    <MobileMenu />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
