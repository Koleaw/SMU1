---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileMenu from '../components/MobileMenu.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { withBase } from '../utils/withBase';
import yandex from '../data/yandex.json';
import siteSettings from '../content/site-settings/global.json';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  robots?: string;
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = '/assets/images/placeholders/og-default.svg',
  robots,
  noindex = false,
  structuredData
} = Astro.props;

const pageTitle = title?.trim() || 'СМУ-1';
const pageDescription =
  description?.trim() ||
  'СМУ-1: производство металлоконструкций, уличной мебели, ограждений и изделий для благоустройства.';
const canonical = new URL(Astro.url.pathname, Astro.site);
const canonicalUrl = canonical.toString();
const robotsContent = robots || (noindex ? 'noindex, nofollow' : undefined);
const toAbsoluteUrl = (path: string) => {
  if (/^https?:\/\//i.test(path)) return path;
  return new URL(withBase(path), Astro.site).toString();
};
const ogImageUrl = toAbsoluteUrl(ogImage);

const settings = siteSettings;
const siteRoot = new URL(withBase('/'), Astro.site).toString();
const isHomePage = Astro.url.pathname === withBase('/');
const organizationData = {
  '@type': 'LocalBusiness',
  '@id': `${siteRoot}#organization`,
  name: settings.companyName || 'СМУ-1',
  url: siteRoot,
  telephone: settings.phonePrimary,
  email: settings.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: settings.address || settings.legalAddress,
    addressLocality: settings.city || 'Курган',
    addressCountry: 'RU'
  },
  sameAs: [settings.telegram].filter(Boolean)
};
const websiteData = isHomePage
  ? {
      '@type': 'WebSite',
      '@id': `${siteRoot}#website`,
      name: settings.companyName || 'СМУ-1',
      url: siteRoot,
      publisher: {
        '@id': `${siteRoot}#organization`
      }
    }
  : null;
const extraStructuredData = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const jsonLdGraph = [organizationData, websiteData, ...extraStructuredData].filter(Boolean);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@600&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    {robotsContent && <meta name="robots" content={robotsContent} />}
    <link rel="icon" type="image/svg+xml" href={withBase('/assets/brand/favicon.svg')} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script type="application/ld+json" set:html={JSON.stringify({ '@context': 'https://schema.org', '@graph': jsonLdGraph })} />
    <script
      is:inline
      define:vars={{
        metrikaCounterId: yandex.metrika.counterId,
        metrikaScriptSrc: yandex.metrika.scriptSrc,
        metrikaInit: yandex.metrika.init,
        metrikaDelayMs: 7000
      }}
    >
      (() => {
        const stateKey = '__smu1MetrikaState';
        window[stateKey] = window[stateKey] || { loaded: false, timer: null };
        const state = window[stateKey];

        const loadMetrika = () => {
          if (state.loaded || !metrikaCounterId || !metrikaScriptSrc) return;
          state.loaded = true;

          (function(m, e, t, r, i, k, a) {
            m[i] = m[i] || function() {
              (m[i].a = m[i].a || []).push(arguments);
            };
            m[i].l = 1 * new Date();
            for (let j = 0; j < document.scripts.length; j++) {
              if (document.scripts[j].src === r) {
                return;
              }
            }
            k = e.createElement(t);
            a = e.getElementsByTagName(t)[0];
            k.async = 1;
            k.src = r;
            a.parentNode.insertBefore(k, a);
          })(window, document, 'script', metrikaScriptSrc, 'ym');

          window.ym(metrikaCounterId, 'init', {
            ...metrikaInit,
            referrer: document.referrer,
            url: location.href
          });
        };

        const scheduleMetrika = () => {
          if (state.loaded || state.timer) return;
          state.timer = window.setTimeout(() => {
            state.timer = null;
            loadMetrika();
          }, metrikaDelayMs);
        };

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', scheduleMetrika, { once: true });
        } else {
          scheduleMetrika();
        }

        document.addEventListener('astro:page-load', scheduleMetrika);
      })();
    </script>
  </head>
  <body>
    <Header />
    <MobileMenu />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
    <script is:inline>
      (() => {
        const revealSelector = [
          '.hero-content',
          '.section-heading',
          '.trust-media',
          '.home-contact-card',
          '.cta-section',
          '.form-block',
          '.contacts-map-card'
        ].join(',');

        const revealItemSelector = [
          '.card',
          '.home-product-card',
          '.home-service-card',
          '.home-pathway-card',
          '.category-choice-card',
          '.product-showcase-card',
          '.object-list-card',
          '.workflow-step',
          '.quick-entry-card'
        ].join(',');

        const staggerContainers = [
          '.home-products-grid',
          '.home-services-grid',
          '.home-pathways__grid',
          '.category-choice-grid',
          '.product-catalog-grid',
          '.object-list-grid',
          '.workflow-grid',
          '.quick-entry-grid',
          '.page-blocks-grid',
          '.contacts-top-grid',
          '.grid'
        ].join(',');

        let revealObserver;

        const prefersReducedMotion = () => window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        const markRevealElements = () => {
          const elements = new Set();

          document.querySelectorAll(revealSelector).forEach((element) => elements.add(element));
          document.querySelectorAll(revealItemSelector).forEach((element) => elements.add(element));

          document.querySelectorAll(staggerContainers).forEach((container) => {
            const children = Array.from(container.children).filter((child) => child instanceof HTMLElement);
            children.forEach((child, index) => {
              child.style.setProperty('--reveal-delay', `${Math.min(index * 70, 280)}ms`);
              elements.add(child);
            });
          });

          return Array.from(elements).filter((element) => {
            if (!(element instanceof HTMLElement)) return false;
            if (element.closest('.site-header, .footer, .cookie-banner, .section-nav')) return false;
            element.setAttribute('data-reveal', '');
            return true;
          });
        };

        const revealElement = (element) => {
          element.classList.add('is-visible');
          if (revealObserver) revealObserver.unobserve(element);
        };

        const initScrollReveal = () => {
          const elements = markRevealElements();

          if (!elements.length || prefersReducedMotion()) {
            document.documentElement.classList.remove('reveal-js');
            elements.forEach((element) => element.classList.add('is-visible'));
            return;
          }

          document.documentElement.classList.add('reveal-js');

          if (!('IntersectionObserver' in window)) {
            elements.forEach(revealElement);
            return;
          }

          if (revealObserver) revealObserver.disconnect();

          revealObserver = new IntersectionObserver((entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) revealElement(entry.target);
            });
          }, {
            rootMargin: '0px 0px -12% 0px',
            threshold: 0.08
          });

          requestAnimationFrame(() => {
            elements.forEach((element) => {
              const rect = element.getBoundingClientRect();
              if (rect.top < window.innerHeight * 0.92 && rect.bottom > 0) {
                revealElement(element);
              } else {
                revealObserver.observe(element);
              }
            });
          });
        };

        initScrollReveal();
        document.addEventListener('astro:page-load', initScrollReveal);
      })();
    </script>
  </body>
</html>
