---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileMenu from '../components/MobileMenu.astro';
import CookieBanner from '../components/CookieBanner.astro';
import { withBase } from '../utils/withBase';
import yandex from '../data/yandex.json';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = '/assets/images/placeholders/og-default.svg' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@600&family=Manrope:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/assets/brand/favicon.svg')} />
    <link rel="canonical" href={canonical.toString()} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={new URL(withBase(ogImage), Astro.site).toString()} />
    <script
      is:inline
      define:vars={{
        metrikaCounterId: yandex.metrika.counterId,
        metrikaScriptSrc: yandex.metrika.scriptSrc,
        metrikaInit: yandex.metrika.init
      }}
    >
      (() => {
        const consentKey = 'smu1_cookie_consent';
        let metrikaLoaded = false;

        const loadMetrika = () => {
          if (metrikaLoaded) return;
          metrikaLoaded = true;

          (function(m, e, t, r, i, k, a) {
            m[i] = m[i] || function() {
              (m[i].a = m[i].a || []).push(arguments);
            };
            m[i].l = 1 * new Date();
            for (let j = 0; j < document.scripts.length; j++) {
              if (document.scripts[j].src === r) {
                return;
              }
            }
            k = e.createElement(t);
            a = e.getElementsByTagName(t)[0];
            k.async = 1;
            k.src = r;
            a.parentNode.insertBefore(k, a);
          })(window, document, 'script', metrikaScriptSrc, 'ym');

          window.ym(metrikaCounterId, 'init', {
            ...metrikaInit,
            referrer: document.referrer,
            url: location.href
          });
        };

        const savedConsent = localStorage.getItem(consentKey);
        if (savedConsent === 'accepted') {
          loadMetrika();
        }

        document.addEventListener('smu1:cookie-consent-changed', (event) => {
          if (event.detail === 'accepted') {
            loadMetrika();
          }
        });
      })();
    </script>
  </head>
  <body>
    <Header />
    <MobileMenu />
    <main>
      <slot />
    </main>
    <Footer />
    <CookieBanner />
  </body>
</html>
