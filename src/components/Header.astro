---
import navItems from '../data/navigation.json';
import site from '../data/site.json';
import { withBase } from '../utils/withBase';

const isActive = (href: string) => href === '/' ? Astro.url.pathname === '/' : Astro.url.pathname.startsWith(href);
---
<header class="header" data-mobile-open="false">
  <div class="container header-inner">
    <div class="header-brand">
      <a href={withBase('/')} class="logo-link" aria-label="СМУ-1 на главную">
        <img class="logo" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
      </a>
    </div>

    <button
      class="mobile-menu-button"
      type="button"
      aria-controls="mobile-drawer"
      aria-expanded="false"
      aria-label="Открыть меню"
      data-mobile-menu-open
    >
      <img src={withBase('/assets/icons/menu.svg')} alt="" aria-hidden="true" />
    </button>

    <div class="header-nav-wrap">
      <nav class="nav" aria-label="Основная навигация">
        {navItems.map((item) => (
          <a class={isActive(item.href) ? 'active' : ''} href={withBase(item.href)}>{item.title}</a>
        ))}
      </nav>
    </div>

    <div class="header-cta">
      <a href={withBase('/izgotovlenie-na-zakaz/')} class="btn btn-primary">Изготовление на заказ</a>
    </div>
  </div>

  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    <button class="mobile-drawer__backdrop" type="button" aria-label="Закрыть меню" data-mobile-menu-close></button>
    <div class="mobile-drawer__panel" role="dialog" aria-modal="true" aria-label="Мобильное меню">
      <div class="mobile-drawer__top container">
        <a href={withBase('/')} class="logo-link" aria-label="СМУ-1 на главную" data-mobile-menu-link>
          <img class="logo logo--mobile" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
        </a>
        <button class="mobile-drawer__close" type="button" aria-label="Закрыть меню" data-mobile-menu-close>
          <img src={withBase('/assets/icons/x.svg')} alt="" aria-hidden="true" />
        </button>
      </div>

      <div class="mobile-drawer__content container">
        <nav class="mobile-nav" aria-label="Мобильная навигация">
          {navItems.map((item) => (
            <a class={isActive(item.href) ? 'active' : ''} href={withBase(item.href)} data-mobile-menu-link>{item.title}</a>
          ))}
        </nav>

        <a class="btn btn-primary mobile-drawer__cta" href={withBase('/izgotovlenie-na-zakaz/')} data-mobile-menu-link>
          Изготовление на заказ
        </a>

        <div class="mobile-drawer__contacts">
          <a href={`tel:${site.phone}`}>
            <img src={withBase('/assets/icons/phone.svg')} alt="" aria-hidden="true" />
            <span>{site.phone}</span>
          </a>
          <a href={`mailto:${site.email}`}>
            <img src={withBase('/assets/icons/mail.svg')} alt="" aria-hidden="true" />
            <span>{site.email}</span>
          </a>
          <a href={site.messengers[1]?.url ?? '#'}>
            <img src={withBase('/assets/icons/send.svg')} alt="" aria-hidden="true" />
            <span>Telegram</span>
          </a>
          <p>
            <img src={withBase('/assets/icons/map-pin.svg')} alt="" aria-hidden="true" />
            <span>{site.address}</span>
          </p>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const initMobileMenu = () => {
    const header = document.querySelector('.header');
    if (!header || header.dataset.mobileMenuReady === 'true') return;

    const drawer = header.querySelector('#mobile-drawer');
    const openButton = header.querySelector('[data-mobile-menu-open]');
    const closeButtons = header.querySelectorAll('[data-mobile-menu-close]');
    const navLinks = header.querySelectorAll('[data-mobile-menu-link]');

    if (!drawer || !openButton) return;

    let scrollTop = 0;

    const lockBodyScroll = () => {
      scrollTop = window.scrollY || document.documentElement.scrollTop || 0;
      document.body.classList.add('mobile-nav-open');
      document.body.style.top = `-${scrollTop}px`;
    };

    const unlockBodyScroll = () => {
      document.body.classList.remove('mobile-nav-open');
      const top = document.body.style.top;
      document.body.style.top = '';
      window.scrollTo(0, top ? Math.abs(parseInt(top, 10)) : scrollTop);
    };

    const setOpenState = (isOpen) => {
      header.classList.toggle('is-mobile-menu-open', isOpen);
      header.setAttribute('data-mobile-open', isOpen ? 'true' : 'false');
      drawer.setAttribute('aria-hidden', isOpen ? 'false' : 'true');
      openButton.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

      if (isOpen) {
        lockBodyScroll();
      } else {
        unlockBodyScroll();
      }
    };

    const onToggleOpen = (event) => {
      event.preventDefault();
      setOpenState(true);
    };

    const onToggleClose = (event) => {
      event.preventDefault();
      setOpenState(false);
    };

    openButton.addEventListener('click', onToggleOpen, { passive: false });
    closeButtons.forEach((button) => button.addEventListener('click', onToggleClose, { passive: false }));
    navLinks.forEach((link) => link.addEventListener('click', () => setOpenState(false)));

    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') setOpenState(false);
    });

    header.dataset.mobileMenuReady = 'true';
    setOpenState(false);
  };

  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
