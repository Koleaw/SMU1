---
import navItems from '../data/navigation.json';
import { withBase } from '../utils/withBase';

const normalizePath = (path: string) => {
  const base = import.meta.env.BASE_URL || '/';
  const normalizedBase = base === '/' ? '/' : base.replace(/\/$/, '');

  if (path === '/') return '/';

  let normalized = path;
  if (normalizedBase !== '/' && normalized.startsWith(normalizedBase)) {
    normalized = normalized.slice(normalizedBase.length) || '/';
  }

  if (!normalized.startsWith('/')) normalized = `/${normalized}`;
  if (normalized !== '/' && !normalized.endsWith('/')) normalized = `${normalized}/`;

  return normalized;
};

const activePathMap: Record<string, string[]> = {
  '/ulichnaya-mebel/': ['/ulichnaya-mebel/'],
  '/ograzhdeniya-i-zabory/': ['/ograzhdeniya-i-zabory/', '/ograzhdeniya/'],
  '/navesy-i-kozyrki/': ['/navesy-i-kozyrki/', '/navesy/'],
  '/metallokonstruktsii-dlya-biznesa/': ['/metallokonstruktsii-dlya-biznesa/', '/metallokonstruktsii/'],
  '/topiarii/': ['/topiarii/'],
  '/blagoustroystvo-territoriy/': ['/blagoustroystvo-territoriy/', '/blagoustroystvo/'],
  '/stroitelstvo-i-remonty/': ['/stroitelstvo-i-remonty/', '/stroitelstvo/'],
  '/vypolnennye-obekty/': ['/vypolnennye-obekty/', '/obekty/'],
  '/kontakty/': ['/kontakty/'],
  '/vakansii/': ['/vakansii/']
};

const currentPathname = normalizePath(Astro.url.pathname);
const isHomePage = currentPathname === '/';

const isActive = (href: string) => {
  const normalizedHref = normalizePath(href);
  const candidates = activePathMap[normalizedHref] ?? [normalizedHref];

  return candidates.some((candidate) => {
    if (candidate === '/') return currentPathname === '/';
    return currentPathname === candidate || currentPathname.startsWith(`${candidate}`);
  });
};
---
<header class={`site-header${isHomePage ? ' site-header--home' : ''}`} data-home-header={isHomePage ? 'true' : undefined}>
  <div class="container site-header__desktop">
    <div class="site-header__left">
      <a href={withBase('/')} class="site-header__logo-link" aria-label="СМУ-1 на главную">
        <img class="site-header__logo" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
      </a>
    </div>

    <div class="site-header__center">
      <nav class="site-header__nav" aria-label="Основная навигация">
        {navItems.map((item) => (
          <a class={isActive(item.href) ? 'active' : ''} href={withBase(item.href)}>{item.title}</a>
        ))}
      </nav>
    </div>

    <div class="site-header__right">
      <div class="site-header__actions" aria-label="Контакты">
        <a class="site-header__phone" href="tel:+79129735006">+7 (912) 973-50-06</a>
        <a class="site-header__telegram" href="https://t.me/smu1build" target="_blank" rel="noopener noreferrer" aria-label="Telegram СМУ-1">
          <img src={withBase('/assets/icons/send.svg')} alt="" aria-hidden="true" />
          <span>@smu1build</span>
        </a>
      </div>
    </div>
  </div>

  <div class="container site-header__mobile-bar">
    <a href={withBase('/')} class="site-header__logo-link" aria-label="СМУ-1 на главную">
      <img class="site-header__logo" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
    </a>

    <button
      class="site-header__menu-button"
      type="button"
      aria-controls="mobile-menu-layer"
      aria-expanded="false"
      aria-label="Открыть меню"
      data-mobile-menu-open
    >
      <img src={withBase('/assets/icons/menu.svg')} alt="" aria-hidden="true" />
    </button>
  </div>
</header>

<script>
  const initHomeHeaderState = () => {
    const header = document.querySelector('[data-home-header="true"]');
    if (!(header instanceof HTMLElement)) return;
    if (header.dataset.homeHeaderReady === 'true') return;

    const hero = document.querySelector('.hero');
    if (!(hero instanceof HTMLElement)) return;

    const SCROLL_THRESHOLD = 72;

    const updateState = () => {
      const heroBottom = hero.getBoundingClientRect().bottom;
      const shouldUseScrolledState = window.scrollY > SCROLL_THRESHOLD || heroBottom <= (header.offsetHeight + 8);
      header.classList.toggle('is-scrolled', shouldUseScrolledState);
    };

    window.addEventListener('scroll', updateState, { passive: true });
    window.addEventListener('resize', updateState);
    updateState();
    header.dataset.homeHeaderReady = 'true';
  };

  initHomeHeaderState();
  document.addEventListener('astro:page-load', initHomeHeaderState);
</script>
