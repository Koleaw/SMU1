---
interface Props { ids: string[] }
import faqs from '../data/faqs.json';
const { ids } = Astro.props;
const entries = faqs.filter((item) => ids.includes(item.id));
---
{entries.length > 0 && (
  <section class="section">
    <div class="container">
      <h2 class="section-title">FAQ</h2>
      <div class="grid grid-2">
        {entries.map((faq) => (
          <article class="card">
            <h3>{faq.question}</h3>
            <p class="lead">{faq.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
)}
