---
interface Props {
  kicker?: string;
  title: string;
  description: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}
import { withBase } from '../utils/withBase';
const { kicker, title, description, primaryLabel, primaryHref = '#lead', secondaryLabel, secondaryHref = withBase('/kontakty/') } = Astro.props;
---
<section class="hero">
  <div class="container">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1>{title}</h1>
    <p>{description}</p>
    <div class="hero-actions">
      {primaryLabel && <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>}
      {secondaryLabel && <a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
    <slot />
  </div>
</section>
