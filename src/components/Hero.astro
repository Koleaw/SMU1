---
import { withBase } from '../utils/withBase';

interface Props {
  className?: string;
  kicker?: string;
  title: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  mediaType?: 'image' | 'video';
  mediaImage?: string;
  mediaVideo?: string;
  mediaVideoMobile?: string;
  mediaPoster?: string;
  mediaPosterMobile?: string;
  mediaAlt?: string;
  mediaCaption?: string;
  overlayOpacity?: number;
  mediaView?: {
    fit?: 'cover' | 'contain';
    positionX?: number;
    positionY?: number;
    scale?: number;
  };
  titleStyle?: unknown;
  descriptionStyle?: unknown;
  contentLayout?: unknown;
}

const {
  className,
  kicker,
  title,
  description,
  primaryLabel,
  primaryHref = withBase('/kontakty/'),
  secondaryLabel,
  secondaryHref = withBase('/kontakty/'),
  mediaType,
  mediaImage: rawMediaImage,
  mediaVideo: rawMediaVideo,
  mediaVideoMobile: rawMediaVideoMobile,
  mediaPoster: rawMediaPoster,
  mediaPosterMobile,
  mediaAlt = 'Фоновое изображение первого экрана',
  mediaCaption,
  overlayOpacity,
  mediaView,
} = Astro.props as Props;

const heroClass = ['hero', className].filter(Boolean).join(' ');
const cleanMediaPath = (value: unknown) => (typeof value === 'string' ? value.trim() : '');
const mediaImage = cleanMediaPath(rawMediaImage) || undefined;
const mediaVideo = cleanMediaPath(rawMediaVideo) || undefined;
const mediaVideoMobile = cleanMediaPath(rawMediaVideoMobile) || undefined;
const mediaPoster = cleanMediaPath(rawMediaPoster) || (cleanMediaPath(rawMediaVideo) && !cleanMediaPath(rawMediaImage) ? withBase('/assets/images/placeholders/construction.svg') : undefined);
const normalizePercent = (value: unknown, fallback = 100) => {
  const number = Number(value);
  if (!Number.isFinite(number)) return fallback;
  return Math.min(100, Math.max(0, number));
};
const safeMediaImage = cleanMediaPath(rawMediaImage);
const safeMediaVideo = cleanMediaPath(rawMediaVideo);
const safeMediaVideoMobile = cleanMediaPath(rawMediaVideoMobile);
const safeMediaPoster = cleanMediaPath(rawMediaPoster);
const shouldRenderVideo = Boolean(safeMediaVideo);
const placeholderPoster = withBase('/assets/images/placeholders/construction.svg');
const safeMediaView = { fit: 'cover', positionX: 50, positionY: 50, scale: 1, ...(mediaView || {}) };
const heroImageStyle = `object-fit:${safeMediaView.fit};object-position:${safeMediaView.positionX}% ${safeMediaView.positionY}%;transform:scale(${safeMediaView.scale});transform-origin:center;`;
const mediaVideoType = safeMediaVideo.toLowerCase().endsWith('.webm') ? 'video/webm' : 'video/mp4';
const mediaVideoMobileType = safeMediaVideoMobile.toLowerCase().endsWith('.webm') ? 'video/webm' : 'video/mp4';
const overlayStyle = `--hero-overlay-strength:${normalizePercent(overlayOpacity) / 100};`;
const resolvedDesktopPoster = mediaPoster || mediaImage;
const resolvedMobilePoster = mediaPosterMobile || resolvedDesktopPoster;
const resolvedPoster = resolvedDesktopPoster || resolvedMobilePoster;
---
<section class={heroClass}>
  {(mediaImage || mediaPoster || mediaPosterMobile || mediaVideo) && (
    <div class="hero-media" aria-hidden="true" data-hero-media data-has-video-fallback={resolvedPoster ? 'true' : undefined}>
      {mediaType === 'video' && mediaVideo ? (
        <>
          <video class="hero-media__video" autoplay muted loop playsinline webkit-playsinline preload="auto" poster={resolvedPoster} data-hero-video data-hero-poster-desktop={resolvedDesktopPoster} data-hero-poster-mobile={resolvedMobilePoster}>
            {mediaVideoMobile && <source src={mediaVideoMobile} type={mediaVideoMobileType} media="(max-width: 900px)" />}
            <source src={mediaVideo} type={mediaVideoType} />
          </video>
          {resolvedPoster && <img class="hero-media__fallback" src={resolvedPoster} alt={mediaAlt} loading="eager" style={heroImageStyle} data-hero-fallback data-hero-poster-desktop={resolvedDesktopPoster} data-hero-poster-mobile={resolvedMobilePoster} />}
        </>
      ) : (
        <img class="hero-media__image" src={mediaImage ?? mediaPoster} alt={mediaAlt} loading="eager" style={heroImageStyle} />
      )}
      <div class="hero-media__overlay" style={overlayStyle}></div>
      {mediaCaption && <p class="hero-media__caption">{mediaCaption}</p>}
    </div>
  )}

  <div class="container hero-content">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1>{title}</h1>
    {description && <p class="hero-description">{description}</p>}
    <div class="hero-actions">
      {primaryLabel && <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>}
      {secondaryLabel && <a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
    <slot />
  </div>
</section>

<script>
  const initHeroVideoFallback = () => {
    const heroMedias = Array.from(document.querySelectorAll('[data-hero-media]'));

    heroMedias.forEach((heroMedia) => {
      if (!(heroMedia instanceof HTMLElement)) return;
      const heroVideo = heroMedia.querySelector('[data-hero-video]');
      if (!(heroVideo instanceof HTMLVideoElement)) return;
      if (heroMedia.dataset.heroVideoReady === 'true') return;
      const heroFallback = heroMedia.querySelector('[data-hero-fallback]');
      const desktopPoster = heroVideo.dataset.heroPosterDesktop || heroVideo.getAttribute('poster') || '';
      const mobilePoster = heroVideo.dataset.heroPosterMobile || desktopPoster;
      const mobilePosterMedia = window.matchMedia('(max-width: 900px)');
      type PlayOptions = { force?: boolean };

      let playPending = false;
      let autoplayRejected = false;
      let interactionAttempted = false;
      const attemptedReasons = new Set();

      const activePoster = () => (mobilePosterMedia.matches && mobilePoster ? mobilePoster : desktopPoster);

      const syncPoster = () => {
        const poster = activePoster();
        if (!poster) return;
        if (heroVideo.getAttribute('poster') !== poster) {
          heroVideo.setAttribute('poster', poster);
        }
        if (heroFallback instanceof HTMLImageElement && heroFallback.getAttribute('src') !== poster) {
          heroFallback.setAttribute('src', poster);
        }
      };

      const markPlaying = () => {
        heroMedia.dataset.videoPlaying = 'true';
        delete heroMedia.dataset.videoFailed;
        autoplayRejected = false;
      };

      const markFailed = () => {
        heroMedia.dataset.videoFailed = 'true';
        delete heroMedia.dataset.videoPlaying;
      };

      heroVideo.muted = true;
      heroVideo.defaultMuted = true;
      heroVideo.setAttribute('muted', '');
      heroVideo.setAttribute('playsinline', '');
      heroVideo.setAttribute('webkit-playsinline', '');
      syncPoster();

      heroVideo.addEventListener('playing', markPlaying);
      heroVideo.addEventListener('canplay', () => {
        if (!heroVideo.paused) markPlaying();
      });

      heroVideo.addEventListener('error', () => {
        markFailed();
      });

      heroVideo.addEventListener('stalled', () => {
        if (!heroVideo.currentSrc) markFailed();
      });

      heroMedia.dataset.heroVideoReady = 'true';

      const prepareVideo = () => {
        heroVideo.muted = true;
        heroVideo.defaultMuted = true;
        heroVideo.setAttribute('muted', '');
        heroVideo.setAttribute('playsinline', '');
        heroVideo.setAttribute('webkit-playsinline', '');
        syncPoster();
      };

      const attemptPlay = (reason: string, options: PlayOptions = {}) => {
        const force = options.force === true;
        if (playPending || heroMedia.dataset.videoPlaying === 'true' || !heroVideo.paused) return;
        if (force) {
          if (interactionAttempted) return;
          interactionAttempted = true;
        } else {
          if (autoplayRejected || attemptedReasons.has(reason)) return;
          attemptedReasons.add(reason);
        }

        prepareVideo();
        playPending = true;
        const playPromise = heroVideo.play();
        if (playPromise && typeof playPromise.then === 'function') {
          playPromise
            .then(() => {
              playPending = false;
              if (!heroVideo.paused) markPlaying();
            })
            .catch(() => {
              playPending = false;
              if (!force) autoplayRejected = true;
              markFailed();
            });
        } else if (!heroVideo.paused) {
          playPending = false;
          markPlaying();
        } else {
          playPending = false;
        }
      };

      const attemptWhenVisible = (reason: string) => {
        if (document.visibilityState && document.visibilityState !== 'visible') return;
        attemptPlay(reason);
      };

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => attemptWhenVisible('dom-ready'), { once: true });
      } else {
        requestAnimationFrame(() => attemptWhenVisible('init'));
      }

      window.addEventListener('pageshow', () => attemptWhenVisible('pageshow'));
      document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') attemptWhenVisible('visibilitychange');
      });

      const attemptAfterInteraction = () => attemptPlay('interaction', { force: true });
      ['touchstart', 'pointerdown', 'click'].forEach((eventName) => {
        window.addEventListener(eventName, attemptAfterInteraction, { once: true, passive: true });
      });

      if (typeof mobilePosterMedia.addEventListener === 'function') {
        mobilePosterMedia.addEventListener('change', syncPoster);
      } else if (typeof mobilePosterMedia.addListener === 'function') {
        mobilePosterMedia.addListener(syncPoster);
      }
    });
  };

  initHeroVideoFallback();
  document.addEventListener('astro:page-load', initHeroVideoFallback);
</script>
