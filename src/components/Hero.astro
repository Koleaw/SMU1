---
interface Props {
  className?: string;
  kicker?: string;
  title: string;
  description?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  mediaType?: 'image' | 'video';
  mediaImage?: string;
  mediaVideo?: string;
  mediaPoster?: string;
  mediaAlt?: string;
  mediaCaption?: string;
  mediaView?: { fit?: 'cover' | 'contain'; positionX?: number; positionY?: number; scale?: number };
}
import { withBase } from '../utils/withBase';

const {
  className,
  kicker,
  title,
  description,
  primaryLabel,
  primaryHref = withBase('/kontakty/'),
  secondaryLabel,
  secondaryHref = withBase('/kontakty/'),
  mediaType,
  mediaImage,
  mediaVideo,
  mediaPoster,
  mediaAlt = 'Фоновое изображение первого экрана',
  mediaCaption,
  mediaView
} = Astro.props;

const heroClass = ['hero', className].filter(Boolean).join(' ');

const resolvedMediaView = {
  fit: mediaView?.fit === 'contain' ? 'contain' : 'cover',
  positionX: Number.isFinite(mediaView?.positionX) ? Number(mediaView.positionX) : 50,
  positionY: Number.isFinite(mediaView?.positionY) ? Number(mediaView.positionY) : 50,
  scale: Number.isFinite(mediaView?.scale) ? Math.min(Math.max(Number(mediaView.scale), 1), 3) : 1
};

---
<section class={heroClass}>
  {(mediaImage || mediaPoster) && (
    <div class="hero-media" aria-hidden="true" data-hero-media>
      {mediaType === 'video' && mediaVideo ? (
        <>
          <video class="hero-media__video" autoplay muted loop playsinline poster={mediaPoster} data-hero-video>
            <source src={mediaVideo} type="video/mp4" />
          </video>
          {mediaPoster && <img class="hero-media__fallback" src={mediaPoster} alt={mediaAlt} loading="eager" />}
        </>
      ) : (
        <img class="hero-media__image" style={`object-fit:${resolvedMediaView.fit};object-position:${resolvedMediaView.positionX}% ${resolvedMediaView.positionY}%;transform:scale(${resolvedMediaView.scale});transform-origin:center;`} src={mediaImage ?? mediaPoster} alt={mediaAlt} loading="eager" />
      )}
      <div class="hero-media__overlay"></div>
      {mediaCaption && <p class="hero-media__caption">{mediaCaption}</p>}
    </div>
  )}

  <div class="container hero-content">
    {kicker && <p class="kicker">{kicker}</p>}
    <h1>{title}</h1>
    {description && <p class="hero-description">{description}</p>}
    <div class="hero-actions">
      {primaryLabel && <a class="btn btn-primary" href={primaryHref}>{primaryLabel}</a>}
      {secondaryLabel && <a class="btn btn-secondary" href={secondaryHref}>{secondaryLabel}</a>}
    </div>
    <slot />
  </div>
</section>

<script>
  const initHeroVideoFallback = () => {
    const heroMedias = Array.from(document.querySelectorAll('[data-hero-media]'));

    heroMedias.forEach((heroMedia) => {
      if (!(heroMedia instanceof HTMLElement)) return;
      const heroVideo = heroMedia.querySelector('[data-hero-video]');
      if (!(heroVideo instanceof HTMLVideoElement)) return;
      if (heroMedia.dataset.heroVideoReady === 'true') return;

      heroVideo.addEventListener('error', () => {
        heroMedia.dataset.videoFailed = 'true';
      });

      heroVideo.addEventListener('stalled', () => {
        if (!heroVideo.currentSrc) heroMedia.dataset.videoFailed = 'true';
      });

      heroMedia.dataset.heroVideoReady = 'true';
    });
  };

  initHeroVideoFallback();
  document.addEventListener('astro:page-load', initHeroVideoFallback);
</script>
