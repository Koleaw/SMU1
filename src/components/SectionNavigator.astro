---
import { withBase } from '../utils/withBase';

interface SectionNavItem {
  id: string;
  label: string;
}

interface Props {
  items: SectionNavItem[];
  title?: string;
}

const { items, title = 'Разделы страницы' } = Astro.props;
const safeItems = items.filter((item) => item?.id && item?.label);
const shouldRender = safeItems.length >= 4;
---
{shouldRender && (
  <div class="section-nav" data-section-nav>
    <nav class="section-nav__desktop" aria-label="Навигация по разделам страницы">
      <ol class="section-nav__list">
        <span class="section-nav__marker" aria-hidden="true" data-section-nav-marker></span>
        {safeItems.map((item) => (
          <li>
            <a href={`#${item.id}`} data-section-nav-link={item.id} data-section-nav-desktop-link={item.id}>{item.label}</a>
          </li>
        ))}
      </ol>
    </nav>

    <button class="section-nav__mobile-toggle" type="button" aria-expanded="false" aria-controls="section-nav-sheet" data-section-nav-toggle hidden>
      <img src={withBase('/assets/icons/menu.svg')} alt="Открыть разделы страницы" />
    </button>

    <div class="section-nav__sheet-backdrop" aria-hidden="true" data-section-nav-backdrop hidden></div>

    <section class="section-nav__sheet" id="section-nav-sheet" aria-hidden="true" data-section-nav-sheet hidden>
      <div class="section-nav__sheet-header">
        <span class="section-nav__sheet-handle" aria-hidden="true"></span>
        <div class="section-nav__sheet-title-row">
          <h2>{title}</h2>
          <button class="section-nav__sheet-close" type="button" aria-label="Закрыть разделы страницы" data-section-nav-close>
            <img src={withBase('/assets/icons/x.svg')} alt="" aria-hidden="true" />
          </button>
        </div>
      </div>
      <nav aria-label="Разделы страницы">
        <ol class="section-nav__sheet-list">
          {safeItems.map((item) => (
            <li>
              <a href={`#${item.id}`} data-section-nav-link={item.id} data-section-nav-sheet-link={item.id}>{item.label}</a>
            </li>
          ))}
        </ol>
      </nav>
    </section>
  </div>
)}

<script>
  const initSectionNavigator = () => {
    const navRoots = Array.from(document.querySelectorAll('[data-section-nav]'));

    navRoots.forEach((navRoot) => {
      if (!(navRoot instanceof HTMLElement)) return;
      if (navRoot.dataset.sectionNavReady === 'true') return;

      const links = Array.from(navRoot.querySelectorAll('[data-section-nav-link]'));
      const desktopLinks = Array.from(navRoot.querySelectorAll('[data-section-nav-desktop-link]'));
      if (!links.length) return;

      const toggleButton = navRoot.querySelector('[data-section-nav-toggle]');
      const closeButton = navRoot.querySelector('[data-section-nav-close]');
      const sheet = navRoot.querySelector('[data-section-nav-sheet]');
      const backdrop = navRoot.querySelector('[data-section-nav-backdrop]');
      const marker = navRoot.querySelector('[data-section-nav-marker]');
      const mobileQuery = window.matchMedia('(max-width: 900px)');

      const getHeaderOffset = () => {
        const header = document.querySelector('.site-header');
        if (!(header instanceof HTMLElement)) return 0;
        return Math.ceil(header.getBoundingClientRect().height) + 14;
      };

      const sectionIds = [
        ...new Set(links.map((link) => link.getAttribute('data-section-nav-link')).filter(Boolean))
      ];

      const sections = sectionIds
        .map((id) => {
          const element = id ? document.getElementById(id) : null;
          return element ? { id, el: element } : null;
        })
        .filter(Boolean);

      if (!sections.length) return;

      let isSheetOpen = false;

      const setSheetState = (open) => {
        isSheetOpen = open;

        if (sheet instanceof HTMLElement) {
          sheet.hidden = !open;
          sheet.setAttribute('aria-hidden', open ? 'false' : 'true');
        }

        if (backdrop instanceof HTMLElement) {
          backdrop.hidden = !open;
          backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
        }

        if (toggleButton instanceof HTMLElement) {
          toggleButton.setAttribute('aria-expanded', open ? 'true' : 'false');
        }
      };

      const setActive = (activeId) => {
        links.forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) return;
          const isActive = link.getAttribute('data-section-nav-link') === activeId;
          link.classList.toggle('is-active', isActive);
          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });

        const activeDesktopLink = desktopLinks.find(
          (link) => link.getAttribute('data-section-nav-desktop-link') === activeId
        );

        if (marker instanceof HTMLElement && activeDesktopLink instanceof HTMLElement) {
          const markerTop = activeDesktopLink.offsetTop + (activeDesktopLink.offsetHeight / 2) - (marker.offsetHeight / 2);
          marker.style.transform = `translateY(${Math.round(markerTop)}px)`;
        }
      };

      const updateScrollMargins = () => {
        const margin = `${getHeaderOffset() + 8}px`;
        sections.forEach((section) => {
          section.el.style.scrollMarginTop = margin;
        });
      };

      const scrollToSection = (sectionId) => {
        const target = sections.find((section) => section.id === sectionId)?.el;
        if (!(target instanceof HTMLElement)) return;

        const offset = getHeaderOffset();
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
        setSheetState(false);
      };

      const updateActiveByScroll = () => {
        const offset = getHeaderOffset() + 18;
        let activeId = sections[0]?.id;

        sections.forEach((section) => {
          const top = section.el.getBoundingClientRect().top;
          if (top - offset <= 0) {
            activeId = section.id;
          }
        });

        if (activeId) setActive(activeId);
      };

      const updateToggleVisibility = () => {
        if (!(toggleButton instanceof HTMLElement)) return;

        if (!mobileQuery.matches) {
          toggleButton.hidden = true;
          if (isSheetOpen) setSheetState(false);
          return;
        }

        const showAfter = window.innerHeight * 0.65;
        const shouldShow = window.scrollY > showAfter;
        toggleButton.hidden = !shouldShow;

        if (!shouldShow && isSheetOpen) {
          setSheetState(false);
        }
      };

      links.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener('click', (event) => {
          const sectionId = link.getAttribute('data-section-nav-link');
          if (!sectionId) return;
          event.preventDefault();
          scrollToSection(sectionId);
        });
      });

      toggleButton?.addEventListener('click', () => {
        if (!mobileQuery.matches) return;
        setSheetState(true);
      });
      closeButton?.addEventListener('click', () => setSheetState(false));
      backdrop?.addEventListener('click', () => setSheetState(false));

      window.addEventListener('scroll', updateActiveByScroll, { passive: true });
      window.addEventListener('scroll', updateToggleVisibility, { passive: true });
      window.addEventListener('resize', () => {
        updateScrollMargins();
        updateActiveByScroll();
        updateToggleVisibility();
      });
      mobileQuery.addEventListener('change', updateToggleVisibility);

      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape') {
          setSheetState(false);
        }
      });

      setSheetState(false);
      updateScrollMargins();
      updateActiveByScroll();
      updateToggleVisibility();
      navRoot.dataset.sectionNavReady = 'true';
    });
  };

  initSectionNavigator();
  document.addEventListener('astro:page-load', initSectionNavigator);
</script>
