---
interface SectionNavItem {
  id: string;
  label: string;
}

interface Props {
  items: SectionNavItem[];
}

const { items } = Astro.props;
const safeItems = items.filter((item) => item?.id && item?.label);
const shouldRender = safeItems.length >= 4;
---
{shouldRender && (
  <aside class="section-nav" data-section-nav data-section-theme="light">
    <nav class="section-nav__desktop" aria-label="Навигация по разделам страницы">
      <ol class="section-nav__list">
        <span class="section-nav__marker" aria-hidden="true" data-section-nav-marker></span>
        {safeItems.map((item) => (
          <li>
            <a href={`#${item.id}`} data-section-nav-link={item.id}>{item.label}</a>
          </li>
        ))}
      </ol>
    </nav>
  </aside>
)}

<script>
  const initSectionNavigator = () => {
    const SECTION_NAV_CLEARANCE = 24;
    const SECTION_SCROLL_MARGIN_GAP = 12;

    const navRoots = Array.from(document.querySelectorAll('[data-section-nav]'));

    navRoots.forEach((navRoot) => {
      if (!(navRoot instanceof HTMLElement)) return;
      if (navRoot.dataset.sectionNavReady === 'true') return;

      const links = Array.from(navRoot.querySelectorAll('[data-section-nav-link]'));
      if (!links.length) return;

      const marker = navRoot.querySelector('[data-section-nav-marker]');

      const getStickyOffset = () => {
        const header = document.querySelector('.site-header');
        const breadcrumbs = document.querySelector('.breadcrumbs-bar');
        const headerHeight = header instanceof HTMLElement ? Math.ceil(header.getBoundingClientRect().height) : 0;
        const breadcrumbsHeight = breadcrumbs instanceof HTMLElement ? Math.ceil(breadcrumbs.getBoundingClientRect().height) : 0;
        return headerHeight + breadcrumbsHeight + SECTION_NAV_CLEARANCE;
      };

      const sectionIds = [
        ...new Set(links.map((link) => link.getAttribute('data-section-nav-link')).filter(Boolean))
      ];

      const parseColorChannels = (value) => {
        const matches = value.match(/[\d.]+/g);
        if (!matches || matches.length < 3) return null;

        const [r, g, b, alpha = '1'] = matches;
        return {
          r: Number(r),
          g: Number(g),
          b: Number(b),
          alpha: Number(alpha)
        };
      };

      const resolveThemeFromColor = (colorValue) => {
        const channels = parseColorChannels(colorValue);
        if (!channels) return null;
        if (channels.alpha === 0) return null;

        const luminance = (0.2126 * channels.r + 0.7152 * channels.g + 0.0722 * channels.b) / 255;
        return luminance < 0.53 ? 'dark' : 'light';
      };

      const getThemeFromSection = (element) => {
        if (!(element instanceof HTMLElement)) return 'light';

        const host = element.closest('[data-section-theme], .section, .hero') ?? element;
        if (!(host instanceof HTMLElement)) return 'light';

        if (host.dataset.sectionTheme === 'dark' || host.classList.contains('section--dark')) {
          return 'dark';
        }

        if (host.dataset.sectionTheme === 'light') {
          return 'light';
        }

        let current = host;
        while (current instanceof HTMLElement && current !== document.body) {
          const colorTheme = resolveThemeFromColor(window.getComputedStyle(current).backgroundColor);
          if (colorTheme) return colorTheme;
          current = current.parentElement;
        }

        return resolveThemeFromColor(window.getComputedStyle(document.body).backgroundColor) ?? 'light';
      };

      const sections = sectionIds
        .map((id) => {
          const element = id ? document.getElementById(id) : null;
          if (!element) return null;
          return { id, el: element };
        })
        .filter(Boolean);

      if (sections.length < 4) {
        navRoot.remove();
        return;
      }

      const setActive = (activeId, forcedTheme) => {
        links.forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) return;
          const isActive = link.getAttribute('data-section-nav-link') === activeId;
          link.classList.toggle('is-active', isActive);

          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });

        const activeSection = sections.find((section) => section.id === activeId);
        const resolvedTheme = forcedTheme ?? getThemeFromSection(activeSection?.el);
        navRoot.dataset.sectionTheme = resolvedTheme === 'dark' ? 'dark' : 'light';

        const activeLink = links.find((link) => link.getAttribute('data-section-nav-link') === activeId);

        if (marker instanceof HTMLElement && activeLink instanceof HTMLElement) {
          const markerTop = activeLink.offsetTop + (activeLink.offsetHeight / 2) - (marker.offsetHeight / 2);
          marker.style.transform = `translateY(${Math.round(markerTop)}px)`;
        }
      };

      const updateScrollMargins = () => {
        const stickyOffset = getStickyOffset();
        const margin = `${stickyOffset + SECTION_SCROLL_MARGIN_GAP}px`;
        navRoot.style.setProperty('--section-nav-sticky-top', `${stickyOffset}px`);
        sections.forEach((section) => {
          section.el.style.scrollMarginTop = margin;
        });
      };

      const scrollToSection = (sectionId) => {
        const target = sections.find((section) => section.id === sectionId)?.el;
        if (!(target instanceof HTMLElement)) return;

        const offset = getStickyOffset();
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      };

      const updateActiveByScroll = () => {
        const offset = getStickyOffset() + SECTION_SCROLL_MARGIN_GAP;
        let activeId = sections[0]?.id;
        let passedFirstSection = false;

        sections.forEach((section) => {
          const top = section.el.getBoundingClientRect().top;
          if (top - offset <= 0) {
            activeId = section.id;
            passedFirstSection = true;
          }
        });

        if (!activeId) return;

        if (!passedFirstSection) {
          const hero = document.querySelector('.hero');
          const heroTheme = hero instanceof HTMLElement ? getThemeFromSection(hero) : undefined;
          setActive(activeId, heroTheme);
          return;
        }

        setActive(activeId);
      };

      links.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener('click', (event) => {
          const sectionId = link.getAttribute('data-section-nav-link');
          if (!sectionId) return;

          event.preventDefault();
          scrollToSection(sectionId);
        });
      });

      window.addEventListener('scroll', updateActiveByScroll, { passive: true });
      window.addEventListener('resize', () => {
        updateScrollMargins();
        updateActiveByScroll();
      });

      updateScrollMargins();
      updateActiveByScroll();
      navRoot.dataset.sectionNavReady = 'true';
    });
  };

  initSectionNavigator();
  document.addEventListener('astro:page-load', initSectionNavigator);
</script>
