---
interface SectionNavItem {
  id: string;
  label: string;
}

interface Props {
  items: SectionNavItem[];
}

const { items } = Astro.props;
const safeItems = items.filter((item) => item?.id && item?.label);
const shouldRender = safeItems.length >= 4;
---
{shouldRender && (
  <aside class="section-nav" data-section-nav data-section-theme="light">
    <nav class="section-nav__desktop" aria-label="Навигация по разделам страницы">
      <ol class="section-nav__list">
        <span class="section-nav__marker" aria-hidden="true" data-section-nav-marker></span>
        {safeItems.map((item) => (
          <li>
            <a href={`#${item.id}`} data-section-nav-link={item.id}>{item.label}</a>
          </li>
        ))}
      </ol>
    </nav>
  </aside>
)}

<script>
  const initSectionNavigator = () => {
    const navRoots = Array.from(document.querySelectorAll('[data-section-nav]'));

    navRoots.forEach((navRoot) => {
      if (!(navRoot instanceof HTMLElement)) return;
      if (navRoot.dataset.sectionNavReady === 'true') return;

      const links = Array.from(navRoot.querySelectorAll('[data-section-nav-link]'));
      if (!links.length) return;

      const marker = navRoot.querySelector('[data-section-nav-marker]');

      const getHeaderOffset = () => {
        const header = document.querySelector('.site-header');
        if (!(header instanceof HTMLElement)) return 0;
        return Math.ceil(header.getBoundingClientRect().height) + 14;
      };

      const sectionIds = [
        ...new Set(links.map((link) => link.getAttribute('data-section-nav-link')).filter(Boolean))
      ];

      const getThemeFromSection = (element) => {
        if (!(element instanceof HTMLElement)) return 'light';

        const host = element.closest('[data-section-theme], .section, .hero') ?? element;
        if (!(host instanceof HTMLElement)) return 'light';

        if (host.dataset.sectionTheme === 'dark' || host.classList.contains('section--dark')) {
          return 'dark';
        }

        if (host.dataset.sectionTheme === 'light') {
          return 'light';
        }

        const bgColor = window.getComputedStyle(host).backgroundColor;
        const rgb = bgColor.match(/\d+/g)?.slice(0, 3).map(Number);
        if (!rgb || rgb.length < 3) return 'light';

        const [r, g, b] = rgb;
        const luminance = (0.2126 * r + 0.7152 * g + 0.0722 * b) / 255;
        return luminance < 0.53 ? 'dark' : 'light';
      };

      const sections = sectionIds
        .map((id) => {
          const element = id ? document.getElementById(id) : null;
          if (!element) return null;
          const theme = getThemeFromSection(element);

          return { id, el: element, theme };
        })
        .filter(Boolean);

      if (sections.length < 4) {
        navRoot.remove();
        return;
      }

      const setActive = (activeId) => {
        links.forEach((link) => {
          if (!(link instanceof HTMLAnchorElement)) return;
          const isActive = link.getAttribute('data-section-nav-link') === activeId;
          link.classList.toggle('is-active', isActive);

          if (isActive) {
            link.setAttribute('aria-current', 'true');
          } else {
            link.removeAttribute('aria-current');
          }
        });

        const activeSection = sections.find((section) => section.id === activeId);
        navRoot.dataset.sectionTheme = activeSection?.theme === 'dark' ? 'dark' : 'light';

        const activeLink = links.find((link) => link.getAttribute('data-section-nav-link') === activeId);

        if (marker instanceof HTMLElement && activeLink instanceof HTMLElement) {
          const markerTop = activeLink.offsetTop + (activeLink.offsetHeight / 2) - (marker.offsetHeight / 2);
          marker.style.transform = `translateY(${Math.round(markerTop)}px)`;
        }
      };

      const updateScrollMargins = () => {
        const margin = `${getHeaderOffset() + 8}px`;
        sections.forEach((section) => {
          section.el.style.scrollMarginTop = margin;
        });
      };

      const scrollToSection = (sectionId) => {
        const target = sections.find((section) => section.id === sectionId)?.el;
        if (!(target instanceof HTMLElement)) return;

        const offset = getHeaderOffset();
        const top = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({ top, behavior: 'smooth' });
      };

      const updateActiveByScroll = () => {
        const offset = getHeaderOffset() + 18;
        let activeId = sections[0]?.id;

        sections.forEach((section) => {
          const top = section.el.getBoundingClientRect().top;
          if (top - offset <= 0) {
            activeId = section.id;
          }
        });

        if (activeId) setActive(activeId);
      };

      links.forEach((link) => {
        if (!(link instanceof HTMLAnchorElement)) return;
        link.addEventListener('click', (event) => {
          const sectionId = link.getAttribute('data-section-nav-link');
          if (!sectionId) return;

          event.preventDefault();
          scrollToSection(sectionId);
        });
      });

      window.addEventListener('scroll', updateActiveByScroll, { passive: true });
      window.addEventListener('resize', () => {
        updateScrollMargins();
        updateActiveByScroll();
      });

      updateScrollMargins();
      updateActiveByScroll();
      navRoot.dataset.sectionNavReady = 'true';
    });
  };

  initSectionNavigator();
  document.addEventListener('astro:page-load', initSectionNavigator);
</script>
