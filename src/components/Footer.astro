---
import settings from '../content/site-settings/global.json';
import { withBase } from '../utils/withBase';
---
<footer class="footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href={withBase('/')} class="logo-link footer-logo-link" aria-label="СМУ-1 на главную">
        <img class="logo footer-logo" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
      </a>
      <p>{settings.companyName}</p>
      <p>ИНН {settings.inn} · КПП {settings.kpp}</p>
      <p>ОГРН {settings.ogrn}</p>
      <p>Дата регистрации: {settings.registrationDate}</p>
    </div>

    <div class="footer-requisites">
      <p><strong>Юридический адрес:</strong></p>
      <p>{settings.legalAddress}</p>
    </div>

    <div class="footer-contacts">
      <p><strong>Контакты:</strong></p>
      <p><a href={`tel:${settings.phonePrimary}`}>{settings.phonePrimary}</a></p>
      <p><a href={`mailto:${settings.email}`}>{settings.email}</a></p>
      <p><a href={settings.telegram} target="_blank" rel="noopener noreferrer">@smu1build</a></p>
    </div>
  </div>

  <div class="container footer-legal-row">
    <small>© ООО «СМУ 1», 2026</small>
    <small>Информация на сайте носит ознакомительный характер и не является публичной офертой.</small>
    <a href={withBase('/politika-konfidencialnosti/')} class="footer-legal-link">Политика конфиденциальности</a>
    <button type="button" class="footer-legal-link footer-legal-button" data-open-cookie-settings>Настройки cookies</button>
  </div>
</footer>
