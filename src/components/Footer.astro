---
import site from '../data/site.json';
import { withBase } from '../utils/withBase';

const addressWithoutCity = site.address.replace(new RegExp(`,\\s*${site.city}\\s*$`, 'i'), '').trim();
---
<footer class="footer">
  <div class="container grid grid-3">
    <div>
      <a href={withBase('/')} class="logo-link footer-logo-link" aria-label="СМУ-1 на главную">
        <img class="logo footer-logo" src={withBase('/assets/brand/logo-full.svg')} alt="СМУ-1" />
      </a>
      <p class="form-note">B2B-first сайт: изделия, проектные услуги, доверительный контур.</p>
    </div>
    <div>
      <p><strong>Основной телефон:</strong> <a href={`tel:${site.phone}`}>{site.phone}</a></p>
      <p><strong>Дополнительный:</strong> <a href={`tel:${site.phoneSecondary}`}>{site.phoneSecondary}</a></p>
      <p><strong>Telegram:</strong> <a href={site.telegramUrl} target="_blank" rel="noopener noreferrer">{site.telegram}</a></p>
      <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <div>
      <p><strong>Город:</strong> {site.city}</p>
      <p><strong>Адрес:</strong> {addressWithoutCity}</p>
      <p class="form-note">{site.legalInfo}</p>
      <small>© {new Date().getFullYear()} {site.companyName}. Каркас сайта для публикации на GitHub Pages.</small>
    </div>
  </div>
</footer>
