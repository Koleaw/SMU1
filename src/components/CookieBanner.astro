---
import { withBase } from '../utils/withBase';
---
<div class="cookie-banner" data-cookie-banner hidden>
  <p>
    Мы используем cookies и сервисы аналитики для улучшения работы сайта.
    Продолжая пользоваться сайтом, вы соглашаетесь с политикой конфиденциальности.
  </p>
  <div class="cookie-banner__actions">
    <a href={withBase('/politika-konfidencialnosti/')} class="cookie-banner__more">Политика конфиденциальности</a>
    <button type="button" class="btn btn-primary" data-cookie-notice-close>Понятно</button>
  </div>
</div>

<script is:inline>
  (() => {
    const noticeKey = 'smu1_cookie_notice_closed';
    const legacyConsentKey = 'smu1_cookie_consent';
    const banner = document.querySelector('[data-cookie-banner]');
    if (!banner) return;

    const hideBanner = () => {
      banner.hidden = true;
      banner.setAttribute('hidden', 'hidden');
    };

    const showBanner = () => {
      banner.hidden = false;
      banner.removeAttribute('hidden');
    };

    const readStorage = (key) => {
      try {
        return localStorage.getItem(key);
      } catch {
        return null;
      }
    };

    const writeStorage = (key, value) => {
      try {
        localStorage.setItem(key, value);
      } catch {
        // storage может быть недоступен, но баннер не должен блокировать сайт
      }
    };

    const clearNotice = () => {
      try {
        localStorage.removeItem(noticeKey);
        localStorage.removeItem(legacyConsentKey);
      } catch {
        // ignore
      }
    };

    const closeNotice = () => {
      writeStorage(noticeKey, 'true');
      hideBanner();
    };

    const legacyValue = readStorage(legacyConsentKey);
    const hasClosed = readStorage(noticeKey) === 'true' || legacyValue === 'accepted' || legacyValue === 'necessary';

    if (hasClosed) {
      writeStorage(noticeKey, 'true');
      hideBanner();
    } else {
      showBanner();
    }

    banner.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const closeTrigger = target.closest('[data-cookie-notice-close]');
      if (!closeTrigger) return;

      event.preventDefault();
      closeNotice();
    });

    const openCookieSettings = () => {
      clearNotice();
      showBanner();
      banner.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    };

    window.smu1OpenCookieSettings = openCookieSettings;

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      const trigger = target.closest('[data-open-cookie-settings]');
      if (!trigger) return;

      event.preventDefault();
      openCookieSettings();
    });
  })();
</script>
