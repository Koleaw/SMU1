---
import forms from '../data/forms.json';
interface Props { type: 'shortLead' | 'calculationForm' | 'customOrderForm'; sourcePage: string; title?: string }
const { type, sourcePage, title = 'Оставьте заявку' } = Astro.props;
const isCalculation = type === 'calculationForm';
const isCustom = type === 'customOrderForm';
---
<section id="lead" class="section">
  <div class="container card">
    <h2 class="section-title">{title}</h2>
    <form class="form" method="POST" action={forms.endpoint}>
      <input type="hidden" name="formType" value={type} />
      <input type="hidden" name="sourcePage" value={sourcePage} />
      <input type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px" />
      <input name="name" required placeholder="Ваше имя" />
      <input name="phone" required placeholder="Телефон" />
      {isCalculation && <input name="city" placeholder="Город" />}
      <textarea name="details" rows="4" placeholder={isCustom ? 'Что нужно изготовить / комментарий / пожелания' : isCalculation ? 'Описание задачи, размеры, условия объекта' : 'Что интересует'} />
      {(isCalculation || isCustom) && <input type="file" name="attachment" />}
      <button class="btn btn-primary" type="submit">Отправить заявку</button>
      <p class="form-note">{forms.successText}</p>
      <p class="form-note">{forms.providerNote}</p>
    </form>
  </div>
</section>
