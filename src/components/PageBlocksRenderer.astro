---
import { withBase } from '../utils/withBase';
import {
  getSectionSpacingVars,
  getTextLayoutVars,
  getTextStyleVars,
  mergeStyleStrings,
  type TextLayoutSettings,
  type TextStyleSettings,
} from '../utils/textStyle';
import PageBlockMedia from './PageBlockMedia.astro';

type Theme = 'dark' | 'light' | 'graphite';
type GridValue = 'auto' | '2' | '3' | '4';
type MediaView = { fit?: 'cover' | 'contain'; positionX?: number; positionY?: number; scale?: number };
type PageBlockVariant = 'projectDirection';

interface BlockItem {
  title?: string;
  text?: string;
  question?: string;
  answer?: string;
  image?: string;
  video?: string;
  poster?: string;
  placeholderLabel?: string;
  buttonLabel?: string;
  buttonHref?: string;
  order?: number;
  isActive?: boolean;
}

interface PageBlock {
  type: string;
  title?: string;
  intro?: string;
  text?: string;
  theme?: Theme;
  background?: Theme;
  grid?: GridValue;
  columns?: 2 | 3 | 4;
  isActive?: boolean;
  order: number;
  sectionId?: string;
  items?: Array<string | BlockItem>;
  steps?: BlockItem[];
  media?: string;
  image?: string;
  video?: string;
  poster?: string;
  placeholderLabel?: string;
  mediaPosition?: 'left' | 'right';
  mediaView?: MediaView;
  buttonLabel?: string;
  buttonHref?: string;
  textWidth?: string;
  textAlign?: 'left' | 'center' | 'right';
  titleSize?: string;
  textSize?: string;
  textWeight?: string | number;
  textItalic?: boolean;
  paddingTop?: string;
  paddingBottom?: string;
  textStyle?: TextStyleSettings;
  titleStyle?: TextStyleSettings;
  layout?: TextLayoutSettings;
}

interface Props {
  pageBlocks?: PageBlock[];
  variant?: PageBlockVariant;
}

const { pageBlocks = [], variant } = Astro.props;
const visibleBlocks = pageBlocks
  .filter((block) => block && block.isActive !== false)
  .slice()
  .sort((a, b) => a.order - b.order);

const getTheme = (block: PageBlock): Theme => block.theme ?? block.background ?? 'light';
const getSectionClass = (theme: Theme, block: PageBlock, variant?: PageBlockVariant) => {
  const themeClass = `page-block-section--${theme}`;
  const typeClass = `page-block-section--${block.type}`;
  const variantClass = variant === 'projectDirection' ? 'page-block-section--project-direction' : '';
  const baseClass = theme === 'dark'
    ? 'section section--dark page-block-section'
    : theme === 'light'
      ? 'section section--soft page-block-section'
      : 'section page-block-section';

  return `${baseClass} ${themeClass} ${typeClass} ${variantClass}`.trim();
};
const getThemeAttr = (theme: Theme) => (theme === 'dark' ? 'dark' : undefined);
const getHeadingClass = (theme: Theme) => (theme === 'dark' ? 'section-heading section-heading--light' : 'section-heading');
const getGridClass = (grid: GridValue = 'auto') => `page-blocks-grid page-blocks-grid--${grid}`;
const getColumnsClass = (columns: number = 2) => `page-blocks-columns page-blocks-columns--${columns === 3 ? '3' : '2'}`;
const isDarkCardTheme = (theme: Theme) => theme === 'dark' || theme === 'graphite';
const resolveHref = (href?: string) => {
  if (!href) return '';
  if (/^(https?:|mailto:|tel:|#)/i.test(href)) return href;
  return withBase(href);
};

const getSectionStyle = (block: PageBlock) => getSectionSpacingVars(block.layout, block);
const getTextStyle = (block: PageBlock) =>
  mergeStyleStrings(getTextLayoutVars(block.layout, block), getTextStyleVars(block.textStyle, block));
const getTitleStyle = (block: PageBlock) =>
  mergeStyleStrings(getTextStyleVars(block.titleStyle ?? block.textStyle, block, true));

const normalizeTextList = (items: Array<string | BlockItem> = []) =>
  items
    .map((item) => (typeof item === 'string' ? item.trim() : item.isActive === false ? '' : item.text?.trim() ?? item.title?.trim() ?? ''))
    .filter(Boolean);

const normalizeCardItems = (items: Array<string | BlockItem> = []) =>
  items
    .map((item, index) => typeof item === 'string' ? { title: item, text: '', order: (index + 1) * 10, isActive: true } : item)
    .filter((item) => item && item.isActive !== false && (item.title?.trim() || item.text?.trim() || item.image?.trim()))
    .slice()
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const normalizeSteps = (steps: BlockItem[] = []) =>
  steps
    .filter((step) => step && step.isActive !== false && (step.title?.trim() || step.text?.trim()))
    .slice()
    .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));

const simpleTextTypes = new Set(['textBlock', 'notice', 'cta', 'customOrder']);
const listTypes = new Set(['listPanel', 'factorList', 'costFactors']);
const cardTypes = new Set(['cardGrid', 'exampleGrid', 'benefits', 'directionCards', 'solutions']);
---
{visibleBlocks.map((block, index) => {
  const sectionId = block.sectionId ?? `page-block-${index + 1}`;
  const theme = getTheme(block);
  const sectionClass = getSectionClass(theme, block, variant);
  const themeAttr = getThemeAttr(theme);
  const sectionStyle = getSectionStyle(block);
  const mediaPosition = block.mediaPosition === 'left' ? 'left' : 'right';

  if (block.type === 'gallery') {
    const items = normalizeCardItems(block.items);
    if (!items.length) return null;

    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class="container">
          <div class={getHeadingClass(theme)} style={getTextStyle(block)}>
            {block.title && <h2 class="section-title" style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
          </div>
          <div class={getGridClass(block.grid ?? 'auto')}>
            {items.map((item) => (
              <article class="page-block-gallery-card">
                <PageBlockMedia block={item} ratio="card" />
                {(item.title || item.text) && (
                  <div class="page-block-gallery-card__body">
                    {item.title && <h3>{item.title}</h3>}
                    {item.text && <p>{item.text}</p>}
                  </div>
                )}
              </article>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (block.type === 'faq') {
    const items = normalizeCardItems(block.items);
    if (!items.length) return null;

    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class="container page-block-narrow" style={getTextStyle(block)}>
          <div class={getHeadingClass(theme)}>
            {block.title && <h2 class="section-title" style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
          </div>
          <div class="page-block-faq-list">
            {items.map((item) => (
              <details class="card page-block-faq-item">
                <summary>{item.question || item.title}</summary>
                <p>{item.answer || item.text}</p>
              </details>
            ))}
          </div>
        </div>
      </section>
    );
  }

  if (cardTypes.has(block.type)) {
    const items = normalizeCardItems(block.items);
    if (!items.length) return null;
    const showCardNumbers = !(variant === 'projectDirection' && (block.type === 'cardGrid' || block.type === 'directionCards'));

    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class="container">
          <div class={getHeadingClass(theme)} style={getTextStyle(block)}>
            {block.title && <h2 class="section-title" style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
          </div>
          <div class={getGridClass(block.grid ?? 'auto')}>
            {items.map((item, itemIndex) => {
              const href = resolveHref(item.buttonHref);
              const content = (
                <>
                  {showCardNumbers && <span class="page-block-card__number">{String(itemIndex + 1).padStart(2, '0')}</span>}
                  <PageBlockMedia block={item} ratio="card" />
                  <div class="page-block-card__body">
                    {item.title && <h3>{item.title}</h3>}
                    {item.text && <p>{item.text}</p>}
                    {item.buttonLabel && <span class="btn btn-secondary page-block-card__cta">{item.buttonLabel}</span>}
                  </div>
                </>
              );

              return href ? (
                <a class={`card page-block-card page-block-card--link ${isDarkCardTheme(theme) ? 'page-block-card--dark' : 'page-block-card--light'}`} href={href}>
                  {content}
                </a>
              ) : (
                <article class={`card page-block-card ${isDarkCardTheme(theme) ? 'page-block-card--dark' : 'page-block-card--light'}`}>
                  {content}
                </article>
              );
            })}
          </div>
        </div>
      </section>
    );
  }

  if (listTypes.has(block.type)) {
    const items = normalizeTextList(block.items);
    if (!items.length) return null;
    const isTechnicalList = block.type === 'factorList' || block.type === 'costFactors';

    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class="container">
          <article class={`card page-block-card page-block-panel ${isTechnicalList ? 'page-block-panel--technical-list' : ''} ${theme === 'graphite' ? 'page-block-card--graphite' : ''}`} style={getTextStyle(block)}>
            {block.title && <h2 style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
            {isTechnicalList ? (
              <div class="page-block-factor-grid">
                {items.map((item, itemIndex) => (
                  <div class="page-block-factor-card">
                    <span class="page-block-factor-card__number">{String(itemIndex + 1).padStart(2, '0')}</span>
                    <p>{item}</p>
                  </div>
                ))}
              </div>
            ) : (
              <ul class={getColumnsClass(block.columns)}>
                {items.map((item) => <li>{item}</li>)}
              </ul>
            )}
          </article>
        </div>
      </section>
    );
  }

  if (block.type === 'process') {
    const steps = normalizeSteps(block.steps);
    if (!steps.length) return null;

    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class={`container page-block-media-layout ${mediaPosition === 'left' ? 'page-block-media-layout--left' : ''}`}>
          <PageBlockMedia block={block} />
          <article class={`card page-block-card page-block-panel ${theme === 'graphite' ? 'page-block-card--graphite' : ''}`} style={getTextStyle(block)}>
            {block.title && <h2 style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
            <ol class="page-block-steps">
              {steps.map((step) => (
                <li>
                  {step.title && <strong>{step.title}</strong>}
                  {step.text && <p>{step.text}</p>}
                </li>
              ))}
            </ol>
          </article>
        </div>
      </section>
    );
  }

  if (block.type === 'mediaText' || block.type === 'whoWeAre' || block.type === 'heroSection') {
    return (
      <section id={sectionId} class={`${sectionClass} ${block.type === 'heroSection' ? 'page-block-hero-section' : ''}`} data-section-theme={themeAttr} style={sectionStyle}>
        <div class={`container page-block-media-layout ${mediaPosition === 'left' ? 'page-block-media-layout--left' : ''}`}>
          <PageBlockMedia block={block} />
          <article class={`card page-block-card page-block-panel ${theme === 'graphite' ? 'page-block-card--graphite' : ''}`} style={getTextStyle(block)}>
            {block.title && <h2 style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
            {block.text && <p>{block.text}</p>}
            {block.buttonLabel && block.buttonHref && <a class="btn btn-primary page-block-button" href={resolveHref(block.buttonHref)}>{block.buttonLabel}</a>}
          </article>
        </div>
      </section>
    );
  }

  if (simpleTextTypes.has(block.type) || block.title || block.text) {
    return (
      <section id={sectionId} class={sectionClass} data-section-theme={themeAttr} style={sectionStyle}>
        <div class="container">
          <article class={`card page-block-card page-block-panel page-block-narrow page-block-panel--${block.type} ${theme === 'graphite' ? 'page-block-card--graphite' : ''}`} style={getTextStyle(block)}>
            {block.title && <h2 style={getTitleStyle(block)}>{block.title}</h2>}
            {block.intro && <p class="lead">{block.intro}</p>}
            {block.text && <p>{block.text}</p>}
            {block.buttonLabel && block.buttonHref && <a class="btn btn-primary page-block-button" href={resolveHref(block.buttonHref)}>{block.buttonLabel}</a>}
          </article>
        </div>
      </section>
    );
  }

  return null;
})}

<style>
  .page-block-section {
    padding-block: var(--page-block-padding-top, clamp(36px, 5vw, 56px)) var(--page-block-padding-bottom, clamp(36px, 5vw, 56px));
  }

  .page-blocks-grid {
    display: grid;
    gap: 16px;
  }

  .page-blocks-grid--auto {
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .page-blocks-grid--2 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .page-blocks-grid--3 {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .page-blocks-grid--4 {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .page-block-card {
    min-height: 100%;
    overflow: hidden;
  }

  .page-block-card__number {
    display: none;
  }

  .page-block-card--link {
    color: inherit;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast), transform var(--transition-fast);
  }

  .page-block-card--link:hover,
  .page-block-card--link:focus-visible {
    transform: translateY(-2px);
  }

  .page-block-card--graphite {
    background: var(--color-surface);
    border-color: var(--color-border);
  }

  .page-block-section--graphite {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgb(255 255 255 / 4%) 0 1px, transparent 1px 38px),
      linear-gradient(90deg, rgb(255 255 255 / 3%) 0 1px, transparent 1px 72px),
      linear-gradient(180deg, #10161b 0%, #141d24 48%, #10161b 100%);
    color: #f2f5f7;
  }

  .page-block-section--graphite::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(90deg, transparent 0%, rgb(24 167 97 / 8%) 46%, transparent 72%),
      linear-gradient(180deg, rgb(255 255 255 / 5%) 0, transparent 160px);
    opacity: 0.78;
  }

  .page-block-section--graphite > .container {
    position: relative;
    z-index: 1;
  }

  .page-block-section--graphite .section-heading,
  .page-block-section--graphite .section-title,
  .page-block-section--graphite .section-heading h2 {
    color: #ffffff;
  }

  .page-block-section--graphite .section-heading .lead,
  .page-block-section--graphite .section-heading p {
    color: rgb(242 245 247 / 78%);
  }

  .page-block-factor-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .page-block-factor-card {
    position: relative;
    display: grid;
    gap: 10px;
    min-height: 124px;
    padding: 18px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-base);
    background: var(--color-surface);
  }

  .page-block-factor-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 18px;
    width: 44px;
    height: 2px;
    background: var(--color-accent);
  }

  .page-block-factor-card__number {
    color: var(--color-accent);
    font-size: var(--font-size-caption);
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0;
  }

  .page-block-factor-card p {
    color: var(--color-text);
  }

  .page-block-section--project-direction.page-block-section--cardGrid,
  .page-block-section--project-direction.page-block-section--directionCards,
  .page-block-section--project-direction.page-block-section--process,
  .page-block-section--project-direction.page-block-section--factorList,
  .page-block-section--project-direction.page-block-section--costFactors {
    position: relative;
    overflow: hidden;
    color: var(--color-text);
    background:
      linear-gradient(180deg, #ffffff 0%, var(--color-bg) 100%);
  }

  .page-block-section--project-direction.page-block-section--cardGrid > .container,
  .page-block-section--project-direction.page-block-section--directionCards > .container,
  .page-block-section--project-direction.page-block-section--process > .container,
  .page-block-section--project-direction.page-block-section--factorList > .container,
  .page-block-section--project-direction.page-block-section--costFactors > .container {
    position: relative;
    z-index: 1;
  }

  .page-block-section--project-direction.page-block-section--cardGrid,
  .page-block-section--project-direction.page-block-section--directionCards {
    padding-top: clamp(72px, 8vw, 112px);
    padding-bottom: clamp(54px, 6vw, 78px);
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-blocks-grid,
  .page-block-section--project-direction.page-block-section--directionCards .page-blocks-grid {
    gap: 18px;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card {
    position: relative;
    isolation: isolate;
    border-color: rgb(16 22 27 / 13%);
    border-radius: var(--radius-max);
    background: #ffffff;
    box-shadow: 0 10px 28px rgb(16 22 27 / 7%);
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card {
    align-content: start;
    gap: 14px;
    min-height: 190px;
    padding: 22px;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card {
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 0;
    padding: 0;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card::before,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card::before {
    display: none;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card::after,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card::after {
    content: '';
    position: absolute;
    right: 16px;
    bottom: 16px;
    z-index: 2;
    width: 24px;
    height: 24px;
    border-right: 1px solid rgb(24 167 97 / 42%);
    border-bottom: 1px solid rgb(24 167 97 / 42%);
    pointer-events: none;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card__number,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card__number {
    display: none;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card__body {
    gap: 12px;
    padding: 0;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card__body {
    gap: 12px;
    padding: 20px 20px 24px;
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card h3,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card h3 {
    color: var(--color-text);
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card p,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card p {
    color: var(--color-text-secondary);
  }

  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card:hover,
  .page-block-section--project-direction.page-block-section--cardGrid .page-block-card:focus-visible,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:hover,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:focus-visible {
    border-color: rgb(16 22 27 / 34%);
    box-shadow: 0 18px 42px rgb(16 22 27 / 10%);
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-media {
    border: 0;
    border-radius: 0;
    background: #e9eef0;
    border-bottom: 1px solid rgb(16 22 27 / 10%);
    box-shadow: none;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-media .media-thumb {
    min-height: 220px;
    border-radius: 0;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    border-color: rgb(16 22 27 / 32%);
    background: #ffffff;
    color: var(--color-text);
    box-shadow: none;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card__cta::after {
    content: '';
    display: inline-block;
    width: 16px;
    height: 1px;
    background: var(--color-accent);
    transition: width var(--transition-fast), background-color var(--transition-fast);
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:hover .page-block-card__cta,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:focus-visible .page-block-card__cta {
    border-color: var(--color-panel-dark);
    background: var(--color-panel-dark);
    color: #ffffff;
  }

  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:hover .page-block-card__cta::after,
  .page-block-section--project-direction.page-block-section--directionCards .page-block-card:focus-visible .page-block-card__cta::after {
    width: 22px;
  }

  .page-block-section--project-direction.page-block-section--process,
  .page-block-section--project-direction.page-block-section--factorList,
  .page-block-section--project-direction.page-block-section--costFactors {
    padding-top: clamp(38px, 5vw, 64px);
    padding-bottom: clamp(58px, 7vw, 88px);
    background:
      linear-gradient(180deg, var(--color-bg) 0%, #ffffff 100%);
  }

  .page-block-section--project-direction.page-block-section--process .page-block-panel {
    padding: clamp(24px, 4vw, 38px);
    border-color: rgb(16 22 27 / 12%);
    background: #ffffff;
    box-shadow: var(--shadow-panel);
  }

  .page-block-section--project-direction.page-block-section--process .page-block-panel::after {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 5px;
    background:
      linear-gradient(180deg, var(--color-panel-dark) 0 72%, var(--color-accent) 72% 100%);
  }

  .page-block-section--project-direction.page-block-section--process .page-block-steps {
    counter-reset: process-step;
    gap: 0;
    padding: 22px 0 0;
    list-style: none;
    border-top: 1px solid rgb(16 22 27 / 12%);
  }

  .page-block-section--project-direction.page-block-section--process .page-block-steps li {
    counter-increment: process-step;
    position: relative;
    padding: 44px 18px 18px 0;
  }

  .page-block-section--project-direction.page-block-section--process .page-block-steps li::before {
    content: counter(process-step, decimal-leading-zero);
    position: absolute;
    top: 0;
    left: 0;
    display: inline-flex;
    align-items: center;
    min-height: 27px;
    padding: 5px 8px;
    border-radius: var(--radius-base);
