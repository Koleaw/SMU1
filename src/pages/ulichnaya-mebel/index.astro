---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import categories from '../../data/categories.json';
import { withBase } from '../../utils/withBase';

const category = categories[0];
const categoryMedia = [
  '/assets/images/products/benches-1.svg',
  '/assets/images/products/bins-1.svg',
  '/assets/images/placeholders/street-furniture.svg',
  '/assets/images/products/benches-2.svg',
  '/assets/images/products/bins-2.svg'
];
---
<BaseLayout title="Уличная мебель — СМУ-1" description={category.shortDescription}>
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Уличная мебель' }]} />
    </div>
  </div>

  <Hero
    kicker="Каталог изделий"
    title={category.h1}
    description={category.shortDescription}
    primaryLabel="Смотреть категории"
    primaryHref="#categories"
    secondaryLabel="Связаться"
    secondaryHref="#direct-contact"
    className="hero--catalog"
  />

  <section id="categories" class="section section--soft">
    <div class="container">
      <div class="section-heading">
        <h2 class="section-title">Категории изделий</h2>
      </div>
      <div class="category-choice-grid">
        {category.subcategories.map((sub, index) => (
          <a class="category-choice-card" href={withBase(`/ulichnaya-mebel/${sub.slug}/`)}>
            <div class="media-block placeholder placeholder--card">
              <img class="media-thumb" src={withBase(categoryMedia[index % categoryMedia.length])} alt={sub.title} loading="lazy" />
              <p class="media-caption">Фото будут обновлены в мае: материалы по категории.</p>
            </div>
            <div class="category-choice-card__body">
              <h3>{sub.title}</h3>
              <p>Типовые решения и адаптация под задачу объекта.</p>
              <span class="btn btn-secondary">Открыть подкатегорию</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="direct-contact" class="section">
    <div class="container">
      <article class="home-contact-card">
        <h2 class="section-title">Не нашли, что искали?</h2>
        <p class="lead">Если типовая категория не закрывает задачу, напишите нам. Подберем решение под объект, референс, ТЗ или чертеж.</p>
        <div class="home-contact-actions">
          <a class="btn btn-primary" href="https://t.me/smu1build" target="_blank" rel="noreferrer">@smu1build · Написать в Telegram</a>
          <a class="btn btn-secondary" href="mailto:smu1.kurgan@yandex.ru">smu1.kurgan@yandex.ru · Написать на почту</a>
          <a class="btn btn-secondary" href="tel:+79129735006">+7 (912) 973-50-06 · Позвонить</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
