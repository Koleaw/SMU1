---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DirectContactBlock from '../components/DirectContactBlock.astro';
import { withBase } from '../utils/withBase';
---
<BaseLayout title="Ограждения и заборы — СМУ-1" description="Ограждения, заборы, калитки и ворота под задачи безопасности и эксплуатации.">
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Ограждения и заборы' }]} />
    </div>
  </div>

  <Hero title="Ограждения и заборы" description="Ограждения, заборы, калитки и ворота под задачи безопасности и эксплуатации." />

  <section class="section"><div class="container grid grid-2">
    <article class="card"><h2>Форматы решений</h2><ul><li>секционные и сварные ограждения</li><li>заборы для коммерческих территорий</li><li>калитки и ворота</li><li>комбинированные решения</li></ul></article>
    <article class="card"><h2>Логика цены</h2><p class="lead">Для типовых секций возможна модель «цена от». Для проектных конфигураций — «по запросу» после уточнения параметров.</p></article>
  </div></section>

  <DirectContactBlock />
</BaseLayout>
