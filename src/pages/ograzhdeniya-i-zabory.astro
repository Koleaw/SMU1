---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DirectContactBlock from '../components/DirectContactBlock.astro';
import { withBase } from '../utils/withBase';

const section = (await getCollection('product-sections')).find(
  ({ data }) => data.slug === 'ograzhdeniya-i-zabory' && data.isActive
);

if (!section) {
  throw new Error('Active section ograzhdeniya-i-zabory not found in content collection.');
}
---
<BaseLayout title={section.data.seoTitle} description={section.data.seoDescription}>
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: section.data.title }]} />
    </div>
  </div>

  <Hero
    className="hero--catalog hero--catalog-clean"
    title={section.data.heroTitle}
    description={section.data.heroDescription}
  />

  <section class="section">
    <div class="container">
      <article class="media-block placeholder placeholder--card">
        <img class="media-thumb" src={withBase(section.data.image)} alt={section.data.title} loading="lazy" />
        <p class="media-caption">{section.data.placeholderLabel}</p>
      </article>
    </div>
  </section>

  <DirectContactBlock />
</BaseLayout>
