---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import yandex from '../data/yandex.json';
import { withBase } from '../utils/withBase';

const settingsEntry = (await getCollection('site-settings'))[0];
if (!settingsEntry) {
  throw new Error('site-settings collection must contain one entry.');
}

const site = settingsEntry.data;
const addressWithoutCity = site.address.replace(new RegExp(`,\\s*${site.city}\\s*$`, 'i'), '').trim();
const telegramLabel = site.telegramLabel ?? site.telegram.replace(/^https?:\/\/t\.me\//, '@');
const regions = site.regions ?? ['Курган', 'Курганская область', 'УрФО', 'по согласованию — соседние регионы'];
---
<BaseLayout title="Контакты — СМУ-1" description="Контакты СМУ-1: телефон, мессенджеры, email, география работ и форма связи.">
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Контакты' }]} />
    </div>
  </div>

  <Hero
    kicker="Связь"
    className="hero--catalog-clean"
    title="Контакты"
  />

  <section class="section section--soft">
    <div class="container contacts-layout-grid">
      <div class="contacts-top-grid">
        <article class="card contacts-main-card">
          <h2>Свяжитесь с СМУ-1</h2>
          <div class="contacts-list">
            <p><strong>Основной телефон:</strong> <a href={`tel:${site.phonePrimary}`}>{site.phonePrimary}</a></p>
            <p>
              <strong>Дополнительный телефон:</strong> <a href={`tel:${site.phoneSecondary}`}>{site.phoneSecondary}</a>
              <span class="contacts-note">руководитель</span>
            </p>
            <p><strong>Telegram:</strong> <a href={site.telegram} target="_blank" rel="noopener noreferrer">{telegramLabel}</a></p>
            <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
            <p><strong>Город:</strong> {site.city}</p>
            <p><strong>Адрес:</strong> {addressWithoutCity}</p>
          </div>
        </article>

        <article class="card contacts-right-column">
          <h2>География работ</h2>
          <ul>{regions.map((r) => <li>{r}</li>)}</ul>
          <p class="contacts-geo-note">Работаем по Кургану, области и по согласованию выезжаем в соседние регионы.</p>
          <p class="contacts-career-entry">
            Хотите работать с нами? Посмотрите открытые вакансии.
            <a href={withBase('/vakansii/')}>Вакансии</a>
          </p>
        </article>
      </div>

      <article class="card contacts-map-card">
        <h2>Мы на карте</h2>
        <div class="contacts-map-embed contacts-map-embed--wide">
          <script type="text/javascript" charset="utf-8" async src={yandex.map.constructorSrc}></script>
        </div>
        <iframe
          class="contacts-yandex-badge"
          src={yandex.ratingBadge.src}
          width={yandex.ratingBadge.width}
          height={yandex.ratingBadge.height}
          frameborder="0"
          title="Рейтинг в Яндекс Бизнес"
          loading="lazy"
        ></iframe>
      </article>
    </div>
  </section>
</BaseLayout>
