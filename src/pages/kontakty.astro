---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import LeadForm from '../components/LeadForm.astro';
import site from '../data/site.json';
import { withBase } from '../utils/withBase';
---
<BaseLayout title="Контакты — СМУ-1" description="Контакты СМУ-1: телефон, мессенджеры, email, география работ и форма связи.">
  <Hero title="Контакты" description="Свяжитесь удобным способом: телефон, мессенджеры, email или форма на сайте." primaryLabel="Позвонить" primaryHref={`tel:${site.phone}`} secondaryLabel="Написать" secondaryHref={`mailto:${site.email}`}>
    <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Контакты' }]} />
  </Hero>
  <section class="section"><div class="container grid grid-2">
    <article class="card"><h2>Контактные данные</h2><p><strong>Телефон:</strong> {site.phone}</p><p><strong>Email:</strong> {site.email}</p><p><strong>Город:</strong> {site.city}</p><p><strong>Адрес:</strong> {site.address}</p></article>
    <article class="card"><h2>География</h2><ul>{site.regions.map((r) => <li>{r}</li>)}</ul><p class="lead">Карта и точный адрес добавляются после финального согласования данных.</p><p class="lead">{site.legalInfo}</p></article>
  </div></section>
  <LeadForm type="shortLead" sourcePage="kontakty" title="Форма связи" />
</BaseLayout>
