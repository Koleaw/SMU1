---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import site from '../data/site.json';
import yandex from '../data/yandex.json';
import { withBase } from '../utils/withBase';

const addressWithoutCity = site.address.replace(new RegExp(`,\\s*${site.city}\\s*$`, 'i'), '').trim();
---
<BaseLayout title="Контакты — СМУ-1" description="Контакты СМУ-1: телефон, мессенджеры, email, география работ и форма связи.">
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Контакты' }]} />
    </div>
  </div>

  <Hero
    kicker="Связь"
    className="hero--service"
    title="Контакты"
    description="Телефоны, Telegram, почта, адрес и карта для быстрого старта проекта."
  />

  <section class="section section--soft">
    <div class="container contacts-trust-grid">
      <article class="card contacts-main-card">
        <h2>Свяжитесь с СМУ-1</h2>
        <div class="contacts-list">
          <p><strong>Основной телефон:</strong> <a href={`tel:${site.phone}`}>{site.phone}</a></p>
          <p>
            <strong>Дополнительный телефон:</strong> <a href={`tel:${site.phoneSecondary}`}>{site.phoneSecondary}</a>
            <span class="contacts-note">руководитель</span>
          </p>
          <p><strong>Telegram:</strong> <a href={site.telegramUrl} target="_blank" rel="noopener noreferrer">{site.telegram}</a></p>
          <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
          <p><strong>Город:</strong> {site.city}</p>
          <p><strong>Адрес:</strong> {addressWithoutCity}</p>
        </div>
      </article>

      <article class="card contacts-right-column">
        <h2>География работ</h2>
        <ul>{site.regions.map((r) => <li>{r}</li>)}</ul>
        <p class="contacts-geo-note">Работаем по Кургану, области и по согласованию выезжаем в соседние регионы.</p>
        <h3>Мы на карте</h3>
        <div class="contacts-map-embed">
          <script type="text/javascript" charset="utf-8" async src={yandex.map.constructorSrc}></script>
        </div>
        <iframe
          class="contacts-yandex-badge"
          src={yandex.ratingBadge.src}
          width={yandex.ratingBadge.width}
          height={yandex.ratingBadge.height}
          frameborder="0"
          title="Рейтинг в Яндекс Бизнес"
          loading="lazy"
        ></iframe>
      </article>
    </div>
  </section>
</BaseLayout>
