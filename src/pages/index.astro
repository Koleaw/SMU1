---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionNavigator from '../components/SectionNavigator.astro';
import { withBase } from '../utils/withBase';

const sectionNavItems = [
  { id: 'home-products', label: 'Продукция' },
  { id: 'home-services', label: 'Услуги' },
  { id: 'home-trust', label: 'Выполненные объекты' },
  { id: 'home-contact', label: 'Связаться' }
];

const productDirections = (await getCollection('product-sections'))
  .map(({ data }) => data)
  .filter((item) => item.showOnHome && item.isActive)
  .sort((a, b) => a.order - b.order);

const serviceDirections = (await getCollection('services'))
  .map(({ data }) => data)
  .filter((item) => item.showOnHome && item.isActive)
  .sort((a, b) => a.order - b.order);

const homePage = (await getCollection('static-pages')).find(({ data }) => data.slug === 'home')?.data;

if (!homePage) {
  throw new Error('static-pages collection must contain home.json.');
}

const pathwayLinks = ['#home-products', '#home-services', '#home-trust'];
const pathwayCards = (homePage.pathwayCards ?? [])
  .filter((item) => item.isActive !== false)
  .slice()
  .sort((a, b) => a.order - b.order);

const homeHeroVideo = homePage.heroMediaVideo || '/assets/video/hero-home.mp4';
---
<BaseLayout title={homePage.seoTitle} description={homePage.seoDescription}>
  <div class="home-page">
    <SectionNavigator items={sectionNavItems} />

    <Hero
      className="hero--media"
      kicker={homePage.heroKicker}
      title={homePage.heroTitle}
      description={homePage.heroDescription}
      primaryLabel={homePage.heroPrimaryLabel}
      primaryHref="#home-contact"
      secondaryLabel={homePage.heroSecondaryLabel}
      secondaryHref={withBase('/vypolnennye-obekty/')}
      mediaType="video"
      mediaVideo={withBase(homeHeroVideo)}
      mediaVideoMobile={homePage.heroMediaVideoMobile ? withBase(homePage.heroMediaVideoMobile) : undefined}
      mediaPoster={withBase(homePage.heroMediaPoster ?? '/assets/images/placeholders/construction.svg')}
      mediaAlt="Производственно-строительные работы СМУ-1"
      mediaCaption={homePage.heroMediaCaption}
      overlayOpacity={homePage.heroOverlayOpacity}
      mediaView={homePage.imageView}
    >
      <div class="home-hero-meta" aria-label="Основные направления">
        <a href="#home-products">Каталог изделий</a>
        <a href="#home-services">Проектные услуги</a>
        <a href="#home-trust">Выполненные объекты</a>
      </div>
    </Hero>

    <section class="home-pathways section" aria-labelledby="home-pathways-title">
      <div class="container">
        <div class="section-heading home-pathways__heading">
          <p class="kicker">{homePage.pathwaysKicker}</p>
          <h2 id="home-pathways-title" class="section-title">{homePage.pathwaysTitle}</h2>
        </div>
        <div class="home-pathways__grid">
          {pathwayCards.map((card, index) => (
            <a class="home-pathway-card" href={pathwayLinks[index] ?? '#home-contact'}>
              <span class="home-pathway-card__index">{String(index + 1).padStart(2, '0')}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="home-products" class="section section--split">
      <div class="container">
        <div class="section-heading">
          <h2 class="section-title">{homePage.productsTitle}</h2>
          <p class="lead">{homePage.productsIntro}</p>
        </div>
        <div class="home-products-grid">
          {productDirections.map((item) => (
            <a class="home-product-card" href={withBase(`/${item.slug}/`)}>
              <div class="media-block placeholder placeholder--card">
                <img class="media-thumb" src={withBase(item.image)} alt={item.title} loading="lazy" />
              </div>
              <div class="home-product-card__body">
                <h3>{item.title}</h3>
                <p>{item.shortDescription}</p>
              </div>
              <span class="btn btn-secondary home-product-card__cta">Перейти в раздел</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="home-services" class="section section--soft">
      <div class="container">
        <div class="section-heading">
          <h2 class="section-title">{homePage.servicesTitle}</h2>
          <p class="lead">{homePage.servicesIntro}</p>
        </div>
        <div class="home-services-grid">
          {serviceDirections.map((item) => (
            <article class="home-service-card">
              <div class="media-block placeholder placeholder--wide-feature">
                <img class="media-thumb" src={withBase(item.image)} alt={item.title} loading="lazy" />
              </div>
              <div class="home-service-card__body">
                <h3>{item.title}</h3>
                <p>{item.shortDescription}</p>
                <a class="btn btn-secondary" href={withBase(`/${item.slug}/`)}>Перейти в раздел</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="home-trust" class="section section--dark">
      <div class="container trust-media-grid">
        <article class="trust-media trust-media--objects">
          <div class="media-block placeholder placeholder--card">
            <img class="media-thumb" src={withBase(homePage.trustImage ?? '/assets/images/objects/object-2.svg')} alt="Выполненные объекты СМУ-1" loading="lazy" />
            <p class="media-caption">{homePage.trustCaption}</p>
          </div>
          <h2>{homePage.trustTitle}</h2>
          <p>{homePage.trustText}</p>
          <a class="btn btn-primary" href={withBase('/vypolnennye-obekty/')}>Наши объекты</a>
        </article>
      </div>
    </section>

    <section id="home-contact" class="section section--split home-contact-section">
      <div class="container">
        <div class="home-contact-card">
          <h2 class="section-title">{homePage.contactTitle}</h2>
          <p class="lead">{homePage.contactDescription}</p>
          <div class="home-contact-actions">
            <a class="btn btn-primary" href="https://t.me/smu1build" target="_blank" rel="noreferrer">Написать в Telegram</a>
            <a class="btn btn-secondary" href="mailto:smu1.kurgan@yandex.ru">Написать на почту</a>
            <a class="btn btn-secondary" href="tel:+79129735006">Позвонить +7 (912) 973-50-06</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
