---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import SectionNavigator from '../components/SectionNavigator.astro';
import { withBase } from '../utils/withBase';

const sectionNavItems = [
  { id: 'home-products', label: 'Продукция' },
  { id: 'home-services', label: 'Услуги' },
  { id: 'home-trust', label: 'Выполненные объекты' },
  { id: 'home-contact', label: 'Связаться' }
];

const productDirections = (await getCollection('product-sections'))
  .map(({ data }) => data)
  .filter((item) => item.showOnHome && item.isActive)
  .sort((a, b) => a.order - b.order);

const serviceDirections = (await getCollection('services'))
  .map(({ data }) => data)
  .filter((item) => item.showOnHome && item.isActive)
  .sort((a, b) => a.order - b.order);
---
<BaseLayout title="СМУ-1 — производство изделий, металлоконструкции и благоустройство" description="СМУ-1 в Кургане: изделия, навесы, металлоконструкции, строительство и благоустройство территорий для коммерческих и общественных объектов.">
  <div class="home-page">
    <SectionNavigator items={sectionNavItems} />

    <Hero
      className="hero--media"
      kicker="СМУ-1 · Курган"
      title="Закрываем объект комплексно: от изделий и металлоконструкций до строительства и благоустройства"
      description="Работаем с коммерческими и общественными площадками: считаем задачу, подбираем формат работ, изготавливаем в цехе и сопровождаем реализацию на объекте."
      primaryLabel="Получить расчет"
      secondaryLabel="Наши объекты"
      secondaryHref={withBase('/vypolnennye-obekty/')}
      mediaType="video"
      mediaVideo={withBase('/assets/video/hero-home.mp4')}
      mediaPoster={withBase('/assets/images/placeholders/construction.svg')}
      mediaAlt="Производственно-строительные работы СМУ-1"
      mediaCaption="Hero video-ready: до майского обновления используется постер, после загрузки финального ролика блок автоматически работает как фоновое видео без звука."
    />

    <section id="home-products" class="section section--split">
      <div class="container">
        <div class="section-heading">
          <h2 class="section-title">Продукция</h2>
          <p class="lead">Здесь собраны продуктовые направления компании для задач общественных, коммерческих и городских территорий.</p>
        </div>
        <div class="home-products-grid">
          {productDirections.map((item) => (
            <a class="home-product-card" href={withBase(`/${item.slug}/`)}>
              <div class="media-block placeholder placeholder--card">
                <img class="media-thumb" src={withBase(item.image)} alt={item.title} loading="lazy" />
              </div>
              <div class="home-product-card__body">
                <h3>{item.title}</h3>
                <p>{item.shortDescription}</p>
              </div>
              <span class="btn btn-secondary home-product-card__cta">Перейти в раздел</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="home-services" class="section section--soft">
      <div class="container">
        <div class="section-heading">
          <h2 class="section-title">Услуги</h2>
          <p class="lead">Сервисные направления для работ под задачу объекта: от подготовки решения до реализации на площадке.</p>
        </div>
        <div class="home-services-grid">
          {serviceDirections.map((item) => (
            <article class="home-service-card">
              <div class="media-block placeholder placeholder--wide-feature">
                <img class="media-thumb" src={withBase(item.image)} alt={item.title} loading="lazy" />
              </div>
              <div class="home-service-card__body">
                <h3>{item.title}</h3>
                <p>{item.shortDescription}</p>
                <a class="btn btn-secondary" href={withBase(`/${item.slug}/`)}>Перейти в раздел</a>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section id="home-trust" class="section section--dark">
      <div class="container trust-media-grid">
        <article class="trust-media trust-media--objects">
          <div class="media-block placeholder placeholder--card">
            <img class="media-thumb" src={withBase('/assets/images/objects/object-2.svg')} alt="Выполненные объекты СМУ-1" loading="lazy" />
            <p class="media-caption">Майское наполнение: фото реализованных объектов и фактические результаты работ.</p>
          </div>
          <h2>Выполненные объекты</h2>
          <p>Показываем не рендеры, а реальные площадки: задачу, объем работ, комплектацию и итог на объекте.</p>
          <a class="btn btn-primary" href={withBase('/vypolnennye-obekty/')}>Наши объекты</a>
        </article>
      </div>
    </section>

    <section id="home-contact" class="section section--split home-contact-section">
      <div class="container">
        <div class="home-contact-card">
          <h2 class="section-title">Не нашли, что искали?</h2>
          <p class="lead">Готовы выполнить решение под ваш объект, ТЗ, референс или чертеж. Напишите нам напрямую, и мы сориентируем по реализации.</p>
          <div class="home-contact-actions">
            <a class="btn btn-primary" href="https://t.me/smu1build" target="_blank" rel="noreferrer">Написать в Telegram</a>
            <a class="btn btn-secondary" href="mailto:smu1.kurgan@yandex.ru">Написать на почту</a>
            <a class="btn btn-secondary" href="tel:+79129735006">Позвонить +7 (912) 973-50-06</a>
          </div>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>
