---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import LeadForm from '../components/LeadForm.astro';
import SectionNavigator from '../components/SectionNavigator.astro';
import projects from '../data/project-pages.json';
import { withBase } from '../utils/withBase';

export function getStaticPaths() {
  return projects.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;

const sectionNavItems = [
  { id: 'project-scope', label: 'Что решаем и состав услуги' },
  { id: 'project-workflow', label: 'Как работаем' },
  { id: 'project-targets', label: 'Для каких объектов' },
  { id: 'project-form', label: 'Форма расчета' },
  { id: 'lead', label: 'Отправить запрос' }
];

---
<BaseLayout title={`${item.menuTitle} — СМУ-1`} description={item.offer}>
  <SectionNavigator items={sectionNavItems} />

  <Hero
    kicker="Проектное направление"
    className="hero--project"
    title={item.h1}
    description={item.offer}
    primaryLabel="Рассчитать стоимость"
    secondaryLabel="Показать объекты"
    secondaryHref={withBase('/vypolnennye-obekty/')}
    mediaImage={withBase(item.heroImages[0])}
    mediaAlt={item.menuTitle}
    mediaCaption="Плейсхолдер под реальные фото объектов и этапов работ."
  >
    <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: item.menuTitle }]} />
  </Hero>

  <section id="project-scope" class="section">
    <div class="container project-content-grid">
      <article class="card project-block project-block--solve">
        <h2>Что решаем</h2>
        <ul>{item.tasksSolved.map((task) => <li>{task}</li>)}</ul>
      </article>
      <article class="card project-block">
        <h2>Что входит в услугу</h2>
        <ul>{item.serviceIncludes.map((part) => <li>{part}</li>)}</ul>
      </article>
      <article class="media-block media-block--objects media-block--strong project-media-block">
        <img class="media-thumb" src={withBase(item.heroImages[0])} alt={item.menuTitle} loading="lazy" />
        <p class="media-caption">Зона для кейсовых фото: объект, узлы, этапы монтажа.</p>
      </article>
    </div>
  </section>

  <section id="project-workflow" class="section section--soft">
    <div class="container">
      <div class="section-heading">
        <h2 class="section-title">Как работаем</h2>
      </div>
      <div class="workflow-grid workflow-grid--project">
        <article class="workflow-step"><span class="badge">Этап 1</span><h3>Фиксируем исходные данные</h3><p>Объект, ограничения площадки, режим эксплуатации и сроки запуска.</p></article>
        <article class="workflow-step"><span class="badge">Этап 2</span><h3>Собираем конструктив и смету</h3><p>Уточняем решения, показываем объем материалов, этапность и бюджет.</p></article>
        <article class="workflow-step"><span class="badge">Этап 3</span><h3>Изготавливаем и выводим на объект</h3><p>Ведем проект в производстве и сопровождаем монтаж до результата.</p></article>
      </div>
    </div>
  </section>

  <section id="project-targets" class="section">
    <div class="container grid grid-2">
      <article class="card"><h2>Для каких объектов</h2><ul>{item.targetObjects.map((obj) => <li>{obj}</li>)}</ul></article>
      <article class="card project-block project-block--inputs"><h2>Что нужно для расчета</h2><ul>{item.calculationInputs.map((input) => <li>{input}</li>)}</ul></article>
    </div>
  </section>

  <section id="project-form" class="section">
    <div class="container form-block form-block--serious">
      <h2 class="section-title">Форма расчета</h2>
      <p class="lead">Заполните базовые вводные — вернемся с рабочим вариантом решения и предварительной стоимостью.</p>
    </div>
  </section>
  <LeadForm type="calculationForm" sourcePage={item.slug} title="Запросить расчет проекта" />
</BaseLayout>
