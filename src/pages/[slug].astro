        <div class="container">
          <div class="section-heading section-heading--light">
            <h2 class="section-title">Какие навесы делаем</h2>
          </div>
          <div class="navesy-type-grid">
            {navesyContent.canopyTypes.map((canopyType) => (
              <article class="card navesy-type-card">
                <h3>{canopyType.title}</h3>
                <p>{canopyType.description}</p>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section id="navesy-targets" class="section section--soft navesy-section-compact">
