    'Напишите нам, и мы сориентируем по составу работ, материалам, конструкциям, монтажу и этапности. Можно отправить фото объекта, размеры, чертеж, ТЗ или описание задачи.'
};

export async function getStaticPaths() {
  const productSections = await getCollection('product-sections');
  const services = await getCollection('services');

  const productSectionPaths = productSections
    .filter(({ data }) => data.isActive && data.slug !== 'ulichnaya-mebel')
    .map(({ data }) => ({ params: { slug: data.slug }, props: { item: data, itemType: 'product-section' } }));

  const servicePaths = services
    .filter(({ data }) => data.isActive)
    .map(({ data }) => ({ params: { slug: data.slug }, props: { item: data, itemType: 'service' } }));

  return [...productSectionPaths, ...servicePaths];
}

const { item, itemType } = Astro.props;
const isCatalogHub = itemType === 'product-section' && item.mode === 'catalog-hub';
const isProjectDirection = itemType === 'product-section' && item.mode === 'custom-direction';
const isNavesyPage = itemType === 'product-section' && item.slug === 'navesy-i-kozyrki';
const isMetalPage = itemType === 'product-section' && item.slug === 'metallokonstruktsii-dlya-biznesa';
const isTopiaryPage = itemType === 'product-section' && item.slug === 'topiarii';
const isLandscapingPage = itemType === 'service' && item.slug === 'blagoustroystvo-territoriy';
const isConstructionPage = itemType === 'service' && item.slug === 'stroitelstvo-i-remonty';
const navesyPageBlocks = isNavesyPage && Array.isArray(item.pageBlocks)
  ? item.pageBlocks
      .filter((block) => block?.isActive !== false)
      .slice()
      .sort((a, b) => a.order - b.order)
      .map((block, index) => ({
        ...block,
        sectionId: `navesy-block-${index + 1}`
      }))
  : [];
const hasNavesyPageBlocks = navesyPageBlocks.length > 0;

const sectionNavItems = isNavesyPage
  ? hasNavesyPageBlocks
    ? navesyPageBlocks.map((block, index) => ({
        id: block.sectionId ?? `navesy-block-${index + 1}`,
        label: block.title
      })).concat([{ id: 'direct-contact', label: 'Связаться напрямую' }])
    : navesyContent.navItems
  : isMetalPage
    ? metalContent.navItems
    : isTopiaryPage
      ? topiaryContent.navItems
      : isLandscapingPage
        ? landscapingContent.navItems
        : isConstructionPage
          ? constructionContent.navItems
        : defaultProjectNavItems;

const categories = isCatalogHub
  ? (await getCollection('product-categories'))
      .map(({ data }) => data)
      .filter((category) => category.parentSectionSlug === item.slug && category.isActive && category.showInSectionGrid)
      .sort((a, b) => a.order - b.order)
  : [];

const contactTitle = isNavesyPage
  ? navesyContent.contactTitle
  : isMetalPage
    ? metalContent.contactTitle
    : isTopiaryPage
      ? topiaryContent.contactTitle
      : isLandscapingPage
        ? landscapingContent.contactTitle
        : isConstructionPage
          ? constructionContent.contactTitle
    : item.slug === 'ograzhdeniya-i-zabory'
    ? 'Нужно ограждение под конкретный объект?'
    : 'Не нашли, что искали?';

const contactDescription = isNavesyPage
  ? navesyContent.contactDescription
  : isMetalPage
    ? metalContent.contactDescription
    : isTopiaryPage
      ? topiaryContent.contactDescription
      : isLandscapingPage
        ? landscapingContent.contactDescription
        : isConstructionPage
          ? constructionContent.contactDescription
    : item.slug === 'ograzhdeniya-i-zabory'
    ? 'Напишите нам, и мы подберем конструкцию под размеры, задачу, внешний вид территории и условия монтажа.'
    : 'Если типовое решение не закрывает задачу, напишите нам. Подберем формат реализации под объект, референс, ТЗ или чертеж.';
---
