---
import '../../../styles/global.css';
import { withBase } from '../../../utils/withBase';

const adminApiBase = import.meta.env.PUBLIC_ADMIN_API_BASE ?? 'http://127.0.0.1:8787/api/admin';
const publicNavesyPath = withBase('/navesy-i-kozyrki/');
const adminHome = withBase('/admin/');
const baseUrl = import.meta.env.BASE_URL ?? '/';
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Редактирование: Навесы — Админка СМУ-1</title>
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; background: #f4f7fb; font-family: var(--font-body); }
      .hidden { display: none !important; }
      .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
      .login-card { width: min(440px, 100%); border-radius: var(--radius-max); border: 1px solid #d6e0ea; background: #fff; padding: 24px; }
      .field { display: grid; gap: 6px; margin-bottom: 12px; }
      .field input, .field textarea, .field select { width: 100%; padding: 10px 12px; border: 1px solid #c6d4e2; border-radius: var(--radius-base); font: inherit; }
      .field textarea { min-height: 90px; resize: vertical; }
      .btn { padding: 7px 11px; font-size: 14px; border-radius: 8px; transition: background-color .16s ease, border-color .16s ease, color .16s ease, box-shadow .16s ease; }
      .btn-secondary { border: 1px solid var(--color-border); background: #fff; color: var(--color-text-primary); }
      .btn-danger { background: #a83737; color: #fff; border: 1px solid #a83737; }
      .btn-xs { font-size: 12px; padding: 5px 8px; font-weight: 600; }
      .btn-secondary.btn-xs { background: #f5f9ff; border-color: #b9cbe0; color: #27415b; }
      .btn-secondary.btn-xs:hover { background: #e9f2fc; border-color: #93afcb; }
      .btn-primary.btn-xs { box-shadow: 0 1px 0 rgb(6 16 27 / 18%); }
      .btn-danger.btn-xs:hover { background: #942f2f; border-color: #942f2f; }
      .btn:focus-visible { outline: 2px solid #6f97bf; outline-offset: 1px; }
      .topbar { position: fixed; top: 0; left: 0; right: 0; z-index: 70; background: #fff; border-bottom: 1px solid #d8e3ed; padding: 10px 14px; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
      .topbar h1 { margin: 0; font-size: 19px; }
      .topbar-left, .topbar-right { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
      .status-clean { color: #2b774b; font-size: 14px; }
      .status-dirty { color: #9e500f; font-size: 14px; font-weight: 700; }
      .workspace { padding-top: 70px; }
      .admin-strip { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-bottom: 10px; }
      .admin-block { margin: 12px 0; border: 1px dashed #89a8c6; border-radius: var(--radius-max); overflow: hidden; }
      .admin-block-head { background: #f2f8ff; border-bottom: 1px solid #d5e4f3; padding: 8px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
      .visual-section-shell { border-radius: 18px; overflow: hidden; border: 1px solid #c9d9ea; background: #fff; }
      .section-admin-toolbar { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; padding: 10px 12px; border-bottom: 1px solid #d8e3ef; background: linear-gradient(180deg, #f8fbff, #eef5fc); }
      .section-admin-toolbar .badge { margin-right: 4px; }
      .section-admin-panel { padding: 10px 12px; border-bottom: 1px solid #d8e3ef; background: #f5f9ff; }
      .badge { border-radius: 999px; background: #e5eef8; color: #36506a; padding: 3px 8px; font-size: 12px; }
      .admin-inline { width: 100%; border: 1px solid #9db7d1; border-radius: var(--radius-base); padding: 8px 10px; font: inherit; background: #fff; }
      .admin-inline-area { min-height: 80px; resize: vertical; }
      .item-editor { border: 1px solid #c9d8e8; border-radius: var(--radius-max); background: #f7fbff; padding: 10px; display: grid; gap: 8px; }
      .hero-edit-box { border: 1px solid #6686a9; border-radius: 16px; background: linear-gradient(180deg, rgb(10 24 37 / 95%), rgb(8 19 30 / 96%)); padding: 20px; display: grid; gap: 14px; max-width: 960px; box-shadow: 0 18px 36px rgb(6 16 27 / 25%); }
      .hero-edit-title { margin: 0; color: #f4f8ff; font-size: 20px; }
      .hero-edit-grid { display: grid; gap: 12px; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); }
      .hero-edit-grid .field { margin: 0; padding: 10px 12px; border-radius: 12px; border: 1px solid rgb(136 164 192 / 35%); background: rgb(13 33 52 / 72%); }
      .hero-edit-grid .field--full { grid-column: 1 / -1; }
      .hero-edit-grid label { display: block; margin-bottom: 6px; font-size: 13px; font-weight: 700; color: #deecfb !important; letter-spacing: .01em; }
      .hero-edit-grid .admin-inline { border-color: #93b1cf; background: #f7fbff !important; color: #162738 !important; padding: 12px 13px; font-size: 14px; }
      .hero-edit-grid textarea.admin-inline, .hero-edit-grid input.admin-inline { color: #162738 !important; background: #f7fbff !important; }
      .hero-edit-grid .admin-inline-area { min-height: 130px; }
      .hero-edit-grid .admin-inline:focus { outline: 2px solid #7fa6cf; outline-offset: 1px; }
      .hero-edit-grid .admin-inline::placeholder { color: #607b97; }
      .hero-edit-box .admin-media-controls { padding-top: 4px; border-top: 1px solid rgb(136 164 192 / 40%); }
      .hero-edit-box .btn { border-radius: 9px; padding: 7px 11px; }
      .hero-edit-box .btn-secondary.btn-xs { background: #eff5fc; border-color: #a8bfd7; color: #233e58; }
      .hero-edit-box .btn-secondary.btn-xs:hover { background: #dbeaf8; border-color: #89a8c8; }
      .hero-edit-box .btn-primary.btn-xs { box-shadow: 0 1px 0 rgb(6 16 27 / 22%); }
      .admin-media-controls { margin-top: 8px; display: flex; gap: 6px; flex-wrap: wrap; }
      .section-settings-inline { margin: 10px 0 0; border: 1px solid #c6d8ea; border-radius: 12px; background: #f7fbff; padding: 12px; display: grid; gap: 10px; }
      .section-settings-inline .field { margin: 0; }
      .section-settings-inline .admin-inline,
      .section-settings-inline select,
      .section-settings-inline textarea { width: 100%; border: 1px solid #9eb8d2; border-radius: 8px; padding: 9px 11px; font: inherit; color: #1f3448; background: #fff; }
      .section-settings-inline label { color: #2a435c; font-weight: 700; font-size: 13px; }
      .frame-editor-inline { margin-top: 12px; border: 1px solid #d5e2ef; border-radius: 14px; background: #fff; padding: 14px; display: grid; gap: 14px; box-shadow: 0 12px 26px rgb(6 16 27 / 12%); }
      .frame-modal-layout { display: grid; gap: 14px; grid-template-columns: minmax(0, 1fr); }
      .frame-preview-wrap { background: linear-gradient(180deg, #f4f8fd, #edf4fb); border: 1px solid #d5e2ef; border-radius: 12px; padding: 14px; min-width: 0; }
      .frame-stage { position: relative; border-radius: 12px; background: #091520; padding: 20px; overflow: hidden; }
      .frame-crop-viewport { position: relative; width: 100%; max-width: min(100%, 680px); margin: 0 auto; aspect-ratio: var(--crop-ratio, 16 / 10); border-radius: 10px; overflow: hidden; border: 1px solid rgb(229 238 248 / 72%); box-shadow: 0 0 0 1px rgb(7 15 24 / 30%); }
      .frame-crop-image { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: var(--fit, cover); object-position: var(--x, 50%) var(--y, 50%); transform: scale(var(--scale, 1)); transform-origin: center center; cursor: grab; user-select: none; -webkit-user-drag: none; touch-action: none; }
      .frame-crop-image.dragging { cursor: grabbing; }
      .frame-crop-shell { position: relative; overflow: hidden; width: 100%; height: 100%; contain: layout paint; }
      .frame-crop-mask { position: absolute; inset: 0; pointer-events: none; box-shadow: inset 0 0 0 999px rgb(6 16 27 / 42%); }
      .frame-crop-guide { position: absolute; inset: 0; pointer-events: none; border: 1px solid rgb(255 255 255 / 82%); }
      .frame-crop-guide::before, .frame-crop-guide::after { content: ''; position: absolute; background: rgb(255 255 255 / 35%); }
      .frame-crop-guide::before { left: 50%; top: 0; bottom: 0; width: 1px; transform: translateX(-50%); }
      .frame-crop-guide::after { top: 50%; left: 0; right: 0; height: 1px; transform: translateY(-50%); }
      .frame-tip { margin: 10px 0 0; color: #5c7187; font-size: 12px; }
      .frame-controls { border: 1px solid #d5e2ef; border-radius: 12px; background: #fff; padding: 12px; display: grid; gap: 10px; align-content: start; min-width: 0; max-height: 100%; position: relative; z-index: 2; }
      .frame-actions { margin-top: 4px; display: flex; gap: 8px; flex-wrap: wrap; }
      .range-row { display: grid; gap: 6px; }
      .range-row-head { display: flex; justify-content: space-between; align-items: center; gap: 8px; font-size: 13px; color: #36506a; }
      .range-value { font-variant-numeric: tabular-nums; color: #1f3449; font-weight: 600; }
      @media (max-width: 899px) {
        .frame-stage { padding: 12px; }
      }
      @media (min-width: 900px) {
        .frame-modal-layout { grid-template-columns: minmax(0, 1.2fr) minmax(280px, .8fr); align-items: start; }
      }
      .factor-item { display: grid; gap: 8px; border: 1px solid #c9d8e8; border-radius: var(--radius-base); padding: 10px; background: #fff; }
      .block-create { margin: 20px 0; padding: 14px; background: #fff; border: 1px solid #d5e2ef; border-radius: var(--radius-max); }
      pre { margin: 0; font-size: 12px; background: #0f1720; color: #d4e3f5; padding: 12px; border-radius: 8px; white-space: pre-wrap; }
      .muted { color: #60758a; }
      .error { color: #b13838; }
    </style>
  </head>
  <body>
    <div id="loginView" class="login-wrap hidden">
      <form id="loginForm" class="login-card">
        <h1>Админка СМУ-1</h1>
        <p class="muted">Войдите, чтобы редактировать страницу «Навесы».</p>
        <div class="field"><label>Логин</label><input name="login" required /></div>
        <div class="field"><label>Пароль</label><input name="password" type="password" required /></div>
        <button class="btn btn-primary" type="submit">Войти</button>
        <p id="loginStatus" class="muted"></p>
      </form>
    </div>

    <div id="editorView" class="hidden">
      <header class="topbar">
        <div class="topbar-left">
          <a class="btn btn-secondary btn-xs" href={adminHome}>← В админку</a>
          <h1>Редактирование: Навесы</h1>
          <span id="dirtyStatus" class="status-clean">Нет изменений</span>
        </div>
        <div class="topbar-right">
          <button id="saveBtn" class="btn btn-primary btn-xs" disabled>Сохранить</button>
          <a class="btn btn-secondary btn-xs" href={publicNavesyPath} target="_blank" rel="noreferrer">Открыть публичную страницу</a>
          <button id="logoutBtn" class="btn btn-secondary btn-xs" type="button">Выйти</button>
        </div>
      </header>
      <main class="workspace" id="workspace"></main>
      <input id="uploadInput" type="file" accept="image/*,.svg" class="hidden" />
    </div>
    <script type="module" define:vars={{ adminApiBase, baseUrl }}>
      const API_BASE = adminApiBase;
      const BLOCK_LABELS = { cardGrid: 'Карточки', listPanel: 'Список', process: 'Процесс', factorList: 'Факторы', mediaText: 'Текст + изображение', notice: 'Вставка', exampleGrid: 'Примеры' };
      const SECTION_TYPES = ['cardGrid', 'listPanel', 'process', 'factorList', 'mediaText', 'notice', 'exampleGrid'];
      const DEFAULT_MEDIA_VIEW = { fit: 'cover', positionX: 50, positionY: 50, scale: 1 };
      const DEFAULT_PLACEHOLDER = 'Фото или рендер будет добавлен позже';
      const state = {
        original: null,
        draft: null,
        alert: '',
        alertError: false,
        editingHero: null,
        editingCard: null,
        editingRow: null,
        editingStep: null,
        editingListBlock: null,
        editingTextBlock: null,
        blockSettings: null,
        frameSettings: null,
        frameDrag: null,
        uploadTarget: null
      };

      const $ = (id) => document.getElementById(id);
      const clone = (v) => JSON.parse(JSON.stringify(v));
      const esc = (v) => String(v ?? '').replace(/[&<>"']/g, (m) => ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[m]));
      const sorted = (arr = []) => arr.slice().sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
      const renumber = (arr = []) => arr.forEach((item, i) => { if (item && typeof item === 'object' && 'order' in item) item.order = (i + 1) * 10; });
      const isDirty = () => JSON.stringify(state.original) !== JSON.stringify(state.draft);
      const getBlocks = () => sorted(state.draft?.pageBlocks || []);
      const setBlocks = (blocks) => { state.draft.pageBlocks = blocks; };
      const toSrc = (src) => {
        if (!src) return '';
        if (/^https?:\/\//.test(src)) return src;
        const normBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
        const clean = src.startsWith('/') ? src.slice(1) : src;
        return `${normBase}${clean}`;
      };
      const clamp = (num, min, max) => Math.min(max, Math.max(min, Number(num) || min));
      const normalizeCards = (items = []) => sorted(items || []);
      const normalizeSteps = (steps = []) => sorted(steps || []);
      const normalizeListItems = (items = []) => (items || []).map((item) => (typeof item === 'string' ? item : { ...item }));
      const getMediaView = (view) => ({ ...DEFAULT_MEDIA_VIEW, ...(view || {}) });
      const getMediaStyle = (view) => {
        const safe = getMediaView(view);
        return `--fit:${safe.fit};--x:${safe.positionX}%;--y:${safe.positionY}%;--scale:${safe.scale};object-fit:${safe.fit};object-position:${safe.positionX}% ${safe.positionY}%;transform:scale(${safe.scale});transform-origin:center;`;
      };

      const getFrameAspectRatio = (target) => {
        if (state.frameSettings?.target === target && state.frameSettings?.aspect) return state.frameSettings.aspect;
        if (target === 'hero-image') return '16 / 10';
        return '16 / 10';
      };
      const frameValue = (value, precision = 0, suffix = '') => `${Number(value).toFixed(precision)}${suffix}`;
      const frameBounds = (view) => {
        const scale = Math.max(1, Number(view?.scale) || 1);
        const spread = (scale - 1) * 50;
        return {
          minX: clamp(50 - spread, 0, 100),
          maxX: clamp(50 + spread, 0, 100),
          minY: clamp(50 - spread, 0, 100),
          maxY: clamp(50 + spread, 0, 100)
        };
      };
      const getTargetAspect = (target) => {
        const targetNode = document.querySelector(`[data-media-target="${target}"]`);
        if (!targetNode) return '16 / 10';
        const rect = targetNode.getBoundingClientRect();
        if (!rect.width || !rect.height) return '16 / 10';
        return `${rect.width} / ${rect.height}`;
      };

      async function api(path, options = {}) {
        const response = await fetch(`${API_BASE}${path}`, {
          ...options,
          credentials: 'include',
          headers: options.body instanceof FormData ? {} : { 'Content-Type': 'application/json', ...(options.headers || {}) }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.error || `HTTP ${response.status}`);
        return data;
      }

      function showLogin(msg = '') {
        $('loginView').classList.remove('hidden');
        $('editorView').classList.add('hidden');
        $('loginStatus').textContent = msg;
      }
      function showEditor() {
        $('loginView').classList.add('hidden');
        $('editorView').classList.remove('hidden');
      }
      function setAlert(text = '', error = false) {
        state.alert = text;
        state.alertError = error;
      }
      function updateStatus() {
        const dirty = isDirty();
        $('dirtyStatus').textContent = dirty ? 'Есть несохраненные изменения' : 'Нет изменений';
        $('dirtyStatus').className = dirty ? 'status-dirty' : 'status-clean';
        $('saveBtn').disabled = !dirty;
      }

      function renderMedia(src, alt, view, caption = '', uploadTarget = '', blockIndex = null) {
        const mediaControls = uploadTarget
          ? `<div class="admin-media-controls"><button class="btn btn-secondary btn-xs" data-action="upload-image" data-target="${uploadTarget}">Заменить фото</button>${blockIndex !== null ? `<button class="btn btn-secondary btn-xs" data-action="clear-block-media" data-block="${blockIndex}">Убрать фото</button>` : `<button class="btn btn-secondary btn-xs" data-action="clear-hero-image">Убрать фото</button>`}<button class="btn btn-secondary btn-xs" data-action="open-frame-settings" data-target="${uploadTarget}">Настроить кадр</button></div>`
          : '';
        return `<article class="media-block placeholder placeholder--wide-feature" data-media-target="${uploadTarget || ''}">${src ? `<img class="media-thumb" src="${esc(toSrc(src))}" alt="${esc(alt)}" style="${esc(getMediaStyle(view))}" />` : ''}${caption ? `<p class="media-caption">${esc(caption)}</p>` : `<p class="media-caption">${DEFAULT_PLACEHOLDER}</p>`}${mediaControls}${renderFrameEditorInline(uploadTarget)}</article>`;
      }

      function renderHero() {
        const d = state.draft;
        const view = d.imageView || DEFAULT_MEDIA_VIEW;
        if (!state.editingHero) {
          return `<section class="section section--dark hero hero--compact"><div class="container"><div class="admin-strip"><button class="btn btn-secondary btn-xs" data-action="edit-hero">Редактировать hero</button><button class="btn btn-secondary btn-xs" data-action="open-frame-settings" data-target="hero-image">Настроить кадр</button></div><div class="grid grid-2" style="align-items:center;"><div><h1 class="hero-title" style="color:#fff;">${esc(d.heroTitle)}</h1><p class="hero-description" style="color:#e2ebf3;">${esc(d.heroDescription)}</p></div>${renderMedia(d.image, d.heroTitle, view, d.placeholderLabel, 'hero-image')}</div></div></section>`;
        }

        const e = state.editingHero;
        return `<section class="section section--dark hero hero--compact"><div class="container"><div class="hero-edit-box"><h3 class="hero-edit-title">Редактирование hero</h3><div class="hero-edit-grid"><div class="field"><label>Заголовок</label><input class="admin-inline" data-inline="hero-title" value="${esc(e.heroTitle)}" placeholder="Заголовок" /></div><div class="field"><label>Путь изображения</label><input class="admin-inline" value="${esc(e.image || '')}" readonly placeholder="Путь изображения" /></div><div class="field field--full"><label>Описание</label><textarea class="admin-inline admin-inline-area" data-inline="hero-description" placeholder="Описание">${esc(e.heroDescription)}</textarea></div><div class="field field--full"><label>Подпись placeholder</label><input class="admin-inline" data-inline="hero-placeholder" value="${esc(e.placeholderLabel)}" placeholder="Подпись placeholder" /></div></div><div class="admin-media-controls"><button class="btn btn-secondary btn-xs" data-action="upload-image" data-target="hero-image">Заменить фото</button><button class="btn btn-secondary btn-xs" data-action="clear-hero-image">Убрать фото</button><button class="btn btn-secondary btn-xs" data-action="open-frame-settings" data-target="hero-image">Настроить кадр</button><button class="btn btn-primary btn-xs" data-action="save-hero">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-hero">Отмена</button></div></div></div></section>`;
      }

      function renderCardItem(blockIndex, itemIndex, item) {
        const key = `${blockIndex}:${itemIndex}`;
        const editing = state.editingCard && state.editingCard.key === key;
        if (editing) {
          const d = state.editingCard.draft;
          return `<article class="card page-block-card item-editor"><input class="admin-inline" data-inline="card-title" value="${esc(d.title)}" placeholder="Заголовок" /><textarea class="admin-inline admin-inline-area" data-inline="card-text" placeholder="Описание">${esc(d.text)}</textarea><label><input type="checkbox" data-inline="card-active" ${d.isActive === false ? '' : 'checked'} /> Активна</label><div class="admin-strip"><button class="btn btn-primary btn-xs" data-action="save-card" data-block="${blockIndex}" data-item="${itemIndex}">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-card">Отмена</button></div></article>`;
        }

        return `<article class="card page-block-card"><h3>${esc(item.title)}</h3><p>${esc(item.text)}</p><div class="admin-strip"><button class="btn btn-secondary btn-xs" data-action="edit-card" data-block="${blockIndex}" data-item="${itemIndex}">Редактировать</button><button class="btn btn-secondary btn-xs" data-action="move-card-up" data-block="${blockIndex}" data-item="${itemIndex}">Выше</button><button class="btn btn-secondary btn-xs" data-action="move-card-down" data-block="${blockIndex}" data-item="${itemIndex}">Ниже</button><button class="btn btn-secondary btn-xs" data-action="toggle-card" data-block="${blockIndex}" data-item="${itemIndex}">${item.isActive === false ? 'Показать' : 'Скрыть'}</button><button class="btn btn-danger btn-xs" data-action="delete-card" data-block="${blockIndex}" data-item="${itemIndex}">Удалить</button></div></article>`;
      }

      function renderListItem(blockIndex, rowIndex, item) {
        const key = `${blockIndex}:${rowIndex}`;
        const editing = state.editingRow && state.editingRow.key === key;
        const text = typeof item === 'string' ? item : item?.text || '';
        if (editing) {
          return `<li class="factor-item"><input class="admin-inline" data-inline="row-text" value="${esc(state.editingRow.draft.text)}" /><div class="admin-strip"><button class="btn btn-primary btn-xs" data-action="save-row" data-block="${blockIndex}" data-item="${rowIndex}">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-row">Отмена</button><button class="btn btn-danger btn-xs" data-action="delete-row" data-block="${blockIndex}" data-item="${rowIndex}">Удалить</button></div></li>`;
        }
        return `<li class="factor-item"><p>${esc(text)}</p><div class="admin-strip"><button class="btn btn-secondary btn-xs" data-action="edit-row" data-block="${blockIndex}" data-item="${rowIndex}">Ред.</button><button class="btn btn-secondary btn-xs" data-action="move-row-up" data-block="${blockIndex}" data-item="${rowIndex}">↑</button><button class="btn btn-secondary btn-xs" data-action="move-row-down" data-block="${blockIndex}" data-item="${rowIndex}">↓</button><button class="btn btn-danger btn-xs" data-action="delete-row" data-block="${blockIndex}" data-item="${rowIndex}">✕</button></div></li>`;
      }


      function renderTextBlockEditor(blockIndex, block) {
        const editing = state.editingTextBlock && state.editingTextBlock.index === blockIndex;
        if (!editing) {
          return `<div class="admin-strip"><button class="btn btn-secondary btn-xs" data-action="edit-text-block" data-block="${blockIndex}">Редактировать текст</button></div>`;
        }
        const draft = state.editingTextBlock.draft;
        return `<div class="item-editor"><div class="field"><label>Заголовок</label><input class="admin-inline" data-inline="text-block-title" value="${esc(draft.title || '')}" /></div>${Object.hasOwn(draft, 'intro') ? `<div class="field"><label>Intro</label><textarea class="admin-inline admin-inline-area" data-inline="text-block-intro">${esc(draft.intro || '')}</textarea></div>` : ''}<div class="field"><label>${block.type === 'notice' ? 'Текст вставки' : 'Основной текст'}</label><textarea class="admin-inline admin-inline-area" data-inline="text-block-body">${esc(draft.text || '')}</textarea></div><div class="admin-strip"><button class="btn btn-primary btn-xs" data-action="save-text-block" data-block="${blockIndex}">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-text-block">Отмена</button></div></div>`;
      }

      function renderStep(blockIndex, stepIndex, step) {
        const key = `${blockIndex}:${stepIndex}`;
        const editing = state.editingStep && state.editingStep.key === key;
        if (editing) {
          const d = state.editingStep.draft;
          return `<li class="item-editor"><input class="admin-inline" data-inline="step-title" value="${esc(d.title)}" placeholder="Заголовок шага" /><textarea class="admin-inline admin-inline-area" data-inline="step-text" placeholder="Описание">${esc(d.text || '')}</textarea><label><input type="checkbox" data-inline="step-active" ${d.isActive === false ? '' : 'checked'} /> Активен</label><div class="admin-strip"><button class="btn btn-primary btn-xs" data-action="save-step" data-block="${blockIndex}" data-item="${stepIndex}">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-step">Отмена</button></div></li>`;
        }
        return `<li><strong>${esc(step.title)}</strong>${step.text ? `<p>${esc(step.text)}</p>` : ''}<div class="admin-strip"><button class="btn btn-secondary btn-xs" data-action="edit-step" data-block="${blockIndex}" data-item="${stepIndex}">Редактировать</button><button class="btn btn-secondary btn-xs" data-action="move-step-up" data-block="${blockIndex}" data-item="${stepIndex}">Выше</button><button class="btn btn-secondary btn-xs" data-action="move-step-down" data-block="${blockIndex}" data-item="${stepIndex}">Ниже</button><button class="btn btn-secondary btn-xs" data-action="toggle-step" data-block="${blockIndex}" data-item="${stepIndex}">${step.isActive === false ? 'Показать' : 'Скрыть'}</button></div></li>`;
      }

      function renderBlock(block, blockIndex) {
        const sectionClass = block.theme === 'dark' ? 'section section--dark navesy-section-compact' : block.theme === 'light' ? 'section section--soft navesy-section-compact' : 'section navesy-section-compact';
        let content = '';

        if ((block.type === 'cardGrid' || block.type === 'exampleGrid') && Array.isArray(block.items)) {
          content = `<div class="page-blocks-grid page-blocks-grid--${block.grid || 'auto'}">${normalizeCards(block.items).map((item, idx) => renderCardItem(blockIndex, idx, item)).join('')}</div><div class="admin-strip" style="margin-top:10px;"><button class="btn btn-secondary btn-xs" data-action="add-card" data-block="${blockIndex}">+ Добавить карточку</button></div>`;
        }

        if ((block.type === 'listPanel' || block.type === 'factorList') && Array.isArray(block.items)) {
          const list = normalizeListItems(block.items);
          const isEditList = state.editingListBlock === blockIndex;
          content = `<ul class="page-blocks-columns page-blocks-columns--${block.columns || 2}">${list.map((item, idx) => isEditList ? renderListItem(blockIndex, idx, item) : `<li>${esc(typeof item === 'string' ? item : item?.text || '')}</li>`).join('')}</ul><div class="admin-strip" style="margin-top:10px;"><button class="btn btn-secondary btn-xs" data-action="toggle-list-edit" data-block="${blockIndex}">${isEditList ? 'Готово' : 'Редактировать список'}</button>${isEditList ? `<button class="btn btn-secondary btn-xs" data-action="add-row" data-block="${blockIndex}">+ Добавить строку</button>` : ''}</div>`;
        }

        if (block.type === 'process') {
          const steps = normalizeSteps(block.steps || []);
          content = `<div class="page-block-media-layout">${renderMedia(block.media, block.title, block.mediaView, block.placeholderLabel, `block-media-${blockIndex}`, blockIndex)}<article class="card page-block-panel"><h2>${esc(block.title)}</h2>${block.intro ? `<p class="lead">${esc(block.intro)}</p>` : ''}<ol class="page-block-steps">${steps.map((step, idx) => renderStep(blockIndex, idx, step)).join('')}</ol><div class="admin-strip" style="margin-top:8px;"><button class="btn btn-secondary btn-xs" data-action="add-step" data-block="${blockIndex}">+ Добавить шаг</button></div></article></div>`;
        }

        if (block.type === 'mediaText') {
          content = `<div class="page-block-media-layout">${renderMedia(block.media, block.title, block.mediaView, block.placeholderLabel, `block-media-${blockIndex}`, blockIndex)}<article class="card page-block-panel"><h2>${esc(block.title)}</h2><p>${esc(block.text || '')}</p>${renderTextBlockEditor(blockIndex, block)}</article></div>`;
        }

        if (block.type === 'notice') {
          content = `<article class="card page-block-panel"><h2>${esc(block.title)}</h2><p>${esc(block.text || '')}</p>${renderTextBlockEditor(blockIndex, block)}</article>`;
        }

        return `<section class="admin-block visual-section-shell"><div class="section-admin-toolbar"><span class="badge">${BLOCK_LABELS[block.type] || block.type}</span><button class="btn btn-secondary btn-xs" data-action="block-up" data-block="${blockIndex}">Выше</button><button class="btn btn-secondary btn-xs" data-action="block-down" data-block="${blockIndex}">Ниже</button><button class="btn btn-secondary btn-xs" data-action="toggle-block" data-block="${blockIndex}">${block.isActive === false ? 'Показать' : 'Скрыть'}</button><button class="btn btn-secondary btn-xs" data-action="open-settings" data-block="${blockIndex}">Настройки</button><button class="btn btn-danger btn-xs" data-action="delete-block" data-block="${blockIndex}">Удалить секцию</button></div>${state.blockSettings && state.blockSettings.index === blockIndex ? `<div class="section-admin-panel">${renderSectionSettingsInline(blockIndex)}</div>` : ''}<section class="${sectionClass}"><div class="container"><h2 class="section-title">${esc(block.title)}</h2>${block.intro ? `<p class="lead">${esc(block.intro)}</p>` : ''}${content}</div></section></section>`;
      }

      function renderSectionSettingsInline(blockIndex) {
        if (!state.blockSettings || state.blockSettings.index !== blockIndex) return '';
        const s = state.blockSettings;
        return `<div class="section-settings-inline"><h3 style="margin:0;color:#1e3247;">Настройки блока</h3><div class="field"><label>Заголовок блока</label><input class="admin-inline" data-modal-field="title" value="${esc(s.title || '')}" /></div><div class="field"><label>Intro</label><textarea class="admin-inline admin-inline-area" data-modal-field="intro">${esc(s.intro || '')}</textarea></div><div class="field"><label>Тема</label><select data-modal-field="theme"><option value="dark" ${s.theme === 'dark' ? 'selected' : ''}>Темная</option><option value="light" ${s.theme === 'light' ? 'selected' : ''}>Светлая</option><option value="graphite" ${s.theme === 'graphite' ? 'selected' : ''}>Графитовая</option></select></div>${Object.hasOwn(s, 'grid') ? `<div class="field"><label>Сетка</label><select data-modal-field="grid"><option value="auto" ${s.grid === 'auto' ? 'selected' : ''}>Авто</option><option value="2" ${s.grid === '2' ? 'selected' : ''}>2</option><option value="3" ${s.grid === '3' ? 'selected' : ''}>3</option><option value="4" ${s.grid === '4' ? 'selected' : ''}>4</option></select></div>` : ''}${Object.hasOwn(s, 'columns') ? `<div class="field"><label>Колонки</label><select data-modal-field="columns"><option value="2" ${String(s.columns) === '2' ? 'selected' : ''}>2</option><option value="3" ${String(s.columns) === '3' ? 'selected' : ''}>3</option></select></div>` : ''}<label style="color:#1f3448;"><input type="checkbox" data-modal-field="isActive" ${s.isActive === false ? '' : 'checked'} /> Активный блок</label><div class="admin-strip" style="margin-top:2px;"><button class="btn btn-primary btn-xs" data-action="save-settings">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-settings">Отмена</button></div></div>`;
      }

      function renderFrameEditorInline(target) {
        if (!state.frameSettings || state.frameSettings.target !== target || !target) return '';
        const f = state.frameSettings;
        return `<div class="frame-editor-inline"><h3 style="margin:0;color:#1e3247;">Настроить кадр</h3><div class="frame-modal-layout"><div class="frame-preview-wrap"><div class="frame-stage"><div class="frame-crop-mask"></div><div class="frame-crop-viewport" style="--crop-ratio:${esc(getFrameAspectRatio(f.target))};"><div class="frame-crop-shell"><img class="frame-crop-image" data-crop-image="true" src="${esc(toSrc(f.src || ''))}" alt="preview" style="${esc(getMediaStyle(f.view))}" /></div><div class="frame-crop-guide"></div></div></div><p class="frame-tip">Перетаскивайте изображение мышью или пальцем. Колесо мыши меняет масштаб.</p></div><div class="frame-controls"><div class="field"><label>Режим отображения</label><select data-frame="fit"><option value="cover" ${f.view.fit === 'cover' ? 'selected' : ''}>Заполнить</option><option value="contain" ${f.view.fit === 'contain' ? 'selected' : ''}>Вписать</option></select></div><div class="range-row"><div class="range-row-head"><label>Масштаб</label><span class="range-value" data-frame-value="scale">${esc(frameValue(f.view.scale, 2))}</span></div><input data-frame="scale" type="range" min="1" max="3" step="0.05" value="${esc(f.view.scale)}" /></div><div class="range-row"><div class="range-row-head"><label>Сдвиг по X</label><span class="range-value" data-frame-value="positionX">${esc(frameValue(f.view.positionX, 0, '%'))}</span></div><input data-frame="positionX" type="range" min="0" max="100" step="1" value="${esc(f.view.positionX)}" /></div><div class="range-row"><div class="range-row-head"><label>Сдвиг по Y</label><span class="range-value" data-frame-value="positionY">${esc(frameValue(f.view.positionY, 0, '%'))}</span></div><input data-frame="positionY" type="range" min="0" max="100" step="1" value="${esc(f.view.positionY)}" /></div><div class="frame-actions"><button class="btn btn-secondary btn-xs" data-action="reset-frame">Сбросить</button><button class="btn btn-primary btn-xs" data-action="save-frame">Готово</button><button class="btn btn-secondary btn-xs" data-action="cancel-frame">Отмена</button></div></div></div></div>`;
      }

      function renderAddSectionPanel() {
        return `<section class="section"><div class="container"><div class="block-create"><h3 style="margin:0 0 10px;">Добавить секцию</h3><div class="admin-strip"><select id="newSectionType" class="admin-inline" style="max-width:240px;">${SECTION_TYPES.map((type) => `<option value="${type}">${BLOCK_LABELS[type]}</option>`).join('')}</select><button class="btn btn-primary btn-xs" data-action="add-block">+ Добавить секцию</button></div></div></div></section>`;
      }

      function renderPage() {
        const root = $('workspace');
        if (!state.draft) { root.innerHTML = ''; return; }
        const blocks = getBlocks();
        root.innerHTML = `${state.alert ? `<div class="container" style="padding-top:12px;"><p class="${state.alertError ? 'error' : 'muted'}">${esc(state.alert)}</p></div>` : ''}${renderHero()}${blocks.map((block, idx) => renderBlock(block, idx)).join('')}${renderAddSectionPanel()}<section class="section"><div class="container"><details><summary>Показать JSON</summary><pre>${esc(JSON.stringify(state.draft, null, 2))}</pre></details></div></section>`;
        updateStatus();
      }
      function scrollToInlineEditor(selector) {
        const panel = document.querySelector(selector);
        if (!panel) return;
        panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }

      function getBlock(index) {
        return getBlocks()[index];
      }
      function applyBlock(index, updater) {
        const blocks = getBlocks();
        updater(blocks[index]);
        setBlocks(blocks);
      }

      function createDefaultBlock(type, order) {
        if (type === 'cardGrid') return { type: 'cardGrid', title: 'Новая секция', theme: 'dark', grid: 'auto', order, isActive: true, items: [] };
        if (type === 'listPanel') return { type: 'listPanel', title: 'Новая секция', theme: 'light', columns: 2, order, isActive: true, items: [] };
        if (type === 'process') return { type: 'process', title: 'Новая секция', theme: 'light', mediaPosition: 'right', placeholderLabel: DEFAULT_PLACEHOLDER, order, isActive: true, steps: [] };
        if (type === 'factorList') return { type: 'factorList', title: 'Новая секция', theme: 'graphite', columns: 2, order, isActive: true, items: [] };
        if (type === 'mediaText') return { type: 'mediaText', title: 'Новая секция', text: '', theme: 'light', mediaPosition: 'right', placeholderLabel: DEFAULT_PLACEHOLDER, order, isActive: true };
        if (type === 'notice') return { type: 'notice', title: 'Новая вставка', text: '', theme: 'light', order, isActive: true };
        return { type: 'exampleGrid', title: 'Новая секция', theme: 'light', grid: 'auto', order, isActive: true, items: [] };
      }

      function openFrameSettings(target) {
        const aspect = getTargetAspect(target);
        if (target === 'hero-image') {
          const startView = getMediaView(state.draft.imageView);
          state.frameSettings = { target, src: state.draft.image || '', view: normalizeFrameView(clone(startView)), initialView: normalizeFrameView(clone(startView)), aspect };
          return;
        }
        if (target.startsWith('block-media-')) {
          const index = Number(target.replace('block-media-', ''));
          const block = getBlock(index);
          const startView = getMediaView(block?.mediaView);
          state.frameSettings = { target, src: block?.media || '', view: normalizeFrameView(clone(startView)), initialView: normalizeFrameView(clone(startView)), aspect };
        }
      }

      function applyFrameViewToDraft(target, view) {
        const safeView = getMediaView(view);
        if (target === 'hero-image') {
          state.draft.imageView = clone(safeView);
          return;
        }
        if (target.startsWith('block-media-')) {
          const index = Number(target.replace('block-media-', ''));
          applyBlock(index, (block) => { block.mediaView = clone(safeView); });
        }
      }

      function closeFrameSettings(rollback = false) {
        if (!state.frameSettings) return;
        state.frameSettings = null;
      }

      function syncFramePreviewUI() {
        if (!state.frameSettings) return;
        const scope = $('workspace');
        const image = scope.querySelector('.frame-crop-image');
        if (image) image.style.cssText = getMediaStyle(state.frameSettings.view);

        const scale = scope.querySelector('[data-frame-value="scale"]');
        const posX = scope.querySelector('[data-frame-value="positionX"]');
        const posY = scope.querySelector('[data-frame-value="positionY"]');
        if (scale) scale.textContent = frameValue(state.frameSettings.view.scale, 2);
        if (posX) posX.textContent = frameValue(state.frameSettings.view.positionX, 0, '%');
        if (posY) posY.textContent = frameValue(state.frameSettings.view.positionY, 0, '%');

        const fitInput = scope.querySelector('[data-frame="fit"]');
        const scaleInput = scope.querySelector('[data-frame="scale"]');
        const xInput = scope.querySelector('[data-frame="positionX"]');
        const yInput = scope.querySelector('[data-frame="positionY"]');
        if (fitInput) fitInput.value = state.frameSettings.view.fit;
        if (scaleInput) scaleInput.value = String(state.frameSettings.view.scale);
        if (xInput) xInput.value = String(state.frameSettings.view.positionX);
        if (yInput) yInput.value = String(state.frameSettings.view.positionY);
      }

      function commitFramePreview() {
        if (!state.frameSettings) return;
        state.frameSettings.view = normalizeFrameView(state.frameSettings.view);
        syncFramePreviewUI();
      }


      function normalizeFrameView(view) {
        const safe = getMediaView(view);
        const bounds = frameBounds(safe);
        safe.positionX = clamp(safe.positionX, bounds.minX, bounds.maxX);
        safe.positionY = clamp(safe.positionY, bounds.minY, bounds.maxY);
        return safe;
      }


      function stopFrameDrag() {
        state.frameDrag = null;
        const image = $('workspace').querySelector('.frame-crop-image');
        if (image) image.classList.remove('dragging');
      }

      async function uploadImage(file, target) {
        const formData = new FormData();
        formData.append('file', file);
        const res = await api('/upload', { method: 'POST', body: formData });
        if (target === 'hero-image') {
          state.draft.image = res.path;
          if (state.editingHero) state.editingHero.image = res.path;
        }
        if (target.startsWith('block-media-')) {
          const index = Number(target.replace('block-media-', ''));
          applyBlock(index, (block) => { block.media = res.path; });
        }
        setAlert('Изображение загружено');
        renderPage();
      }

      function closeModals() {
        state.blockSettings = null;
        stopFrameDrag();
        closeFrameSettings(true);
      }

      function handleInputEvent(event) {
        const key = event.target.dataset.inline;
        if (key === 'hero-title' && state.editingHero) state.editingHero.heroTitle = event.target.value;
        if (key === 'hero-description' && state.editingHero) state.editingHero.heroDescription = event.target.value;
        if (key === 'hero-placeholder' && state.editingHero) state.editingHero.placeholderLabel = event.target.value;
        if (key === 'card-title' && state.editingCard) state.editingCard.draft.title = event.target.value;
        if (key === 'card-text' && state.editingCard) state.editingCard.draft.text = event.target.value;
        if (key === 'row-text' && state.editingRow) state.editingRow.draft.text = event.target.value;
        if (key === 'step-title' && state.editingStep) state.editingStep.draft.title = event.target.value;
        if (key === 'step-text' && state.editingStep) state.editingStep.draft.text = event.target.value;
        if (key === 'text-block-title' && state.editingTextBlock) state.editingTextBlock.draft.title = event.target.value;
        if (key === 'text-block-intro' && state.editingTextBlock) state.editingTextBlock.draft.intro = event.target.value;
        if (key === 'text-block-body' && state.editingTextBlock) state.editingTextBlock.draft.text = event.target.value;

        const modalKey = event.target.dataset.modalField;
        if (modalKey && state.blockSettings) state.blockSettings[modalKey] = event.target.value;

        const frameKey = event.target.dataset.frame;
        if (frameKey && state.frameSettings) {
          if (frameKey === 'fit') state.frameSettings.view.fit = event.target.value === 'contain' ? 'contain' : 'cover';
          if (frameKey === 'scale') state.frameSettings.view.scale = clamp(event.target.value, 1, 3);
          const bounds = frameBounds(state.frameSettings.view);
          if (frameKey === 'positionX') state.frameSettings.view.positionX = clamp(event.target.value, bounds.minX, bounds.maxX);
          if (frameKey === 'positionY') state.frameSettings.view.positionY = clamp(event.target.value, bounds.minY, bounds.maxY);
          commitFramePreview();
        }
      }

      function handleChangeEvent(event) {
        const key = event.target.dataset.inline;
        if (key === 'card-active' && state.editingCard) state.editingCard.draft.isActive = event.target.checked;
        if (key === 'step-active' && state.editingStep) state.editingStep.draft.isActive = event.target.checked;

        const modalKey = event.target.dataset.modalField;
        if (modalKey === 'isActive' && state.blockSettings) state.blockSettings.isActive = event.target.checked;
      }

      function handleActionClick(event) {
        const el = event.target.closest('[data-action]');
        if (!el) return;
        const action = el.dataset.action;
        const blockIndex = Number(el.dataset.block);
        const itemIndex = Number(el.dataset.item);

        if (action === 'edit-hero') { state.editingHero = clone({ heroTitle: state.draft.heroTitle, heroDescription: state.draft.heroDescription, image: state.draft.image, placeholderLabel: state.draft.placeholderLabel }); renderPage(); return; }
        if (action === 'cancel-hero') { state.editingHero = null; renderPage(); return; }
        if (action === 'save-hero') { Object.assign(state.draft, state.editingHero); state.editingHero = null; renderPage(); return; }
        if (action === 'clear-hero-image') { state.draft.image = ''; if (state.editingHero) state.editingHero.image = ''; renderPage(); return; }

        if (action === 'edit-card') { state.editingCard = { key: `${blockIndex}:${itemIndex}`, draft: clone(getBlock(blockIndex).items[itemIndex]) }; renderPage(); return; }
        if (action === 'cancel-card') { state.editingCard = null; renderPage(); return; }
        if (action === 'save-card') { applyBlock(blockIndex, (block) => { block.items[itemIndex] = clone(state.editingCard.draft); }); state.editingCard = null; renderPage(); return; }
        if (action === 'delete-card') { if (!confirm('Удалить карточку?')) return; applyBlock(blockIndex, (block) => { block.items.splice(itemIndex, 1); renumber(block.items); }); state.editingCard = null; renderPage(); return; }
        if (action === 'move-card-up' || action === 'move-card-down') { applyBlock(blockIndex, (block) => { const arr = normalizeCards(block.items || []); const to = action === 'move-card-up' ? itemIndex - 1 : itemIndex + 1; if (to < 0 || to >= arr.length) return; [arr[itemIndex], arr[to]] = [arr[to], arr[itemIndex]]; renumber(arr); block.items = arr; }); renderPage(); return; }
        if (action === 'toggle-card') { applyBlock(blockIndex, (block) => { block.items[itemIndex].isActive = block.items[itemIndex].isActive === false; }); renderPage(); return; }
        if (action === 'add-card') { applyBlock(blockIndex, (block) => { block.items = normalizeCards(block.items || []); block.items.push({ title: 'Новая карточка', text: '', order: (block.items.length + 1) * 10, isActive: true }); renumber(block.items); }); const block = getBlock(blockIndex); state.editingCard = { key: `${blockIndex}:${block.items.length - 1}`, draft: clone(block.items[block.items.length - 1]) }; renderPage(); return; }

        if (action === 'toggle-list-edit') { state.editingListBlock = state.editingListBlock === blockIndex ? null : blockIndex; state.editingRow = null; renderPage(); return; }
        if (action === 'edit-row') {
          const rawItem = getBlock(blockIndex).items[itemIndex];
          state.editingRow = { key: `${blockIndex}:${itemIndex}`, wasString: typeof rawItem === 'string', original: clone(rawItem), draft: { text: typeof rawItem === 'string' ? rawItem : rawItem?.text || '' } };
          renderPage();
          return;
        }
        if (action === 'cancel-row') { state.editingRow = null; renderPage(); return; }
        if (action === 'save-row') {
          applyBlock(blockIndex, (block) => {
            if (state.editingRow.wasString) block.items[itemIndex] = state.editingRow.draft.text;
            else block.items[itemIndex] = { ...state.editingRow.original, text: state.editingRow.draft.text };
          });
          state.editingRow = null;
          renderPage();
          return;
        }
        if (action === 'add-row') { applyBlock(blockIndex, (block) => { block.items.push('Новая строка'); }); state.editingRow = { key: `${blockIndex}:${getBlock(blockIndex).items.length - 1}`, wasString: true, original: 'Новая строка', draft: { text: 'Новая строка' } }; renderPage(); return; }
        if (action === 'delete-row') { if (!confirm('Удалить строку?')) return; applyBlock(blockIndex, (block) => { block.items.splice(itemIndex, 1); }); state.editingRow = null; renderPage(); return; }
        if (action === 'move-row-up' || action === 'move-row-down') { applyBlock(blockIndex, (block) => { const to = action === 'move-row-up' ? itemIndex - 1 : itemIndex + 1; if (to < 0 || to >= block.items.length) return; [block.items[itemIndex], block.items[to]] = [block.items[to], block.items[itemIndex]]; }); renderPage(); return; }

        if (action === 'edit-step') { state.editingStep = { key: `${blockIndex}:${itemIndex}`, draft: clone(getBlock(blockIndex).steps[itemIndex]) }; renderPage(); return; }
        if (action === 'cancel-step') { state.editingStep = null; renderPage(); return; }
        if (action === 'save-step') { applyBlock(blockIndex, (block) => { block.steps[itemIndex] = clone(state.editingStep.draft); }); state.editingStep = null; renderPage(); return; }
        if (action === 'move-step-up' || action === 'move-step-down') { applyBlock(blockIndex, (block) => { const arr = normalizeSteps(block.steps || []); const to = action === 'move-step-up' ? itemIndex - 1 : itemIndex + 1; if (to < 0 || to >= arr.length) return; [arr[itemIndex], arr[to]] = [arr[to], arr[itemIndex]]; renumber(arr); block.steps = arr; }); renderPage(); return; }
        if (action === 'toggle-step') { applyBlock(blockIndex, (block) => { block.steps[itemIndex].isActive = block.steps[itemIndex].isActive === false; }); renderPage(); return; }
        if (action === 'add-step') { applyBlock(blockIndex, (block) => { block.steps = normalizeSteps(block.steps || []); block.steps.push({ title: 'Новый шаг', text: '', order: (block.steps.length + 1) * 10, isActive: true }); renumber(block.steps); }); const b = getBlock(blockIndex); state.editingStep = { key: `${blockIndex}:${b.steps.length - 1}`, draft: clone(b.steps[b.steps.length - 1]) }; renderPage(); return; }

        if (action === 'block-up' || action === 'block-down') { const blocks = getBlocks(); const to = action === 'block-up' ? blockIndex - 1 : blockIndex + 1; if (to >= 0 && to < blocks.length) [blocks[blockIndex], blocks[to]] = [blocks[to], blocks[blockIndex]]; renumber(blocks); setBlocks(blocks); renderPage(); return; }
        if (action === 'toggle-block') { applyBlock(blockIndex, (block) => { block.isActive = block.isActive === false; }); renderPage(); return; }
        if (action === 'open-settings') { state.editingTextBlock = null; state.blockSettings = { index: blockIndex, ...clone(getBlock(blockIndex)) }; renderPage(); scrollToInlineEditor('.section-settings-inline'); return; }
        if (action === 'cancel-settings') { state.blockSettings = null; renderPage(); return; }
        if (action === 'save-settings') { const { index, ...payload } = state.blockSettings; applyBlock(index, (block) => { block.title = payload.title; block.intro = payload.intro; block.theme = payload.theme; if ('grid' in block) block.grid = payload.grid; if ('columns' in block) block.columns = Number(payload.columns); block.isActive = payload.isActive; }); state.blockSettings = null; renderPage(); return; }
        if (action === 'edit-text-block') { state.blockSettings = null; state.editingTextBlock = { index: blockIndex, draft: { title: getBlock(blockIndex).title || '', intro: getBlock(blockIndex).intro || '', text: getBlock(blockIndex).text || '' } }; renderPage(); return; }
        if (action === 'cancel-text-block') { state.editingTextBlock = null; renderPage(); return; }
        if (action === 'save-text-block') { const payload = clone(state.editingTextBlock.draft); applyBlock(blockIndex, (block) => { block.title = payload.title; if ('intro' in block || payload.intro) block.intro = payload.intro; block.text = payload.text; }); state.editingTextBlock = null; renderPage(); return; }
        if (action === 'delete-block') { if (!confirm('Удалить секцию?')) return; const blocks = getBlocks(); blocks.splice(blockIndex, 1); renumber(blocks); setBlocks(blocks); renderPage(); return; }
        if (action === 'add-block') { const type = $('newSectionType')?.value || 'cardGrid'; const blocks = getBlocks(); blocks.push(createDefaultBlock(type, (blocks.length + 1) * 10)); renumber(blocks); setBlocks(blocks); renderPage(); return; }

        if (action === 'clear-block-media') { applyBlock(blockIndex, (block) => { block.media = ''; }); renderPage(); return; }
        if (action === 'upload-image') { state.uploadTarget = el.dataset.target; $('uploadInput').click(); return; }
        if (action === 'open-frame-settings') { state.blockSettings = null; state.editingTextBlock = null; openFrameSettings(el.dataset.target); renderPage(); scrollToInlineEditor('.frame-editor-inline'); return; }
        if (action === 'reset-frame') { state.frameSettings.view = normalizeFrameView(clone(state.frameSettings.initialView)); commitFramePreview(); return; }
        if (action === 'cancel-frame') { stopFrameDrag(); closeFrameSettings(true); renderPage(); return; }
        if (action === 'save-frame') {
          stopFrameDrag();
          applyFrameViewToDraft(state.frameSettings.target, state.frameSettings.view);
          closeFrameSettings(false);
          renderPage();
          return;
        }
      }

      $('workspace').addEventListener('input', handleInputEvent);
      $('workspace').addEventListener('change', handleChangeEvent);
      $('workspace').addEventListener('click', handleActionClick);
      $('workspace').addEventListener('pointerdown', (event) => {
        if (!state.frameSettings) return;
        const image = event.target.closest('[data-crop-image]');
        if (!image) return;
        const viewport = image.closest('.frame-crop-viewport');
        if (!viewport) return;
        event.preventDefault();
        image.setPointerCapture(event.pointerId);
        image.classList.add('dragging');
        state.frameDrag = {
          pointerId: event.pointerId,
          startX: event.clientX,
          startY: event.clientY,
          startPosX: state.frameSettings.view.positionX,
          startPosY: state.frameSettings.view.positionY,
          width: viewport.clientWidth,
          height: viewport.clientHeight
        };
      });

      $('workspace').addEventListener('pointermove', (event) => {
        if (!state.frameSettings || !state.frameDrag || state.frameDrag.pointerId !== event.pointerId) return;
        const drag = state.frameDrag;
        const dx = event.clientX - drag.startX;
        const dy = event.clientY - drag.startY;
        const sensitivity = 1.15;
        const bounds = frameBounds(state.frameSettings.view);
        state.frameSettings.view.positionX = clamp(drag.startPosX - (dx / Math.max(drag.width, 1)) * 100 * sensitivity, bounds.minX, bounds.maxX);
        state.frameSettings.view.positionY = clamp(drag.startPosY - (dy / Math.max(drag.height, 1)) * 100 * sensitivity, bounds.minY, bounds.maxY);
        commitFramePreview();
      });

      $('workspace').addEventListener('pointerup', stopFrameDrag);
      $('workspace').addEventListener('pointercancel', stopFrameDrag);
      $('workspace').addEventListener('wheel', (event) => {
        if (!state.frameSettings) return;
        if (!event.target.closest('.frame-crop-viewport')) return;
        event.preventDefault();
        const delta = Math.sign(event.deltaY) * -0.08;
        state.frameSettings.view.scale = clamp(state.frameSettings.view.scale + delta, 1, 3);
        state.frameSettings.view = normalizeFrameView(state.frameSettings.view);
        commitFramePreview();
      }, { passive: false });

      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && (state.blockSettings || state.frameSettings)) {
          closeModals();
          renderPage();
        }
      });

      $('uploadInput').addEventListener('change', async (event) => {
        const file = event.target.files?.[0];
        if (!file || !state.uploadTarget) return;
        setAlert('Загрузка изображения...');
        renderPage();
        try {
          await uploadImage(file, state.uploadTarget);
        } catch (error) {
          setAlert(error.message || 'Ошибка загрузки изображения', true);
          renderPage();
        } finally {
          event.target.value = '';
          state.uploadTarget = null;
        }
      });

      $('saveBtn').addEventListener('click', async () => {
        setAlert('Сохраняем...');
        renderPage();
        try {
          await api('/content/product-sections/navesy', { method: 'PUT', body: JSON.stringify(state.draft) });
          state.original = clone(state.draft);
          setAlert('Сохранено');
          renderPage();
        } catch (error) {
          setAlert(error.message || 'Ошибка сохранения', true);
          renderPage();
        }
      });

      $('logoutBtn').addEventListener('click', async () => {
        await api('/logout', { method: 'POST' }).catch(() => {});
        showLogin('Вы вышли из админки.');
      });

      $('loginForm').addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new FormData(event.currentTarget);
        try {
          await api('/login', { method: 'POST', body: JSON.stringify({ login: formData.get('login'), password: formData.get('password') }) });
          showEditor();
          const data = await api('/content/product-sections/navesy');
          state.original = clone(data.content);
          state.draft = clone(data.content);
          renderPage();
        } catch (error) {
          $('loginStatus').textContent = error.message || 'Ошибка входа';
          $('loginStatus').className = 'muted error';
        }
      });

      async function boot() {
        try {
          await api('/me');
          showEditor();
          const data = await api('/content/product-sections/navesy');
          state.original = clone(data.content);
          state.draft = clone(data.content);
          renderPage();
        } catch {
          showLogin('Введите логин и пароль.');
        }
      }

      boot();
    </script>
  </body>
</html>
