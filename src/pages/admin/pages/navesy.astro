---
import '../../../styles/global.css';
import { withBase } from '../../../utils/withBase';

const adminApiBase = import.meta.env.PUBLIC_ADMIN_API_BASE ?? 'http://127.0.0.1:8787/api/admin';
const publicNavesyPath = withBase('/navesy-i-kozyrki/');
const adminHome = withBase('/admin/');
const baseUrl = import.meta.env.BASE_URL ?? '/';
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Редактирование: Навесы - Админка СМУ-1</title>
    <style is:global>
      * {
        box-sizing: border-box;
      }

      :root {
        color-scheme: light;
      }

      body {
        margin: 0;
        background: #f3f6f8;
      }

      button,
      input,
      select,
      textarea {
        font: inherit;
      }

      .hidden {
        display: none !important;
      }

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .login-wrap {
        min-height: 100vh;
        display: grid;
        place-items: center;
        padding: 24px;
        background: linear-gradient(180deg, #f6f8fb, #edf2f6);
      }

      .login-card {
        width: min(440px, 100%);
        display: grid;
        gap: 14px;
        padding: 26px;
        border: 1px solid rgb(16 22 27 / 12%);
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 20px 50px rgb(16 22 27 / 10%);
      }

      .login-card h1,
      .login-card p {
        margin: 0;
      }

      .login-card h1 {
        font-size: 28px;
      }

      .admin-field {
        display: grid;
        gap: 7px;
      }

      .admin-field label {
        color: #516273;
        font-size: 13px;
        font-weight: 700;
      }

      .admin-field input,
      .admin-field select,
      .admin-field textarea {
        width: 100%;
        min-width: 0;
        padding: 10px 11px;
        border: 1px solid #c9d5df;
        border-radius: 8px;
        background: #fff;
        color: #17212b;
      }

      .admin-field textarea {
        min-height: 92px;
        resize: vertical;
      }

      .admin-topbar {
        position: fixed;
        z-index: 1000;
        top: 0;
        left: 0;
        right: 0;
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 12px;
        align-items: center;
        min-height: 64px;
        padding: 10px 16px;
        border-bottom: 1px solid rgb(16 22 27 / 12%);
        background: rgb(255 255 255 / 94%);
        box-shadow: 0 12px 34px rgb(16 22 27 / 8%);
        backdrop-filter: blur(14px);
      }

      .admin-topbar__left,
      .admin-topbar__right {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        align-items: center;
      }

      .admin-topbar h1 {
        margin: 0;
        color: #17212b;
        font-size: 18px;
        line-height: 1.2;
      }

      .admin-status {
        color: #587085;
        font-size: 13px;
        font-weight: 700;
      }

      .admin-status.is-dirty {
        color: #9a4f00;
      }

      .admin-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        min-height: 34px;
        padding: 7px 10px;
        border: 1px solid #c4d0da;
        border-radius: 8px;
        background: #ffffff;
        color: #233445;
        font-size: 13px;
        font-weight: 700;
        line-height: 1;
        text-decoration: none;
        cursor: pointer;
      }

      .admin-btn:hover,
      .admin-btn:focus-visible {
        border-color: #95a8b8;
        background: #f5f8fb;
      }

      .admin-btn--primary {
        border-color: #167a50;
        background: #167a50;
        color: #ffffff;
      }

      .admin-btn--primary:hover,
      .admin-btn--primary:focus-visible {
        border-color: #0d6440;
        background: #0d6440;
      }

      .admin-btn--danger {
        border-color: #b94a48;
        background: #b94a48;
        color: #ffffff;
      }

      .admin-btn--ghost {
        background: rgb(255 255 255 / 82%);
      }

      .admin-btn[disabled] {
        opacity: 0.45;
        cursor: not-allowed;
      }

      .workspace {
        min-height: 100vh;
        padding-top: 64px;
        background: #ffffff;
      }

      .admin-alert {
        position: sticky;
        z-index: 90;
        top: 64px;
        display: none;
        padding: 10px 16px;
        border-bottom: 1px solid rgb(16 22 27 / 9%);
        background: #edf7f1;
        color: #1f6a44;
        font-size: 14px;
        font-weight: 700;
      }

      .admin-alert.is-visible {
        display: block;
      }

      .admin-alert.is-error {
        background: #fff0ef;
        color: #a53532;
      }

      .editor-canvas {
        background: #ffffff;
      }

      [data-editable] {
        min-width: 1ch;
        border-radius: 6px;
        outline: 1px dashed transparent;
        outline-offset: 4px;
        cursor: text;
        white-space: pre-wrap;
      }

      [data-editable]:hover {
        outline-color: rgb(22 122 80 / 38%);
        background: rgb(22 122 80 / 5%);
      }

      [data-editable]:focus {
        outline: 2px solid #18b663;
        background: rgb(255 255 255 / 92%);
        color: #17212b !important;
      }

      [data-editable][data-placeholder]:empty::before {
        content: attr(data-placeholder);
        color: #8a98a5;
      }

      .section--dark [data-editable]:focus,
      .hero [data-editable]:focus {
        background: rgb(255 255 255 / 96%);
        color: #17212b !important;
      }

      .admin-tools {
        position: relative;
        z-index: 20;
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        align-items: center;
        margin-bottom: 18px;
      }

      .admin-tools--floating {
        position: absolute;
        top: 20px;
        right: max(16px, calc((100vw - var(--container-max-width)) / 2 + 24px));
        max-width: min(620px, calc(100vw - 32px));
        padding: 8px;
        border: 1px solid rgb(255 255 255 / 18%);
        border-radius: 10px;
        background: rgb(16 22 27 / 62%);
        box-shadow: 0 16px 40px rgb(0 0 0 / 22%);
        backdrop-filter: blur(12px);
      }

      .admin-tools--floating .admin-btn {
        border-color: rgb(255 255 255 / 18%);
        background: rgb(255 255 255 / 92%);
      }

      .admin-badge {
        display: inline-flex;
        align-items: center;
        min-height: 26px;
        padding: 4px 8px;
        border-radius: 999px;
        background: #edf2f6;
        color: #425466;
        font-size: 12px;
        font-weight: 800;
      }

      .admin-badge--hidden {
        background: #fff0ef;
        color: #9a3835;
      }

      .admin-select {
        min-height: 34px;
        padding: 6px 28px 6px 9px;
        border: 1px solid #c4d0da;
        border-radius: 8px;
        background: #ffffff;
        color: #233445;
        font-size: 13px;
        font-weight: 700;
      }

      .admin-section {
        position: relative;
      }

      .admin-section.is-hidden-content {
        opacity: 0.72;
      }

      .admin-section.is-hidden-content::after {
        content: 'Секция скрыта на публичной странице';
        position: absolute;
        top: 14px;
        left: max(16px, calc((100vw - var(--container-max-width)) / 2 + 24px));
        z-index: 15;
        padding: 5px 9px;
        border-radius: 999px;
        background: #fff0ef;
        color: #9a3835;
        font-size: 12px;
        font-weight: 800;
      }

      .admin-item-tools {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        align-items: center;
        margin-top: 10px;
        opacity: 0.72;
      }

      .card:hover .admin-item-tools,
      .page-block-panel:hover .admin-item-tools,
      li:hover .admin-item-tools,
      .admin-item-tools:focus-within {
        opacity: 1;
      }

      .admin-card-hidden,
      .admin-row-hidden {
        opacity: 0.55;
        outline: 1px dashed #b94a48;
        outline-offset: -3px;
      }

      .admin-list-item {
        break-inside: avoid;
        margin-bottom: 9px;
      }

      .admin-list-row {
        display: grid;
        gap: 7px;
      }

      .admin-list-row .admin-item-tools {
        margin-top: 0;
      }

      .admin-step-row {
        display: grid;
        gap: 4px;
      }

      .admin-step-row p {
        margin: 0;
      }

      .admin-media-frame {
        position: relative;
        overflow: hidden;
        contain: paint;
        isolation: isolate;
        border-bottom: 1px solid var(--color-border);
        background:
          linear-gradient(135deg, rgb(237 246 241 / 74%) 0%, rgb(255 255 255 / 82%) 42%, rgb(225 232 238 / 72%) 100%),
          repeating-linear-gradient(135deg, #f0f0f0 0, #f0f0f0 11px, #e7e7e7 11px, #e7e7e7 22px);
      }

      .placeholder--wide-feature .admin-media-frame {
        aspect-ratio: 16 / 9;
      }

      .admin-media-frame .media-thumb {
        position: absolute;
        inset: 0;
        display: block;
        width: 100%;
        height: 100%;
        aspect-ratio: auto;
        max-width: none;
        pointer-events: none;
        user-select: none;
        -webkit-user-drag: none;
      }

      .admin-media-frame.is-active-crop,
      .hero-media.is-active-crop {
        outline: 3px solid #18b663;
        outline-offset: -3px;
        cursor: grab;
        touch-action: none;
      }

      .admin-media-frame.is-active-crop::after,
      .hero-media.is-active-crop::after {
        content: 'Перетащите фото внутри рамки';
        position: absolute;
        z-index: 4;
        right: 12px;
        bottom: 12px;
        padding: 6px 9px;
        border-radius: 999px;
        background: rgb(16 22 27 / 72%);
        color: #ffffff;
        font-size: 12px;
        font-weight: 800;
        pointer-events: none;
      }

      .admin-media-frame.is-active-crop.is-dragging,
      .hero-media.is-active-crop.is-dragging {
        cursor: grabbing;
      }

      .admin-media-empty {
        display: grid;
        min-height: 100%;
        place-items: center;
        padding: 18px;
        color: #627487;
        font-size: 14px;
        font-weight: 700;
        text-align: center;
      }

      .admin-media-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        padding: 10px var(--card-padding);
        border-top: 1px solid rgb(16 22 27 / 8%);
        background: #fff;
      }

      .hero-media[data-image-frame] {
        cursor: default;
        overflow: hidden;
        contain: paint;
        isolation: isolate;
      }

      .hero-media[data-image-frame] .hero-media__image {
        pointer-events: none;
      }

      .hero-media .admin-media-empty {
        min-height: 100%;
        color: rgb(255 255 255 / 74%);
        background:
          linear-gradient(105deg, rgb(7 10 13 / 82%) 0%, rgb(12 17 21 / 70%) 42%, rgb(17 22 26 / 34%) 100%),
          repeating-linear-gradient(135deg, #22303a 0, #22303a 16px, #1a252e 16px, #1a252e 32px);
      }

      .admin-hero-meta {
        display: grid;
        gap: 7px;
        max-width: 620px;
        margin-top: 18px;
        padding: 11px 12px;
        border: 1px solid rgb(255 255 255 / 18%);
        border-radius: 10px;
        background: rgb(16 22 27 / 48%);
        color: rgb(255 255 255 / 78%);
        font-size: 13px;
        backdrop-filter: blur(10px);
      }

      .admin-hero-meta strong {
        color: #ffffff;
      }

      .admin-hero-photo-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
        max-width: 760px;
        margin-top: 16px;
        padding: 10px;
        border: 1px solid rgb(255 255 255 / 18%);
        border-radius: 10px;
        background: rgb(16 22 27 / 58%);
        backdrop-filter: blur(10px);
      }

      .crop-editor {
        position: relative;
        z-index: 30;
        padding: 18px 0;
        background: #edf3f7;
        border-block: 1px solid rgb(16 22 27 / 10%);
      }

      .crop-editor--inline {
        padding: 12px 0 0;
        background: transparent;
        border: 0;
      }

      .crop-editor--inline .container {
        width: 100%;
      }

      .crop-editor__shell {
        display: grid;
        grid-template-columns: minmax(280px, 460px);
        gap: 12px;
        align-items: start;
      }

      .crop-panel {
        display: grid;
        gap: 12px;
        padding: 14px;
        border: 1px solid #c5d3df;
        border-radius: 12px;
        background: #ffffff;
        box-shadow: 0 12px 30px rgb(16 22 27 / 10%);
      }

      .hero + .crop-editor .crop-panel {
        margin-top: 0;
      }

      .crop-panel h3,
      .crop-panel p {
        margin: 0;
      }

      .crop-panel h3 {
        color: #17212b;
        font-size: 18px;
      }

      .crop-tip {
        color: #627487;
        font-size: 13px;
      }

      .range-row {
        display: grid;
        gap: 7px;
      }

      .range-row__head {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        color: #41556a;
        font-size: 13px;
        font-weight: 800;
      }

      .range-row input[type='range'] {
        width: 100%;
      }

      .range-value {
        color: #17212b;
        font-variant-numeric: tabular-nums;
      }

      .crop-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 7px;
      }

      .add-section {
        padding: 28px 0 48px;
        background: #f4f7f9;
        border-top: 1px solid rgb(16 22 27 / 9%);
      }

      .add-section__panel {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
        padding: 16px;
        border: 1px solid #d0dbe4;
        border-radius: 12px;
        background: #ffffff;
      }

      .debug-json {
        padding: 0 0 40px;
        background: #f4f7f9;
      }

      .debug-json details {
        border: 1px solid #d0dbe4;
        border-radius: 12px;
        background: #ffffff;
      }

      .debug-json summary {
        padding: 12px 14px;
        cursor: pointer;
        font-weight: 800;
      }

      .debug-json pre {
        overflow: auto;
        max-height: 420px;
        margin: 0;
        padding: 14px;
        border-top: 1px solid #d0dbe4;
        background: #111922;
        color: #d9e5ef;
        font-size: 12px;
        line-height: 1.5;
        white-space: pre-wrap;
      }

      .navesy-section-compact {
        padding-block: clamp(36px, 5vw, 56px);
      }

      .page-blocks-grid {
        display: grid;
        gap: 16px;
      }

      .page-blocks-grid--auto {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      }

      .page-blocks-grid--2 {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .page-blocks-grid--3 {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .page-blocks-grid--4 {
        grid-template-columns: repeat(4, minmax(0, 1fr));
      }

      .page-block-card {
        min-height: 100%;
      }

      .page-block-card--graphite {
        background: var(--color-surface);
        border-color: var(--color-border);
      }

      .page-block-panel {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .page-blocks-columns {
        margin: 0;
        padding-left: 18px;
        column-gap: 20px;
        row-gap: 8px;
      }

      .page-blocks-columns--2 {
        columns: 2;
      }

      .page-blocks-columns--3 {
        columns: 3;
      }

      .page-block-media-layout {
        display: grid;
        gap: 20px;
        align-items: start;
      }

      .page-block-media-layout--left .media-block {
        order: 0;
      }

      .page-block-media-layout--left .page-block-panel {
        order: 1;
      }

      .page-block-media-layout .media-block {
        order: 1;
      }

      .page-block-media-layout .page-block-panel {
        order: 0;
      }

      .page-block-steps {
        margin: 0;
        padding-left: 18px;
        display: grid;
        gap: 8px;
      }

      .page-block-steps li p {
        margin-top: 4px;
      }

      .home-contact-card .admin-item-tools {
        margin-top: 12px;
      }

      @media (min-width: 920px) {
        .page-block-media-layout {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 1100px) {
        .admin-topbar {
          grid-template-columns: 1fr;
        }

        .workspace {
          padding-top: 108px;
        }

        .admin-alert {
          top: 108px;
        }

        .crop-editor__shell {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 1024px) {
        .page-blocks-grid--4,
        .page-blocks-grid--3 {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 767px) {
        .admin-topbar {
          padding-inline: 10px;
        }

        .admin-topbar h1 {
          width: 100%;
        }

        .workspace {
          padding-top: 150px;
        }

        .admin-alert {
          top: 150px;
        }

        .admin-tools--floating {
          position: relative;
          top: auto;
          right: auto;
          margin: 0 16px 12px;
        }

        .page-blocks-grid,
        .page-blocks-grid--2,
        .page-blocks-grid--3,
        .page-blocks-grid--4,
        .page-blocks-grid--auto {
          grid-template-columns: 1fr;
        }

        .page-blocks-columns {
          columns: 1;
        }
      }
    </style>
  </head>
  <body>
    <div id="loginView" class="login-wrap hidden">
      <form id="loginForm" class="login-card">
        <h1>Админка СМУ-1</h1>
        <p class="muted">Войдите, чтобы редактировать страницу «Навесы» в визуальном режиме.</p>
        <div class="admin-field">
          <label for="login">Логин</label>
          <input id="login" name="login" required />
        </div>
        <div class="admin-field">
          <label for="password">Пароль</label>
          <input id="password" name="password" type="password" required />
        </div>
        <button class="admin-btn admin-btn--primary" type="submit">Войти</button>
        <p id="loginStatus" class="muted"></p>
      </form>
    </div>

    <div id="editorView" class="hidden">
      <header class="admin-topbar">
        <div class="admin-topbar__left">
          <a class="admin-btn" href={adminHome}>В админку</a>
          <h1>Редактирование: Навесы</h1>
          <span id="dirtyStatus" class="admin-status">Нет изменений</span>
        </div>
        <div class="admin-topbar__right">
          <button id="saveBtn" class="admin-btn admin-btn--primary" type="button" disabled>Сохранить</button>
          <a class="admin-btn" href={publicNavesyPath} target="_blank" rel="noreferrer">Открыть публичную страницу</a>
          <button id="logoutBtn" class="admin-btn" type="button">Выйти</button>
        </div>
      </header>
      <main class="workspace">
        <div id="alertBox" class="admin-alert"></div>
        <div id="workspace" class="editor-canvas"></div>
      </main>
      <input id="uploadInput" class="hidden" type="file" accept="image/*,.svg" />
    </div>

    <script type="module" define:vars={{ adminApiBase, publicNavesyPath, baseUrl }}>
      const API_BASE = adminApiBase;
      const PUBLIC_PAGE_PATH = publicNavesyPath;
      const DEFAULT_MEDIA_VIEW = { fit: 'cover', positionX: 50, positionY: 50, scale: 1 };
      const DEFAULT_CONTACT = {
        contactTitle: 'Нужен навес под конкретный объект?',
        contactDescription: 'Напишите нам, и мы подберем конструкцию под размеры площадки, назначение, внешний вид территории и условия монтажа.',
        contactTelegramLabel: '@smu1build · Написать в Telegram',
        contactEmailLabel: 'smu1.kurgan@yandex.ru · Написать на почту',
        contactPhoneLabel: '+7 (912) 973-50-06 · Позвонить'
      };
      const SECTION_TYPES = [
        ['cardGrid', 'Карточки'],
        ['listPanel', 'Список'],
        ['process', 'Процесс'],
        ['factorList', 'Факторы стоимости'],
        ['mediaText', 'Фото + текст'],
        ['notice', 'Текстовая вставка'],
        ['exampleGrid', 'Примеры']
      ];
      const SECTION_LABELS = Object.fromEntries(SECTION_TYPES);
      const state = {
        original: null,
        draft: null,
        alert: '',
        alertError: false,
        crop: null,
        cropDrag: null,
        uploadTarget: null
      };

      const $ = (id) => document.getElementById(id);
      const clone = (value) => JSON.parse(JSON.stringify(value));
      const esc = (value) => String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char]));
      const clamp = (value, min, max) => Math.min(max, Math.max(min, Number(value) || min));
      const sorted = (items = []) => items.slice().sort((a, b) => (a?.order ?? 0) - (b?.order ?? 0));
      const renumber = (items = []) => items.forEach((item, index) => {
        if (item && typeof item === 'object' && 'order' in item) item.order = (index + 1) * 10;
      });
      const getBlocks = () => state.draft?.pageBlocks || [];
      const setBlocks = (blocks) => {
        state.draft.pageBlocks = blocks;
        renumber(state.draft.pageBlocks);
      };
      const stableJson = (value) => JSON.stringify(value);
      const isDirty = () => Boolean(state.original && state.draft && stableJson(state.original) !== stableJson(state.draft));
      const normalizeEditableText = (value) => String(value ?? '').replace(/\u00a0/g, ' ').replace(/\r/g, '').trim();

      function toSrc(src) {
        if (!src) return '';
        if (/^https?:\/\//i.test(src)) return src;
        const normBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
        const clean = src.startsWith('/') ? src.slice(1) : src;
        return `${normBase}${clean}`;
      }

      function getMediaView(view) {
        return { ...DEFAULT_MEDIA_VIEW, ...(view || {}) };
      }

      function normalizeMediaView(view) {
        const safe = getMediaView(view);
        return {
          fit: safe.fit === 'contain' ? 'contain' : 'cover',
          positionX: clamp(safe.positionX, 0, 100),
          positionY: clamp(safe.positionY, 0, 100),
          scale: clamp(safe.scale, 1, 3)
        };
      }

      function mediaStyle(view) {
        const safe = normalizeMediaView(view);
        return `object-fit:${safe.fit};object-position:${safe.positionX}% ${safe.positionY}%;transform:scale(${safe.scale});transform-origin:center;`;
      }

      function getByPath(path) {
        return String(path).split('.').reduce((cursor, key) => cursor?.[key], state.draft);
      }

      function setByPath(path, value) {
        const parts = String(path).split('.');
        let cursor = state.draft;
        for (let index = 0; index < parts.length - 1; index += 1) {
          const key = parts[index];
          if (cursor[key] === undefined || cursor[key] === null) cursor[key] = {};
          cursor = cursor[key];
        }
        cursor[parts[parts.length - 1]] = value;
      }

      function editable(path, placeholder = 'Введите текст', singleLine = false) {
        return `contenteditable="plaintext-only" spellcheck="true" data-editable="true" data-path="${esc(path)}" data-placeholder="${esc(placeholder)}" ${singleLine ? 'data-single-line="true"' : ''}`;
      }

      function listItemText(item) {
        return typeof item === 'string' ? item : item?.text ?? '';
      }

      function listItemActive(item) {
        return typeof item === 'string' ? true : item?.isActive !== false;
      }

      function setListItemText(blockIndex, itemIndex, text) {
        const item = state.draft.pageBlocks[blockIndex].items[itemIndex];
        if (typeof item === 'string') state.draft.pageBlocks[blockIndex].items[itemIndex] = text;
        else state.draft.pageBlocks[blockIndex].items[itemIndex] = { ...item, text };
      }

      function markDirtyStatus() {
        const dirty = isDirty();
        const status = $('dirtyStatus');
        const saveBtn = $('saveBtn');
        status.textContent = dirty ? 'Есть несохраненные изменения' : 'Нет изменений';
        status.classList.toggle('is-dirty', dirty);
        saveBtn.disabled = !dirty;
      }

      function setAlert(text = '', error = false) {
        state.alert = text;
        state.alertError = error;
        renderAlert();
      }

      function renderAlert() {
        const alertBox = $('alertBox');
        alertBox.textContent = state.alert;
        alertBox.className = `admin-alert ${state.alert ? 'is-visible' : ''} ${state.alertError ? 'is-error' : ''}`;
      }

      async function api(path, options = {}) {
        let response;
        try {
          response = await fetch(`${API_BASE}${path}`, {
            ...options,
            credentials: 'include',
            headers: options.body instanceof FormData ? (options.headers || {}) : { 'Content-Type': 'application/json', ...(options.headers || {}) }
          });
        } catch {
          throw new Error('Не удалось подключиться к backend API. Запустите npm run admin:api.');
        }
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.error || `HTTP ${response.status}`);
        return data;
      }

      function showLogin(message = '') {
        $('loginView').classList.remove('hidden');
        $('editorView').classList.add('hidden');
        $('loginStatus').textContent = message;
      }

      function showEditor() {
        $('loginView').classList.add('hidden');
        $('editorView').classList.remove('hidden');
      }

      function prepareDraft(content) {
        const draft = clone(content);
        draft.pageBlocks = sorted(Array.isArray(draft.pageBlocks) ? draft.pageBlocks : []);
        draft.pageBlocks.forEach((block) => {
          if ((block.type === 'cardGrid' || block.type === 'exampleGrid') && Array.isArray(block.items)) block.items = sorted(block.items);
          if (Array.isArray(block.steps)) block.steps = sorted(block.steps);
        });
        return draft;
      }

      async function loadContent() {
        const data = await api('/content/product-sections/navesy');
        state.original = prepareDraft(data.content);
        state.draft = prepareDraft(data.content);
        state.crop = null;
        renderPage();
      }

      function sectionClass(theme) {
        if (theme === 'dark') return 'section section--dark navesy-section-compact';
        if (theme === 'light') return 'section section--soft navesy-section-compact';
        return 'section navesy-section-compact';
      }

      function headingClass(theme) {
        return theme === 'dark' ? 'section-heading section-heading--light' : 'section-heading';
      }

      function isDarkCardTheme(theme) {
        return theme === 'dark' || theme === 'graphite';
      }

      function renderHero() {
        const draft = state.draft;
        const target = 'hero';
        const image = draft.image;
        const isCropTarget = state.crop?.target === target;
        return `
          <section class="hero hero--media navesy-hero">
            <div class="hero-media ${isCropTarget ? 'is-active-crop' : ''}" data-image-frame="${target}">
              ${image ? `<img class="hero-media__image" data-image-img="${target}" src="${esc(toSrc(image))}" alt="${esc(draft.title || draft.heroTitle)}" style="${esc(mediaStyle(draft.imageView))}" />` : `<div class="admin-media-empty">Фото первого экрана не выбрано</div>`}
              <div class="hero-media__overlay"></div>
            </div>
            <div class="container hero-content">
              <p class="kicker">Проектное направление</p>
              <h1 ${editable('heroTitle', 'Заголовок первого экрана', true)}>${esc(draft.heroTitle)}</h1>
              <p class="hero-description" ${editable('heroDescription', 'Описание первого экрана')}>${esc(draft.heroDescription)}</p>
              <div class="admin-hero-meta">
                <strong>Подпись заглушки</strong>
                <span ${editable('placeholderLabel', 'Подпись для фото или заглушки')}>${esc(draft.placeholderLabel)}</span>
              </div>
              <div class="admin-hero-photo-actions">
                <button class="admin-btn" type="button" data-action="upload-image" data-target="${target}">Добавить/заменить фото</button>
                <button class="admin-btn" type="button" data-action="open-crop" data-target="${target}">Редактировать кадр</button>
                <button class="admin-btn" type="button" data-action="clear-image" data-target="${target}">Убрать фото</button>
              </div>
            </div>
          </section>
          ${isCropTarget ? renderCropControls() : ''}
        `;
      }

      function renderSectionToolbar(block, blockIndex) {
        const hasGrid = block.type === 'cardGrid' || block.type === 'exampleGrid';
        const hasColumns = block.type === 'listPanel' || block.type === 'factorList';
        const hasMediaPosition = block.type === 'process' || block.type === 'mediaText';
        return `
          <div class="admin-tools">
            <span class="admin-badge">${esc(SECTION_LABELS[block.type] || block.type)}</span>
            ${block.isActive === false ? '<span class="admin-badge admin-badge--hidden">Скрыта</span>' : ''}
            <button class="admin-btn" type="button" data-action="move-block" data-index="${blockIndex}" data-dir="-1">Выше</button>
            <button class="admin-btn" type="button" data-action="move-block" data-index="${blockIndex}" data-dir="1">Ниже</button>
            <button class="admin-btn" type="button" data-action="toggle-block" data-index="${blockIndex}">${block.isActive === false ? 'Показать' : 'Скрыть'}</button>
            <label>
              <span class="sr-only">Тема</span>
              <select class="admin-select" data-select-path="pageBlocks.${blockIndex}.theme">
                ${['dark', 'light', 'graphite'].map((theme) => `<option value="${theme}" ${block.theme === theme ? 'selected' : ''}>Тема: ${theme}</option>`).join('')}
              </select>
            </label>
            ${hasGrid ? `
              <label>
                <span class="sr-only">Сетка</span>
                <select class="admin-select" data-select-path="pageBlocks.${blockIndex}.grid">
                  ${['auto', '2', '3', '4'].map((grid) => `<option value="${grid}" ${String(block.grid) === grid ? 'selected' : ''}>Сетка: ${grid}</option>`).join('')}
                </select>
              </label>
            ` : ''}
            ${hasColumns ? `
              <label>
                <span class="sr-only">Колонки</span>
                <select class="admin-select" data-select-path="pageBlocks.${blockIndex}.columns" data-value-type="number">
                  ${[2, 3].map((columns) => `<option value="${columns}" ${Number(block.columns) === columns ? 'selected' : ''}>Колонки: ${columns}</option>`).join('')}
                </select>
              </label>
            ` : ''}
            ${hasMediaPosition ? `
              <label>
                <span class="sr-only">Положение фото</span>
                <select class="admin-select" data-select-path="pageBlocks.${blockIndex}.mediaPosition">
                  ${['right', 'left'].map((position) => `<option value="${position}" ${(block.mediaPosition || 'right') === position ? 'selected' : ''}>Фото: ${position === 'right' ? 'справа' : 'слева'}</option>`).join('')}
                </select>
              </label>
            ` : ''}
            <button class="admin-btn admin-btn--danger" type="button" data-action="delete-block" data-index="${blockIndex}">Удалить секцию</button>
          </div>
        `;
      }

      function renderBlockTitle(block, blockIndex) {
        return `
          <div class="${headingClass(block.theme)}">
            <h2 class="section-title" ${editable(`pageBlocks.${blockIndex}.title`, 'Заголовок секции', true)}>${esc(block.title)}</h2>
            ${block.intro !== undefined ? `<p class="lead" ${editable(`pageBlocks.${blockIndex}.intro`, 'Вступительный текст')}>${esc(block.intro)}</p>` : `<p class="lead admin-editable" contenteditable="plaintext-only" data-editable="true" data-path="pageBlocks.${blockIndex}.intro" data-placeholder="Добавить вступительный текст"></p>`}
          </div>
        `;
      }

      function renderCard(block, blockIndex, item, itemIndex) {
        const hidden = item.isActive === false;
        return `
          <article class="card page-block-card ${isDarkCardTheme(block.theme) ? 'page-block-card--dark' : 'page-block-card--light'} ${hidden ? 'admin-card-hidden' : ''}" draggable="true" data-drag-type="card" data-block-index="${blockIndex}" data-item-index="${itemIndex}">
            ${hidden ? '<span class="admin-badge admin-badge--hidden">Скрыта</span>' : ''}
            <h3 ${editable(`pageBlocks.${blockIndex}.items.${itemIndex}.title`, 'Заголовок карточки', true)}>${esc(item.title)}</h3>
            <p ${editable(`pageBlocks.${blockIndex}.items.${itemIndex}.text`, 'Описание карточки')}>${esc(item.text)}</p>
            <div class="admin-item-tools">
              <button class="admin-btn" type="button" data-action="move-card" data-block="${blockIndex}" data-index="${itemIndex}" data-dir="-1">Левее/выше</button>
              <button class="admin-btn" type="button" data-action="move-card" data-block="${blockIndex}" data-index="${itemIndex}" data-dir="1">Правее/ниже</button>
              <button class="admin-btn" type="button" data-action="toggle-card" data-block="${blockIndex}" data-index="${itemIndex}">${hidden ? 'Показать' : 'Скрыть'}</button>
              <button class="admin-btn admin-btn--danger" type="button" data-action="delete-card" data-block="${blockIndex}" data-index="${itemIndex}">Удалить</button>
            </div>
          </article>
        `;
      }

      function renderListRow(blockIndex, item, itemIndex) {
        const hidden = !listItemActive(item);
        return `
          <li class="admin-list-item ${hidden ? 'admin-row-hidden' : ''}" draggable="true" data-drag-type="row" data-block-index="${blockIndex}" data-item-index="${itemIndex}">
            <div class="admin-list-row">
              <span ${editable(`list:${blockIndex}:${itemIndex}`, 'Текст строки')}>${esc(listItemText(item))}</span>
              <span class="admin-item-tools">
                ${hidden ? '<span class="admin-badge admin-badge--hidden">Скрыта</span>' : ''}
                <button class="admin-btn" type="button" data-action="move-row" data-block="${blockIndex}" data-index="${itemIndex}" data-dir="-1">Выше</button>
                <button class="admin-btn" type="button" data-action="move-row" data-block="${blockIndex}" data-index="${itemIndex}" data-dir="1">Ниже</button>
                <button class="admin-btn" type="button" data-action="toggle-row" data-block="${blockIndex}" data-index="${itemIndex}">${hidden ? 'Показать' : 'Скрыть'}</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-row" data-block="${blockIndex}" data-index="${itemIndex}">Удалить</button>
              </span>
            </div>
          </li>
        `;
      }

      function renderStep(blockIndex, step, stepIndex) {
        const hidden = step.isActive === false;
        return `
          <li class="${hidden ? 'admin-row-hidden' : ''}" draggable="true" data-drag-type="step" data-block-index="${blockIndex}" data-item-index="${stepIndex}">
            <div class="admin-step-row">
              ${hidden ? '<span class="admin-badge admin-badge--hidden">Скрыт</span>' : ''}
              <strong ${editable(`pageBlocks.${blockIndex}.steps.${stepIndex}.title`, 'Название шага', true)}>${esc(step.title)}</strong>
              <p ${editable(`pageBlocks.${blockIndex}.steps.${stepIndex}.text`, 'Описание шага')}>${esc(step.text || '')}</p>
              <span class="admin-item-tools">
                <button class="admin-btn" type="button" data-action="move-step" data-block="${blockIndex}" data-index="${stepIndex}" data-dir="-1">Выше</button>
                <button class="admin-btn" type="button" data-action="move-step" data-block="${blockIndex}" data-index="${stepIndex}" data-dir="1">Ниже</button>
                <button class="admin-btn" type="button" data-action="toggle-step" data-block="${blockIndex}" data-index="${stepIndex}">${hidden ? 'Показать' : 'Скрыть'}</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-step" data-block="${blockIndex}" data-index="${stepIndex}">Удалить</button>
              </span>
            </div>
          </li>
        `;
      }

      function renderMediaBlock(block, blockIndex) {
        const target = `block:${blockIndex}`;
        const isCropTarget = state.crop?.target === target;
        const captionPath = `pageBlocks.${blockIndex}.placeholderLabel`;
        return `
          <article class="media-block placeholder placeholder--wide-feature">
            <div class="admin-media-frame ${isCropTarget ? 'is-active-crop' : ''}" data-image-frame="${target}">
              ${block.media ? `<img class="media-thumb" data-image-img="${target}" src="${esc(toSrc(block.media))}" alt="${esc(block.title)}" loading="lazy" style="${esc(mediaStyle(block.mediaView))}" />` : `<div class="admin-media-empty">Фото не выбрано</div>`}
            </div>
            <p class="media-caption" ${editable(captionPath, 'Подпись фото или заглушки')}>${esc(block.placeholderLabel || '')}</p>
            <div class="admin-media-actions">
              <button class="admin-btn" type="button" data-action="upload-image" data-target="${target}">Добавить/заменить фото</button>
              <button class="admin-btn" type="button" data-action="open-crop" data-target="${target}">Редактировать кадр</button>
              <button class="admin-btn" type="button" data-action="clear-image" data-target="${target}">Убрать фото</button>
            </div>
            ${isCropTarget ? renderCropControls('inline') : ''}
          </article>
        `;
      }

      function renderBlock(block, blockIndex) {
        const active = block.isActive !== false;
        const sectionAttr = block.theme === 'dark' ? 'data-section-theme="dark"' : '';

        if (block.type === 'cardGrid' || block.type === 'exampleGrid') {
          const items = Array.isArray(block.items) ? block.items : [];
          return `
            <section id="navesy-block-${blockIndex + 1}" class="${sectionClass(block.theme)} admin-section ${active ? '' : 'is-hidden-content'}" ${sectionAttr}>
              <div class="container">
                ${renderSectionToolbar(block, blockIndex)}
                ${renderBlockTitle(block, blockIndex)}
                <div class="page-blocks-grid page-blocks-grid--${esc(block.grid || 'auto')}" data-drop-zone="card" data-block-index="${blockIndex}">
                  ${items.map((item, itemIndex) => renderCard(block, blockIndex, item, itemIndex)).join('')}
                </div>
                <div class="admin-item-tools">
                  <button class="admin-btn admin-btn--primary" type="button" data-action="add-card" data-block="${blockIndex}">Добавить карточку</button>
                </div>
              </div>
            </section>
          `;
        }

        if (block.type === 'listPanel' || block.type === 'factorList') {
          const items = Array.isArray(block.items) ? block.items : [];
          return `
            <section id="navesy-block-${blockIndex + 1}" class="${sectionClass(block.theme)} admin-section ${active ? '' : 'is-hidden-content'}" ${sectionAttr}>
              <div class="container">
                ${renderSectionToolbar(block, blockIndex)}
                <article class="card page-block-card page-block-panel ${block.theme === 'graphite' ? 'page-block-card--graphite' : ''}">
                  <h2 ${editable(`pageBlocks.${blockIndex}.title`, 'Заголовок секции', true)}>${esc(block.title)}</h2>
                  ${block.intro !== undefined ? `<p class="lead" ${editable(`pageBlocks.${blockIndex}.intro`, 'Вступительный текст')}>${esc(block.intro)}</p>` : `<p class="lead admin-editable" contenteditable="plaintext-only" data-editable="true" data-path="pageBlocks.${blockIndex}.intro" data-placeholder="Добавить вступительный текст"></p>`}
                  <ul class="page-blocks-columns page-blocks-columns--${Number(block.columns) === 3 ? '3' : '2'}" data-drop-zone="row" data-block-index="${blockIndex}">
                    ${items.map((item, itemIndex) => renderListRow(blockIndex, item, itemIndex)).join('')}
                  </ul>
                  <div class="admin-item-tools">
                    <button class="admin-btn admin-btn--primary" type="button" data-action="add-row" data-block="${blockIndex}">Добавить строку</button>
                  </div>
                </article>
              </div>
            </section>
          `;
        }

        if (block.type === 'process') {
          const steps = Array.isArray(block.steps) ? block.steps : [];
          const mediaPosition = block.mediaPosition === 'left' ? 'left' : 'right';
          return `
            <section id="navesy-block-${blockIndex + 1}" class="${sectionClass(block.theme)} admin-section ${active ? '' : 'is-hidden-content'}" ${sectionAttr}>
              <div class="container">
                ${renderSectionToolbar(block, blockIndex)}
              </div>
              <div class="container page-block-media-layout ${mediaPosition === 'left' ? 'page-block-media-layout--left' : ''}">
                ${renderMediaBlock(block, blockIndex)}
                <article class="card page-block-card page-block-panel ${block.theme === 'graphite' ? 'page-block-card--graphite' : ''}">
                  <h2 ${editable(`pageBlocks.${blockIndex}.title`, 'Заголовок секции', true)}>${esc(block.title)}</h2>
                  ${block.intro !== undefined ? `<p class="lead" ${editable(`pageBlocks.${blockIndex}.intro`, 'Вступительный текст')}>${esc(block.intro)}</p>` : `<p class="lead admin-editable" contenteditable="plaintext-only" data-editable="true" data-path="pageBlocks.${blockIndex}.intro" data-placeholder="Добавить вступительный текст"></p>`}
                  <ol class="page-block-steps" data-drop-zone="step" data-block-index="${blockIndex}">
                    ${steps.map((step, stepIndex) => renderStep(blockIndex, step, stepIndex)).join('')}
                  </ol>
                  <div class="admin-item-tools">
                    <button class="admin-btn admin-btn--primary" type="button" data-action="add-step" data-block="${blockIndex}">Добавить шаг</button>
                  </div>
                </article>
              </div>
            </section>
          `;
        }

        if (block.type === 'mediaText') {
          const mediaPosition = block.mediaPosition === 'left' ? 'left' : 'right';
          return `
            <section id="navesy-block-${blockIndex + 1}" class="${sectionClass(block.theme)} admin-section ${active ? '' : 'is-hidden-content'}" ${sectionAttr}>
              <div class="container">
                ${renderSectionToolbar(block, blockIndex)}
              </div>
              <div class="container page-block-media-layout ${mediaPosition === 'left' ? 'page-block-media-layout--left' : ''}">
                ${renderMediaBlock(block, blockIndex)}
                <article class="card page-block-card page-block-panel ${block.theme === 'graphite' ? 'page-block-card--graphite' : ''}">
                  <h2 ${editable(`pageBlocks.${blockIndex}.title`, 'Заголовок секции', true)}>${esc(block.title)}</h2>
                  ${block.intro !== undefined ? `<p class="lead" ${editable(`pageBlocks.${blockIndex}.intro`, 'Вступительный текст')}>${esc(block.intro)}</p>` : ''}
                  <p ${editable(`pageBlocks.${blockIndex}.text`, 'Текст секции')}>${esc(block.text)}</p>
                </article>
              </div>
            </section>
          `;
        }

        if (block.type === 'notice') {
          return `
            <section id="navesy-block-${blockIndex + 1}" class="${sectionClass(block.theme)} admin-section ${active ? '' : 'is-hidden-content'}" ${sectionAttr}>
              <div class="container">
                ${renderSectionToolbar(block, blockIndex)}
                <article class="card page-block-card page-block-panel ${block.theme === 'graphite' ? 'page-block-card--graphite' : ''}">
                  <h2 ${editable(`pageBlocks.${blockIndex}.title`, 'Заголовок секции', true)}>${esc(block.title)}</h2>
                  <p ${editable(`pageBlocks.${blockIndex}.text`, 'Текст секции')}>${esc(block.text)}</p>
                </article>
              </div>
            </section>
          `;
        }

        return '';
      }

      function renderContact() {
        const title = state.draft.contactTitle ?? DEFAULT_CONTACT.contactTitle;
        const description = state.draft.contactDescription ?? DEFAULT_CONTACT.contactDescription;
        const telegramLabel = state.draft.contactTelegramLabel ?? DEFAULT_CONTACT.contactTelegramLabel;
        const emailLabel = state.draft.contactEmailLabel ?? DEFAULT_CONTACT.contactEmailLabel;
        const phoneLabel = state.draft.contactPhoneLabel ?? DEFAULT_CONTACT.contactPhoneLabel;
        return `
          <section id="direct-contact" class="section">
            <div class="container">
              <article class="home-contact-card">
                <span class="admin-badge">Контактный блок</span>
                <h2 class="section-title" ${editable('contactTitle', 'Заголовок контактного блока', true)}>${esc(title)}</h2>
                <p class="lead" ${editable('contactDescription', 'Описание контактного блока')}>${esc(description)}</p>
                <div class="home-contact-actions">
                  <a class="btn btn-primary" href="https://t.me/smu1build" target="_blank" rel="noreferrer" ${editable('contactTelegramLabel', 'Текст кнопки Telegram', true)}>${esc(telegramLabel)}</a>
                  <a class="btn btn-secondary" href="mailto:smu1.kurgan@yandex.ru" ${editable('contactEmailLabel', 'Текст кнопки email', true)}>${esc(emailLabel)}</a>
                  <a class="btn btn-secondary" href="tel:+79129735006" ${editable('contactPhoneLabel', 'Текст кнопки телефона', true)}>${esc(phoneLabel)}</a>
                </div>
                <div class="admin-item-tools">
                  <span class="crop-tip">Редактируются только надписи. Ссылки берутся из настроек сайта.</span>
                </div>
              </article>
            </div>
          </section>
        `;
      }

      function renderCropControls(variant = 'band') {
        if (!state.crop) return '';
        const view = normalizeMediaView(state.crop.view);
        const src = getImageSrcForTarget(state.crop.target);
        const shellClass = variant === 'inline' ? 'crop-editor crop-editor--inline' : 'crop-editor';
        return `
          <section class="${shellClass}" data-crop-editor="${esc(state.crop.target)}">
            <div class="container crop-editor__shell">
              <aside class="crop-panel">
                <h3>Кадр изображения</h3>
                <p class="crop-tip">${src ? 'Двигайте фото прямо в рамке на странице. Все, что видно внутри рамки сейчас, будет видно на сайте после сохранения.' : 'Сначала загрузите фото через кнопку рядом с рамкой.'}</p>
                <label class="admin-field">
                  <span>Режим заполнения</span>
                  <select data-crop-field="fit">
                    <option value="cover" ${view.fit === 'cover' ? 'selected' : ''}>Заполнить рамку</option>
                    <option value="contain" ${view.fit === 'contain' ? 'selected' : ''}>Показать целиком</option>
                  </select>
                </label>
                ${rangeControl('scale', 'Масштаб', view.scale, 1, 3, 0.01, `${view.scale.toFixed(2)}x`)}
                ${rangeControl('positionX', 'Положение по X', view.positionX, 0, 100, 1, `${Math.round(view.positionX)}%`)}
                ${rangeControl('positionY', 'Положение по Y', view.positionY, 0, 100, 1, `${Math.round(view.positionY)}%`)}
                <div class="crop-actions">
                  <button class="admin-btn" type="button" data-action="reset-crop">Сбросить</button>
                  <button class="admin-btn" type="button" data-action="cancel-crop">Отмена</button>
                  <button class="admin-btn admin-btn--primary" type="button" data-action="close-crop">Готово</button>
                </div>
              </aside>
            </div>
          </section>
        `;
      }

      function rangeControl(field, label, value, min, max, step, formatted) {
        return `
          <label class="range-row">
            <span class="range-row__head"><span>${label}</span><span class="range-value" data-crop-value="${field}">${formatted}</span></span>
            <input type="range" min="${min}" max="${max}" step="${step}" value="${esc(value)}" data-crop-field="${field}" />
          </label>
        `;
      }

      function renderAddSection() {
        return `
          <section class="add-section">
            <div class="container">
              <div class="add-section__panel">
                <strong>Добавить секцию</strong>
                <select id="newSectionType" class="admin-select">
                  ${SECTION_TYPES.map(([type, label]) => `<option value="${type}">${label}</option>`).join('')}
                </select>
                <button class="admin-btn admin-btn--primary" type="button" data-action="add-block">Добавить</button>
              </div>
            </div>
          </section>
        `;
      }

      function renderDebugJson() {
        return `
          <section class="debug-json">
            <div class="container">
              <details>
                <summary>Показать JSON</summary>
                <pre>${esc(JSON.stringify(state.draft, null, 2))}</pre>
              </details>
            </div>
          </section>
        `;
      }

      function renderPage() {
        if (!state.draft) return;
        $('workspace').innerHTML = [
          renderHero(),
          getBlocks().map((block, blockIndex) => renderBlock(block, blockIndex)).join(''),
          renderContact(),
          renderAddSection(),
          renderDebugJson()
        ].join('');
        markDirtyStatus();
        renderAlert();
        updateCropAspect();
      }

      function createDefaultBlock(type, order) {
        if (type === 'cardGrid' || type === 'exampleGrid') {
          return { type, title: 'Новая секция', intro: '', theme: 'light', grid: 'auto', isActive: true, order, items: [{ title: 'Новая карточка', text: 'Описание карточки', order: 10, isActive: true }] };
        }
        if (type === 'listPanel' || type === 'factorList') {
          return { type, title: 'Новая секция', intro: '', theme: 'light', columns: 2, isActive: true, order, items: ['Новая строка'] };
        }
        if (type === 'process') {
          return { type, title: 'Новая секция', intro: '', theme: 'graphite', media: '', placeholderLabel: 'Фото будет добавлено позже', mediaPosition: 'right', isActive: true, order, steps: [{ title: 'Новый шаг', text: '', order: 10, isActive: true }] };
        }
        if (type === 'mediaText') {
          return { type, title: 'Новая секция', text: 'Текст секции', theme: 'light', media: '', placeholderLabel: 'Фото будет добавлено позже', mediaPosition: 'right', isActive: true, order };
        }
        return { type: 'notice', title: 'Новая секция', text: 'Текст секции', theme: 'light', isActive: true, order };
      }

      function moveArrayItem(items, index, dir) {
        const to = index + dir;
        if (to < 0 || to >= items.length) return false;
        [items[index], items[to]] = [items[to], items[index]];
        renumber(items);
        return true;
      }

      function targetToPaths(target) {
        if (target === 'hero') return { imagePath: 'image', viewPath: 'imageView' };
        const match = String(target || '').match(/^block:(\d+)$/);
        if (!match) return null;
        const index = Number(match[1]);
        return { imagePath: `pageBlocks.${index}.media`, viewPath: `pageBlocks.${index}.mediaView`, blockIndex: index };
      }

      function getImageSrcForTarget(target) {
        const paths = targetToPaths(target);
        return paths ? getByPath(paths.imagePath) : '';
      }

      function getImageViewForTarget(target) {
        const paths = targetToPaths(target);
        return paths ? normalizeMediaView(getByPath(paths.viewPath)) : normalizeMediaView();
      }

      function setImageViewForTarget(target, view) {
        const paths = targetToPaths(target);
        if (!paths) return;
        setByPath(paths.viewPath, normalizeMediaView(view));
      }

      function setImageSrcForTarget(target, src) {
        const paths = targetToPaths(target);
        if (!paths) return;
        setByPath(paths.imagePath, src);
        if (!getByPath(paths.viewPath)) setByPath(paths.viewPath, clone(DEFAULT_MEDIA_VIEW));
      }

      function measureTargetAspect(target) {
        const frame = document.querySelector(`[data-image-frame="${CSS.escape(target)}"]`);
        if (!(frame instanceof HTMLElement)) return '16 / 9';
        const rect = frame.getBoundingClientRect();
        if (!rect.width || !rect.height) return '16 / 9';
        return `${Math.round(rect.width)} / ${Math.round(rect.height)}`;
      }

      function openCrop(target) {
        if (!getImageSrcForTarget(target)) {
          setAlert('Сначала добавьте фото, затем откройте редактирование кадра.', true);
          return;
        }
        state.crop = {
          target,
          view: getImageViewForTarget(target),
          before: getImageViewForTarget(target),
          aspect: measureTargetAspect(target)
        };
        renderPage();
        document.querySelector(`[data-image-frame="${CSS.escape(target)}"]`)?.scrollIntoView({ block: 'center', behavior: 'smooth' });
      }

      function updateCropAspect() {
        if (!state.crop) return;
        state.crop.aspect = measureTargetAspect(state.crop.target);
      }

      function applyCropPreview() {
        if (!state.crop) return;
        state.crop.view = normalizeMediaView(state.crop.view);
        setImageViewForTarget(state.crop.target, state.crop.view);
        document.querySelectorAll(`[data-image-img="${CSS.escape(state.crop.target)}"]`).forEach((img) => {
          if (img instanceof HTMLElement) img.setAttribute('style', mediaStyle(state.crop.view));
        });
        document.querySelectorAll('[data-crop-field]').forEach((field) => {
          if (!(field instanceof HTMLInputElement || field instanceof HTMLSelectElement)) return;
          const key = field.dataset.cropField;
          if (!key || document.activeElement === field) return;
          field.value = String(state.crop.view[key]);
        });
        updateCropLabels();
        markDirtyStatus();
      }

      function updateCropLabels() {
        if (!state.crop) return;
        const view = state.crop.view;
        const labels = {
          scale: `${Number(view.scale).toFixed(2)}x`,
          positionX: `${Math.round(view.positionX)}%`,
          positionY: `${Math.round(view.positionY)}%`
        };
        Object.entries(labels).forEach(([key, value]) => {
          const node = document.querySelector(`[data-crop-value="${key}"]`);
          if (node) node.textContent = value;
        });
      }

      function closeCrop() {
        state.crop = null;
        state.cropDrag = null;
        renderPage();
      }

      function cancelCrop() {
        if (state.crop) setImageViewForTarget(state.crop.target, state.crop.before);
        closeCrop();
      }

      function resetCrop() {
        if (!state.crop) return;
        state.crop.view = clone(DEFAULT_MEDIA_VIEW);
        applyCropPreview();
      }

      async function uploadImage(file, target) {
        const formData = new FormData();
        formData.append('file', file);
        const data = await api('/upload', { method: 'POST', body: formData });
        setImageSrcForTarget(target, data.path);
        state.crop = {
          target,
          view: getImageViewForTarget(target),
          before: getImageViewForTarget(target),
          aspect: measureTargetAspect(target)
        };
        renderPage();
        setAlert('Фото загружено. Можно сразу настроить кадр.');
      }

      function handleEditableInput(target) {
        const path = target.dataset.path;
        const value = normalizeEditableText(target.innerText);
        if (path?.startsWith('list:')) {
          const [, blockIndex, itemIndex] = path.split(':').map((part, index) => index === 0 ? part : Number(part));
          setListItemText(blockIndex, itemIndex, value);
        } else if (path) {
          setByPath(path, value);
        }
        target.dataset.empty = value ? 'false' : 'true';
        markDirtyStatus();
      }

      function handleAction(action, el) {
        const blockIndex = Number(el.dataset.block ?? el.dataset.index);
        const itemIndex = Number(el.dataset.index);
        const dir = Number(el.dataset.dir);

        if (action === 'move-block') {
          moveArrayItem(getBlocks(), Number(el.dataset.index), dir);
          renderPage();
          return;
        }
        if (action === 'toggle-block') {
          const block = getBlocks()[Number(el.dataset.index)];
          block.isActive = block.isActive === false;
          renderPage();
          return;
        }
        if (action === 'delete-block') {
          if (!confirm('Удалить секцию?')) return;
          getBlocks().splice(Number(el.dataset.index), 1);
          renumber(getBlocks());
          renderPage();
          return;
        }
        if (action === 'add-block') {
          const type = $('newSectionType')?.value || 'cardGrid';
          const blocks = getBlocks();
          blocks.push(createDefaultBlock(type, (blocks.length + 1) * 10));
          setBlocks(blocks);
          renderPage();
          return;
        }
        if (action === 'add-card') {
          const block = getBlocks()[blockIndex];
          block.items = Array.isArray(block.items) ? block.items : [];
          block.items.push({ title: 'Новая карточка', text: 'Описание карточки', order: (block.items.length + 1) * 10, isActive: true });
          renumber(block.items);
          renderPage();
          return;
        }
        if (action === 'move-card') {
          const items = getBlocks()[blockIndex].items || [];
          moveArrayItem(items, itemIndex, dir);
          renderPage();
          return;
        }
        if (action === 'toggle-card') {
          const item = getBlocks()[blockIndex].items[itemIndex];
          item.isActive = item.isActive === false;
          renderPage();
          return;
        }
        if (action === 'delete-card') {
          if (!confirm('Удалить карточку?')) return;
          getBlocks()[blockIndex].items.splice(itemIndex, 1);
          renumber(getBlocks()[blockIndex].items);
          renderPage();
          return;
        }
        if (action === 'add-row') {
          const block = getBlocks()[blockIndex];
          block.items = Array.isArray(block.items) ? block.items : [];
          block.items.push('Новая строка');
          renderPage();
          return;
        }
        if (action === 'move-row') {
          moveArrayItem(getBlocks()[blockIndex].items, itemIndex, dir);
          renderPage();
          return;
        }
        if (action === 'toggle-row') {
          const items = getBlocks()[blockIndex].items;
          const item = items[itemIndex];
          if (typeof item === 'string') items[itemIndex] = { text: item, isActive: false, order: (itemIndex + 1) * 10 };
          else item.isActive = item.isActive === false;
          renderPage();
          return;
        }
        if (action === 'delete-row') {
          if (!confirm('Удалить строку?')) return;
          getBlocks()[blockIndex].items.splice(itemIndex, 1);
          renderPage();
          return;
        }
        if (action === 'add-step') {
          const block = getBlocks()[blockIndex];
          block.steps = Array.isArray(block.steps) ? block.steps : [];
          block.steps.push({ title: 'Новый шаг', text: '', order: (block.steps.length + 1) * 10, isActive: true });
          renumber(block.steps);
          renderPage();
          return;
        }
        if (action === 'move-step') {
          moveArrayItem(getBlocks()[blockIndex].steps, itemIndex, dir);
          renderPage();
          return;
        }
        if (action === 'toggle-step') {
          const step = getBlocks()[blockIndex].steps[itemIndex];
          step.isActive = step.isActive === false;
          renderPage();
          return;
        }
        if (action === 'delete-step') {
          if (!confirm('Удалить шаг?')) return;
          getBlocks()[blockIndex].steps.splice(itemIndex, 1);
          renumber(getBlocks()[blockIndex].steps);
          renderPage();
          return;
        }
        if (action === 'upload-image') {
          state.uploadTarget = el.dataset.target;
          $('uploadInput').click();
          return;
        }
        if (action === 'clear-image') {
          setImageSrcForTarget(el.dataset.target, '');
          renderPage();
          return;
        }
        if (action === 'open-crop') {
          openCrop(el.dataset.target);
          return;
        }
        if (action === 'close-crop') {
          closeCrop();
          return;
        }
        if (action === 'cancel-crop') {
          cancelCrop();
          return;
        }
        if (action === 'reset-crop') {
          resetCrop();
        }
      }

      function bindEvents() {
        $('workspace').addEventListener('input', (event) => {
          const editableTarget = event.target.closest?.('[data-editable]');
          if (editableTarget) {
            handleEditableInput(editableTarget);
            return;
          }
          const cropField = event.target.closest?.('[data-crop-field]');
          if (cropField && state.crop) {
            const key = cropField.dataset.cropField;
            if (key === 'fit') state.crop.view.fit = cropField.value === 'contain' ? 'contain' : 'cover';
            if (key === 'scale') state.crop.view.scale = Number(cropField.value);
            if (key === 'positionX') state.crop.view.positionX = Number(cropField.value);
            if (key === 'positionY') state.crop.view.positionY = Number(cropField.value);
            applyCropPreview();
          }
        });

        $('workspace').addEventListener('change', (event) => {
          const select = event.target.closest?.('[data-select-path]');
          if (select) {
            const value = select.dataset.valueType === 'number' ? Number(select.value) : select.value;
            setByPath(select.dataset.selectPath, value);
            renderPage();
            return;
          }
          const cropField = event.target.closest?.('[data-crop-field]');
          if (cropField && state.crop) {
            const key = cropField.dataset.cropField;
            if (key === 'fit') state.crop.view.fit = cropField.value === 'contain' ? 'contain' : 'cover';
            applyCropPreview();
          }
        });

        $('workspace').addEventListener('click', (event) => {
          const editableLink = event.target.closest?.('a[data-editable]');
          if (editableLink) event.preventDefault();
          const actionEl = event.target.closest?.('[data-action]');
          if (!actionEl) return;
          event.preventDefault();
          handleAction(actionEl.dataset.action, actionEl);
        });

        $('workspace').addEventListener('keydown', (event) => {
          const editableTarget = event.target.closest?.('[data-editable]');
          if (editableTarget?.dataset.singleLine === 'true' && event.key === 'Enter') {
            event.preventDefault();
            editableTarget.blur();
            return;
          }
          if (!state.crop) return;
          const step = event.shiftKey ? 5 : 1;
          if (event.key === 'ArrowLeft') { event.preventDefault(); state.crop.view.positionX = clamp(state.crop.view.positionX - step, 0, 100); applyCropPreview(); }
          if (event.key === 'ArrowRight') { event.preventDefault(); state.crop.view.positionX = clamp(state.crop.view.positionX + step, 0, 100); applyCropPreview(); }
          if (event.key === 'ArrowUp') { event.preventDefault(); state.crop.view.positionY = clamp(state.crop.view.positionY - step, 0, 100); applyCropPreview(); }
          if (event.key === 'ArrowDown') { event.preventDefault(); state.crop.view.positionY = clamp(state.crop.view.positionY + step, 0, 100); applyCropPreview(); }
          if (event.key === '+' || event.key === '=') { event.preventDefault(); state.crop.view.scale = clamp(state.crop.view.scale + 0.05, 1, 3); applyCropPreview(); }
          if (event.key === '-') { event.preventDefault(); state.crop.view.scale = clamp(state.crop.view.scale - 0.05, 1, 3); applyCropPreview(); }
          if (event.key === 'Escape') { event.preventDefault(); closeCrop(); }
        });

        $('workspace').addEventListener('paste', (event) => {
          const editableTarget = event.target.closest?.('[data-editable]');
          if (!editableTarget) return;
          event.preventDefault();
          const text = event.clipboardData?.getData('text/plain') || '';
          document.execCommand('insertText', false, text);
        });

        $('workspace').addEventListener('pointerdown', (event) => {
          if (!state.crop) return;
          if (event.target.closest?.('[data-action], [data-editable], input, select, textarea, a, button')) return;
          const frame = event.target.closest?.('[data-image-frame]');
          if (!(frame instanceof HTMLElement)) return;
          if (frame.dataset.imageFrame !== state.crop.target) return;
          event.preventDefault();
          frame.setPointerCapture(event.pointerId);
          frame.classList.add('is-dragging');
          state.cropDrag = {
            pointerId: event.pointerId,
            startX: event.clientX,
            startY: event.clientY,
            startPositionX: state.crop.view.positionX,
            startPositionY: state.crop.view.positionY,
            width: frame.clientWidth,
            height: frame.clientHeight
          };
        });

        $('workspace').addEventListener('pointermove', (event) => {
          if (!state.crop || !state.cropDrag || state.cropDrag.pointerId !== event.pointerId) return;
          const drag = state.cropDrag;
          const dx = event.clientX - drag.startX;
          const dy = event.clientY - drag.startY;
          const scaleBoost = Math.max(1, state.crop.view.scale);
          state.crop.view.positionX = clamp(drag.startPositionX - (dx / Math.max(drag.width, 1)) * 100 / scaleBoost, 0, 100);
          state.crop.view.positionY = clamp(drag.startPositionY - (dy / Math.max(drag.height, 1)) * 100 / scaleBoost, 0, 100);
          applyCropPreview();
        });

        const stopDrag = () => {
          state.cropDrag = null;
          document.querySelector(`[data-image-frame="${CSS.escape(state.crop?.target || '')}"]`)?.classList.remove('is-dragging');
        };
        $('workspace').addEventListener('pointerup', stopDrag);
        $('workspace').addEventListener('pointercancel', stopDrag);

        $('workspace').addEventListener('wheel', (event) => {
          if (!state.crop) return;
          const frame = event.target.closest?.('[data-image-frame]');
          if (!frame) return;
          if (frame.dataset.imageFrame !== state.crop.target) return;
          event.preventDefault();
          state.crop.view.scale = clamp(state.crop.view.scale + Math.sign(event.deltaY) * -0.06, 1, 3);
          applyCropPreview();
        }, { passive: false });

        $('workspace').addEventListener('dragstart', (event) => {
          const item = event.target.closest?.('[draggable="true"]');
          if (!item) return;
          event.dataTransfer.effectAllowed = 'move';
          event.dataTransfer.setData('application/json', JSON.stringify({
            type: item.dataset.dragType,
            blockIndex: Number(item.dataset.blockIndex),
            itemIndex: Number(item.dataset.itemIndex)
          }));
        });

        $('workspace').addEventListener('dragover', (event) => {
          const zone = event.target.closest?.('[data-drop-zone]');
          if (!zone) return;
          event.preventDefault();
          event.dataTransfer.dropEffect = 'move';
        });

        $('workspace').addEventListener('drop', (event) => {
          const zone = event.target.closest?.('[data-drop-zone]');
          if (!zone) return;
          event.preventDefault();
          const raw = event.dataTransfer.getData('application/json');
          if (!raw) return;
          const drag = JSON.parse(raw);
          const dropItem = event.target.closest('[data-item-index]');
          const toIndex = dropItem ? Number(dropItem.dataset.itemIndex) : null;
          const blockIndex = Number(zone.dataset.blockIndex);
          if (drag.blockIndex !== blockIndex || toIndex === null || drag.itemIndex === toIndex) return;
          const block = getBlocks()[blockIndex];
          const list = drag.type === 'step' ? block.steps : block.items;
          if (!Array.isArray(list)) return;
          const [item] = list.splice(drag.itemIndex, 1);
          list.splice(toIndex, 0, item);
          renumber(list);
          renderPage();
        });

        $('uploadInput').addEventListener('change', async (event) => {
          const file = event.target.files?.[0];
          if (!file || !state.uploadTarget) return;
          setAlert('Загружаем фото...');
          try {
            await uploadImage(file, state.uploadTarget);
          } catch (error) {
            setAlert(error.message || 'Ошибка загрузки фото', true);
          } finally {
            event.target.value = '';
            state.uploadTarget = null;
          }
        });

        $('saveBtn').addEventListener('click', async () => {
          if (!state.draft) return;
          setAlert('Сохраняем...');
          $('saveBtn').disabled = true;
          try {
            const data = await api('/content/product-sections/navesy', { method: 'PUT', body: JSON.stringify(state.draft) });
            state.original = prepareDraft(data.content);
            state.draft = prepareDraft(data.content);
            state.crop = null;
            setAlert('Изменения сохранены в navesy.json.');
            renderPage();
          } catch (error) {
            setAlert(error.message || 'Ошибка сохранения', true);
            markDirtyStatus();
          }
        });

        $('logoutBtn').addEventListener('click', async () => {
          await api('/logout', { method: 'POST' }).catch(() => {});
          showLogin('Вы вышли из админки.');
        });

        $('loginForm').addEventListener('submit', async (event) => {
          event.preventDefault();
          const formData = new FormData(event.currentTarget);
          $('loginStatus').textContent = 'Выполняем вход...';
          try {
            await api('/login', { method: 'POST', body: JSON.stringify({ login: formData.get('login'), password: formData.get('password') }) });
            showEditor();
            await loadContent();
          } catch (error) {
            $('loginStatus').textContent = error.message || 'Ошибка входа';
          }
        });

        window.addEventListener('resize', () => updateCropAspect());
        window.addEventListener('beforeunload', (event) => {
          if (!isDirty()) return;
          event.preventDefault();
          event.returnValue = '';
        });
      }

      async function boot() {
        bindEvents();
        try {
          const me = await api('/me');
          if (!me.authenticated) {
            showLogin('Введите логин и пароль.');
            return;
          }
          showEditor();
          await loadContent();
        } catch (error) {
          showLogin(error.message || 'Введите логин и пароль.');
        }
      }

      boot();
    </script>
  </body>
</html>
