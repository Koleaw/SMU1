---
import '../../../styles/global.css';
import { withBase } from '../../../utils/withBase';

const adminApiBase = import.meta.env.PUBLIC_ADMIN_API_BASE ?? 'http://127.0.0.1:8787/api/admin';
const adminHome = withBase('/admin/');
const publicNavesyPath = withBase('/navesy-i-kozyrki/');
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Редактирование: Навесы — Админка СМУ-1</title>
    <style>
      :root {
        color-scheme: light;
        font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
      }
      * { box-sizing: border-box; }
      body { margin: 0; background: #f3f6fa; color: #1f2d3d; }
      .hidden { display: none !important; }
      .topbar {
        position: sticky;
        top: 0;
        z-index: 20;
        background: #fff;
        border-bottom: 1px solid #d8e1eb;
        padding: 10px 14px;
        display: flex;
        gap: 10px;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
      }
      .topbar-group { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; }
      h1 { margin: 0; font-size: 18px; }
      .status-clean { color: #1f7a3f; font-size: 14px; }
      .status-dirty { color: #9b5a13; font-size: 14px; font-weight: 700; }
      .btn {
        border: 1px solid #0f6a4d;
        background: #0f6a4d;
        color: #fff;
        border-radius: 8px;
        padding: 7px 10px;
        font: inherit;
        cursor: pointer;
        text-decoration: none;
      }
      .btn:disabled { opacity: .6; cursor: not-allowed; }
      .btn-secondary { background: #fff; color: #1f3550; border-color: #c2d0e0; }
      .container { width: min(1080px, calc(100% - 24px)); margin: 16px auto 32px; }
      .panel { background: #fff; border: 1px solid #d8e1eb; border-radius: 12px; padding: 14px; margin-bottom: 14px; }
      .muted { color: #5e7389; }
      .error-box { border: 1px solid #e4b3b3; background: #fff2f2; color: #9f2f2f; border-radius: 10px; padding: 12px; margin-bottom: 12px; }
      .field { display: grid; gap: 6px; margin-bottom: 10px; }
      .field input, .field textarea {
        width: 100%;
        border: 1px solid #c4d2e3;
        border-radius: 8px;
        padding: 8px 10px;
        font: inherit;
        background: #fff;
      }
      .field textarea { min-height: 90px; resize: vertical; }
      .hero-preview { border: 1px dashed #97b1ca; border-radius: 10px; padding: 12px; background: #f8fbff; }
      .hero-media { margin-top: 10px; border: 1px solid #d4deea; border-radius: 8px; overflow: hidden; background: #fff; }
      .hero-media img { width: 100%; max-height: 260px; object-fit: cover; display: block; }
      .placeholder { padding: 12px; color: #5e7389; }
      .block-head { display: flex; justify-content: space-between; gap: 8px; margin-bottom: 10px; align-items: center; }
      .badge { display: inline-block; font-size: 12px; padding: 2px 8px; border-radius: 999px; background: #e7eef8; color: #39546f; }
      .card-item { border: 1px solid #d5dfeb; background: #f9fbff; border-radius: 10px; padding: 10px; margin-bottom: 10px; }
      .item-actions { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 8px; }
      .item-inactive { opacity: 0.65; }
      .small { font-size: 13px; }
    </style>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-group">
        <a class="btn btn-secondary" href={adminHome}>← В админку</a>
        <h1>Редактирование: Навесы</h1>
        <span id="dirtyStatus" class="status-clean">Нет изменений</span>
      </div>
      <div class="topbar-group">
        <button id="saveBtn" class="btn" type="button" disabled>Сохранить</button>
        <a class="btn btn-secondary" href={publicNavesyPath} target="_blank" rel="noreferrer">Открыть публичную страницу</a>
        <button id="logoutBtn" class="btn btn-secondary" type="button">Выйти</button>
      </div>
    </header>

    <main class="container" id="app">
      <section class="panel" id="loadingView">
        <p id="loadingText" class="muted">Загрузка данных…</p>
      </section>
      <section class="panel hidden" id="errorView"></section>
      <section class="panel hidden" id="authView">
        <h2>Требуется вход в админку</h2>
        <a class="btn btn-secondary" href={adminHome}>В админку</a>
      </section>
      <section class="hidden" id="editorView">
        <div id="heroSection" class="panel"></div>
        <div id="blocksSection"></div>
      </section>
    </main>

    <script type="module" define:vars={{ adminApiBase }}>
      const API_BASE = adminApiBase;
      const CONTENT_ENDPOINT = '/content/product-sections/navesy';

      let entry = null;
      let draft = null;
      let dirty = false;
      let loading = true;
      let error = null;

      const loadingView = document.getElementById('loadingView');
      const loadingText = document.getElementById('loadingText');
      const errorView = document.getElementById('errorView');
      const authView = document.getElementById('authView');
      const editorView = document.getElementById('editorView');
      const heroSection = document.getElementById('heroSection');
      const blocksSection = document.getElementById('blocksSection');
      const saveBtn = document.getElementById('saveBtn');
      const logoutBtn = document.getElementById('logoutBtn');
      const dirtyStatus = document.getElementById('dirtyStatus');

      function safeArray(value) {
        return Array.isArray(value) ? value : [];
      }

      function safeString(value, fallback = '') {
        return typeof value === 'string' ? value : fallback;
      }

      function isActive(item) {
        return item?.isActive !== false;
      }

      function sortByOrder(items) {
        return safeArray(items).slice().sort((a, b) => (a?.order ?? 0) - (b?.order ?? 0));
      }

      function escapeHtml(value) {
        return String(value ?? '').replace(/[&<>"']/g, (char) => ({
          '&': '&amp;',
          '<': '&lt;',
          '>': '&gt;',
          '"': '&quot;',
          "'": '&#39;'
        }[char]));
      }

      function setStatus(text) {
        dirtyStatus.textContent = text;
      }

      function markDirty() {
        dirty = true;
        saveBtn.disabled = false;
        dirtyStatus.className = 'status-dirty';
        setStatus('Есть несохраненные изменения');
      }

      function clearDirty() {
        dirty = false;
        saveBtn.disabled = true;
        dirtyStatus.className = 'status-clean';
        setStatus('Нет изменений');
      }

      function showError(message, details = '') {
        error = { message, details };
        loading = false;
        loadingView.classList.add('hidden');
        authView.classList.add('hidden');
        editorView.classList.add('hidden');
        errorView.classList.remove('hidden');
        const detailText = details ? `<pre class="small">${escapeHtml(details)}</pre>` : '';
        errorView.innerHTML = `<div class="error-box"><h2>Ошибка</h2><p>${escapeHtml(message)}</p>${detailText}</div>`;
      }

      function showLoading(text) {
        loading = true;
        loadingText.textContent = text;
        loadingView.classList.remove('hidden');
        authView.classList.add('hidden');
        errorView.classList.add('hidden');
        editorView.classList.add('hidden');
      }

      function showAuthRequired() {
        loading = false;
        loadingView.classList.add('hidden');
        errorView.classList.add('hidden');
        editorView.classList.add('hidden');
        authView.classList.remove('hidden');
      }

      function showEditor() {
        loading = false;
        loadingView.classList.add('hidden');
        errorView.classList.add('hidden');
        authView.classList.add('hidden');
        editorView.classList.remove('hidden');
      }

      function deepCopy(value) {
        return JSON.parse(JSON.stringify(value));
      }

      function fetchWithTimeout(url, options = {}, timeoutMs = 10000) {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), timeoutMs);
        return fetch(url, { ...options, signal: controller.signal })
          .finally(() => clearTimeout(timeoutId));
      }

      async function requestJson(endpoint, options = {}) {
        const url = `${API_BASE}${endpoint}`;
        try {
          const response = await fetchWithTimeout(url, {
            credentials: 'include',
            ...options,
            headers: {
              'Content-Type': 'application/json',
              ...(options.headers || {})
            }
          }, 10000);

          const data = await response.json().catch(() => ({}));

          if (!response.ok) {
            throw new Error(
              `API base: ${API_BASE}\nendpoint: ${endpoint}\nstatus: ${response.status}\nmessage: ${data?.error || response.statusText || 'HTTP error'}`
            );
          }

          return data;
        } catch (requestError) {
          if (requestError?.name === 'AbortError') {
            throw new Error(
              `Не удалось загрузить данные редактора. Проверьте, что запущен npm run admin:api.\nAPI base: ${API_BASE}\nendpoint: ${endpoint}\nstatus: timeout`
            );
          }
          throw requestError;
        }
      }

      function getRowsArray(block) {
        if (Array.isArray(block.items)) return block.items;
        if (Array.isArray(block.list)) return block.list;
        if (Array.isArray(block.factors)) return block.factors;
        return [];
      }

      function getCardsArray(block) {
        if (Array.isArray(block.cards)) return block.cards;
        if (Array.isArray(block.items)) return block.items;
        return [];
      }

      function getStepsArray(block) {
        if (Array.isArray(block.steps)) return block.steps;
        if (Array.isArray(block.items)) return block.items;
        return [];
      }

      function normalizeOrder(items) {
        safeArray(items).forEach((item, index) => {
          if (item && typeof item === 'object') {
            item.order = (index + 1) * 10;
          }
        });
      }

      function moveItem(items, index, direction) {
        const nextIndex = direction === 'up' ? index - 1 : index + 1;
        if (nextIndex < 0 || nextIndex >= items.length) return;
        const currentItem = items[index];
        items[index] = items[nextIndex];
        items[nextIndex] = currentItem;
        normalizeOrder(items);
      }

      function renderHero() {
        const heroTitle = safeString(draft?.heroTitle);
        const heroDescription = safeString(draft?.heroDescription);
        const image = safeString(draft?.image);
        const placeholderLabel = safeString(draft?.placeholderLabel, 'Фото будет добавлено позже');

        heroSection.innerHTML = `
          <div class="block-head">
            <h2>Hero</h2>
            <span class="badge">visual Stage A</span>
          </div>
          <div class="hero-preview">
            <h3>${escapeHtml(heroTitle || 'Без заголовка')}</h3>
            <p>${escapeHtml(heroDescription || 'Описание отсутствует')}</p>
            <div class="hero-media">
              ${image ? `<img src="${escapeHtml(image)}" alt="Hero" />` : `<div class="placeholder">${escapeHtml(placeholderLabel)}</div>`}
            </div>
          </div>
          <div class="field">
            <label for="heroTitleInput">Заголовок hero</label>
            <input id="heroTitleInput" data-hero-field="heroTitle" value="${escapeHtml(heroTitle)}" />
          </div>
          <div class="field">
            <label for="heroDescriptionInput">Описание hero</label>
            <textarea id="heroDescriptionInput" data-hero-field="heroDescription">${escapeHtml(heroDescription)}</textarea>
          </div>
          <div class="field">
            <label for="heroImageInput">Путь изображения</label>
            <input id="heroImageInput" data-hero-field="image" value="${escapeHtml(image)}" />
          </div>
          <div class="field">
            <label for="heroPlaceholderInput">Подпись placeholder</label>
            <input id="heroPlaceholderInput" data-hero-field="placeholderLabel" value="${escapeHtml(placeholderLabel)}" />
          </div>
        `;

        heroSection.querySelectorAll('[data-hero-field]').forEach((field) => {
          field.addEventListener('change', (event) => {
            const input = event.currentTarget;
            const fieldName = input.getAttribute('data-hero-field');
            draft[fieldName] = input.value;
            markDirty();
            renderHero();
          });
        });
      }

      function renderRowsBlock(block, blockIndex) {
        const rows = getRowsArray(block);
        const sortedRows = sortByOrder(rows);
        const rowsMarkup = sortedRows.map((row, rowIndex) => {
          const rowText = typeof row === 'string'
            ? row
            : safeString(row?.text) || safeString(row?.title);
          return `
            <div class="card-item">
              <div class="field">
                <label>Строка ${rowIndex + 1}</label>
                <textarea data-row-text="${blockIndex}:${rowIndex}">${escapeHtml(rowText)}</textarea>
              </div>
            </div>
          `;
        }).join('');

        return `
          <div class="panel">
            <div class="block-head">
              <h3>${escapeHtml(safeString(block.title, 'Список'))}</h3>
              <span class="badge">${escapeHtml(safeString(block.type))}</span>
            </div>
            ${rowsMarkup || '<p class="muted">Список пуст.</p>'}
          </div>
        `;
      }

      function renderCardsBlock(block, blockIndex) {
        const cards = getCardsArray(block);
        const sortedCards = sortByOrder(cards);
        const cardsMarkup = sortedCards.map((card, cardIndex) => {
          const inactiveClass = isActive(card) ? '' : 'item-inactive';
          return `
            <div class="card-item ${inactiveClass}">
              <div class="item-actions">
                <button type="button" class="btn btn-secondary small" data-card-move="up:${blockIndex}:${cardIndex}">Выше</button>
                <button type="button" class="btn btn-secondary small" data-card-move="down:${blockIndex}:${cardIndex}">Ниже</button>
                <button type="button" class="btn btn-secondary small" data-card-toggle="${blockIndex}:${cardIndex}">${isActive(card) ? 'Скрыть' : 'Показать'}</button>
              </div>
              <div class="field">
                <label>Заголовок</label>
                <input data-card-title="${blockIndex}:${cardIndex}" value="${escapeHtml(safeString(card?.title))}" />
              </div>
              <div class="field">
                <label>Описание</label>
                <textarea data-card-text="${blockIndex}:${cardIndex}">${escapeHtml(safeString(card?.text))}</textarea>
              </div>
            </div>
          `;
        }).join('');

        return `
          <div class="panel">
            <div class="block-head">
              <h3>${escapeHtml(safeString(block.title, 'Карточки'))}</h3>
              <span class="badge">${escapeHtml(safeString(block.type))}</span>
            </div>
            ${safeString(block.intro) ? `<p>${escapeHtml(block.intro)}</p>` : ''}
            ${cardsMarkup || '<p class="muted">Карточки отсутствуют.</p>'}
          </div>
        `;
      }

      function renderProcessBlock(block, blockIndex) {
        const steps = getStepsArray(block);
        const sortedSteps = sortByOrder(steps);
        const stepsMarkup = sortedSteps.map((step, stepIndex) => {
          const inactiveClass = isActive(step) ? '' : 'item-inactive';
          return `
            <div class="card-item ${inactiveClass}">
              <div class="item-actions">
                <button type="button" class="btn btn-secondary small" data-step-move="up:${blockIndex}:${stepIndex}">Выше</button>
                <button type="button" class="btn btn-secondary small" data-step-move="down:${blockIndex}:${stepIndex}">Ниже</button>
                <button type="button" class="btn btn-secondary small" data-step-toggle="${blockIndex}:${stepIndex}">${isActive(step) ? 'Скрыть' : 'Показать'}</button>
              </div>
              <div class="field">
                <label>Заголовок</label>
                <input data-step-title="${blockIndex}:${stepIndex}" value="${escapeHtml(safeString(step?.title))}" />
              </div>
              <div class="field">
                <label>Описание</label>
                <textarea data-step-text="${blockIndex}:${stepIndex}">${escapeHtml(safeString(step?.text))}</textarea>
              </div>
            </div>
          `;
        }).join('');

        return `
          <div class="panel">
            <div class="block-head">
              <h3>${escapeHtml(safeString(block.title, 'Процесс'))}</h3>
              <span class="badge">process</span>
            </div>
            ${stepsMarkup || '<p class="muted">Шаги отсутствуют.</p>'}
          </div>
        `;
      }

      function renderMediaTextBlock(block, blockIndex) {
        return `
          <div class="panel">
            <div class="block-head">
              <h3>${escapeHtml(safeString(block.title, 'Текст + изображение'))}</h3>
              <span class="badge">mediaText</span>
            </div>
            <div class="field">
              <label>Заголовок</label>
              <input data-block-field="${blockIndex}:title" value="${escapeHtml(safeString(block.title))}" />
            </div>
            <div class="field">
              <label>Текст</label>
              <textarea data-block-field="${blockIndex}:text">${escapeHtml(safeString(block.text))}</textarea>
            </div>
            <div class="field">
              <label>Media path</label>
              <input data-block-field="${blockIndex}:media" value="${escapeHtml(safeString(block.media))}" />
            </div>
            <div class="field">
              <label>Placeholder</label>
              <input data-block-field="${blockIndex}:placeholderLabel" value="${escapeHtml(safeString(block.placeholderLabel))}" />
            </div>
          </div>
        `;
      }

      function renderNoticeBlock(block, blockIndex) {
        return `
          <div class="panel">
            <div class="block-head">
              <h3>${escapeHtml(safeString(block.title, 'Вставка'))}</h3>
              <span class="badge">notice</span>
            </div>
            <div class="field">
              <label>Заголовок</label>
              <input data-block-field="${blockIndex}:title" value="${escapeHtml(safeString(block.title))}" />
            </div>
            <div class="field">
              <label>Текст</label>
              <textarea data-block-field="${blockIndex}:text">${escapeHtml(safeString(block.text))}</textarea>
            </div>
          </div>
        `;
      }

      function renderUnknownBlock(block) {
        return `
          <div class="panel">
            <div class="error-box">
              <strong>Неизвестный или поврежденный блок</strong>
              <p>type: ${escapeHtml(safeString(block?.type, 'unknown'))}</p>
            </div>
          </div>
        `;
      }

      function renderBlocks() {
        const blocks = draft?.pageBlocks;
        if (!Array.isArray(blocks)) {
          blocksSection.innerHTML = '<div class="panel"><p class="muted">У страницы нет pageBlocks.</p></div>';
          return;
        }

        const visibleBlocks = sortByOrder(blocks).filter((block) => isActive(block));
        if (!visibleBlocks.length) {
          blocksSection.innerHTML = '<div class="panel"><p class="muted">Нет активных блоков для отображения.</p></div>';
          return;
        }

        const html = visibleBlocks.map((block) => {
          const blockIndex = blocks.indexOf(block);
          if (block.type === 'cardGrid' || block.type === 'exampleGrid') {
            return renderCardsBlock(block, blockIndex);
          }
          if (block.type === 'listPanel' || block.type === 'factorList') {
            return renderRowsBlock(block, blockIndex);
          }
          if (block.type === 'process') {
            return renderProcessBlock(block, blockIndex);
          }
          if (block.type === 'mediaText') {
            return renderMediaTextBlock(block, blockIndex);
          }
          if (block.type === 'notice') {
            return renderNoticeBlock(block, blockIndex);
          }
          return renderUnknownBlock(block);
        }).join('');

        blocksSection.innerHTML = html;
      }

      function renderEditor() {
        showEditor();
        renderHero();
        renderBlocks();
      }

      function parsePair(value) {
        const [a, b] = String(value).split(':');
        return [Number(a), Number(b)];
      }

      function handleBlocksChange(event) {
        const target = event.target;

        if (target.hasAttribute('data-row-text')) {
          const [blockIndex, rowIndex] = parsePair(target.getAttribute('data-row-text'));
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          const rows = getRowsArray(block);
          const sortedRows = sortByOrder(rows);
          const row = sortedRows[rowIndex];
          if (typeof row === 'string') {
            const originalIndex = rows.indexOf(row);
            rows[originalIndex] = target.value;
          } else if (row && typeof row === 'object') {
            row.text = target.value;
          }
          markDirty();
          return;
        }

        if (target.hasAttribute('data-card-title') || target.hasAttribute('data-card-text')) {
          const token = target.getAttribute('data-card-title') || target.getAttribute('data-card-text');
          const [blockIndex, cardIndex] = parsePair(token);
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          const cards = sortByOrder(getCardsArray(block));
          const card = cards[cardIndex];
          if (!card || typeof card !== 'object') return;
          if (target.hasAttribute('data-card-title')) card.title = target.value;
          if (target.hasAttribute('data-card-text')) card.text = target.value;
          markDirty();
          return;
        }

        if (target.hasAttribute('data-step-title') || target.hasAttribute('data-step-text')) {
          const token = target.getAttribute('data-step-title') || target.getAttribute('data-step-text');
          const [blockIndex, stepIndex] = parsePair(token);
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          const steps = sortByOrder(getStepsArray(block));
          const step = steps[stepIndex];
          if (!step || typeof step !== 'object') return;
          if (target.hasAttribute('data-step-title')) step.title = target.value;
          if (target.hasAttribute('data-step-text')) step.text = target.value;
          markDirty();
          return;
        }

        if (target.hasAttribute('data-block-field')) {
          const [blockIndexRaw, field] = target.getAttribute('data-block-field').split(':');
          const blockIndex = Number(blockIndexRaw);
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          block[field] = target.value;
          markDirty();
        }
      }

      function handleBlocksClick(event) {
        const moveCardToken = event.target.getAttribute('data-card-move');
        if (moveCardToken) {
          const [direction, blockIndexRaw, cardIndexRaw] = moveCardToken.split(':');
          const block = draft.pageBlocks?.[Number(blockIndexRaw)];
          if (!block) return;
          const cards = getCardsArray(block);
          const sortedCards = sortByOrder(cards);
          const card = sortedCards[Number(cardIndexRaw)];
          const currentIndex = cards.indexOf(card);
          moveItem(cards, currentIndex, direction);
          markDirty();
          renderBlocks();
          return;
        }

        const toggleCardToken = event.target.getAttribute('data-card-toggle');
        if (toggleCardToken) {
          const [blockIndex, cardIndex] = parsePair(toggleCardToken);
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          const cards = sortByOrder(getCardsArray(block));
          const card = cards[cardIndex];
          if (!card || typeof card !== 'object') return;
          card.isActive = !isActive(card);
          markDirty();
          renderBlocks();
          return;
        }

        const moveStepToken = event.target.getAttribute('data-step-move');
        if (moveStepToken) {
          const [direction, blockIndexRaw, stepIndexRaw] = moveStepToken.split(':');
          const block = draft.pageBlocks?.[Number(blockIndexRaw)];
          if (!block) return;
          const steps = getStepsArray(block);
          const sortedSteps = sortByOrder(steps);
          const step = sortedSteps[Number(stepIndexRaw)];
          const currentIndex = steps.indexOf(step);
          moveItem(steps, currentIndex, direction);
          markDirty();
          renderBlocks();
          return;
        }

        const toggleStepToken = event.target.getAttribute('data-step-toggle');
        if (toggleStepToken) {
          const [blockIndex, stepIndex] = parsePair(toggleStepToken);
          const block = draft.pageBlocks?.[blockIndex];
          if (!block) return;
          const steps = sortByOrder(getStepsArray(block));
          const step = steps[stepIndex];
          if (!step || typeof step !== 'object') return;
          step.isActive = !isActive(step);
          markDirty();
          renderBlocks();
        }
      }

      async function saveDraft() {
        if (!draft) return;
        saveBtn.disabled = true;
        setStatus('Сохраняем…');
        try {
          await requestJson(CONTENT_ENDPOINT, {
            method: 'PUT',
            body: JSON.stringify(draft)
          });
          entry = deepCopy(draft);
          clearDirty();
          setStatus('Нет изменений');
          alert('Сохранено');
        } catch (saveError) {
          console.error('[navesy-editor] save error', saveError);
          showError('Не удалось сохранить данные.', String(saveError?.message || saveError));
          if (dirty) {
            saveBtn.disabled = false;
          }
        }
      }

      async function logout() {
        try {
          await requestJson('/logout', { method: 'POST' });
        } catch (logoutError) {
          console.error('[navesy-editor] logout error', logoutError);
        } finally {
          window.location.href = '/SMU1/admin/';
        }
      }

      async function initialize() {
        showLoading('Загрузка данных…');
        try {
          const meResponse = await requestJson('/me');
          if (!meResponse?.authenticated) {
            showAuthRequired();
            return;
          }

          const contentResponse = await requestJson(CONTENT_ENDPOINT);
          const loadedEntry = contentResponse?.entry || contentResponse;
          entry = deepCopy(loadedEntry || {});
          draft = deepCopy(loadedEntry || {});
          clearDirty();
          renderEditor();
        } catch (initError) {
          console.error('[navesy-editor] init error', initError);
          showError('Не удалось загрузить данные редактора. Проверьте, что запущен npm run admin:api.', String(initError?.message || initError));
        }
      }

      saveBtn.addEventListener('click', saveDraft);
      logoutBtn.addEventListener('click', logout);
      blocksSection.addEventListener('change', handleBlocksChange);
      blocksSection.addEventListener('click', handleBlocksClick);

      window.addEventListener('error', (event) => {
        console.error('[navesy-editor] runtime error', event.error || event.message);
        showError('Произошла ошибка в редакторе.', String(event.error?.message || event.message || 'unknown error'));
      });

      window.addEventListener('unhandledrejection', (event) => {
        console.error('[navesy-editor] unhandled rejection', event.reason);
        showError('Необработанная ошибка в редакторе.', String(event.reason?.message || event.reason || 'unknown rejection'));
      });

      initialize();
    </script>
  </body>
</html>
