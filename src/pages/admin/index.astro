---
import { withBase } from '../../utils/withBase';
const adminApiBase = import.meta.env.PUBLIC_ADMIN_API_BASE ?? 'http://127.0.0.1:8787/api/admin';

const cards = [
  { title: 'Главная страница', description: 'Первый экран, блоки главной, направления, доверительный блок и контакты.', href: withBase('/admin/visual/?collection=static-pages&slug=home'), cta: 'Редактировать главную', primary: true },
  { title: 'Страницы и услуги', description: 'Создание новых страниц, меню, публикация, hero-медиа и конструктор секций.', href: withBase('/admin/visual/?collection=static-pages'), cta: 'Открыть список страниц', primary: true },
  { title: 'Уличная мебель', description: 'Страница раздела, подстраницы лавочек, урн, вазонов, велопарковок и модели изделий внутри них.', href: withBase('/admin/visual/?collection=product-sections&slug=ulichnaya-mebel'), cta: 'Открыть раздел' },
  { title: 'Ограждения', description: 'Страница ограждений и вложенные типы: заборы, ворота, калитки, секции, перила и другие позиции.', href: withBase('/admin/visual/?collection=product-sections&slug=ograzhdeniya-i-zabory'), cta: 'Открыть раздел' },
  { title: 'Навесы', description: 'Страница направления навесов и козырьков с редактируемыми секциями.', href: withBase('/admin/visual/?collection=product-sections&slug=navesy-i-kozyrki'), cta: 'Редактировать навесы' },
  { title: 'Металлоконструкции', description: 'Страница направления для бизнес-задач, сварочных работ и конструкций на заказ.', href: withBase('/admin/visual/?collection=product-sections&slug=metallokonstruktsii-dlya-biznesa'), cta: 'Открыть раздел' },
  { title: 'Топиарии', description: 'Страница декоративных топиарных конструкций и проектных решений.', href: withBase('/admin/visual/?collection=product-sections&slug=topiarii'), cta: 'Открыть раздел' },
  { title: 'Благоустройство', description: 'Страница проектной услуги по благоустройству территорий.', href: withBase('/admin/visual/?collection=services&slug=blagoustroystvo-territoriy'), cta: 'Редактировать страницу' },
  { title: 'Строительство', description: 'Страница строительных и ремонтных работ.', href: withBase('/admin/visual/?collection=services&slug=stroitelstvo-i-remonty'), cta: 'Редактировать страницу' },
  { title: 'Выполненные объекты', description: 'Листинг и карточки объектов доверительного контура.', href: withBase('/admin/visual/?collection=projects'), cta: 'Открыть объекты' },
  { title: 'Контакты', description: 'Телефоны, Telegram, email, адрес, регионы и общие настройки компании.', href: withBase('/admin/visual/?collection=site-settings&slug=global'), cta: 'Редактировать контакты' },
  { title: 'Вакансии', description: 'Добавление, удаление и редактирование вакансий.', href: withBase('/admin/visual/?collection=jobs'), cta: 'Открыть вакансии' },
  { title: 'Изготовление на заказ', description: 'Служебная посадочная страница для индивидуальных заказов.', href: withBase('/admin/visual/?collection=static-pages&slug=custom-order'), cta: 'Редактировать страницу' }
];
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Админка СМУ-1</title>
    <style>
      * { box-sizing: border-box; }
      body { margin: 0; font-family: Inter, system-ui, sans-serif; color: #1c2d3f; background: linear-gradient(180deg, #f4f6fa 0%, #eef2f7 100%); }
      .hidden { display: none !important; }
      .login-wrap { min-height: 100vh; display: grid; place-items: center; padding: 24px; }
      .login-card { width: min(460px, 100%); background: #fff; border: 1px solid #d8e2ec; border-radius: 16px; padding: 28px; box-shadow: 0 18px 40px rgb(23 39 56 / 10%); }
      .login-card h1 { margin: 0 0 10px; font-size: 28px; }
      .login-card p { margin: 0 0 18px; color: #576b80; }
      .field { display: grid; gap: 8px; margin-bottom: 12px; }
      .field label { font-size: 14px; color: #41566d; }
      .field input { border: 1px solid #c8d6e4; border-radius: 10px; padding: 12px 14px; font: inherit; font-size: 16px; }
      .btn { border: 1px solid #0b6b4f; border-radius: 10px; background: #0b6b4f; color: #fff; padding: 12px 16px; font: inherit; font-weight: 700; cursor: pointer; }
      .btn:disabled { opacity: .5; cursor: wait; }
      .muted { color: #60758a; font-size: 14px; }
      .error { color: #b13838; }
      .app { min-height: 100vh; padding: 32px 24px 56px; }
      .shell { max-width: 1120px; margin: 0 auto; }
      .topbar { display: flex; justify-content: space-between; gap: 14px; align-items: center; margin-bottom: 24px; }
      .topbar h1 { margin: 0; font-size: clamp(30px, 4vw, 42px); }
      .topbar p { margin: 8px 0 0; color: #556d85; }
      .topbar-actions { display: flex; gap: 10px; }
      .btn-secondary { background: #fff; color: #26405a; border-color: #c2d2e2; }
      .cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; }
      .card { background: #fff; border: 1px solid #d5e0ea; border-radius: 14px; padding: 18px; display: grid; gap: 12px; min-height: 190px; }
      .card h2 { margin: 0; font-size: 22px; }
      .card p { margin: 0; color: #5e7388; }
      .card .cta { margin-top: auto; display: inline-flex; align-items: center; justify-content: center; text-decoration: none; padding: 11px 14px; border-radius: 10px; font-weight: 700; }
      .cta-primary { background: #0b6b4f; color: #fff; }
      .cta-muted { background: #ecf1f6; color: #4c6075; }
    </style>
  </head>
  <body>
    <div id="loginView" class="login-wrap hidden">
      <form id="loginForm" class="login-card">
        <h1>Админка СМУ-1</h1>
        <p>Войдите, чтобы перейти к редактированию контента.</p>
        <div class="field"><label for="login">Логин</label><input id="login" name="login" required /></div>
        <div class="field"><label for="password">Пароль</label><input id="password" type="password" name="password" required /></div>
        <button class="btn" type="submit">Войти</button>
        <p id="loginStatus" class="muted" style="margin-top: 12px;"></p>
      </form>
    </div>

    <main id="appView" class="app hidden">
      <div class="shell">
        <div class="topbar">
          <div>
            <h1>Админка СМУ-1</h1>
            <p>Выберите страницу или раздел для редактирования.</p>
          </div>
          <div class="topbar-actions">
            <a class="btn btn-secondary" href={withBase('/admin/technical/')}>Технический режим</a>
            <button id="logoutBtn" class="btn btn-secondary" type="button">Выйти</button>
          </div>
        </div>
        <section class="cards">
          {cards.map((card) => (
            <article class="card">
              <h2>{card.title}</h2>
              <p>{card.description}</p>
              {card.href ? (
                <a class={`cta ${card.primary ? 'cta-primary' : 'cta-muted'}`} href={card.href}>{card.cta ?? 'Открыть'}</a>
              ) : (
                <span class="cta cta-muted">Скоро</span>
              )}
            </article>
          ))}
        </section>
      </div>
    </main>

    <script type="module" define:vars={{ adminApiBase }}>
      const API_BASE = adminApiBase;
      const loginView = document.getElementById('loginView');
      const appView = document.getElementById('appView');
      const loginStatus = document.getElementById('loginStatus');
      const loginForm = document.getElementById('loginForm');

      const api = async (path, options = {}) => {
        const response = await fetch(`${API_BASE}${path}`, {
          ...options,
          credentials: 'include',
          headers: { 'Content-Type': 'application/json', ...(options.headers || {}) }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.error || `HTTP ${response.status}`);
        return data;
      };

      const showLogin = (msg = '') => {
        loginView.classList.remove('hidden');
        appView.classList.add('hidden');
        loginStatus.textContent = msg;
        loginStatus.className = 'muted';
      };
      const showApp = () => {
        loginView.classList.add('hidden');
        appView.classList.remove('hidden');
      };

      async function boot() {
        try {
          const me = await api('/me');
          if (me.authenticated) showApp();
          else showLogin('Введите логин и пароль.');
        } catch {
          showLogin('Введите логин и пароль.');
        }
      }

      loginForm?.addEventListener('submit', async (event) => {
        event.preventDefault();
        loginStatus.textContent = 'Выполняем вход…';
        const formData = new FormData(loginForm);
        try {
          await api('/login', { method: 'POST', body: JSON.stringify({ login: formData.get('login'), password: formData.get('password') }) });
          showApp();
        } catch (error) {
          loginStatus.textContent = error.message || 'Ошибка входа.';
          loginStatus.className = 'muted error';
        }
      });

      document.getElementById('logoutBtn')?.addEventListener('click', async () => {
        await api('/logout', { method: 'POST' }).catch(() => {});
        showLogin('Вы вышли из админки.');
      });

      boot();
    </script>
  </body>
</html>
