      function moveItem(items, index, dir) {
        const to = index + dir;
        if (to < 0 || to >= items.length) return;
        [items[index], items[to]] = [items[to], items[index]];
        renumber(items);
      }

      async function saveAll() {
        const dirty = dirtyRecords();
        const navigationDirty = isNavigationDirty();
        if (!dirty.length && !navigationDirty) return;
        $('saveBtn').disabled = true;
        setAlert('Сохраняем...');
        try {
          for (const record of dirty) {
            const data = await api(`/content/${record.collection}/${record.slug}`, { method: 'PUT', body: JSON.stringify(stripPresentationFields(record.draft)) });
            record.original = clone(data.content);
            record.draft = clone(data.content);
          }
          if (navigationDirty) {
            const data = await api('/navigation', { method: 'PUT', body: JSON.stringify({ items: state.navigationItems }) });
            const items = normalizeNavigationItems(data.items || []);
            state.navigationItems = clone(items);
            state.navigationOriginal = clone(items);
          }
          renderApp({ preserveScroll: true });
          await publishSavedChanges('Изменения сохранены.');
        } catch (error) {
          setAlert(error.message || 'Ошибка сохранения', true);
          markDirty();
        }
      }

      async function publishSavedChanges(savedMessage) {
        setAlert(`${savedMessage} Публикуем тестовую версию на GitHub...`);
        try {
          const publish = await api('/publish', { method: 'POST', body: JSON.stringify({ target: 'test', source: 'visual-auto-save-test' }) });
          setPublishStatus({ ...publish, status: publish.status || 'queued', reportAvailable: false });
          startPublishPolling(publish);
          setAlert(publish.message || 'Изменения опубликованы в тестовую версию.');
          return true;
        } catch (publishError) {
          const status = {
            mode: 'test',
            target: 'test',
            requestedTarget: 'test',
            publishSource: 'visual-auto-save-test',
            status: 'failure',
            error: publishError.message || 'ошибка Git push',
            code: publishError.data?.code || '',
            reportAvailable: true
          };
          setPublishStatus(status);
          setAlert(`${savedMessage} Но тестовая публикация не прошла: ${status.error}`, true);
          return false;
        }
      }

      async function publishWholeSite(target = 'test') {
        if (dirtyCount()) {
          setAlert('Сначала нажмите «Сохранить», чтобы записать текущие правки страницы.', true);
          return;
        }
        const isProduction = target === 'production';
        const confirmText = isProduction
          ? 'Опубликовать на основной сайт? Будет использована production-ветка. Продолжить?'
          : 'Опубликовать тестовую версию? Будут отправлены исходники, настройки, public и docs в тестовую ветку.';
        if (!confirm(confirmText)) return;

        $('publishTestBtn').disabled = true;
        $('publishProductionBtn').disabled = true;
        setAlert(isProduction ? 'Проверяем production-настройки и публикуем на сайт...' : 'Публикуем тестовую версию на GitHub...');
        try {
          const publish = await api('/publish-all', { method: 'POST', body: JSON.stringify({ target, source: isProduction ? 'visual-production-button' : 'visual-test-button' }) });
          setPublishStatus({ ...publish, status: publish.status || 'queued', reportAvailable: false });
          startPublishPolling(publish);
          setAlert(publish.message || (isProduction ? 'Публикация на сайт запущена.' : 'Тестовая публикация запущена.'));
        } catch (error) {
          const status = {
            mode: target,
            target,
            requestedTarget: target,
            publishSource: isProduction ? 'visual-production-button' : 'visual-test-button',
            status: 'failure',
            error: error.message || (isProduction ? 'Ошибка публикации на сайт' : 'Ошибка тестовой публикации'),
            code: error.data?.code || '',
            reportAvailable: true,
            probableCause: error.data?.code === 'PRODUCTION_NOT_READY' ? 'SITE_URL для боевого сайта еще не настроен.' : '',
            nextStep: error.data?.code === 'PRODUCTION_NOT_READY' ? 'Используйте тестовую публикацию. После подключения домена и хостинга задайте SITE_URL.' : ''
          };
          setPublishStatus(status);
          setAlert(status.error, true);
        } finally {
          $('publishTestBtn').disabled = false;
          $('publishProductionBtn').disabled = false;
        }
      }

      async function uploadImage(file) {
        if (!state.uploadTarget) return;
        const formData = new FormData();
        formData.append('file', file);
        const data = await api('/upload', { method: 'POST', body: formData });
        const uploadedPath = typeof data.path === 'string' ? data.path.trim() : '';
        if (!uploadedPath) throw new Error('Backend загрузил файл, но не вернул путь к нему.');
        const record = getRecord(state.uploadTarget.ref);
        if (state.uploadTarget.mode === 'append-structured-gallery') {
          const arr = getPath(record, state.uploadTarget.path) || [];
          arr.push({ src: uploadedPath, alt: '', caption: '' });
          setPath(record, state.uploadTarget.path, arr);
          state.crop = null;
          renderApp({ preserveScroll: true });
          setAlert(`Фото добавлено в галерею: ${fileNameFromPath(uploadedPath)}.`);
          return;
        }
        setPath(record, state.uploadTarget.path, uploadedPath);
        if (state.uploadTarget.viewPath && !getPath(record, state.uploadTarget.viewPath)) setPath(record, state.uploadTarget.viewPath, clone(DEFAULT_MEDIA_VIEW));
        state.crop = state.uploadTarget.viewPath ? { ...state.uploadTarget } : null;
        renderApp({ preserveScroll: true });
        setAlert(`Фото загружено: ${fileNameFromPath(uploadedPath)}.`);
      }

      async function uploadGalleryImages(files) {
        if (!state.galleryUploadTarget) return;
        const record = getRecord(state.galleryUploadTarget.ref);
        const path = state.galleryUploadTarget.path || 'gallery';
        const sourceList = Array.isArray(getPath(record, path)) ? getPath(record, path) : [];
        const list = sourceList
          .map(normalizeStructuredGalleryItem)
          .filter((item) => item.src || item.alt || item.caption);
        const uploaded = [];

        for (const file of files) {
          const formData = new FormData();
          formData.append('file', file);
          const data = await api('/upload', { method: 'POST', body: formData });
          const uploadedPath = typeof data.path === 'string' ? data.path.trim() : '';
          if (!uploadedPath) throw new Error('Backend загрузил файл, но не вернул путь к нему.');
          uploaded.push(uploadedPath);
        }

        const existing = new Set(list.map((item) => item.src).filter(Boolean));
        uploaded.forEach((uploadedPath) => {
          if (!existing.has(uploadedPath)) {
            list.push({ src: uploadedPath, alt: '', caption: '' });
            existing.add(uploadedPath);
          }
        });

        if (!record.draft.image && uploaded[0]) record.draft.image = uploaded[0];
        setPath(record, path, list);
        renderApp({ preserveScroll: true });
        setAlert(`Фото загружены: ${uploaded.length}.`);
      }

