      function nextOrder(collection) {
        const records = Object.values(state.records).filter((record) => record.collection === collection);
        return records.length ? Math.max(...records.map((record) => Number(record.draft.order) || 0)) + 10 : 10;
      }

      async function createRecord(collection, panel) {
        const fields = {};
        panel.querySelectorAll('[data-create-field]').forEach((input) => { fields[input.dataset.createField] = input.value; });
        const content = defaultContent(collection, fields);
        if (!content.slug) throw new Error('Заполните slug латиницей');
        const cleanContent = stripPresentationFields(content);
        const data = await api(`/content/${collection}`, { method: 'POST', body: JSON.stringify({ slug: cleanContent.slug, content: cleanContent }) });
        state.records[keyOf(collection, data.slug)] = { collection, slug: data.slug, original: clone(data.content), draft: clone(data.content) };
        await loadCollection(collection);
        if (state.collection === collection && collection !== 'jobs' && collection !== 'projects') state.selectedSlug = data.slug;
        renderApp();
        await publishSavedChanges('Запись создана.');
      }

      async function deleteRecord(ref) {
        const record = getRecord(ref);
        if (!record) return;
        if (record.collection === 'products') {
          await deleteProductRecord(ref);
          return;
        }
        if (!confirm(`Удалить запись "${record.draft.title || record.slug}"?`)) return;
        await api(`/content/${record.collection}/${record.slug}`, { method: 'DELETE' });
        delete state.records[ref];
        await loadCollection(record.collection);
        if (state.selectedSlug === record.slug && state.collection === record.collection) state.selectedSlug = '';
        renderApp();
        await publishSavedChanges('Запись удалена.');
      }

      function visibleSelectedProductRefs() {
        return Array.from(document.querySelectorAll('[data-product-select]:checked'))
          .map((input) => input.dataset.ref)
          .filter((ref) => getRecord(ref)?.collection === 'products');
      }

      function syncProductSelectionUi() {
        document.querySelectorAll('[data-product-select]').forEach((input) => {
          input.checked = state.selectedProductRefs.has(input.dataset.ref);
        });
        const visibleCount = visibleSelectedProductRefs().length;
        document.querySelectorAll('[data-selected-products-count]').forEach((node) => {
          node.textContent = String(visibleCount);
        });
        document.querySelectorAll('[data-action="bulk-delete-products"], [data-action="clear-product-selection"]').forEach((button) => {
          button.disabled = visibleCount === 0;
        });
      }

      function removeProductCardFromDom(ref) {
        document.querySelectorAll(`[data-product-card][data-ref="${CSS.escape(ref)}"]`).forEach((card) => card.remove());
        renderNav();
        syncProductSelectionUi();
        markDirty();
      }

      async function deleteProductRecord(ref, options = {}) {
        const { confirmDelete = true, publish = true } = options;
        const record = getRecord(ref);
        if (!record || record.collection !== 'products') return { ok: false, error: 'Товар не найден.' };
        if (confirmDelete && !confirm(`Удалить товар "${record.draft.title || record.slug}"?`)) return { ok: false, cancelled: true };

        await api(`/content/products/${encodeURIComponent(record.slug)}`, { method: 'DELETE' });
        delete state.records[ref];
        state.selectedProductRefs.delete(ref);
        await loadCollection('products');

        if (state.selectedSlug === record.slug && state.collection === 'products') {
          state.selectedSlug = '';
          renderApp();
        } else if (document.querySelector(`[data-product-card][data-ref="${CSS.escape(ref)}"]`)) {
          removeProductCardFromDom(ref);
        } else {
          renderApp();
        }

        if (publish) await publishSavedChanges('Товар удален.');
        return { ok: true };
      }

      async function bulkDeleteSelectedProducts() {
        const refs = visibleSelectedProductRefs();
        if (!refs.length) {
          setAlert('Выберите товары для удаления.', true);
          return;
        }
        if (!confirm(`Удалить ${refs.length} товаров? Это действие нельзя отменить.`)) return;

        const result = { deleted: 0, errors: [], deletedRefs: [] };
        setAlert(`Удаляем товары: ${refs.length}...`);
        for (const ref of refs) {
          const record = getRecord(ref);
          if (!record || record.collection !== 'products') continue;
          try {
            await api(`/content/products/${encodeURIComponent(record.slug)}`, { method: 'DELETE' });
            delete state.records[ref];
            state.selectedProductRefs.delete(ref);
            result.deleted += 1;
            result.deletedRefs.push(ref);
          } catch (error) {
            result.errors.push(`${record.draft.title || record.slug}: ${error.message || 'ошибка удаления'}`);
          }
        }

        await loadCollection('products');
        result.deletedRefs.forEach((ref) => document.querySelectorAll(`[data-product-card][data-ref="${CSS.escape(ref)}"]`).forEach((card) => card.remove()));
        renderNav();
        syncProductSelectionUi();
        markDirty();

        const published = result.deleted
          ? await publishSavedChanges(`Удалено товаров: ${result.deleted}. Ошибок: ${result.errors.length}.`)
          : false;
        if (result.errors.length) {
          setAlert(`Удалено: ${result.deleted}, ошибок: ${result.errors.length}. ${result.errors.join('; ')}`, true);
        } else if (published || !result.deleted) {
          setAlert(`Удалено: ${result.deleted}, ошибок: 0.`);
        }
      }

      function readImportFile(file) {
        const name = file?.name || '';
        if (!/\.json$/i.test(name) && file?.type !== 'application/json') {
          throw new Error('Выберите файл .json.');
        }
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            state.importText = String(reader.result || '');
            state.importFileName = name;
            state.importPreview = null;
            state.importResult = null;
            renderApp();
            setAlert(`JSON-файл загружен: ${name}. Нажмите «Проверить».`);
            resolve();
          };
          reader.onerror = () => reject(new Error('Не удалось прочитать JSON-файл.'));
          reader.readAsText(file, 'utf-8');
        });
      }

      async function moveCategoryRecord(ref, dir) {
        const record = getRecord(ref);
        if (!record || record.collection !== 'product-categories') return;
        const parentSlug = record.draft.parentSectionSlug;
        const siblings = Object.values(state.records)
          .filter((item) => item.collection === 'product-categories' && item.draft.parentSectionSlug === parentSlug)
          .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
        const index = siblings.findIndex((item) => keyOf(item.collection, item.slug) === ref);
        const nextIndex = index + dir;
        if (index < 0 || nextIndex < 0 || nextIndex >= siblings.length) return;

        const previousOrders = new Map(siblings.map((item) => [keyOf(item.collection, item.slug), item.draft.order]));
        const reordered = siblings.slice();
        [reordered[index], reordered[nextIndex]] = [reordered[nextIndex], reordered[index]];
        reordered.forEach((item, itemIndex) => {
          item.draft.order = (itemIndex + 1) * 10;
        });

        renderApp();
        setAlert('Сохраняем порядок типов изделий...');
        try {
          for (const item of reordered) {
          const data = await api(`/content/product-categories/${encodeURIComponent(item.slug)}`, { method: 'PUT', body: JSON.stringify(stripPresentationFields(item.draft)) });
            item.original = clone(data.content);
            item.draft = clone(data.content);
          }
          await loadCollection('product-categories');
          renderApp();
          await publishSavedChanges('Порядок типов изделий сохранен.');
        } catch (error) {
          previousOrders.forEach((order, itemRef) => {
            const item = getRecord(itemRef);
            if (item) item.draft.order = order;
          });
          renderApp();
          throw error;
        }
      }

