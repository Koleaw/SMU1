        return `<div class="admin-media-frame admin-media-frame--${size} ${isCrop ? 'is-active-crop' : ''}" data-image-frame="${esc(target)}">${image ? `<img class="media-thumb" data-image-img="${esc(target)}" src="${esc(toSrc(image))}" alt="" style="${esc(mediaStyle(view))}" />` : '<div class="admin-media-empty">Фото не выбрано</div>'}</div>${renderMediaButtons(ref, imagePath, viewPath, target)}${isCrop ? renderCropControls() : ''}`;
