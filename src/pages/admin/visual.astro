      function setPublishStatus(status) {
        state.publishStatus = status;
        renderPublishStatus();
      }

      function renderPublishStatus() {
        const box = $('publishStatusBox');
        const status = state.publishStatus;
        if (!status) {
          box.className = 'publish-status';
          box.innerHTML = '';
          return;
        }

        const mode = status.mode || status.target || 'test';
        const commitLabel = status.commit || (status.commitSha ? status.commitSha.slice(0, 7) : '');
        const runLabel = status.workflowRunUrl ? 'Открыть run' : 'run еще не найден';
        const errorText = status.error || status.statusError || '';
        const canDownloadReport = status.status === 'failure' || status.reportAvailable || Boolean(errorText);
        box.className = 'publish-status is-visible';
        box.innerHTML = `
          <div class="publish-status__grid">
            <div class="publish-status__item"><span>Режим</span><strong>${esc(deployModeLabel(mode))}</strong></div>
            <div class="publish-status__item"><span>Branch</span><strong>${esc(status.branch || '')}</strong></div>
            <div class="publish-status__item"><span>Ref</span><strong>${esc(status.ref || (status.branch ? `refs/heads/${status.branch}` : ''))}</strong></div>
            <div class="publish-status__item"><span>Commit</span>${status.commitUrl ? `<a href="${esc(status.commitUrl)}" target="_blank" rel="noreferrer">${esc(commitLabel)}</a>` : `<strong>${esc(commitLabel || '-')}</strong>`}</div>
            <div class="publish-status__item"><span>Commit message</span><strong>${esc(status.commitMessage || '-')}</strong></div>
            <div class="publish-status__item"><span>GitHub Actions</span>${status.workflowRunUrl ? `<a href="${esc(status.workflowRunUrl)}" target="_blank" rel="noreferrer">${runLabel}</a>` : `<strong>${runLabel}</strong>`}</div>
            <div class="publish-status__item"><span>Статус</span><strong>${esc(publishStatusLabel(status.status))}</strong></div>
            <div class="publish-status__item"><span>Event</span><strong>${esc(status.workflowEvent || '-')}</strong></div>
            <div class="publish-status__item"><span>Workflow target</span><strong>${esc(status.workflowDeployTarget || mode)}</strong></div>
            <div class="publish-status__item"><span>Production check</span><strong>${status.productionCheckRan ? 'yes' : 'no'}</strong></div>
          </div>
          ${status.failedJob || status.failedStep ? `<p class="publish-status__message is-error">Failed job: ${esc(status.failedJob || '-')}. Failed step: ${esc(status.failedStep || '-')}.</p>` : ''}
          ${errorText ? `<p class="publish-status__message is-error">${esc(errorText)}</p>` : ''}
          ${status.message ? `<p class="publish-status__message">${esc(status.message)}</p>` : ''}
          ${canDownloadReport ? `<button class="admin-btn" type="button" data-action="download-publish-report">Скачать отчет об ошибке</button>` : ''}
        `;
      }

      function stopPublishPolling() {
        if (state.publishPollTimer) window.clearInterval(state.publishPollTimer);
        state.publishPollTimer = null;
      }

      async function pollPublishStatus() {
        const current = state.publishStatus;
        if (!current?.branch || !current?.commitSha) return;
        const params = new URLSearchParams();
        params.set('target', current.mode || current.target || 'test');
        params.set('branch', current.branch);
        params.set('commitSha', current.commitSha);
        if (current.workflowRunId) params.set('runId', current.workflowRunId);
        const next = await api(`/publish-status?${params.toString()}`);
        setPublishStatus({ ...current, ...next, message: current.message });
        if (next.status === 'success' || next.status === 'failure') stopPublishPolling();
      }

      function startPublishPolling(publish) {
        stopPublishPolling();
        if (!publish?.published || !publish.commitSha) return;
        state.publishPollAttempts = 0;
        state.publishPollTimer = window.setInterval(async () => {
          state.publishPollAttempts += 1;
          try {
            await pollPublishStatus();
          } catch (error) {
            setPublishStatus({ ...state.publishStatus, statusError: error.message || 'Не удалось получить статус GitHub Actions. Откройте run вручную.' });
          }
          if (state.publishPollAttempts >= 45) {
            stopPublishPolling();
            setPublishStatus({ ...state.publishStatus, statusError: 'Не удалось получить финальный статус GitHub Actions. Откройте run вручную.' });
          }
        }, 7000);
        window.setTimeout(() => pollPublishStatus().catch(() => {}), 2000);
      }

      function downloadTextFile(filename, content) {
        const blob = new Blob([content], { type: 'text/plain;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

      function buildLocalPublishReport(status) {
        const lines = [
          'SMU-1 publish/build error report',
          '',
          `Дата и время: ${new Date().toISOString()}`,
          `Кнопка/источник в админке: ${status.publishSource || ''}`,
          `Target, отправленный админкой: ${status.requestedTarget || status.mode || status.target || 'test'}`,
          `Режим публикации: ${status.mode || status.target || 'test'}`,
          `Branch: ${status.branch || ''}`,
          `Ref: ${status.ref || (status.branch ? `refs/heads/${status.branch}` : '')}`,
          `Commit hash: ${status.commitSha || ''}`,
          `Commit message: ${status.commitMessage || ''}`,
          `Workflow event: ${status.workflowEvent || ''}`,
          `Workflow branch: ${status.workflowBranch || status.branch || ''}`,
          `Deploy target from workflow: ${status.workflowDeployTarget || status.mode || status.target || 'test'}`,
          `Check production settings ran: ${status.productionCheckRan ? 'yes' : 'no'}`,
          `Workflow run URL: ${status.workflowRunUrl || ''}`,
          `Run status: ${status.status || 'failure'}`,
          `Failed job: ${status.failedJob || ''}`,
          `Failed step: ${status.failedStep || ''}`,
          '',
          'Короткое объяснение ошибки:',
          status.error || status.statusError || 'Публикация или сборка завершилась с ошибкой.',
          '',
          'Вероятная причина:',
          status.probableCause || (status.code === 'PRODUCTION_NOT_READY'
            ? 'SITE_URL для боевого сайта еще не настроен.'
            : 'Причина указана в сообщении ошибки или GitHub Actions run.'),
          '',
          'Что сделать дальше:',
          status.nextStep || (status.code === 'PRODUCTION_NOT_READY'
            ? 'Используйте тестовую публикацию. После подключения домена и хостинга задайте SITE_URL и повторите публикацию на сайт.'
            : 'Запустите локальные проверки, исправьте ошибку и повторите публикацию.'),
          '',
          'Команды для локальной проверки:',
          'npm run check',
          'npm run build',
          '',
          'Последние строки лога failed step/job:',
          status.logTail || '(лог недоступен)'
        ];
        return lines.join('\n');
      }

      async function downloadPublishReport() {
        const status = state.publishStatus;
        if (!status) return;
        if (status.branch && (status.commitSha || status.workflowRunId)) {
          const params = new URLSearchParams();
          params.set('target', status.mode || status.target || 'test');
          params.set('branch', status.branch);
          if (status.commitSha) params.set('commitSha', status.commitSha);
          if (status.commitMessage) params.set('commitMessage', status.commitMessage);
          if (status.workflowRunId) params.set('runId', status.workflowRunId);
          if (status.requestedTarget) params.set('requestedTarget', status.requestedTarget);
          if (status.publishSource) params.set('publishSource', status.publishSource);
          if (status.ref) params.set('ref', status.ref);
          try {
            const response = await fetch(`${API_BASE}/publish-report?${params.toString()}`, { credentials: 'include' });
            if (response.ok) {
              const blob = await response.blob();
              const url = URL.createObjectURL(blob);
              const link = document.createElement('a');
              link.href = url;
              link.download = filenameFromDisposition(response.headers.get('Content-Disposition'));
              document.body.append(link);
              link.click();
              link.remove();
              URL.revokeObjectURL(url);
              return;
            }
          } catch {
            // Fall back to a local report below.
          }
        }
        downloadTextFile(`smu1-publish-report-${new Date().toISOString().slice(0, 10)}.txt`, buildLocalPublishReport(status));
      }

      function markDirty() {
        const count = dirtyCount();
        const dirty = count > 0;
        $('dirtyStatus').textContent = dirty ? `Есть изменения: ${count}` : 'Нет изменений';
        $('dirtyStatus').classList.toggle('is-dirty', dirty);
        $('saveBtn').disabled = !dirty;
      }

      function publicUrl(collection, item) {
        if (!item) return '#';
        if (collection === 'product-sections' || collection === 'services') return withBasePath(`/${item.slug}/`);
        if (collection === 'product-categories') return withBasePath(item.parentSectionSlug === 'ulichnaya-mebel' ? `/ulichnaya-mebel/${item.slug}/` : `/${item.parentSectionSlug}/${item.slug}/`);
        if (collection === 'products') {
          const category = findRecordByField('product-categories', 'slug', item.productCategorySlug)?.draft;
          if (!category) return withBasePath('/');
          return withBasePath(`/${category.parentSectionSlug}/${category.slug}/${item.slug}/`);
        }
        if (collection === 'projects') return withBasePath(`/vypolnennye-obekty/${item.slug}/`);
        if (collection === 'jobs') return withBasePath('/vakansii/');
        if (collection === 'site-settings') return withBasePath('/kontakty/');
        if (collection === 'static-pages') return item.slug === 'home' ? withBasePath('/') : item.slug === 'custom-order' ? withBasePath('/izgotovlenie-na-zakaz/') : withBasePath(`/${item.slug}/`);
        return '#';
      }

      function withBasePath(path) {
        const normBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
        return `${normBase}${path.startsWith('/') ? path.slice(1) : path}`;
      }

      function findRecordByField(collection, field, value) {
        return Object.values(state.records).find((record) => record.collection === collection && record.draft?.[field] === value);
      }

      function normalizeLookupText(value) {
        return String(value || '').trim().toLowerCase();
      }

      function categorySlugFromHref(href, parentSlug = '') {
        const raw = typeof href === 'string' ? href.trim() : '';
        if (!raw) return '';
        const pathOnly = raw.replace(/^[a-z][a-z0-9+.-]*:\/\/[^/]+/i, '').split(/[?#]/)[0];
        const segments = pathOnly.split('/').filter(Boolean);
        const sectionIndex = parentSlug ? segments.lastIndexOf(parentSlug) : -1;
        if (sectionIndex >= 0 && segments[sectionIndex + 1]) return segments[sectionIndex + 1];
        return segments.length ? segments[segments.length - 1] : '';
      }

      function findCategoryForDirectionCard(parentRecord, item) {
        if (!parentRecord || !item || typeof item !== 'object') return null;
        const parentSlug = parentRecord.draft?.slug || parentRecord.slug || '';
        const categorySlug = String(item.categorySlug || '').trim() || categorySlugFromHref(item.buttonHref, parentSlug);
        const bySlug = categorySlug
          ? Object.values(state.records).find((record) =>
              record.collection === 'product-categories'
              && record.draft.parentSectionSlug === parentSlug
              && record.draft.slug === categorySlug
            )
          : null;
        if (bySlug) return bySlug;

        const title = normalizeLookupText(item.title);
        return title
          ? Object.values(state.records).find((record) =>
              record.collection === 'product-categories'
              && record.draft.parentSectionSlug === parentSlug
              && normalizeLookupText(record.draft.title) === title
            ) || null
          : null;
      }

      function renderDirectionCategoryEditButton(parentRecord, item) {
        const categoryRecord = findCategoryForDirectionCard(parentRecord, item);
        if (!categoryRecord) {
          return '<button class="admin-btn" type="button" disabled title="Связанная внутренняя страница направления не найдена">Нет страницы направления</button>';
        }

        return `<button class="admin-btn admin-btn--primary" type="button" data-action="open-related" data-collection="product-categories" data-slug="${esc(categoryRecord.draft.slug || categoryRecord.slug)}">Редактировать направление</button>`;
      }

      async function loadCollection(collection) {
        const data = await api(`/content/${collection}`);
        state.entries[collection] = data.entries || [];
        return state.entries[collection];
      }

      async function loadRecord(collection, slug) {
        const key = keyOf(collection, slug);
        if (state.records[key]) return state.records[key];
        const data = await api(`/content/${collection}/${slug}`);
        state.records[key] = { collection, slug, original: clone(data.content), draft: clone(data.content) };
        return state.records[key];
      }

      async function loadRecordsForCollection(collection) {
        const entries = await loadCollection(collection);
        await Promise.all(entries.map((entry) => loadRecord(collection, entry.slug)));
      }

      function normalizeNavigationItems(items = []) {
        return items
          .map((item, index) => ({
            title: String(item?.title ?? '').trim(),
            href: String(item?.href ?? '').trim(),
            isActive: item?.isActive !== false,
            order: Number.isFinite(Number(item?.order)) ? Number(item.order) : (index + 1) * 10
          }))
          .filter((item) => item.title || item.href)
          .sort((a, b) => a.order - b.order)
          .map((item, index) => ({ ...item, order: (index + 1) * 10 }));
      }

      async function loadNavigation() {
        const data = await api('/navigation');
        const items = normalizeNavigationItems(data.items || []);
        state.navigationItems = clone(items);
        state.navigationOriginal = clone(items);
        state.navigationLoaded = true;
        return items;
      }

      async function openEditor(collection, slug = '') {
        if (dirtyCount() && !confirm('Есть несохраненные изменения. Перейти без сохранения?')) return;
        state.collection = collection;
        state.selectedSlug = slug;
        state.records = {};
        state.crop = null;
        const params = new URLSearchParams();
        params.set('collection', collection);
        if (slug) params.set('slug', slug);
        history.replaceState(null, '', `${location.pathname}?${params.toString()}`);

        if (collection === 'data-import') {
          state.selectedSlug = '';
          state.entries[collection] = [];
          await loadRecordsForCollection('product-categories');
          await loadRecordsForCollection('products');
          renderApp();
          return;
        }

        if (collection === 'navigation') {
          state.selectedSlug = '';
          state.entries[collection] = [];
          await loadNavigation();
          renderApp();
          return;
        }

        await loadCollection(collection);
        if (slug) await loadRecord(collection, slug);
        if (collection === 'product-sections' || collection === 'services') {
          await loadRecordsForCollection('product-categories');
          await loadRecordsForCollection('products');
        }
        if (collection === 'product-categories') {
          await loadRecordsForCollection('product-sections');
          await loadRecordsForCollection('products');
        }
        if (collection === 'products') {
          await loadRecordsForCollection('product-sections');
          await loadRecordsForCollection('product-categories');
          await loadRecordsForCollection('products');
        }
        if (collection === 'static-pages') {
          await loadRecordsForCollection('product-sections');
          await loadRecordsForCollection('services');
        }
        if (collection === 'jobs' || collection === 'projects') {
          await loadRecordsForCollection(collection);
        }
        if (collection === 'site-settings' && !slug) {
          await loadRecord('site-settings', 'global');
          state.selectedSlug = 'global';
        }
        renderApp();
      }

      function renderApp(options = {}) {
        const scrollY = options.preserveScroll ? window.scrollY : null;
        renderNav();
        renderWorkspace();
        renderBreadcrumbs();
        renderAlert();
        renderPublishStatus();
        markDirty();
        if (scrollY !== null) requestAnimationFrame(() => window.scrollTo(0, scrollY));
      }

      function renderNav() {
        const renderSiteButton = (item) => {
          const active = state.collection === item.collection && (item.slug ? state.selectedSlug === item.slug : !state.selectedSlug);
          return `<button class="sidebar-link ${active ? 'is-active' : ''}" type="button" data-action="open-related" data-collection="${item.collection}" data-slug="${item.slug}"><span>${item.label}</span></button>`;
        };
        $('collectionNav').innerHTML = `
          <div class="sidebar-group"><h2>Страницы сайта</h2>${SITE_NAV_ITEMS.map(renderSiteButton).join('')}</div>
          <div class="sidebar-group"><h2>Рабочие списки</h2>${WORK_NAV_ITEMS.map(renderSiteButton).join('')}</div>
        `;
        const entries = state.entries[state.collection] || [];
        const groups = [];

        if (state.collection === 'product-sections' && state.selectedSlug) {
          const categories = Object.values(state.records)
            .filter((record) => record.collection === 'product-categories' && record.draft.parentSectionSlug === state.selectedSlug)
            .sort((a, b) => {
              const orderA = typeof a.draft.order === 'number' ? a.draft.order : Number.MAX_SAFE_INTEGER;
              const orderB = typeof b.draft.order === 'number' ? b.draft.order : Number.MAX_SAFE_INTEGER;
              if (orderA !== orderB) return orderA - orderB;
              return String(a.draft.title || a.slug).localeCompare(String(b.draft.title || b.slug), 'ru');
            });
          if (categories.length) {
            groups.push(`<div class="sidebar-group"><h2>Подстраницы раздела</h2>${categories.map((record) => `<button class="sidebar-entry" type="button" data-action="open-related" data-collection="product-categories" data-slug="${esc(record.slug)}"><strong>${esc(record.draft.title || record.slug)}</strong><small>${esc(record.slug)}</small></button>`).join('')}</div>`);
          }
        }

        if (state.collection === 'product-categories' && state.selectedSlug) {
          const products = Object.values(state.records)
            .filter((record) => record.collection === 'products' && record.draft.productCategorySlug === state.selectedSlug)
            .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
          if (products.length) {
            groups.push(`<div class="sidebar-group"><h2>Товары подстраницы</h2>${products.map((record) => `<button class="sidebar-entry" type="button" data-action="open-related" data-collection="products" data-slug="${esc(record.slug)}"><strong>${esc(record.draft.title || record.slug)}</strong><small>${esc(record.slug)}</small></button>`).join('')}</div>`);
          }
        }

        if (state.collection && state.collection !== 'data-import' && state.collection !== 'navigation' && (!state.selectedSlug || state.collection === 'products' || state.collection === 'static-pages')) {
          groups.push(`<div class="sidebar-group"><h2>Записи</h2>${entries.map((entry) => `<button class="sidebar-entry ${state.selectedSlug === entry.slug ? 'is-active' : ''}" type="button" data-open-entry="${entry.slug}"><strong>${esc(entry.title || entry.slug)}</strong><small>${esc(entry.slug)}</small></button>`).join('')}</div>`);
        }

        $('entryNav').innerHTML = groups.join('');
      }

      function renderWorkspace() {
        const collection = state.collection;
        const ref = getMainRef();
        const record = ref ? getRecord(ref) : null;
        const collectionLabel = COLLECTION_LABELS[collection] || collection;
        $('editorTitle').textContent = collection ? `${collectionLabel}${record ? ` · ${record.draft.title || record.draft.companyName || record.slug}` : ''}` : 'Визуальный редактор';
        $('publicLink').href = record ? publicUrl(collection, record.draft) : collection === 'jobs' ? withBasePath('/vakansii/') : collection === 'projects' ? withBasePath('/vypolnennye-obekty/') : collection === 'navigation' ? withBasePath('/') : '#';

        if (!collection) {
          $('workspace').innerHTML = renderWelcome();
          return;
        }
        if (collection === 'navigation') {
          $('workspace').innerHTML = renderNavigationPage();
          return;
        }
        if (collection === 'data-import') {
          $('workspace').innerHTML = renderImportPage();
          return;
        }
        if ((collection === 'jobs' || collection === 'projects') && !state.selectedSlug) {
          $('workspace').innerHTML = collection === 'jobs' ? renderJobsPage() : renderProjectsPage();
          return;
        }
        if (!record) {
          $('workspace').innerHTML = renderCollectionList(collection);
          return;
        }
        if (collection === 'product-sections' || collection === 'services') $('workspace').innerHTML = renderDirectionPage(ref);
        else if (collection === 'product-categories') $('workspace').innerHTML = renderCategoryPage(ref);
        else if (collection === 'products') $('workspace').innerHTML = renderProductPage(ref);
        else if (collection === 'projects') $('workspace').innerHTML = renderProjectPage(ref);
        else if (collection === 'jobs') $('workspace').innerHTML = renderJobCard(ref, true);
        else if (collection === 'static-pages') $('workspace').innerHTML = renderStaticPage(ref);
        else $('workspace').innerHTML = renderSettingsPage(ref);
      }

      function breadcrumbButton(label, collection, slug) {
        return `<button class="admin-breadcrumbs__link" type="button" data-action="open-related" data-collection="${esc(collection)}" data-slug="${esc(slug || '')}">${esc(label)}</button>`;
      }

      function breadcrumbCurrent(label) {
        return `<span class="admin-breadcrumbs__current" aria-current="page">${esc(label)}</span>`;
      }

      function renderBreadcrumbs() {
        const breadcrumbs = $('adminBreadcrumbs');
        if (!breadcrumbs) return;

        const mainRef = getMainRef();
        const record = mainRef ? getRecord(mainRef) : null;
        const parts = [`<a class="admin-breadcrumbs__link" href="${esc(adminHome)}">Админка</a>`];

        if (!state.collection) {
          breadcrumbs.innerHTML = parts.join('');
          return;
        }

        if (state.collection === 'navigation') {
          parts.push(breadcrumbCurrent('Навигация / Шапка сайта'));
        } else if (state.collection === 'products' && record) {
          const category = findRecordByField('product-categories', 'slug', record.draft.productCategorySlug);
          const section = category ? findRecordByField('product-sections', 'slug', category.draft.parentSectionSlug) : null;
          if (section) parts.push(breadcrumbButton(section.draft.title || section.slug, 'product-sections', section.slug));
          if (category) parts.push(breadcrumbButton(category.draft.title || category.slug, 'product-categories', category.slug));
          parts.push(breadcrumbCurrent(record.draft.title || record.slug));
        } else if (state.collection === 'product-categories' && record) {
          const section = findRecordByField('product-sections', 'slug', record.draft.parentSectionSlug);
          if (section) parts.push(breadcrumbButton(section.draft.title || section.slug, 'product-sections', section.slug));
          parts.push(breadcrumbCurrent(record.draft.title || record.slug));
        } else if (state.collection === 'product-sections' && record) {
          parts.push(breadcrumbCurrent(record.draft.title || record.slug));
        } else if (state.collection === 'projects' && record) {
          parts.push(breadcrumbButton('Выполненные объекты', 'projects', ''));
          parts.push(breadcrumbCurrent(record.draft.title || record.slug));
        } else if (record) {
          parts.push(breadcrumbCurrent(record.draft.title || record.draft.companyName || record.slug));
        } else {
          parts.push(breadcrumbCurrent(COLLECTION_LABELS[state.collection] || state.collection));
        }

        breadcrumbs.innerHTML = parts.join('<span class="admin-breadcrumbs__separator">/</span>');
      }

      function renderWelcome() {
        return `<section class="section section--soft"><div class="container"><article class="card"><h2>Выберите раздел слева</h2><p class="lead">Откроется визуальный редактор страницы или коллекции.</p></article></div></section>`;
      }

      function renderNavigationPage() {
        const items = state.navigationItems;
        return `
          <section class="section section--soft">
            <div class="container admin-navigation-page">
              <div class="section-heading">
                <p class="kicker">Настройки сайта</p>
                <h1 class="section-title">Навигация / Шапка сайта</h1>
                <p class="lead">Эти пункты выводятся в верхней шапке и в мобильном меню. Скрытие пункта не удаляет страницу и не меняет ее URL.</p>
              </div>
              <div class="admin-navigation-list">
                ${items.map((item, index) => `
                  <article class="admin-navigation-row ${item.isActive === false ? 'is-hidden' : ''}">
                    <div class="admin-navigation-row__index">${String(index + 1).padStart(2, '0')}</div>
                    <div class="admin-grid-3">
                      <label class="admin-field">
                        <span>Название</span>
                        <input data-nav-field="title" data-nav-index="${index}" value="${esc(item.title)}" />
                      </label>
                      <label class="admin-field">
                        <span>URL</span>
                        <input data-nav-field="href" data-nav-index="${index}" value="${esc(item.href)}" inputmode="url" />
                      </label>
                      <label class="admin-field">
                        <span>Показывать в шапке</span>
                        <select data-nav-field="isActive" data-nav-index="${index}">
                          <option value="true" ${item.isActive !== false ? 'selected' : ''}>Да</option>
                          <option value="false" ${item.isActive === false ? 'selected' : ''}>Нет</option>
                        </select>
                      </label>
                    </div>
                    <div class="admin-item-tools">
                      <button class="admin-btn" type="button" data-action="move-nav-item" data-index="${index}" data-dir="-1" ${index === 0 ? 'disabled' : ''}>Выше</button>
                      <button class="admin-btn" type="button" data-action="move-nav-item" data-index="${index}" data-dir="1" ${index === items.length - 1 ? 'disabled' : ''}>Ниже</button>
                    </div>
                  </article>
                `).join('')}
              </div>
            </div>
          </section>`;
      }

      function renderCollectionList(collection) {
        const entries = state.entries[collection] || [];
        if (collection === 'products') {
          const products = Object.values(state.records)
            .filter((record) => record.collection === 'products')
            .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
          return `
            ${renderCreatePanel('products')}
            <section class="section">
              <div class="container">
                <div class="section-heading"><h2 class="section-title">${esc(COLLECTION_LABELS[collection])}</h2></div>
                ${renderProductBulkToolbar(products)}
                <div class="product-catalog-grid">
                  ${products.map((productRecord) => renderProductCard(productRecord)).join('')}
                </div>
              </div>
            </section>`;
        }
        return `
          ${renderCreatePanel(collection)}
          <section class="section">
            <div class="container">
              <div class="section-heading"><h2 class="section-title">${esc(COLLECTION_LABELS[collection])}</h2></div>
              <div class="page-blocks-grid page-blocks-grid--auto">
                ${entries.map((entry) => `<article class="card"><h3>${esc(entry.title || entry.slug)}</h3><p>${esc(entry.summary?.shortDescription || entry.slug)}</p><button class="admin-btn admin-btn--primary" type="button" data-open-entry="${entry.slug}">Открыть</button></article>`).join('')}
              </div>
            </div>
          </section>`;
      }

      function renderImportPage() {
        const preview = state.importPreview;
        const result = state.importResult;
        const modeOptions = IMPORT_MODES.map(([value, label]) => `<option value="${esc(value)}" ${state.importMode === value ? 'selected' : ''}>${esc(label)}</option>`).join('');
        const canImport = Boolean(preview && !preview.hasBlockingErrors && preview.rows.length);
        const previewMarkup = preview ? renderImportPreview(preview) : '';
        const resultMarkup = result ? `
          <article class="admin-panel-card">
            <strong>Результат импорта</strong>
            <div class="admin-import-result">
              <span>Создано: ${result.created}</span>
              <span>Обновлено: ${result.updated}</span>
              <span>Пропущено: ${result.skipped}</span>
              <span>Ошибок: ${result.errors}</span>
            </div>
            ${result.messages?.length ? `<ul class="admin-import-list admin-import-list--errors">${result.messages.map((message) => `<li>${esc(message)}</li>`).join('')}</ul>` : ''}
          </article>` : '';
        return `
          <section class="section section--soft">
            <div class="container admin-import-page">
              <div class="admin-import-head">
                <h1 class="section-title">Импорт / экспорт данных</h1>
                <p class="lead">Вставьте JSON с товарами каталога. Сначала проверьте файл, затем импортируйте позиции.</p>
              </div>
              <article class="admin-panel-card">
                <strong>Экспорт данных</strong>
                <p class="admin-field-hint">Скачайте полный актуальный каталог: страницы каталога, типы изделий и товары. В JSON сохраняются пути к изображениям, сами файлы не включаются.</p>
                <div class="admin-import-toolbar">
                  <button class="admin-btn admin-btn--primary" type="button" data-action="download-catalog-export">Скачать JSON каталога</button>
                </div>
              </article>
              <article class="admin-panel-card">
                <label class="admin-field">
                  <span>Режим импорта</span>
                  <select data-import-mode>${modeOptions}</select>
                </label>
                <div class="admin-import-file-row">
                  <button class="admin-btn" type="button" data-action="choose-import-file">Загрузить JSON-файл</button>
                  <span class="admin-muted">${state.importFileName ? `Файл: ${esc(state.importFileName)}` : 'Файл не выбран'}</span>
                </div>
                <label class="admin-field">
                  <span>Вставьте JSON сюда</span>
                  <textarea class="admin-import-textarea" data-import-json spellcheck="false" placeholder='{"type":"products_import","version":1,"items":[]}' >${esc(state.importText)}</textarea>
                </label>
                <div class="admin-import-toolbar">
                  <button class="admin-btn admin-btn--primary" type="button" data-action="validate-products-import">Проверить</button>
                  <button class="admin-btn" type="button" data-action="run-products-import" ${canImport ? '' : 'disabled'}>Импортировать</button>
                </div>
              </article>
              ${previewMarkup}
              ${resultMarkup}
            </div>
          </section>`;
      }

      function renderImportPreview(preview) {
        const totals = preview.rows.reduce((acc, row) => {
          acc[row.action] = (acc[row.action] || 0) + 1;
          return acc;
        }, {});
        const summary = `
          <div class="admin-import-result">
            <span>Всего: ${preview.rows.length}</span>
            <span>Будет создано: ${totals.create || 0}</span>
            <span>Будет обновлено: ${totals.update || 0}</span>
            <span>Будет пропущено: ${totals.skip || 0}</span>
            <span>Ошибок: ${preview.errorCount}</span>
            <span>Предупреждений: ${preview.warningCount}</span>
          </div>`;
        const globalErrors = preview.errors.length
          ? `<ul class="admin-import-list admin-import-list--errors">${preview.errors.map((error) => `<li>${esc(error)}</li>`).join('')}</ul>`
          : '';
        const rows = preview.rows.map((row) => `
          <tr>
            <td>${row.index + 1}</td>
            <td>${esc(row.title || '-')}</td>
            <td><code>${esc(row.slug || '-')}</code></td>
            <td>${esc(row.categoryTitle || row.productCategorySlug || '-')}</td>
            <td>${esc(importActionLabel(row.action))}</td>
            <td>${renderImportMessageList(row.warnings, 'admin-import-list--warnings')}</td>
            <td>${renderImportMessageList(row.errors, 'admin-import-list--errors')}</td>
          </tr>`).join('');
        return `
          <article class="admin-panel-card">
            <strong>Предпросмотр</strong>
            ${summary}
            ${globalErrors}
            <div class="admin-import-table-wrap">
              <table class="admin-import-table">
                <thead>
                  <tr>
                    <th>№</th>
                    <th>Название</th>
                    <th>Slug</th>
                    <th>Категория</th>
                    <th>Действие</th>
                    <th>Предупреждения</th>
                    <th>Ошибки</th>
                  </tr>
                </thead>
                <tbody>${rows || '<tr><td colspan="7">Нет товаров для импорта.</td></tr>'}</tbody>
              </table>
            </div>
          </article>`;
      }

      function renderImportMessageList(items, className) {
        return items.length ? `<ul class="admin-import-list ${className}">${items.map((item) => `<li>${esc(item)}</li>`).join('')}</ul>` : '<span class="admin-muted">-</span>';
      }

      function importActionLabel(action) {
        if (action === 'create') return 'будет создан';
        if (action === 'update') return 'будет обновлен';
        return 'будет пропущен';
      }

      function validateProductsImport(rawText, mode = state.importMode) {
        const preview = { rows: [], errors: [], errorCount: 0, warningCount: 0, hasBlockingErrors: false };
        const text = String(rawText || '').trim();
        if (!text) {
          preview.errors.push('JSON пустой.');
          return finishImportPreview(preview);
        }

        let payload;
        try {
          payload = JSON.parse(text);
        } catch (error) {
          preview.errors.push(`JSON не читается: ${error.message || 'ошибка синтаксиса'}`);
          return finishImportPreview(preview);
        }

        if (!payload || typeof payload !== 'object' || Array.isArray(payload)) preview.errors.push('Корневой объект JSON должен быть объектом.');
        if (payload?.type !== 'products_import') preview.errors.push('type должен быть равен "products_import".');
        if (!Array.isArray(payload?.items)) preview.errors.push('items отсутствует или не является массивом.');
        if (preview.errors.length) return finishImportPreview(preview);

        const categories = new Map(Object.values(state.records)
          .filter((record) => record.collection === 'product-categories')
          .map((record) => [record.draft.slug || record.slug, record]));
        const products = new Map(Object.values(state.records)
          .filter((record) => record.collection === 'products')
          .map((record) => [record.draft.slug || record.slug, record]));
        const importSlugCounts = countValues(payload.items.map((item) => safeText(item?.slug)));
        const importOrderCounts = countValues(payload.items.map((item) => numberOrNull(item?.order)).filter((value) => value !== null));
        const existingOrderMap = new Map();
        products.forEach((record, slug) => {
          const order = numberOrNull(record.draft.order);
          if (order === null) return;
          if (!existingOrderMap.has(order)) existingOrderMap.set(order, []);
          existingOrderMap.get(order).push(slug);
        });

        payload.items.forEach((item, index) => {
          const row = validateImportItem(item, index, mode, categories, products, importSlugCounts, importOrderCounts, existingOrderMap);
          preview.rows.push(row);
        });
        return finishImportPreview(preview);
      }

      function finishImportPreview(preview) {
        preview.errorCount = preview.errors.length + preview.rows.reduce((sum, row) => sum + row.errors.length, 0);
        preview.warningCount = preview.rows.reduce((sum, row) => sum + row.warnings.length, 0);
        preview.hasBlockingErrors = preview.errorCount > 0;
        return preview;
      }

      function validateImportItem(rawItem, index, mode, categories, products, importSlugCounts, importOrderCounts, existingOrderMap) {
        const errors = [];
        const warnings = [];
        const item = rawItem && typeof rawItem === 'object' && !Array.isArray(rawItem) ? rawItem : {};
        if (item !== rawItem) errors.push('Товар должен быть объектом.');

        const title = safeText(item.title);
        const slug = safeText(item.slug);
        const productCategorySlug = safeText(item.productCategorySlug);
        const categoryRecord = categories.get(productCategorySlug);
        const existingRecord = products.get(slug);
        const exists = Boolean(existingRecord);

        if (!title) errors.push('Нет title.');
        if (!slug) errors.push('Нет slug.');
        else if (!IMPORT_SLUG_RE.test(slug)) errors.push('slug содержит недопустимые символы. Разрешены латиница, цифры и дефисы.');
        if (!productCategorySlug) errors.push('Нет productCategorySlug.');
        else if (!categoryRecord) errors.push(`Категория "${productCategorySlug}" не найдена.`);
        if (slug && importSlugCounts.get(slug) > 1) errors.push('slug повторяется в импортируемом JSON.');

        validateArrayField(item, 'images', errors);
        validateArrayField(item, 'advantages', errors);
        validateArrayField(item, 'customProduction', errors);
        validateArrayField(item, 'materials', errors);
        validateArrayField(item, 'colors', errors);
        validateArrayField(item, 'relatedProducts', errors);
        validateSpecsField(item.specs, errors);

        const images = Array.isArray(item.images) ? cleanStringArray(item.images) : [];
        if (!images.length) warnings.push(exists ? 'images пустой: при обновлении существующие фото сохранятся.' : 'images пустой: товар будет создан без фото.');
        if (!safeText(item.seoTitle)) warnings.push('seoTitle пустой: будет использовано название товара.');
        if (!safeText(item.seoDescription)) warnings.push('seoDescription пустой: будет использовано краткое описание или лид-текст.');
        if (!safeText(item.price) && numberOrNull(item.priceFrom) === null) warnings.push('price пустой.');
        if (!safeText(item.sku)) warnings.push('sku пустой.');
        if (exists) warnings.push('slug уже существует.');

        const order = numberOrNull(item.order);
        if (order !== null) {
          const existingSameOrder = (existingOrderMap.get(order) || []).filter((existingSlug) => existingSlug !== slug);
          if (existingSameOrder.length) warnings.push(`order совпадает с другим товаром: ${existingSameOrder.join(', ')}.`);
          if (importOrderCounts.get(order) > 1) warnings.push('order совпадает с другим товаром в импортируемом JSON.');
        }

        const action = importActionForItem(exists, mode);
        if (action === 'skip' && !exists && mode === 'update-only') warnings.push('Товар не найден и будет пропущен.');
        if (action === 'skip' && exists && (mode === 'create-only' || mode === 'skip-existing')) warnings.push('Товар уже существует и будет пропущен.');

        const normalized = errors.length ? null : normalizeImportedProduct(item, existingRecord?.draft);
        return {
          index,
          title,
          slug,
          productCategorySlug,
          categoryTitle: categoryRecord?.draft?.title || '',
          action,
          warnings,
          errors,
          normalized
        };
      }

      function validateArrayField(item, field, errors) {
        if (item[field] !== undefined && !Array.isArray(item[field])) errors.push(`${field} не является массивом.`);
      }

      function validateSpecsField(specs, errors) {
        if (specs === undefined) return;
        if (!Array.isArray(specs)) {
          errors.push('specs имеет неправильный формат.');
          return;
        }
        specs.forEach((spec, index) => {
          if (!spec || typeof spec !== 'object' || Array.isArray(spec) || !safeText(spec.name ?? spec.label) || !safeText(spec.value)) {
            errors.push(`specs[${index}] должен быть объектом с name и value.`);
          }
        });
      }

      function importActionForItem(exists, mode) {
        if (mode === 'create-only') return exists ? 'skip' : 'create';
        if (mode === 'update-only') return exists ? 'update' : 'skip';
        if (mode === 'skip-existing') return exists ? 'skip' : 'create';
        return exists ? 'update' : 'create';
      }

      function normalizeImportedProduct(item, existing = null) {
        const title = safeText(item.title);
        const leadText = safeText(item.leadText) || safeText(item.shortDescription);
        const shortDescription = safeText(item.shortDescription) || leadText;
        const next = existing ? clone(existing) : {};
        const priceFrom = normalizePriceFrom(item.priceFrom ?? item.price);
        const priceMode = normalizePriceMode(item.priceMode, priceFrom);

        Object.assign(next, {
          title,
          slug: safeText(item.slug),
          productCategorySlug: safeText(item.productCategorySlug),
          sku: safeText(item.sku),
          shortDescription,
          leadText,
          description: safeText(item.description),
          materials: cleanStringArray(item.materials),
          colors: cleanStringArray(item.colors),
          dimensions: normalizeImportSpecs(item.specs),
          features: cleanStringArray(item.advantages),
          customizationItems: cleanStringArray(item.customProduction),
          showDeliveryBlock: booleanOrDefault(item.showDelivery, true),
          deliveryText: safeText(item.deliveryText),
          relatedProductSlugs: cleanStringArray(item.relatedProducts),
          showCustomProjectBlock: booleanOrDefault(item.showCustomProject, true),
          customProjectTitle: safeText(item.customProjectTitle) || 'Не нашли подходящее изделие?',
          customProjectText: safeText(item.customProjectText) || 'Изготовим решение под ваш объект: по фото, эскизу, размерам или техническому заданию.',
          priceMode,
          priceFrom: priceMode === 'from' ? priceFrom : null,
          currency: safeText(item.currency) || next.currency || 'RUB',
          placeholderLabel: safeText(item.placeholderLabel) || next.placeholderLabel || 'Фото изделия будут добавлены позже.',
          order: numberOrNull(item.order) ?? 999,
          isActive: booleanOrDefault(item.isActive, true),
          showInCatalog: booleanOrDefault(item.showInCatalog, true),
          seoTitle: safeText(item.seoTitle) || title,
          seoDescription: safeText(item.seoDescription) || shortDescription || leadText
        });

        const images = Array.isArray(item.images) ? cleanStringArray(item.images) : [];
        if (images.length) {
          next.image = images[0];
          next.gallery = images.slice(1);
        } else if (!existing) {
          next.image = '';
          next.gallery = [];
        } else {
          next.image = typeof next.image === 'string' ? next.image : '';
          next.gallery = Array.isArray(next.gallery) ? next.gallery : [];
        }

        return next;
      }

      function normalizePriceMode(mode, priceFrom) {
        const value = safeText(mode).toLowerCase();
        if (value === 'from') return 'from';
        if (value === 'none') return 'none';
        if (value === 'request' || value === 'on_request') return 'on_request';
        if (value === '') return priceFrom !== null ? 'from' : 'on_request';
        return priceFrom !== null ? 'from' : 'on_request';
      }

      function normalizePriceFrom(value) {
        if (value === undefined || value === null || value === '') return null;
        const prepared = String(value).replace(/\s+/g, '').replace(',', '.').replace(/[^\d.-]/g, '');
        const number = Number(prepared);
        return Number.isFinite(number) && number >= 0 ? number : null;
      }

      function normalizeImportSpecs(specs) {
        if (!Array.isArray(specs)) return [];
        return specs
          .map((spec, index) => ({
            label: safeText(spec.name ?? spec.label),
            value: safeText(spec.value),
            order: numberOrNull(spec.order) ?? (index + 1) * 10,
            isActive: booleanOrDefault(spec.isActive, true)
          }))
          .filter((spec) => spec.label && spec.value);
      }

      function cleanStringArray(value) {
        return Array.isArray(value) ? value.map((item) => safeText(item)).filter(Boolean) : [];
      }

      function safeText(value) {
        if (value === undefined || value === null) return '';
        return String(value).replace(/\u0000/g, '').trim();
      }

      function booleanOrDefault(value, fallback) {
        return typeof value === 'boolean' ? value : fallback;
      }

      function numberOrNull(value) {
        if (value === undefined || value === null || value === '') return null;
        const number = Number(value);
        return Number.isFinite(number) ? number : null;
      }

      function countValues(values) {
        const map = new Map();
        values.forEach((value) => {
          if (value === '' || value === null || value === undefined) return;
          map.set(value, (map.get(value) || 0) + 1);
        });
        return map;
      }

      async function runProductsImport(preview, mode = state.importMode) {
        const currentPreview = preview || validateProductsImport(state.importText, mode);
        if (currentPreview.hasBlockingErrors) {
          state.importPreview = currentPreview;
          state.importResult = null;
          renderApp();
          setAlert('Исправьте ошибки перед импортом.', true);
          return;
        }

        const result = { created: 0, updated: 0, skipped: 0, errors: 0, messages: [] };
        setAlert('Импортируем товары...');
        for (const row of currentPreview.rows) {
          if (row.action === 'skip') {
            result.skipped += 1;
            continue;
          }
          try {
            if (row.action === 'create') {
              const data = await api('/content/products', { method: 'POST', body: JSON.stringify({ slug: row.normalized.slug, content: row.normalized }) });
              state.records[keyOf('products', data.slug)] = { collection: 'products', slug: data.slug, original: clone(data.content), draft: clone(data.content) };
              result.created += 1;
            } else if (row.action === 'update') {
              const data = await api(`/content/products/${encodeURIComponent(row.slug)}`, { method: 'PUT', body: JSON.stringify(row.normalized) });
              state.records[keyOf('products', row.slug)] = { collection: 'products', slug: row.slug, original: clone(data.content), draft: clone(data.content) };
              result.updated += 1;
            }
          } catch (error) {
            result.errors += 1;
            result.messages.push(`${row.title || row.slug || `строка ${row.index + 1}`}: ${error.message || 'ошибка импорта'}`);
          }
        }

        await loadRecordsForCollection('product-categories');
        await loadRecordsForCollection('products');
        state.importPreview = validateProductsImport(state.importText, mode);
        state.importResult = result;
        renderApp();

        if (result.created || result.updated) {
          await publishSavedChanges('Импорт товаров завершен.');
        } else {
          setAlert('Импорт завершен без изменений.');
        }
      }

      function renderCreatePanel(collection, context = {}) {
        if (collection === 'site-settings') return '';
        const title = collection === 'product-categories' ? 'Добавить тип изделия' : collection === 'products' ? 'Добавить модель изделия' : collection === 'jobs' ? 'Добавить вакансию' : collection === 'projects' ? 'Добавить объект' : collection === 'static-pages' ? 'Добавить страницу' : `Добавить запись`;
        const parentField = collection === 'product-categories'
          ? `<label class="admin-field"><span>Раздел</span><select data-create-field="parentSectionSlug">${productSectionsOptions(context.parentSectionSlug)}</select></label>`
          : collection === 'products'
            ? `<label class="admin-field"><span>Тип изделия</span><select data-create-field="productCategorySlug">${productCategoryOptions(context.productCategorySlug)}</select></label>`
            : '';
        return `
          <section class="admin-create">
            <div class="container">
              <div class="admin-create-panel" data-create-panel="${collection}">
                <strong>${title}</strong>
                <div class="admin-create-grid">
                  <label class="admin-field"><span>Название</span><input data-create-field="title" placeholder="Название" /></label>
                  <label class="admin-field"><span>Slug латиницей</span><input data-create-field="slug" placeholder="novaya-zapis" /></label>
                  ${parentField}
                </div>
                <button class="admin-btn admin-btn--primary" type="button" data-action="create-record" data-collection="${collection}">Создать</button>
              </div>
            </div>
          </section>`;
      }

      function productSectionsOptions(selected = '') {
        return Object.values(state.records)
          .filter((record) => record.collection === 'product-sections')
          .map((record) => `<option value="${esc(record.draft.slug)}" ${record.draft.slug === selected ? 'selected' : ''}>${esc(record.draft.title)}</option>`)
          .join('');
      }

      function productCategoryOptions(selected = '') {
        return Object.values(state.records)
          .filter((record) => record.collection === 'product-categories')
          .map((record) => `<option value="${esc(record.draft.slug)}" ${record.draft.slug === selected ? 'selected' : ''}>${esc(record.draft.title)}</option>`)
          .join('');
      }

      function productSlugOptions(selected = '', currentSlug = '') {
        return Object.values(state.records)
          .filter((record) => record.collection === 'products' && record.draft.slug !== currentSlug)
          .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0))
          .map((record) => `<option value="${esc(record.draft.slug)}" ${record.draft.slug === selected ? 'selected' : ''}>${esc(record.draft.title || record.draft.slug)}</option>`)
          .join('');
      }

      function renderDirectionPage(ref) {
        const record = getRecord(ref);
        const item = record.draft;
        const isCatalog = item.mode === 'catalog-hub';
        const settingsFields = record.collection === 'product-sections'
          ? ['title', 'slug', 'shortDescription', 'order', 'showOnHome', 'isActive', 'showInMenu', 'menuTitle', 'showBadge', 'mode', 'seoTitle', 'seoDescription']
          : ['title', 'slug', 'shortDescription', 'order', 'showOnHome', 'isActive', 'showInMenu', 'menuTitle', 'showBadge', 'seoTitle', 'seoDescription'];
        return `
          ${renderHero(ref, isCatalog ? 'catalog' : 'media')}
          ${renderHeroMediaPanel(ref)}
          ${renderHeroTextSettings(ref)}
          ${renderRecordSettings(ref, settingsFields)}
          ${isCatalog ? renderCatalogHub(ref) : renderPageBlocks(ref)}
          ${renderContactBlock(ref)}
        `;
      }

      function renderHero(ref, mode = 'catalog') {
        const record = getRecord(ref);
        const item = record.draft;
        const hasMedia = mode === 'media';
        const target = `${ref}:image`;
        const isCrop = state.crop?.target === target;
        const video = cleanMediaPath(item.heroMediaVideo);
        const image = cleanMediaPath(item.image);
        const poster = cleanMediaPath(item.heroMediaPoster) || image;
        const overlayStyle = heroOverlayStyle(item.heroOverlayOpacity);
        const mediaMarkup = video
          ? `<video class="hero-media__video" autoplay muted loop playsinline preload="metadata" poster="${esc(toSrc(poster))}"><source src="${esc(toSrc(video))}" type="${esc(mediaMimeType(video))}" /></video>${poster ? `<img class="hero-media__fallback" src="${esc(toSrc(poster))}" alt="${esc(item.title)}" />` : ''}`
          : image
            ? `<img class="hero-media__image" data-image-img="${esc(target)}" src="${esc(toSrc(image))}" alt="${esc(item.title)}" style="${esc(mediaStyle(item.imageView))}" />`
            : '<div class="admin-media-empty">Фото не выбрано</div>';
        return `
          <section class="hero ${hasMedia ? 'hero--media navesy-hero' : 'hero--catalog hero--catalog-clean'}">
            ${hasMedia ? `<div class="admin-media-frame admin-media-frame--hero ${isCrop && !video ? 'is-active-crop' : ''}" data-image-frame="${esc(target)}">${mediaMarkup}<div class="hero-media__overlay" style="${esc(overlayStyle)}"></div></div>` : ''}
            <div class="container hero-content">
              <p class="kicker" ${editable(ref, 'heroKicker', 'Надзаголовок', true)}>${esc(item.showBadge === false ? '' : item.heroKicker || (hasMedia ? 'Проектное направление' : 'Каталог изделий'))}</p>
              <h1 ${editable(ref, 'heroTitle', 'Заголовок первого экрана', true)}>${esc(item.heroTitle || item.title)}</h1>
              <p class="hero-description" ${editable(ref, 'heroDescription', 'Описание первого экрана')}>${esc(item.heroDescription || item.shortDescription || '')}</p>
            </div>
          </section>
          ${hasMedia && isCrop && !video ? renderCropControls() : ''}
        `;
      }

      function renderRecordSettings(ref, fields) {
        const record = getRecord(ref);
        return `
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card">
                <strong>Настройки записи</strong>
                <div class="admin-grid-3">
                  ${fields.map((field) => renderField(ref, field, record.draft[field])).join('')}
                </div>
              </div>
            </div>
          </section>`;
      }

      function renderField(ref, field, value) {
        const booleanFields = new Set(['showOnHome', 'showInSectionGrid', 'isActive', 'showInCatalog', 'showInMenu', 'showBadge', 'showDeliveryBlock', 'showCustomProjectBlock']);
        const numberFields = new Set(['order', 'year', 'heroOverlayOpacity']);
        const textareaFields = new Set(['seoDescription', 'deliveryText', 'customProjectText']);
        const label = FIELD_LABELS[field] || field;
        const hint = FIELD_HINTS[field] ? `<p class="admin-field-hint">${esc(FIELD_HINTS[field])}</p>` : '';
        if (typeof value === 'boolean' || booleanFields.has(field)) {
          const normalized = value !== false;
          return `<label class="admin-field"><span>${esc(label)}</span><select data-field-ref="${ref}" data-field-path="${field}" data-field-type="boolean"><option value="true" ${normalized ? 'selected' : ''}>Да</option><option value="false" ${!normalized ? 'selected' : ''}>Нет</option></select>${hint}</label>`;
        }
        if (field === 'productCategorySlug') {
          return `<label class="admin-field"><span>${esc(label)}</span><select data-field-ref="${ref}" data-field-path="${field}">${productCategoryOptions(value)}</select>${hint}</label>`;
        }
        if (typeof value === 'number' || numberFields.has(field)) {
          return `<label class="admin-field"><span>${esc(label)}</span><input type="number" data-field-ref="${ref}" data-field-path="${field}" value="${esc(value ?? '')}" />${hint}</label>`;
        }
        if (field === 'mode') return `<label class="admin-field"><span>${esc(label)}</span><select data-field-ref="${ref}" data-field-path="${field}"><option value="catalog-hub" ${value === 'catalog-hub' ? 'selected' : ''}>catalog-hub</option><option value="custom-direction" ${value === 'custom-direction' ? 'selected' : ''}>custom-direction</option><option value="catalog-list" ${value === 'catalog-list' ? 'selected' : ''}>catalog-list</option><option value="custom-list" ${value === 'custom-list' ? 'selected' : ''}>custom-list</option></select>${hint}</label>`;
        if (textareaFields.has(field)) {
          return `<label class="admin-field"><span>${esc(label)}</span><textarea data-field-ref="${ref}" data-field-path="${field}">${esc(value ?? '')}</textarea>${hint}</label>`;
        }
        return `<label class="admin-field"><span>${esc(label)}</span><input data-field-ref="${ref}" data-field-path="${field}" value="${esc(value ?? '')}" ${field === 'slug' ? 'inputmode="url"' : ''} />${hint}</label>`;
      }

      function optionList(options, selected, emptyLabel = 'По умолчанию') {
        return `<option value="" ${selected === undefined || selected === null || selected === '' ? 'selected' : ''}>${emptyLabel}</option>${options.map(([value, label]) => `<option value="${value}" ${selected === value ? 'selected' : ''}>${label}</option>`).join('')}`;
      }

      function renderSelectControl(ref, path, label, options, selected) {
        return `<label class="admin-field"><span>${esc(label)}</span><select data-field-ref="${ref}" data-field-path="${path}" data-field-empty="undefined">${optionList(options, selected)}</select></label>`;
      }

      function renderNumberControl(ref, path, label, value, min, max, step = 1, placeholder = '') {
        return `<label class="admin-field"><span>${esc(label)}</span><input type="number" min="${min}" max="${max}" step="${step}" data-field-ref="${ref}" data-field-path="${path}" data-field-min="${min}" data-field-max="${max}" data-field-empty="undefined" value="${esc(value ?? '')}" placeholder="${esc(placeholder)}" /></label>`;
      }

      function renderTextStyleControls(ref, basePath, value, title) {
        const style = value || {};
        return `<div class="admin-control-group"><strong>${esc(title)}</strong><div class="admin-grid-3">
          ${renderSelectControl(ref, `${basePath}.fontSize`, 'Размер шрифта', TEXT_SIZE_OPTIONS, style.fontSize)}
          ${renderSelectControl(ref, `${basePath}.fontWeight`, 'Жирность', FONT_WEIGHT_OPTIONS, style.fontWeight)}
          <label class="admin-field"><span>Курсив</span><select data-field-ref="${ref}" data-field-path="${basePath}.italic" data-field-type="boolean" data-field-empty="undefined"><option value="" ${typeof style.italic !== 'boolean' ? 'selected' : ''}>По умолчанию</option><option value="false" ${style.italic === false ? 'selected' : ''}>Выключен</option><option value="true" ${style.italic === true ? 'selected' : ''}>Включен</option></select></label>
          ${renderSelectControl(ref, `${basePath}.align`, 'Выравнивание', TEXT_ALIGN_OPTIONS, style.align)}
          ${renderSelectControl(ref, `${basePath}.lineHeight`, 'Межстрочный интервал', LINE_HEIGHT_OPTIONS, style.lineHeight)}
          ${renderSelectControl(ref, `${basePath}.color`, 'Цвет текста', TEXT_COLOR_OPTIONS, style.color)}
        </div></div>`;
      }

      function renderTextLayoutControls(ref, basePath, value, title) {
        const layout = value || {};
        return `<div class="admin-control-group"><strong>${esc(title)}</strong><div class="admin-grid-3">
          ${renderSelectControl(ref, `${basePath}.width`, 'Ширина блока', BLOCK_WIDTH_OPTIONS, layout.width)}
          ${renderNumberControl(ref, `${basePath}.widthPercent`, 'Ширина блока, %', layout.widthPercent, 30, 100, 5, '70')}
          ${renderNumberControl(ref, `${basePath}.maxWidth`, 'Максимальная ширина, px', layout.maxWidth, 280, 1200, 20, '720')}
          ${renderSelectControl(ref, `${basePath}.position`, 'Положение', BLOCK_POSITION_OPTIONS, layout.position)}
          ${renderSelectControl(ref, `${basePath}.padding`, 'Внутренние отступы', BLOCK_SPACING_OPTIONS, layout.padding)}
          ${renderSelectControl(ref, `${basePath}.verticalPadding`, 'Отступы секции', BLOCK_SPACING_OPTIONS, layout.verticalPadding)}
        </div><p class="admin-field-hint">На мобильной версии текстовый блок автоматически становится во всю ширину экрана.</p></div>`;
      }

      function renderHeroTextSettings(ref) {
        return '';
      }

      const PREVIEW_TEXT_SIZE = { small: '14px', base: '16px', large: '18px', xl: '22px', '2xl': '28px' };
      const PREVIEW_TITLE_SIZE = { small: '28px', base: '36px', large: '44px', xl: '54px', '2xl': '64px' };
      const PREVIEW_WEIGHT = { normal: 400, medium: 500, semibold: 600, bold: 700 };
      const PREVIEW_LINE_HEIGHT = { compact: 1.28, normal: 1.55, relaxed: 1.75 };
      const PREVIEW_COLOR = { primary: 'var(--color-text)', secondary: 'var(--color-muted)', white: '#fff', accent: 'var(--color-accent)' };
      const PREVIEW_WIDTH = {
        narrow: { width: '50%', maxWidth: '560px' },
        medium: { width: '70%', maxWidth: '720px' },
        wide: { width: '90%', maxWidth: '960px' },
        full: { width: '100%' }
      };
      const PREVIEW_POSITION = {
        left: { justify: 'start', margin: '0 auto 0 0' },
        center: { justify: 'center', margin: '0 auto' },
        right: { justify: 'end', margin: '0 0 0 auto' }
      };
      const PREVIEW_PADDING = { compact: '14px', normal: '22px', large: '32px' };

      function adminStyleString(styles) {
        return styles.filter(Boolean).join(';');
      }

      function adminTextStyle(style = {}, legacy = {}, title = false) {
        const sizeMap = title ? PREVIEW_TITLE_SIZE : PREVIEW_TEXT_SIZE;
        const styles = [];
        if (sizeMap[style.fontSize]) styles.push(`font-size:${sizeMap[style.fontSize]}`);
        else if (title && /^\d{1,2}px$/.test(String(legacy.titleSize || ''))) styles.push(`font-size:${legacy.titleSize}`);
        else if (!title && /^\d{1,2}px$/.test(String(legacy.textSize || ''))) styles.push(`font-size:${legacy.textSize}`);
        if (PREVIEW_WEIGHT[style.fontWeight]) styles.push(`font-weight:${PREVIEW_WEIGHT[style.fontWeight]}`);
        else if (['400', '500', '600', '700'].includes(String(legacy.textWeight || ''))) styles.push(`font-weight:${legacy.textWeight}`);
        if (typeof style.italic === 'boolean') styles.push(`font-style:${style.italic ? 'italic' : 'normal'}`);
        else if (legacy.textItalic) styles.push('font-style:italic');
        if (['left', 'center', 'right'].includes(style.align)) styles.push(`text-align:${style.align}`);
        else if (['left', 'center', 'right'].includes(legacy.textAlign)) styles.push(`text-align:${legacy.textAlign}`);
        if (PREVIEW_LINE_HEIGHT[style.lineHeight]) styles.push(`line-height:${PREVIEW_LINE_HEIGHT[style.lineHeight]}`);
        if (PREVIEW_COLOR[style.color]) styles.push(`color:${PREVIEW_COLOR[style.color]}`);
        return adminStyleString(styles);
      }

      function adminLayoutStyle(layout = {}, legacy = {}) {
        const preset = PREVIEW_WIDTH[layout.width];
        const position = PREVIEW_POSITION[layout.position];
        const widthPercent = clampNumber(Number(layout.widthPercent), 30, 100, undefined);
        const maxWidth = clampNumber(Number(layout.maxWidth), 280, 1200, undefined);
        const styles = [];
        if (widthPercent !== undefined) styles.push(`width:${Math.round(widthPercent)}%`);
        else if (preset?.width) styles.push(`width:${preset.width}`);
        else if (/^\d{2,3}%$/.test(String(legacy.textWidth || '')) || /^\d{3,4}px$/.test(String(legacy.textWidth || ''))) styles.push(`width:${legacy.textWidth}`);
        if (maxWidth !== undefined) styles.push(`max-width:${Math.round(maxWidth)}px`);
        else if (preset?.maxWidth) styles.push(`max-width:${preset.maxWidth}`);
        if (position) {
          styles.push(`justify-self:${position.justify}`);
          styles.push(`margin:${position.margin}`);
        }
        if (PREVIEW_PADDING[layout.padding]) styles.push(`padding:${PREVIEW_PADDING[layout.padding]}`);
        return adminStyleString(styles);
      }

      function blockTextStyle(block) {
        return adminStyleString([adminLayoutStyle(block.layout || {}, block), adminTextStyle(block.textStyle || {}, block)]);
      }

      function blockTitleStyle(block) {
        return adminTextStyle(block.titleStyle || block.textStyle || {}, block, true);
      }

      function renderHeroMediaPanel(ref) {
        const imageTarget = `${ref}:image`;
        const posterTarget = `${ref}:heroMediaPoster`;
        return `
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card">
                <strong>Hero-медиа</strong>
                <p class="admin-muted">Если загружено Hero-видео, оно используется как фон. Poster показывается до загрузки видео и при ошибке. Если видео не задано, используется Hero-фото.</p>
                <div class="admin-grid-2">
                  <div>
                    <strong>Hero-фото</strong>
                    <p class="admin-field-hint">Основная картинка первого экрана, если Hero-видео не задано.</p>
                    ${renderMediaButtons(ref, 'image', 'imageView', imageTarget)}
                  </div>
                  <div>
                    <strong>Poster / превью видео</strong>
                    <p class="admin-field-hint">Показывается до загрузки Hero-видео и остается fallback при ошибке видео.</p>
                    ${renderMediaButtons(ref, 'heroMediaPoster', '', posterTarget)}
                  </div>
                </div>
                <div class="admin-grid-2">
                  ${renderVideoButtons(ref, 'heroMediaVideo', 'Hero-видео')}
                  ${renderVideoButtons(ref, 'heroMediaVideoMobile', 'Hero-видео для мобильных')}
                </div>
                ${renderHeroOverlayControl(ref)}
              </div>
            </div>
          </section>`;
      }

      function renderCatalogHub(ref) {
        const item = getRecord(ref).draft;
        const categories = Object.values(state.records)
          .filter((record) => record.collection === 'product-categories' && record.draft.parentSectionSlug === item.slug)
          .sort((a, b) => {
            const orderA = typeof a.draft.order === 'number' ? a.draft.order : Number.MAX_SAFE_INTEGER;
            const orderB = typeof b.draft.order === 'number' ? b.draft.order : Number.MAX_SAFE_INTEGER;
            if (orderA !== orderB) return orderA - orderB;
            return String(a.draft.title || a.slug).localeCompare(String(b.draft.title || b.slug), 'ru');
          });
        return `
          ${renderCreatePanel('product-categories', { parentSectionSlug: item.slug })}
          <section id="categories" class="section section--soft">
            <div class="container">
              <div class="section-heading"><h2 class="section-title">Типы изделий</h2><p class="lead">Карточки ниже сохраняются в коллекцию типов изделий.</p></div>
              <div class="category-choice-grid">
                ${categories.map((categoryRecord, index) => renderCategoryCard(categoryRecord, index, categories.length)).join('')}
              </div>
            </div>
          </section>`;
      }

      function renderCategoryCard(categoryRecord, index = 0, total = 1) {
        const ref = keyOf(categoryRecord.collection, categoryRecord.slug);
        const item = categoryRecord.draft;
        const target = `${ref}:image`;
        const isCrop = state.crop?.target === target;
        return `
          <article class="category-choice-card ${item.isActive === false ? 'admin-card-hidden' : ''}">
            <div class="media-block placeholder placeholder--card">
              <div class="admin-media-frame admin-media-frame--card ${isCrop ? 'is-active-crop' : ''}" data-image-frame="${esc(target)}">
                ${item.image ? `<img class="media-thumb" data-image-img="${esc(target)}" src="${esc(toSrc(item.image))}" alt="${esc(item.title)}" style="${esc(mediaStyle(item.imageView))}" />` : '<div class="admin-media-empty">Фото не выбрано</div>'}
              </div>
              ${renderMediaButtons(ref, 'image', 'imageView', target)}
              ${isCrop ? renderCropControls() : ''}
            </div>
            <div class="category-choice-card__body">
              <h3 ${editable(ref, 'title', 'Название типа', true)}>${esc(item.title)}</h3>
              <p ${editable(ref, 'shortDescription', 'Описание типа')}>${esc(item.shortDescription || '')}</p>
              <div class="admin-item-tools">
                <button class="admin-btn" type="button" data-action="move-category-record" data-ref="${ref}" data-dir="-1" ${index === 0 ? 'disabled' : ''}>Выше</button>
                <button class="admin-btn" type="button" data-action="move-category-record" data-ref="${ref}" data-dir="1" ${index === total - 1 ? 'disabled' : ''}>Ниже</button>
                <button class="admin-btn" type="button" data-action="toggle-record" data-ref="${ref}" data-field="isActive">${item.isActive === false ? 'Показать' : 'Скрыть'}</button>
                <button class="admin-btn admin-btn--primary" type="button" data-action="open-related" data-collection="product-categories" data-slug="${esc(item.slug)}">Редактировать направление</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-record" data-ref="${ref}">Удалить</button>
              </div>
            </div>
          </article>`;
      }

      function renderProductBulkToolbar(products) {
        const visibleRefs = products.map((record) => keyOf(record.collection, record.slug));
        const selectedCount = visibleRefs.filter((ref) => state.selectedProductRefs.has(ref)).length;
        return `
          <div class="admin-product-bulk" data-product-bulk-toolbar>
            <span><strong data-selected-products-count>${selectedCount}</strong> выбрано из ${products.length}</span>
            <div class="admin-product-bulk__actions">
              <button class="admin-btn admin-btn--danger" type="button" data-action="bulk-delete-products" ${selectedCount ? '' : 'disabled'}>Удалить выбранные</button>
              <button class="admin-btn" type="button" data-action="clear-product-selection" ${selectedCount ? '' : 'disabled'}>Снять выбор</button>
            </div>
          </div>`;
      }

      function normalizeStructuredGalleryItem(item) {
        if (typeof item === 'string') return { src: item, alt: '', caption: '' };
        if (item && typeof item === 'object') {
          return {
            src: cleanMediaPath(item.src),
            alt: typeof item.alt === 'string' ? item.alt : '',
            caption: typeof item.caption === 'string' ? item.caption : ''
          };
        }
        return { src: '', alt: '', caption: '' };
      }

      function renderStructuredGalleryEditor(ref, path, title) {
        const record = getRecord(ref);
        const sourceItems = Array.isArray(getPath(record, path)) ? getPath(record, path) : [];
        const items = sourceItems.map(normalizeStructuredGalleryItem);
        if (items !== sourceItems) setPath(record, path, items);
        return `<div class="admin-product-details"><strong>${esc(title)}</strong><p class="admin-field-hint">Изображения из этого списка выводятся на внутренней странице направления в блоке «Примеры решений». Основная картинка карточки на странице категории хранится отдельно.</p><div class="admin-gallery-list">${items.map((item, index) => {
          const itemPath = `${path}.${index}`;
          const imagePath = `${itemPath}.src`;
          const displayName = item.caption || item.alt || fileNameFromPath(item.src) || `Фото ${index + 1}`;
          const displayPath = item.src || 'Файл не выбран';
          return `<div class="admin-gallery-row">
            <div class="admin-gallery-thumb">${item.src ? `<img src="${esc(toSrc(item.src))}" alt="" />` : '<span>Фото не выбрано</span>'}</div>
            <div class="admin-product-panel-grid">
              <div class="admin-gallery-meta"><strong>${esc(displayName)}</strong><small>${esc(displayPath)}</small></div>
              <div class="admin-grid-2">
                <label class="admin-field"><span>Alt</span><input data-field-ref="${ref}" data-field-path="${itemPath}.alt" value="${esc(item.alt || '')}" placeholder="Краткое описание изображения" /></label>
                <label class="admin-field"><span>Caption</span><input data-field-ref="${ref}" data-field-path="${itemPath}.caption" value="${esc(item.caption || '')}" placeholder="Подпись под фото, если нужна" /></label>
              </div>
              <div class="admin-item-tools">
                <button class="admin-btn" type="button" data-action="upload-image" data-ref="${ref}" data-path="${esc(imagePath)}" data-target="${esc(`${ref}:${imagePath}`)}">Загрузить/заменить</button>
                <button class="admin-btn" type="button" data-action="move-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="-1" ${index === 0 ? 'disabled' : ''}>Выше</button>
                <button class="admin-btn" type="button" data-action="move-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="1" ${index === items.length - 1 ? 'disabled' : ''}>Ниже</button>
                <button class="admin-btn" type="button" data-action="promote-gallery-image" data-ref="${ref}" data-path="${path}" data-index="${index}">Сделать основным</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}">Удалить</button>
              </div>
              <details class="admin-gallery-technical">
                <summary>Технический путь</summary>
                <label class="admin-field"><span>Путь к фото</span><input data-field-ref="${ref}" data-field-path="${imagePath}" value="${esc(item.src || '')}" placeholder="/uploads/photo.jpg" /></label>
              </details>
            </div>
          </div>`;
        }).join('')}</div><div class="admin-item-tools"><button class="admin-btn admin-btn--primary" type="button" data-action="upload-gallery-images" data-ref="${ref}" data-path="${path}">Загрузить несколько фото</button><button class="admin-btn" type="button" data-action="add-structured-gallery-image" data-ref="${ref}" data-path="${path}">Добавить фото по пути</button></div></div>`;
      }

      function renderCategoryMediaPanel(ref) {
        const category = getRecord(ref).draft;
        return `
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card admin-product-panel-grid">
                <strong>Медиа направления</strong>
                <div class="admin-product-media-grid">
                  <div>
                    <strong>Основное фото направления</strong>
                    <p class="admin-field-hint">Используется в карточке на странице родительской категории. Если галерея направления пустая, это фото также показывается в блоке «Примеры решений» на внутренней странице.</p>
                    ${renderImageOnly(ref, 'image', 'imageView', 'wide')}
                  </div>
                  <div class="admin-product-panel-grid">
                    ${renderField(ref, 'placeholderLabel', category.placeholderLabel)}
                    <p class="admin-field-hint">Подпись относится к основному фото направления и не заменяет подписи в галерее.</p>
                    <label class="admin-field"><span>Текст перед галереей</span><textarea data-field-ref="${ref}" data-field-path="galleryIntro">${esc(category.galleryIntro || '')}</textarea><p class="admin-field-hint">Опционально. Если поле пустое, на сайте используется общий текст блока.</p></label>
                  </div>
                </div>
                ${renderStructuredGalleryEditor(ref, 'gallery', 'Галерея направления')}
              </div>
            </div>
          </section>`;
      }

      function renderCategoryParentNav(ref) {
        const category = getRecord(ref).draft;
        const section = findRecordByField('product-sections', 'slug', category.parentSectionSlug);
        if (!section) return '';

        return `
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card">
                <button class="admin-btn" type="button" data-action="open-related" data-collection="product-sections" data-slug="${esc(section.draft.slug || section.slug)}">Назад к разделу: ${esc(section.draft.title || section.slug)}</button>
              </div>
            </div>
          </section>`;
      }

      function renderCategoryPage(ref) {
        const category = getRecord(ref).draft;
        const products = Object.values(state.records)
          .filter((record) => record.collection === 'products' && record.draft.productCategorySlug === category.slug)
          .sort((a, b) => {
            const orderA = typeof a.draft.order === 'number' ? a.draft.order : Number.MAX_SAFE_INTEGER;
            const orderB = typeof b.draft.order === 'number' ? b.draft.order : Number.MAX_SAFE_INTEGER;
            if (orderA !== orderB) return orderA - orderB;
            return String(a.draft.title || a.slug).localeCompare(String(b.draft.title || b.slug), 'ru');
          });
        return `
          ${renderCategoryParentNav(ref)}
          ${renderHero(ref, 'catalog')}
          ${renderHeroTextSettings(ref)}
          ${renderCategoryMediaPanel(ref)}
          ${renderRecordSettings(ref, ['title', 'slug', 'parentSectionSlug', 'shortDescription', 'placeholderLabel', 'order', 'showInSectionGrid', 'isActive', 'mode', 'seoTitle', 'seoDescription'])}
          ${renderCreatePanel('products', { productCategorySlug: category.slug })}
          <section id="products" class="section">
            <div class="container">
              <div class="section-heading"><h2 class="section-title">Модели изделий</h2></div>
              ${renderProductBulkToolbar(products)}
              <div class="product-catalog-grid">
                ${products.map((productRecord) => renderProductCard(productRecord)).join('')}
              </div>
            </div>
          </section>
          ${renderContactBlock()}`;
      }

      function formatPrice(product) {
        if (product.priceMode === 'from' && typeof product.priceFrom === 'number') return `от ${product.priceFrom.toLocaleString('ru-RU')} ₽`;
        if (product.priceMode === 'on_request') return 'Цена по запросу';
        return 'Рассчитывается индивидуально';
      }

      function renderProductCard(productRecord) {
        const ref = keyOf(productRecord.collection, productRecord.slug);
        const item = productRecord.draft;
        const target = `${ref}:image`;
        const isCrop = state.crop?.target === target;
        const isSelected = state.selectedProductRefs.has(ref);
        return `
          <article class="product-showcase-card ${item.isActive === false || item.showInCatalog === false ? 'admin-card-hidden' : ''}" data-product-card data-ref="${esc(ref)}">
            <div class="product-showcase-card__media-wrap">
              <div class="admin-media-frame admin-media-frame--card ${isCrop ? 'is-active-crop' : ''}" data-image-frame="${esc(target)}">
                ${item.image ? `<img class="product-showcase-card__media" data-image-img="${esc(target)}" src="${esc(toSrc(item.image))}" alt="${esc(item.title)}" style="${esc(mediaStyle(item.imageView))}" />` : '<div class="admin-media-empty">Фото не выбрано</div>'}
              </div>
            </div>
            <div class="product-showcase-card__body">
              <label class="admin-product-select"><input type="checkbox" data-product-select data-ref="${esc(ref)}" ${isSelected ? 'checked' : ''} /> <span>Выбрать</span></label>
              <h3 ${editable(ref, 'title', 'Название модели', true)}>${esc(item.title)}</h3>
              <p class="product-showcase-card__descriptor" ${editable(ref, 'shortDescription', 'Описание модели')}>${esc(item.shortDescription || '')}</p>
              <p class="product-showcase-card__price">${esc(formatPrice(item))}</p>
              ${renderProductControls(ref)}
              ${renderMediaButtons(ref, 'image', 'imageView', target, 'placeholderLabel')}
              ${isCrop ? renderCropControls() : ''}
              <div class="admin-item-tools">
                <button class="admin-btn" type="button" data-action="open-related" data-collection="products" data-slug="${esc(item.slug)}">Открыть модель</button>
                <button class="admin-btn" type="button" data-action="toggle-record" data-ref="${ref}" data-field="showInCatalog">${item.showInCatalog === false ? 'В каталог' : 'Убрать из каталога'}</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-record" data-ref="${ref}">Удалить</button>
              </div>
            </div>
          </article>`;
      }

      function renderProductControls(ref) {
        const item = getRecord(ref).draft;
        return `
          <div class="admin-grid-3">
            <label class="admin-field"><span>Цена</span><input type="number" data-field-ref="${ref}" data-field-path="priceFrom" value="${esc(item.priceFrom ?? '')}" /></label>
            <label class="admin-field"><span>Режим цены</span><select data-field-ref="${ref}" data-field-path="priceMode"><option value="from" ${item.priceMode === 'from' ? 'selected' : ''}>от суммы</option><option value="on_request" ${item.priceMode === 'on_request' ? 'selected' : ''}>по запросу</option><option value="none" ${item.priceMode === 'none' ? 'selected' : ''}>индивидуальный расчет</option></select></label>
            <label class="admin-field"><span>Порядок показа</span><input type="number" data-field-ref="${ref}" data-field-path="order" value="${esc(item.order ?? 0)}" /></label>
          </div>`;
      }

      function renderProductSpecEditor(ref, path, title) {
        const items = getPath(getRecord(ref), path) || [];
        return `
          <div class="admin-product-details">
            <strong>${title}</strong>
            <div class="admin-product-specs">
              ${items.map((item, index) => `<div class="admin-product-spec-row ${item.isActive === false ? 'is-hidden' : ''}">
                <label class="admin-field"><span>Параметр</span><input data-field-ref="${ref}" data-field-path="${path}.${index}.label" value="${esc(item.label || '')}" /></label>
                <label class="admin-field"><span>Значение</span><input data-field-ref="${ref}" data-field-path="${path}.${index}.value" value="${esc(item.value || '')}" /></label>
                <div class="admin-item-tools" style="grid-column: 1 / -1;">
                  <button class="admin-btn" type="button" data-action="move-product-spec" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="-1">Выше</button>
                  <button class="admin-btn" type="button" data-action="move-product-spec" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="1">Ниже</button>
                  <button class="admin-btn" type="button" data-action="toggle-product-spec" data-ref="${ref}" data-path="${path}" data-index="${index}">${item.isActive === false ? 'Показать' : 'Скрыть'}</button>
                  <button class="admin-btn admin-btn--danger" type="button" data-action="delete-product-spec" data-ref="${ref}" data-path="${path}" data-index="${index}">Удалить</button>
                </div>
              </div>`).join('')}
            </div>
            <button class="admin-btn admin-btn--primary" type="button" data-action="add-product-spec" data-ref="${ref}" data-path="${path}">Добавить параметр</button>
          </div>`;
      }

      function renderProductSlugEditor(ref, path, title) {
        const record = getRecord(ref);
        const items = getPath(record, path) || [];
        const currentSlug = record.draft.slug;
        return `
          <div class="admin-product-details">
            <strong>${esc(title)}</strong>
            <p class="admin-field-hint">Выберите изделия, которые будут показаны в блоке «Дополнить объект». Если список пустой, сайт подберет товары из той же или соседней категории.</p>
            <div class="admin-product-specs">
              ${items.map((slug, index) => `<div class="admin-product-spec-row">
                <label class="admin-field"><span>Связанное изделие</span><select data-field-ref="${ref}" data-field-path="${path}.${index}">${productSlugOptions(slug, currentSlug)}</select></label>
                <div class="admin-item-tools" style="grid-column: 1 / -1;">
                  <button class="admin-btn" type="button" data-action="delete-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}">Удалить</button>
                </div>
              </div>`).join('')}
            </div>
            <button class="admin-btn admin-btn--primary" type="button" data-action="add-related-product" data-ref="${ref}" data-path="${path}">Добавить связанное изделие</button>
          </div>`;
      }

      function renderProductPage(ref) {
        const item = getRecord(ref).draft;
        return `
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card admin-product-panel-grid">
                <strong>Основное</strong>
                <div class="admin-grid-2">
                  ${renderField(ref, 'title', item.title)}
                  ${renderField(ref, 'productCategorySlug', item.productCategorySlug)}
                </div>
                <div class="admin-grid-2">
                  <label class="admin-field"><span>Лид-текст</span><textarea data-field-ref="${ref}" data-field-path="leadText">${esc(item.leadText || '')}</textarea></label>
                  <label class="admin-field"><span>Краткое описание</span><textarea data-field-ref="${ref}" data-field-path="shortDescription">${esc(item.shortDescription || '')}</textarea></label>
                </div>
                <div class="admin-grid-3">
                  <label class="admin-field"><span>Цена</span><input type="number" data-field-ref="${ref}" data-field-path="priceFrom" value="${esc(item.priceFrom ?? '')}" /></label>
                  <label class="admin-field"><span>Режим цены</span><select data-field-ref="${ref}" data-field-path="priceMode"><option value="from" ${item.priceMode === 'from' ? 'selected' : ''}>от суммы</option><option value="on_request" ${item.priceMode === 'on_request' ? 'selected' : ''}>по запросу</option><option value="none" ${item.priceMode === 'none' ? 'selected' : ''}>индивидуальный расчет</option></select></label>
                  ${renderField(ref, 'order', item.order)}
