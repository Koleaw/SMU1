                <label class="admin-field"><span>Подробное описание</span><textarea data-field-ref="${ref}" data-field-path="description">${esc(item.description || '')}</textarea></label>
                ${renderImageListEditor(ref, 'gallery', 'Дополнительные фото')}
                <p class="admin-field-hint">Для дополнительных фото укажите пути вида /assets/... или /uploads/.... Если фото одно, галерея на сайте не выводится.</p>
                ${renderArrayEditor(ref, 'features', 'Преимущества товара')}
                ${renderArrayEditor(ref, 'customizationItems', 'Пункты блока «Изготовление под задачу»')}
                ${renderArrayEditor(ref, 'materials', 'Материалы')}
                ${renderArrayEditor(ref, 'colors', 'Цвета / покрытие')}
                ${renderProductSpecEditor(ref, 'dimensions', 'Размеры и характеристики')}
              </div>
            </div>
          </section>
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card admin-product-panel-grid">
                <strong>Доставка и индивидуальный проект</strong>
                <div class="admin-grid-2">
                  ${renderField(ref, 'showDeliveryBlock', item.showDeliveryBlock)}
                  ${renderField(ref, 'showCustomProjectBlock', item.showCustomProjectBlock)}
                </div>
                ${renderField(ref, 'deliveryText', item.deliveryText)}
                <div class="admin-grid-2">
                  ${renderField(ref, 'customProjectTitle', item.customProjectTitle)}
                  ${renderField(ref, 'customProjectText', item.customProjectText)}
                </div>
              </div>
            </div>
          </section>
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card">
                ${renderProductSlugEditor(ref, 'relatedProductSlugs', 'Связанные товары')}
              </div>
            </div>
          </section>
          ${renderRecordSettings(ref, ['slug', 'sku', 'isActive', 'showInCatalog', 'seoTitle', 'seoDescription'])}`;
      }

      function renderJobsPage() {
        const jobs = Object.values(state.records).filter((record) => record.collection === 'jobs').sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
        return `
          ${renderCreatePanel('jobs')}
          <section class="hero hero--catalog-clean"><div class="container hero-content"><p class="kicker">Команда</p><h1>Вакансии</h1></div></section>
          <section class="section section--soft"><div class="container"><div class="grid grid-2">${jobs.map((job) => renderJobCard(keyOf('jobs', job.slug))).join('')}</div></div></section>`;
      }

      function renderJobCard(ref, standalone = false) {
        const job = getRecord(ref).draft;
        return `
          <article class="card ${job.isActive === false ? 'admin-card-hidden' : ''}">
            <span class="admin-badge">Вакансия</span>
            <h2 ${editable(ref, 'title', 'Название вакансии', true)}>${esc(job.title)}</h2>
            <p><strong>Город:</strong> <span ${editable(ref, 'city', 'Город', true)}>${esc(job.city)}</span></p>
            <p><strong>Формат:</strong> <span ${editable(ref, 'employmentType', 'Формат', true)}>${esc(job.employmentType)}</span></p>
            <p><strong>Оплата:</strong> <span ${editable(ref, 'salary', 'Оплата', true)}>${esc(job.salary)}</span></p>
            <p ${editable(ref, 'shortDescription', 'Краткое описание')}>${esc(job.shortDescription)}</p>
            ${renderArrayEditor(ref, 'responsibilities', 'Обязанности')}
            ${renderArrayEditor(ref, 'requirements', 'Требования')}
            ${renderArrayEditor(ref, 'conditions', 'Условия')}
            <div class="admin-item-tools">
              <button class="admin-btn" type="button" data-action="toggle-record" data-ref="${ref}" data-field="isActive">${job.isActive === false ? 'Показать' : 'Скрыть'}</button>
              <button class="admin-btn admin-btn--danger" type="button" data-action="delete-record" data-ref="${ref}">Удалить</button>
            </div>
          </article>`;
      }

      function renderArrayEditor(ref, path, title) {
        const items = getPath(getRecord(ref), path) || [];
        return `<div><strong>${title}</strong><ul>${items.map((item, index) => `<li><span ${editable(ref, `${path}.${index}`, 'Строка')}>${esc(item)}</span> <button class="admin-btn" type="button" data-action="delete-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}">Удалить</button></li>`).join('')}</ul><button class="admin-btn" type="button" data-action="add-array-item" data-ref="${ref}" data-path="${path}">Добавить строку</button></div>`;
      }

      function renderImageListEditor(ref, path, title) {
        const record = getRecord(ref);
        const items = getPath(record, path) || [];
        const batchUploadButton = record.collection === 'projects'
          ? `<button class="admin-btn" type="button" data-action="upload-gallery-images" data-ref="${ref}" data-path="${path}">Загрузить несколько фото</button>`
          : '';
        return `<div class="admin-product-details"><strong>${esc(title)}</strong><div class="admin-gallery-list">${items.map((image, index) => {
          const imagePath = `${path}.${index}`;
          const displayName = fileNameFromPath(image) || `Фото ${index + 1}`;
          const displayPath = image || 'Файл не выбран';
          return `<div class="admin-gallery-row">
            <div class="admin-gallery-thumb">${image ? `<img src="${esc(toSrc(image))}" alt="" />` : '<span>Фото не выбрано</span>'}</div>
            <div class="admin-product-panel-grid">
              <div class="admin-gallery-meta"><strong>${esc(displayName)}</strong><small>${esc(displayPath)}</small></div>
              <div class="admin-item-tools">
                <button class="admin-btn" type="button" data-action="upload-image" data-ref="${ref}" data-path="${esc(imagePath)}" data-target="${esc(`${ref}:${imagePath}`)}">Загрузить/заменить</button>
                <button class="admin-btn" type="button" data-action="move-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="-1">Выше</button>
                <button class="admin-btn" type="button" data-action="move-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}" data-dir="1">Ниже</button>
                <button class="admin-btn" type="button" data-action="promote-gallery-image" data-ref="${ref}" data-path="${path}" data-index="${index}">Сделать основным</button>
                <button class="admin-btn admin-btn--danger" type="button" data-action="delete-array-item" data-ref="${ref}" data-path="${path}" data-index="${index}">Удалить</button>
              </div>
              <details class="admin-gallery-technical">
                <summary>Технический путь</summary>
                <label class="admin-field"><span>Путь к фото</span><input data-field-ref="${ref}" data-field-path="${imagePath}" value="${esc(image || '')}" placeholder="/uploads/photo.jpg" /></label>
              </details>
            </div>
          </div>`;
        }).join('')}</div><div class="admin-item-tools"><button class="admin-btn admin-btn--primary" type="button" data-action="add-gallery-image" data-ref="${ref}" data-path="${path}">Добавить фото по пути</button>${batchUploadButton}</div></div>`;
      }

      function renderProjectsPage() {
        const projects = Object.values(state.records).filter((record) => record.collection === 'projects').sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
        return `
          ${renderCreatePanel('projects')}
          <section class="hero hero--trust hero--catalog-clean"><div class="container hero-content"><p class="kicker">Доверительный контур</p><h1>Выполненные объекты</h1></div></section>
          <section class="section"><div class="container object-list-grid">${projects.map((project) => renderProjectListCard(keyOf('projects', project.slug))).join('')}</div></section>`;
      }

      function renderProjectListCard(ref) {
        const item = getRecord(ref).draft;
        const meta = [item.city, item.year].filter(Boolean).join(', ');
        const workType = item.workType || item.category || item.shortCategory || item.shortDescription || '';
        return `<article class="object-list-card ${item.isActive === false ? 'admin-card-hidden' : ''}">
          <div class="media-block placeholder placeholder--card">${renderImageOnly(ref, 'image', null, 'card')}</div>
          <div class="object-list-card__body">
            ${meta ? `<p class="object-list-card__meta">${esc(meta)}</p>` : ''}
            <h2 ${editable(ref, 'title', 'Название объекта', true)}>${esc(item.title)}</h2>
            ${workType ? `<p class="object-list-card__type">${esc(workType)}</p>` : ''}
            <p class="object-list-card__description" ${editable(ref, 'whatWasDone', 'Краткое описание')}>${esc(item.whatWasDone || item.shortDescription || '')}</p>
            <div class="admin-item-tools">
              <button class="admin-btn" type="button" data-action="open-related" data-collection="projects" data-slug="${esc(item.slug)}">Открыть объект</button>
              <button class="admin-btn" type="button" data-action="toggle-record" data-ref="${ref}" data-field="isActive">${item.isActive === false ? 'Показать' : 'Скрыть'}</button>
              <button class="admin-btn admin-btn--danger" type="button" data-action="delete-record" data-ref="${ref}">Удалить</button>
            </div>
          </div>
        </article>`;
      }

      function renderProjectPage(ref) {
        const item = getRecord(ref).draft;
        const yearText = item.year ? `, ${esc(item.year)}` : '';
        const workType = item.workType || item.category || item.shortCategory || item.shortDescription || '';
        return `
          ${renderHeroLike('Кейс объекта', ref, 'title', `${esc(item.shortDescription || '')} · ${esc(item.city || '')}${yearText}`)}
          <section class="admin-panel">
            <div class="container">
              <div class="admin-panel-card admin-product-panel-grid">
                <strong>Фото объекта</strong>
                <p class="admin-field-hint">Главное фото хранится в поле image и используется как обложка. Галерея хранится в gallery; публичная страница показывает обложку первой и убирает дубли.</p>
                <div class="admin-product-media-grid">
                  <div>
                    <strong>Обложка объекта</strong>
                    ${renderImageOnly(ref, 'image', null, 'wide')}
                  </div>
                  <div class="admin-product-panel-grid">
                    <label class="admin-field"><span>Тип работ / короткая категория</span><input data-field-ref="${ref}" data-field-path="workType" value="${esc(item.workType || '')}" placeholder="${esc(item.shortDescription || 'Например: благоустройство территории')}" /></label>
                    <label class="admin-field"><span>Подпись к фото-заглушке</span><input data-field-ref="${ref}" data-field-path="placeholderLabel" value="${esc(item.placeholderLabel || '')}" placeholder="Фото объекта будет добавлено позже" /></label>
                    <button class="admin-btn" type="button" data-action="upload-gallery-images" data-ref="${ref}" data-path="gallery">Загрузить несколько фото в галерею</button>
                  </div>
                </div>
                ${renderImageListEditor(ref, 'gallery', 'Галерея объекта')}
              </div>
            </div>
          </section>
          <section class="section section--soft">
            <div class="container object-story-grid">
              <article class="card"><h2>Кратко</h2><p class="lead" ${editable(ref, 'shortDescription', 'Кратко')}>${esc(item.shortDescription || '')}</p></article>
              <article class="card"><h2>Что сделали</h2><p class="lead" ${editable(ref, 'whatWasDone', 'Что сделали')}>${esc(item.whatWasDone || '')}</p></article>
              <article class="card"><h2>Город</h2><p class="lead" ${editable(ref, 'city', 'Город', true)}>${esc(item.city || '')}</p></article>
            </div>
          </section>
          ${renderRecordSettings(ref, ['title', 'slug', 'city', 'year', 'workType', 'order', 'isActive', 'seoTitle', 'seoDescription'])}`;
      }

      function renderHeroLike(kicker, ref, titlePath, description) {
        const item = getRecord(ref).draft;
        return `<section class="hero hero--trust"><div class="container hero-content"><p class="kicker">${kicker}</p><h1 ${editable(ref, titlePath, 'Заголовок', true)}>${esc(getPath(getRecord(ref), titlePath) || item.title)}</h1><p class="hero-description">${description}</p></div></section>`;
      }

      function renderSettingsPage(ref) {
        const item = getRecord(ref).draft;
        return `<section class="section section--soft"><div class="container contacts-layout-grid"><article class="card contacts-main-card"><h2>Контакты и настройки</h2><div class="contacts-list">${Object.keys(item).map((key) => Array.isArray(item[key]) ? renderArrayEditor(ref, key, key) : `<p><strong>${esc(key)}:</strong> <span ${editable(ref, key, key, true)}>${esc(item[key])}</span></p>`).join('')}</div></article></div></section>`;
      }

      function renderStaticPage(ref) {
        const page = getRecord(ref).draft;
        if (page.slug === 'home') return renderHomePage(ref);
        return `
          ${renderStaticHero(ref, 'hero--service')}
          ${renderHeroMediaPanel(ref)}
          ${renderHeroTextSettings(ref)}
          ${renderRecordSettings(ref, ['title', 'slug', 'order', 'isActive', 'showInMenu', 'menuTitle', 'showBadge', 'seoTitle', 'seoDescription'])}
          ${renderPageBlocks(ref)}
          ${renderContactBlock(ref)}
        `;
      }

      function renderStaticHero(ref, className = 'hero--catalog-clean') {
        const page = getRecord(ref).draft;
        const isHomePage = page.slug === 'home';
        const video = cleanMediaPath(page.heroMediaVideo);
        const imagePath = cleanMediaPath(page.image);
        const posterPath = cleanMediaPath(page.heroMediaPoster);
        const hasMedia = Boolean(video || imagePath || posterPath);
        const mediaPath = video && posterPath ? 'heroMediaPoster' : isHomePage && posterPath ? 'heroMediaPoster' : !imagePath && posterPath ? 'heroMediaPoster' : 'image';
        const target = `${ref}:${mediaPath}`;
        const isCrop = state.crop?.target === target;
        const image = getPath(getRecord(ref), mediaPath);
        const poster = posterPath || imagePath;
        const overlayStyle = heroOverlayStyle(page.heroOverlayOpacity);
        const mediaMarkup = video
          ? `<video class="hero-media__video" autoplay muted loop playsinline preload="metadata" poster="${esc(toSrc(poster))}"><source src="${esc(toSrc(video))}" type="${esc(mediaMimeType(video))}" /></video>${poster ? `<img class="hero-media__fallback" src="${esc(toSrc(poster))}" alt="${esc(page.title)}" />` : ''}`
          : image
            ? `<img class="hero-media__image" data-image-img="${esc(target)}" src="${esc(toSrc(image))}" alt="${esc(page.title)}" style="${esc(mediaStyle(page.imageView))}" />`
            : '<div class="admin-media-empty">Фото не выбрано</div>';
        return `
          <section class="hero ${hasMedia ? 'hero--media' : className}">
            ${hasMedia ? `<div class="admin-media-frame admin-media-frame--hero ${isCrop && !video ? 'is-active-crop' : ''}" data-image-frame="${esc(target)}">${mediaMarkup}<div class="hero-media__overlay" style="${esc(overlayStyle)}"></div></div>` : ''}
            <div class="container hero-content">
              ${page.showBadge === false ? '' : `<p class="kicker" ${editable(ref, 'heroKicker', 'Надзаголовок', true)}>${esc(page.heroKicker || '')}</p>`}
              <h1 ${editable(ref, 'heroTitle', 'Заголовок первого экрана', true)}>${esc(page.heroTitle || page.title)}</h1>
              <p class="hero-description" ${editable(ref, 'heroDescription', 'Описание первого экрана')}>${esc(page.heroDescription || '')}</p>
            </div>
          </section>
          ${hasMedia && isCrop && !video ? renderCropControls() : ''}`;
      }

      function renderHomePage(ref) {
        const page = getRecord(ref).draft;
        const productDirections = Object.values(state.records)
          .filter((record) => record.collection === 'product-sections' && record.draft.showOnHome && record.draft.isActive)
          .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
        const serviceDirections = Object.values(state.records)
          .filter((record) => record.collection === 'services' && record.draft.showOnHome && record.draft.isActive)
          .sort((a, b) => (a.draft.order ?? 0) - (b.draft.order ?? 0));
        const pathways = Array.isArray(page.pathwayCards) ? page.pathwayCards : (page.pathwayCards = []);
        return `
          ${renderStaticHero(ref, 'hero--media')}
          ${renderHeroMediaPanel(ref)}
          ${renderHeroTextSettings(ref)}
          ${renderRecordSettings(ref, ['title', 'slug', 'order', 'isActive', 'showInMenu', 'menuTitle', 'showBadge', 'seoTitle', 'seoDescription'])}
          ${renderPageBlocks(ref)}
          <section class="home-pathways section">
            <div class="container">
              <div class="section-heading home-pathways__heading">
                <p class="kicker" ${editable(ref, 'pathwaysKicker', 'Надзаголовок', true)}>${esc(page.pathwaysKicker || '')}</p>
                <h2 class="section-title" ${editable(ref, 'pathwaysTitle', 'Заголовок секции', true)}>${esc(page.pathwaysTitle || '')}</h2>
              </div>
              <div class="home-pathways__grid">
                ${pathways.map((card, index) => `<article class="home-pathway-card"><span class="home-pathway-card__index">${String(index + 1).padStart(2, '0')}</span><h3 ${editable(ref, `pathwayCards.${index}.title`, 'Заголовок карточки', true)}>${esc(card.title)}</h3><p ${editable(ref, `pathwayCards.${index}.text`, 'Текст карточки')}>${esc(card.text)}</p></article>`).join('')}
              </div>
            </div>
          </section>
          <section class="section section--split">
            <div class="container">
              <div class="section-heading"><h2 class="section-title" ${editable(ref, 'productsTitle', 'Заголовок продукции', true)}>${esc(page.productsTitle || '')}</h2><p class="lead" ${editable(ref, 'productsIntro', 'Описание продукции')}>${esc(page.productsIntro || '')}</p></div>
              <div class="home-products-grid">${productDirections.map((record) => renderHomeDirectionCard(record)).join('')}</div>
            </div>
          </section>
          <section class="section section--soft">
            <div class="container">
              <div class="section-heading"><h2 class="section-title" ${editable(ref, 'servicesTitle', 'Заголовок услуг', true)}>${esc(page.servicesTitle || '')}</h2><p class="lead" ${editable(ref, 'servicesIntro', 'Описание услуг')}>${esc(page.servicesIntro || '')}</p></div>
              <div class="home-services-grid">${serviceDirections.map((record) => renderHomeServiceCard(record)).join('')}</div>
            </div>
          </section>
          <section class="section section--dark home-trust-section">
            <div class="container trust-media-grid">
              <article class="trust-media trust-media--objects">
                <div class="media-block placeholder placeholder--card">${renderImageOnly(ref, 'trustImage', null, 'card')}${String(page.trustCaption || '').trim() ? `<p class="media-caption" ${editable(ref, 'trustCaption', 'Подпись изображения')}>${esc(String(page.trustCaption || '').trim())}</p>` : ''}</div>
                <h2 ${editable(ref, 'trustTitle', 'Заголовок блока', true)}>${esc(page.trustTitle || '')}</h2>
                <p ${editable(ref, 'trustText', 'Текст блока')}>${esc(page.trustText || '')}</p>
              </article>
            </div>
          </section>
          ${renderContactBlock(ref)}
        `;
      }

      function renderHomeDirectionCard(record) {
        const ref = keyOf(record.collection, record.slug);
        const item = record.draft;
        return `<article class="home-product-card"><div class="media-block placeholder placeholder--card">${renderImageOnly(ref, 'image', 'imageView', 'card')}</div><div class="home-product-card__body"><h3 ${editable(ref, 'title', 'Название раздела', true)}>${esc(item.title)}</h3><p ${editable(ref, 'shortDescription', 'Описание раздела')}>${esc(item.shortDescription || '')}</p></div></article>`;
      }

      function renderHomeServiceCard(record) {
        const ref = keyOf(record.collection, record.slug);
        const item = record.draft;
        return `<article class="home-service-card"><div class="media-block placeholder placeholder--wide-feature">${renderImageOnly(ref, 'image', 'imageView', 'wide')}</div><div class="home-service-card__body"><h3 ${editable(ref, 'title', 'Название услуги', true)}>${esc(item.title)}</h3><p ${editable(ref, 'shortDescription', 'Описание услуги')}>${esc(item.shortDescription || '')}</p></div></article>`;
      }

      function renderPageBlocks(ref) {
        const record = getRecord(ref);
        const blocks = Array.isArray(record.draft.pageBlocks) ? record.draft.pageBlocks : (record.draft.pageBlocks = []);
        return `
          <section class="admin-create"><div class="container"><div class="admin-create-panel"><strong>Секции страницы</strong><p class="admin-muted">Добавляйте, скрывайте, удаляйте и меняйте порядок блоков. Кнопки «Выше» и «Ниже» сразу переставляют секцию в данных.</p><div class="admin-create-grid"><select id="newBlockType" class="admin-select">${SECTION_TYPES.map(([type, label]) => `<option value="${type}">${label}</option>`).join('')}</select><button class="admin-btn admin-btn--primary" type="button" data-action="add-block" data-ref="${ref}">Добавить секцию</button></div></div></div></section>
          ${blocks.map((block, index) => renderBlock(ref, block, index)).join('')}`;
      }

      function sectionClass(theme) {
        if (theme === 'dark') return 'section section--dark navesy-section-compact';
        if (theme === 'light') return 'section section--soft navesy-section-compact';
        return 'section navesy-section-compact';
      }

      function renderBlockToolbar(ref, block, index) {
