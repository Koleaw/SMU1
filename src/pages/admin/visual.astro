---
import '../../styles/global.css';
import { withBase } from '../../utils/withBase';

const adminApiBase = import.meta.env.PUBLIC_ADMIN_API_BASE ?? 'http://127.0.0.1:8787/api/admin';
const adminHome = withBase('/admin/');
const baseUrl = import.meta.env.BASE_URL ?? '/';
---

<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow, noarchive" />
    <meta name="googlebot" content="noindex, nofollow, noarchive" />
    <title>Визуальный редактор — Админка СМУ-1</title>
    <style is:global>
      * { box-sizing: border-box; }
      body { margin: 0; background: #f2f5f7; }
      button, input, select, textarea { font: inherit; }
      .hidden { display: none !important; }
      .admin-login { min-height: 100vh; display: grid; place-items: center; padding: 24px; background: linear-gradient(180deg, #f7f9fb, #edf2f6); }
      .admin-login-card { width: min(440px, 100%); display: grid; gap: 14px; padding: 26px; border: 1px solid rgb(16 22 27 / 12%); border-radius: 12px; background: #fff; box-shadow: 0 20px 50px rgb(16 22 27 / 10%); }
      .admin-login-card h1, .admin-login-card p { margin: 0; }
      .visual-shell { min-height: 100vh; display: grid; grid-template-columns: 310px minmax(0, 1fr); }
      .visual-sidebar { position: sticky; top: 0; height: 100vh; overflow: auto; padding: 16px; border-right: 1px solid rgb(16 22 27 / 11%); background: #101820; color: #e8eef3; }
      .visual-sidebar h1 { margin: 0 0 12px; font-size: 22px; color: #fff; }
      .visual-sidebar__top { display: grid; gap: 10px; margin-bottom: 16px; }
      .visual-main { min-width: 0; }
      .visual-topbar { position: sticky; top: 0; z-index: 100; display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; align-items: center; padding: 10px 16px; border-bottom: 1px solid rgb(16 22 27 / 11%); background: rgb(255 255 255 / 94%); box-shadow: 0 12px 34px rgb(16 22 27 / 8%); backdrop-filter: blur(14px); }
      .visual-topbar h2 { margin: 0; font-size: 19px; }
      .visual-topbar__left, .visual-topbar__right { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
      .publish-actions { display: flex; flex-wrap: wrap; gap: 8px; align-items: stretch; }
      .publish-action { display: grid; gap: 4px; max-width: 230px; }
      .publish-action .admin-field-hint { max-width: 210px; }
      .visual-canvas { background: #fff; min-height: calc(100vh - 58px); }
      .admin-btn { display: inline-flex; align-items: center; justify-content: center; gap: 6px; min-height: 34px; padding: 7px 10px; border: 1px solid #c4d0da; border-radius: 8px; background: #fff; color: #233445; font-size: 13px; font-weight: 700; line-height: 1; text-decoration: none; cursor: pointer; }
      .admin-btn:hover, .admin-btn:focus-visible { border-color: #95a8b8; background: #f5f8fb; }
      .admin-btn--primary { border-color: #167a50; background: #167a50; color: #fff; }
      .admin-btn--danger { border-color: #b94a48; background: #b94a48; color: #fff; }
      .admin-btn--dark { border-color: rgb(255 255 255 / 18%); background: rgb(255 255 255 / 9%); color: #fff; }
      .admin-btn[disabled] { opacity: .45; cursor: not-allowed; }
      .admin-field { display: grid; gap: 7px; }
      .admin-field label, .admin-field > span, .admin-label { color: #516273; font-size: 13px; font-weight: 800; }
      .admin-field input, .admin-field select, .admin-field textarea, .admin-input, .admin-select { width: 100%; min-width: 0; padding: 9px 10px; border: 1px solid #c9d5df; border-radius: 8px; background: #fff; color: #17212b; }
      .admin-field textarea { min-height: 92px; resize: vertical; }
      .admin-field-hint { margin: 0; color: #687b8d; font-size: 12px; line-height: 1.45; }
      .sidebar-group { display: grid; gap: 8px; margin-bottom: 16px; }
      .sidebar-group h2 { margin: 0; color: rgb(255 255 255 / 66%); font-size: 12px; text-transform: uppercase; letter-spacing: .06em; }
      .sidebar-link { width: 100%; display: flex; justify-content: space-between; gap: 8px; align-items: center; padding: 9px 10px; border: 0; border-radius: 8px; background: transparent; color: inherit; text-align: left; cursor: pointer; }
      .sidebar-link:hover, .sidebar-link.is-active { background: #1b2834; }
      .sidebar-entry { width: 100%; display: grid; gap: 4px; padding: 9px 10px; border: 1px solid rgb(255 255 255 / 9%); border-radius: 8px; background: rgb(255 255 255 / 4%); color: inherit; text-align: left; cursor: pointer; }
      .sidebar-entry:hover, .sidebar-entry.is-active { border-color: rgb(255 255 255 / 22%); background: #1b2834; }
      .sidebar-entry small { color: rgb(232 238 243 / 62%); }
      .admin-alert { display: none; padding: 10px 16px; border-bottom: 1px solid rgb(16 22 27 / 9%); background: #edf7f1; color: #1f6a44; font-weight: 800; }
      .admin-alert.is-visible { display: block; }
      .admin-alert.is-error { background: #fff0ef; color: #a53532; }
      .publish-status { display: none; padding: 12px 16px; border-bottom: 1px solid rgb(16 22 27 / 9%); background: #f7fafb; }
      .publish-status.is-visible { display: grid; gap: 10px; }
      .publish-status__grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 8px; }
      .publish-status__item { display: grid; gap: 3px; min-width: 0; padding: 10px; border: 1px solid #d7e0e7; border-radius: 10px; background: #fff; }
      .publish-status__item span { color: #607386; font-size: 12px; font-weight: 800; }
      .publish-status__item strong, .publish-status__item a { overflow-wrap: anywhere; color: #17212b; font-size: 13px; font-weight: 800; }
      .publish-status__message { margin: 0; color: #516273; font-size: 13px; line-height: 1.45; }
      .publish-status__message.is-error { color: #a53532; font-weight: 800; }
      .admin-status { color: #587085; font-size: 13px; font-weight: 800; }
      .admin-status.is-dirty { color: #9a4f00; }
      .admin-breadcrumbs { align-items: center; background: #ffffff; border-bottom: 1px solid rgb(16 22 27 / 8%); color: #5d7185; display: flex; flex-wrap: wrap; font-size: 13px; gap: 6px; line-height: 1.35; min-height: 40px; padding: 8px 16px; }
      .admin-breadcrumbs:empty { display: none; }
      .admin-breadcrumbs__link { background: transparent; border: 0; color: #24465f; cursor: pointer; font: inherit; font-weight: 800; padding: 2px 0; text-decoration: none; }
      .admin-breadcrumbs__link:hover, .admin-breadcrumbs__link:focus-visible { color: #167a50; text-decoration: underline; }
      .admin-breadcrumbs__separator { color: #9badbd; }
      .admin-breadcrumbs__current { color: #17212b; font-weight: 800; }
      [data-editable] { min-width: 1ch; border-radius: 6px; outline: 1px dashed transparent; outline-offset: 4px; cursor: text; white-space: pre-wrap; }
      [data-editable]:hover { outline-color: rgb(22 122 80 / 38%); background: rgb(22 122 80 / 5%); }
      [data-editable]:focus { outline: 2px solid #18b663; background: rgb(255 255 255 / 94%); color: #17212b !important; }
      [data-editable][data-placeholder]:empty::before { content: attr(data-placeholder); color: #8a98a5; }
      .section--dark [data-editable]:focus, .hero [data-editable]:focus { background: rgb(255 255 255 / 96%); color: #17212b !important; }
      .admin-tools { position: relative; z-index: 20; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; margin-bottom: 18px; }
      .admin-item-tools { display: flex; flex-wrap: wrap; gap: 5px; align-items: center; margin-top: 10px; opacity: .76; }
      .card:hover .admin-item-tools, .product-showcase-card:hover .admin-item-tools, .category-choice-card:hover .admin-item-tools, .object-list-card:hover .admin-item-tools, .admin-item-tools:focus-within { opacity: 1; }
      .admin-badge { display: inline-flex; align-items: center; width: fit-content; min-height: 26px; padding: 4px 8px; border-radius: 999px; background: #edf2f6; color: #425466; font-size: 12px; font-weight: 800; }
      .admin-badge--hidden { background: #fff0ef; color: #9a3835; }
      .admin-muted { color: #607386; }
      .admin-create { padding: 20px 0; background: #f3f7f9; border-block: 1px solid rgb(16 22 27 / 9%); }
      .admin-create-panel { display: grid; gap: 12px; padding: 16px; border: 1px solid #d0dbe4; border-radius: 12px; background: #fff; }
      .admin-create-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; }
      .admin-grid-2 { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
      .admin-grid-3 { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }
      .admin-panel { padding: 20px 0; background: #f7fafb; border-block: 1px solid rgb(16 22 27 / 8%); }
      .admin-panel-card { display: grid; gap: 12px; padding: 16px; border: 1px solid #d0dbe4; border-radius: 12px; background: #fff; }
      .admin-import-page { display: grid; gap: 18px; }
      .admin-import-head { display: grid; gap: 8px; }
      .admin-import-head h1, .admin-import-head p { margin: 0; }
      .admin-import-toolbar { display: flex; flex-wrap: wrap; gap: 10px; align-items: end; }
      .admin-import-toolbar .admin-field { min-width: min(420px, 100%); }
      .admin-import-textarea { min-height: 360px; font-family: ui-monospace, SFMono-Regular, Consolas, 'Liberation Mono', monospace; font-size: 13px; line-height: 1.55; }
      .admin-import-table-wrap { width: 100%; overflow-x: auto; border: 1px solid #d0dbe4; border-radius: 10px; background: #fff; }
      .admin-import-table { width: 100%; min-width: 920px; border-collapse: collapse; font-size: 13px; }
      .admin-import-table th, .admin-import-table td { padding: 9px 10px; border-bottom: 1px solid #e2e9ef; vertical-align: top; text-align: left; }
      .admin-import-table th { background: #f4f7fa; color: #405468; font-weight: 800; }
      .admin-import-table tr:last-child td { border-bottom: 0; }
      .admin-import-list { display: grid; gap: 4px; margin: 0; padding-left: 16px; }
      .admin-import-list--errors { color: #a53532; }
      .admin-import-list--warnings { color: #8a5b00; }
      .admin-import-result { display: flex; flex-wrap: wrap; gap: 8px; }
      .admin-import-result span { display: inline-flex; min-height: 30px; align-items: center; padding: 5px 9px; border-radius: 999px; background: #edf2f6; color: #31485d; font-weight: 800; }
      .admin-import-file-row { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
      .admin-product-bulk { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; align-items: center; margin-bottom: 14px; padding: 12px; border: 1px solid #d0dbe4; border-radius: 10px; background: #f8fbfd; }
      .admin-product-bulk__actions { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }
      .admin-product-select { display: inline-flex; gap: 7px; align-items: center; width: fit-content; min-height: 30px; padding: 5px 8px; border: 1px solid #d0dbe4; border-radius: 8px; background: #fff; color: #31485d; font-size: 13px; font-weight: 800; }
      .admin-product-select input { width: 16px; height: 16px; margin: 0; }
      .admin-block-settings { margin-bottom: 16px; padding: 12px; border: 1px solid #d0dbe4; border-radius: 10px; background: rgb(255 255 255 / 78%); }
      .admin-block-settings summary { cursor: pointer; font-weight: 800; color: #31485d; }
      .admin-block-settings__body { display: grid; gap: 12px; margin-top: 12px; }
      .admin-control-group { display: grid; gap: 10px; padding: 12px; border: 1px solid #e0e7ed; border-radius: 10px; background: #f8fbfd; }
      .admin-control-group > strong { color: #31485d; }
      .admin-gallery-list { display: grid; gap: 10px; }
      .admin-gallery-row { display: grid; grid-template-columns: 120px minmax(0, 1fr); gap: 12px; align-items: start; padding: 12px; border: 1px solid #d8e2eb; border-radius: 10px; background: #fff; }
      .admin-gallery-thumb { aspect-ratio: 4 / 3; overflow: hidden; border-radius: 8px; border: 1px solid #d0dbe4; background: #edf2f6; }
      .admin-gallery-thumb img { display: block; width: 100%; height: 100%; object-fit: cover; }
      .admin-gallery-thumb span { display: grid; width: 100%; height: 100%; place-items: center; padding: 10px; color: #687b8d; font-size: 12px; font-weight: 800; text-align: center; }
      .admin-gallery-meta { display: grid; gap: 3px; }
      .admin-gallery-meta strong { color: #17212b; font-size: 14px; }
      .admin-gallery-meta small { color: #6a7f91; font-size: 12px; overflow-wrap: anywhere; }
      .admin-gallery-technical { margin-top: 2px; }
      .admin-gallery-technical summary { color: #587085; cursor: pointer; font-size: 12px; font-weight: 800; }
      .admin-navigation-page { display: grid; gap: 18px; }
      .admin-navigation-list { display: grid; gap: 12px; }
      .admin-navigation-row { display: grid; grid-template-columns: 44px minmax(0, 1fr); gap: 12px; align-items: start; padding: 14px; border: 1px solid #d0dbe4; border-radius: 12px; background: #fff; }
      .admin-navigation-row.is-hidden { opacity: .62; outline: 1px dashed #b94a48; outline-offset: -4px; }
      .admin-navigation-row__index { display: grid; place-items: center; width: 36px; height: 36px; border-radius: 999px; background: #edf2f6; color: #405468; font-size: 13px; font-weight: 900; }
      .admin-navigation-row .admin-item-tools { grid-column: 2; margin-top: 0; }
      .admin-product-details { display: grid; gap: 18px; }
      .admin-product-panel-grid { display: grid; gap: 14px; }
      .admin-product-media-grid { display: grid; grid-template-columns: minmax(0, 1.15fr) minmax(280px, .85fr); gap: 14px; align-items: start; }
      .admin-product-media-grid .media-caption { min-height: 0; }
      .admin-product-specs { display: grid; gap: 10px; }
      .admin-product-spec-row { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1.3fr); gap: 10px; padding: 12px; border: 1px solid #d8e2eb; border-radius: 10px; background: #fff; }
      .admin-product-spec-row.is-hidden { opacity: .55; outline: 1px dashed #b94a48; outline-offset: -3px; }
      .admin-media-frame { position: relative; overflow: hidden; contain: paint; isolation: isolate; background: linear-gradient(135deg, rgb(237 246 241 / 74%), rgb(255 255 255 / 82%) 42%, rgb(225 232 238 / 72%)), repeating-linear-gradient(135deg, #f0f0f0 0 11px, #e7e7e7 11px 22px); }
      .admin-media-frame--card { aspect-ratio: 4 / 3; }
      .admin-media-frame--wide { aspect-ratio: 16 / 9; }
      .admin-media-frame--hero { position: absolute; inset: 0; }
      .admin-media-frame img, .admin-media-frame video, .admin-media-frame .media-thumb, .admin-media-frame .hero-media__image, .admin-media-frame .hero-media__video { position: absolute; inset: 0; display: block; width: 100%; height: 100%; max-width: none; aspect-ratio: auto; object-fit: cover; pointer-events: none; user-select: none; -webkit-user-drag: none; }
      .admin-media-frame.is-active-crop { outline: 3px solid #18b663; outline-offset: -3px; cursor: grab; touch-action: none; }
      .admin-media-frame.is-active-crop::after { content: 'Перетащите фото внутри рамки'; position: absolute; z-index: 4; right: 12px; bottom: 12px; padding: 6px 9px; border-radius: 999px; background: rgb(16 22 27 / 72%); color: #fff; font-size: 12px; font-weight: 800; pointer-events: none; }
      .admin-media-frame.is-dragging { cursor: grabbing; }
      .admin-media-empty { display: grid; min-height: 100%; place-items: center; padding: 18px; color: #627487; font-size: 14px; font-weight: 800; text-align: center; }
      .admin-media-actions { display: flex; flex-wrap: wrap; gap: 6px; padding: 10px var(--card-padding); border-top: 1px solid rgb(16 22 27 / 8%); background: #fff; }
      .admin-media-actions--settings { align-items: end; }
      .admin-percent-field { display: grid; gap: 6px; min-width: 190px; max-width: 220px; }
      .admin-percent-field span { color: #516273; font-size: 13px; font-weight: 800; }
      .admin-percent-field input { width: 100%; min-width: 0; padding: 9px 10px; border: 1px solid #c9d5df; border-radius: 8px; background: #fff; color: #17212b; font: inherit; }
      .crop-editor { padding: 12px 0 0; }
      .crop-panel { display: grid; gap: 12px; padding: 14px; border: 1px solid #c5d3df; border-radius: 12px; background: #fff; box-shadow: 0 12px 30px rgb(16 22 27 / 10%); }
      .crop-panel h3, .crop-panel p { margin: 0; }
      .range-row { display: grid; gap: 7px; }
      .range-row__head { display: flex; justify-content: space-between; gap: 10px; color: #41556a; font-size: 13px; font-weight: 800; }
      .range-row input[type='range'] { width: 100%; }
      .range-value { color: #17212b; font-variant-numeric: tabular-nums; }
      .page-blocks-grid { display: grid; gap: 16px; }
      .page-blocks-grid--auto { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
      .page-blocks-grid--2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .page-blocks-grid--3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
      .page-blocks-grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
      .page-block-card { min-height: 100%; }
      .page-block-card--graphite { background: var(--color-surface); border-color: var(--color-border); }
      .page-block-panel { display: flex; flex-direction: column; gap: 12px; }
      .page-blocks-columns { margin: 0; padding-left: 18px; column-gap: 20px; row-gap: 8px; }
      .page-blocks-columns--2 { columns: 2; }
      .page-blocks-columns--3 { columns: 3; }
      .page-block-media-layout { display: grid; gap: 20px; align-items: start; }
      .page-block-media-layout .media-block { order: 1; }
      .page-block-media-layout .page-block-panel { order: 0; }
      .page-block-media-layout--left .media-block { order: 0; }
      .page-block-media-layout--left .page-block-panel { order: 1; }
      .page-block-steps { margin: 0; padding-left: 18px; display: grid; gap: 8px; }
      .admin-row-hidden, .admin-card-hidden { opacity: .55; outline: 1px dashed #b94a48; outline-offset: -3px; }
      .home-contact-card .admin-item-tools { margin-top: 12px; }
      @media (min-width: 920px) { .page-block-media-layout { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 1100px) { .visual-shell { grid-template-columns: 1fr; } .visual-sidebar { position: relative; height: auto; } .admin-create-grid, .admin-grid-2, .admin-grid-3, .admin-product-media-grid, .publish-status__grid { grid-template-columns: 1fr; } .admin-navigation-row { grid-template-columns: 1fr; } .admin-navigation-row .admin-item-tools { grid-column: auto; } }
      @media (max-width: 767px) { .page-blocks-grid, .page-blocks-grid--2, .page-blocks-grid--3, .page-blocks-grid--4, .page-blocks-grid--auto { grid-template-columns: 1fr; } .page-blocks-columns { columns: 1; } }
    </style>
  </head>
  <body>
    <div id="loginView" class="admin-login hidden">
      <form id="loginForm" class="admin-login-card">
        <h1>Админка СМУ-1</h1>
        <p class="admin-muted">Войдите, чтобы открыть визуальный редактор.</p>
        <div class="admin-field"><label for="login">Логин</label><input id="login" name="login" required /></div>
        <div class="admin-field"><label for="password">Пароль</label><input id="password" name="password" type="password" required /></div>
        <button class="admin-btn admin-btn--primary" type="submit">Войти</button>
        <p id="loginStatus" class="admin-muted"></p>
      </form>
    </div>

    <div id="appView" class="visual-shell hidden">
      <aside class="visual-sidebar">
        <div class="visual-sidebar__top">
          <h1>Визуальный редактор</h1>
          <a class="admin-btn admin-btn--dark" href={adminHome}>В админку</a>
        </div>
        <div id="collectionNav"></div>
        <div id="entryNav"></div>
      </aside>
      <main class="visual-main">
        <header class="visual-topbar">
          <div class="visual-topbar__left">
            <h2 id="editorTitle">Загрузка...</h2>
            <span id="dirtyStatus" class="admin-status">Нет изменений</span>
          </div>
          <div class="visual-topbar__right">
            <button id="saveBtn" class="admin-btn admin-btn--primary" type="button" disabled>Сохранить</button>
            <div class="publish-actions" aria-label="Публикация сайта">
              <div class="publish-action">
                <button id="publishTestBtn" class="admin-btn" type="button">Опубликовать тестовую версию</button>
                <span class="admin-field-hint">Для проверки изменений. Не требует боевого домена.</span>
              </div>
              <div class="publish-action">
                <button id="publishProductionBtn" class="admin-btn" type="button">Опубликовать на сайт</button>
                <span class="admin-field-hint">Для публикации на основной сайт. Будет доступно после настройки домена и хостинга.</span>
              </div>
            </div>
            <a id="publicLink" class="admin-btn" href="#" target="_blank" rel="noreferrer">Открыть страницу</a>
            <button id="logoutBtn" class="admin-btn" type="button">Выйти</button>
          </div>
        </header>
        <nav id="adminBreadcrumbs" class="admin-breadcrumbs" aria-label="Хлебные крошки"></nav>
        <div id="alertBox" class="admin-alert"></div>
        <div id="publishStatusBox" class="publish-status"></div>
        <div id="workspace" class="visual-canvas"></div>
      </main>
      <input id="uploadInput" class="hidden" type="file" accept="image/*,.svg" multiple />
      <input id="uploadGalleryInput" class="hidden" type="file" accept="image/*,.svg" multiple />
      <input id="uploadVideoInput" class="hidden" type="file" accept="video/mp4,video/webm,.mp4,.webm" />
      <input id="jsonImportInput" class="hidden" type="file" accept="application/json,.json" />
    </div>

    <script type="module" define:vars={{ adminApiBase, baseUrl, adminHome }}>
      const API_BASE = adminApiBase;
      const DEFAULT_MEDIA_VIEW = { fit: 'cover', positionX: 50, positionY: 50, scale: 1 };
      const COLLECTIONS = [
        ['static-pages', 'Страницы сайта'],
        ['product-sections', 'Страницы каталога'],
        ['product-categories', 'Подстраницы каталога'],
        ['products', 'Товары каталога'],
        ['services', 'Проектные страницы'],
        ['projects', 'Выполненные объекты'],
        ['jobs', 'Вакансии'],
        ['site-settings', 'Контакты и настройки']
      ];
      const COLLECTION_LABELS = { ...Object.fromEntries(COLLECTIONS), navigation: 'Навигация / Шапка сайта', 'data-import': 'Импорт данных' };
      const IMPORT_SLUG_RE = /^[a-z0-9]+(?:-[a-z0-9]+)*$/;
      const IMPORT_MODES = [
        ['upsert', 'Создать новые и обновить существующие по slug'],
        ['create-only', 'Создать только новые'],
        ['update-only', 'Обновить только существующие'],
