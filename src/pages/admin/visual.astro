      function stripPresentationFields(value) {
        if (Array.isArray(value)) return value.map((item) => stripPresentationFields(item));
        if (!value || typeof value !== 'object') return value;
        return Object.fromEntries(Object.entries(value)
          .filter(([key]) => !PRESENTATION_FIELD_KEYS.has(key))
          .map(([key, item]) => [key, stripPresentationFields(item)]));
      }

      function toSrc(src) {
        if (!src) return '';
        if (/^https?:\/\//i.test(src)) return src;
        const normBase = baseUrl.endsWith('/') ? baseUrl : `${baseUrl}/`;
        const clean = src.startsWith('/') ? src.slice(1) : src;
        return `${normBase}${clean}`;
      }

      function fileNameFromPath(src) {
        const clean = String(src || '').split(/[?#]/)[0].replace(/\/+$/, '');
        return clean.split('/').pop() || clean || '';
      }

      function mediaMimeType(src) {
        return String(src || '').toLowerCase().endsWith('.webm') ? 'video/webm' : 'video/mp4';
      }

      function cleanMediaPath(value) {
        return typeof value === 'string' ? value.trim() : '';
      }

      function getPath(record, path) {
        return String(path).split('.').reduce((cursor, part) => cursor?.[part], record?.draft);
      }

      function setPath(record, path, value) {
        const parts = String(path).split('.');
        let cursor = record.draft;
        for (let i = 0; i < parts.length - 1; i += 1) {
          const part = parts[i];
          if (cursor[part] === undefined || cursor[part] === null) cursor[part] = /^\d+$/.test(parts[i + 1]) ? [] : {};
          cursor = cursor[part];
        }
        cursor[parts[parts.length - 1]] = value;
      }

      function editable(ref, path, placeholder = 'Введите текст', singleLine = false, valueType = 'string') {
        return `contenteditable="plaintext-only" spellcheck="true" data-editable data-ref="${esc(ref)}" data-path="${esc(path)}" data-placeholder="${esc(placeholder)}" data-value-type="${esc(valueType)}" ${singleLine ? 'data-single-line="true"' : ''}`;
      }

      function getMediaView(view) {
        const safe = { ...DEFAULT_MEDIA_VIEW, ...(view || {}) };
        return {
          fit: safe.fit === 'contain' ? 'contain' : 'cover',
          positionX: clamp(safe.positionX, 0, 100),
          positionY: clamp(safe.positionY, 0, 100),
          scale: clamp(safe.scale, 1, 3)
        };
      }

      function mediaStyle(view) {
        const safe = getMediaView(view);
        return `object-fit:${safe.fit};object-position:${safe.positionX}% ${safe.positionY}%;transform:scale(${safe.scale});transform-origin:center;`;
      }

      function heroOverlayPercent(value) {
        return clampNumber(value, 0, 100, 100);
      }

      function heroOverlayStyle(value) {
        return `--hero-overlay-strength:${heroOverlayPercent(value) / 100};`;
      }

      function renumber(items = []) {
        items.forEach((item, index) => {
          if (item && typeof item === 'object' && 'order' in item) item.order = (index + 1) * 10;
        });
      }

      async function api(path, options = {}) {
        let response;
        try {
          response = await fetch(`${API_BASE}${path}`, {
            ...options,
            credentials: 'include',
            headers: options.body instanceof FormData ? (options.headers || {}) : { 'Content-Type': 'application/json', ...(options.headers || {}) }
          });
        } catch {
          throw new Error('Не удалось подключиться к backend API. Запустите npm run admin:api.');
        }
        const data = await response.json().catch(() => ({}));
        if (!response.ok) {
          const error = new Error(data.error || `HTTP ${response.status}`);
          error.data = data;
          throw error;
        }
        return data;
      }

      function filenameFromDisposition(value) {
        const match = String(value || '').match(/filename="?([^";]+)"?/i);
        return match?.[1] || `smu1-catalog-export-${new Date().toISOString().slice(0, 10)}.json`;
      }

      async function downloadCatalogExport() {
        let response;
        try {
          response = await fetch(`${API_BASE}/export-catalog`, { credentials: 'include' });
        } catch {
          throw new Error('Не удалось подключиться к backend API. Запустите npm run admin:api.');
        }
        if (!response.ok) {
          const data = await response.json().catch(() => ({}));
          throw new Error(data.error || `HTTP ${response.status}`);
        }
        const blob = await response.blob();
        const filename = filenameFromDisposition(response.headers.get('Content-Disposition'));
        const url = URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;
        link.download = filename;
        document.body.append(link);
        link.click();
        link.remove();
        URL.revokeObjectURL(url);
      }

