---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DirectContactBlock from '../components/DirectContactBlock.astro';
import PageBlocksRenderer from '../components/PageBlocksRenderer.astro';
import { withBase } from '../utils/withBase';

const page = (await getCollection('static-pages')).find(({ data }) => data.slug === 'custom-order')?.data;

if (!page) {
  throw new Error('static-pages collection must contain custom-order.json.');
}
---
<BaseLayout title={page.seoTitle} description={page.seoDescription}>
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: page.title }]} />
    </div>
  </div>

  <Hero
    kicker={page.heroKicker}
    className="hero--service"
    title={page.heroTitle}
    description={page.heroDescription}
  />

  <PageBlocksRenderer pageBlocks={page.pageBlocks ?? []} />

  <DirectContactBlock title={page.contactTitle} description={page.contactDescription} />
</BaseLayout>
