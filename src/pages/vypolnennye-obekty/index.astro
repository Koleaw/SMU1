---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ObjectCardCarousel from '../../components/ObjectCardCarousel.astro';
import { getProjectImages } from '../../utils/projectImages';
import { withBase } from '../../utils/withBase';

const objects = (await getCollection('projects'))
  .map(({ data }) => data)
  .filter((item) => item.isActive)
  .sort((a, b) => a.order - b.order);

const displayObjects = objects.map((obj) => {
  const meta = [obj.city, obj.year].filter(Boolean).join(', ');
  const workType = obj.workType || obj.category || obj.shortCategory || obj.shortDescription || '';
  const description = obj.summary || obj.task || obj.whatWasDone || obj.shortDescription || '';

  return {
    ...obj,
    href: withBase(`/vypolnennye-obekty/${obj.slug}/`),
    images: getProjectImages(obj),
    meta,
    workType,
    description
  };
});
---
<BaseLayout title="Выполненные объекты — СМУ-1" description="Подтверждаем опыт через реальные объекты: задача, выполненные работы, результат.">
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Выполненные объекты' }]} />
    </div>
  </div>

  <Hero kicker="Доверительный контур" className="hero--trust hero--catalog-clean objects-hero" title="Выполненные объекты" />
  <section class="section objects-list-section">
    <div class="container object-list-grid">
      {displayObjects.map((obj) => (
        <ObjectCardCarousel
          title={obj.title}
          href={obj.href}
          images={obj.images}
          meta={obj.meta}
          workType={obj.workType}
          description={obj.description}
        />
      ))}
    </div>
  </section>
</BaseLayout>
