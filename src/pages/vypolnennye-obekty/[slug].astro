---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import objects from '../../data/objects.json';
import { withBase } from '../../utils/withBase';

export function getStaticPaths() {
  return objects.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
---
<BaseLayout title={`${item.title} — СМУ-1`} description={item.task}>
  <div class="breadcrumbs-bar">
    <div class="container">
      <Breadcrumbs items={[{ title: 'Главная', href: withBase('/') }, { title: 'Выполненные объекты', href: withBase('/vypolnennye-obekty/') }, { title: item.title }]} />
    </div>
  </div>

  <Hero
    kicker="Кейс объекта"
    className="hero--trust"
    title={item.title}
    description={`${item.workType} · ${item.city}, ${item.region}`}
    primaryLabel="Обсудить похожую задачу"
    secondaryLabel="Все объекты"
    secondaryHref={withBase('/vypolnennye-obekty/')}
  />

  <section class="section">
    <div class="container object-hero-media">
      <article class="media-block media-block--objects media-block--strong">
        <img class="media-thumb" src={withBase(item.gallery[0])} alt={item.title} />
        <p class="media-caption">Ключевой кадр объекта будет заменен на фактическое фото в мае.</p>
      </article>
      <article class="media-block media-block--objects">
        <img class="media-thumb" src={withBase(item.gallery[1] ?? item.gallery[0])} alt={item.title} />
        <p class="media-caption">Второй кадр: детали реализации и результат на площадке.</p>
      </article>
    </div>
  </section>

  <section class="section section--soft">
    <div class="container object-story-grid">
      <article class="card"><h2>Задача</h2><p class="lead">{item.task}</p></article>
      <article class="card"><h2>Что сделали</h2><p class="lead">{item.whatWasDone}</p></article>
      <article class="card"><h2>Результат</h2><p class="lead">{item.result}</p></article>
    </div>
  </section>
</BaseLayout>
