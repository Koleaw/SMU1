{
  "$ref": "#/definitions/product-sections",
  "definitions": {
    "product-sections": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "heroTitle": {
          "type": "string"
        },
        "heroDescription": {
          "type": "string"
        },
        "order": {
          "type": "number"
        },
        "showOnHome": {
          "type": "boolean"
        },
        "isActive": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "catalog-hub",
            "custom-direction"
          ]
        },
        "showInMenu": {
          "type": "boolean"
        },
        "menuTitle": {
          "type": "string"
        },
        "heroKicker": {
          "type": "string"
        },
        "showBadge": {
          "type": "boolean"
        },
        "heroMediaVideo": {
          "type": "string"
        },
        "heroMediaVideoMobile": {
          "type": "string"
        },
        "heroMediaPoster": {
          "type": "string"
        },
        "heroMediaPosterMobile": {
          "type": "string"
        },
        "heroOverlayOpacity": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "heroTitleStyle": {
          "type": "object",
          "properties": {
            "fontSize": {
              "type": "string",
              "enum": [
                "small",
                "base",
                "large",
                "xl",
                "2xl"
              ]
            },
            "fontWeight": {
              "type": "string",
              "enum": [
                "normal",
                "medium",
                "semibold",
                "bold"
              ]
            },
            "italic": {
              "type": "boolean"
            },
            "align": {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            "lineHeight": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "relaxed"
              ]
            },
            "color": {
              "type": "string",
              "enum": [
                "primary",
                "secondary",
                "white",
                "accent"
              ]
            }
          },
          "additionalProperties": false
        },
        "heroDescriptionStyle": {
          "$ref": "#/definitions/product-sections/properties/heroTitleStyle"
        },
        "heroLayout": {
          "type": "object",
          "properties": {
            "width": {
              "type": "string",
              "enum": [
                "narrow",
                "medium",
                "wide",
                "full"
              ]
            },
            "widthPercent": {
              "type": "number",
              "minimum": 30,
              "maximum": 100
            },
            "maxWidth": {
              "type": "number",
              "minimum": 280,
              "maximum": 1200
            },
            "position": {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            "padding": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "large"
              ]
            },
            "verticalPadding": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "large"
              ]
            }
          },
          "additionalProperties": false
        },
        "image": {
          "type": "string"
        },
        "imageView": {
          "type": "object",
          "properties": {
            "fit": {
              "type": "string",
              "enum": [
                "cover",
                "contain"
              ]
            },
            "positionX": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "positionY": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "scale": {
              "type": "number",
              "minimum": 1,
              "maximum": 3
            }
          },
          "required": [
            "fit",
            "positionX",
            "positionY",
            "scale"
          ],
          "additionalProperties": false
        },
        "gallery": {
          "type": "array",
          "items": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "object",
                "properties": {
                  "src": {
                    "type": "string"
                  },
                  "alt": {
                    "type": "string"
                  },
                  "caption": {
                    "type": "string"
                  }
                },
                "required": [
                  "src"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "galleryIntro": {
          "type": "string"
        },
        "placeholderLabel": {
          "type": "string"
        },
        "contactTitle": {
          "type": "string"
        },
        "contactDescription": {
          "type": "string"
        },
        "contactTelegramLabel": {
          "type": "string"
        },
        "contactEmailLabel": {
          "type": "string"
        },
        "contactPhoneLabel": {
          "type": "string"
        },
        "seoTitle": {
          "type": "string"
        },
        "seoDescription": {
          "type": "string"
        },
        "pageBlocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "title": {
                "type": "string"
              },
              "intro": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "theme": {
                "type": "string",
                "enum": [
                  "dark",
                  "light",
                  "graphite"
                ]
              },
              "background": {
                "$ref": "#/definitions/product-sections/properties/pageBlocks/items/properties/theme"
              },
              "grid": {
                "type": "string",
                "enum": [
                  "auto",
                  "2",
                  "3",
                  "4"
                ]
              },
              "columns": {
                "type": "number",
                "enum": [
                  2,
                  3,
                  4
                ]
              },
              "isActive": {
                "type": "boolean"
              },
              "order": {
                "type": "number"
              },
              "sectionId": {
                "type": "string"
              },
              "items": {
                "type": "array"
              },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "title": {
                      "type": "string"
                    },
                    "text": {
                      "type": "string"
                    },
                    "order": {
                      "type": "number"
                    },
                    "isActive": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "title",
                    "order"
                  ],
                  "additionalProperties": true
                }
              },
              "media": {
                "type": "string"
              },
              "image": {
                "type": "string"
              },
              "video": {
                "type": "string"
              },
              "poster": {
                "type": "string"
              },
              "placeholderLabel": {
                "type": "string"
              },
              "mediaPosition": {
                "type": "string",
                "enum": [
                  "left",
                  "right"
                ]
              },
              "mediaView": {
                "$ref": "#/definitions/product-sections/properties/imageView"
              },
              "buttonLabel": {
                "type": "string"
              },
              "buttonHref": {
                "type": "string"
              },
              "textWidth": {
                "type": "string"
              },
              "textAlign": {
                "type": "string",
                "enum": [
                  "left",
                  "center",
                  "right"
                ]
              },
              "titleSize": {
                "type": "string"
              },
              "textSize": {
                "type": "string"
              },
              "textWeight": {
                "type": [
                  "string",
                  "number"
                ]
              },
              "textItalic": {
                "type": "boolean"
              },
              "textStyle": {
                "$ref": "#/definitions/product-sections/properties/heroTitleStyle"
              },
              "titleStyle": {
                "$ref": "#/definitions/product-sections/properties/heroTitleStyle"
              },
              "layout": {
                "$ref": "#/definitions/product-sections/properties/heroLayout"
              },
              "paddingTop": {
                "type": "string"
              },
              "paddingBottom": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "order"
            ],
            "additionalProperties": true
          }
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "slug",
        "shortDescription",
        "heroTitle",
        "heroDescription",
        "order",
        "showOnHome",
        "isActive",
        "mode",
        "image",
        "placeholderLabel",
        "seoTitle",
        "seoDescription"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}