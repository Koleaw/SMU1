{
  "$ref": "#/definitions/products",
  "definitions": {
    "products": {
      "type": "object",
      "properties": {
        "title": {
          "type": "string"
        },
        "slug": {
          "type": "string"
        },
        "productCategorySlug": {
          "type": "string"
        },
        "sku": {
          "type": "string"
        },
        "shortDescription": {
          "type": "string"
        },
        "leadText": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "materials": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "colors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": {
                "type": "string"
              },
              "value": {
                "type": "string"
              },
              "order": {
                "type": "number"
              },
              "isActive": {
                "type": "boolean"
              }
            },
            "required": [
              "label",
              "value"
            ],
            "additionalProperties": false
          }
        },
        "features": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "priceMode": {
          "type": "string",
          "enum": [
            "from",
            "on_request",
            "none"
          ]
        },
        "priceFrom": {
          "type": [
            "number",
            "null"
          ]
        },
        "currency": {
          "type": "string"
        },
        "image": {
          "type": "string"
        },
        "imageView": {
          "type": "object",
          "properties": {
            "fit": {
              "type": "string",
              "enum": [
                "cover",
                "contain"
              ]
            },
            "positionX": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "positionY": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "scale": {
              "type": "number",
              "minimum": 1,
              "maximum": 3
            }
          },
          "required": [
            "fit",
            "positionX",
            "positionY",
            "scale"
          ],
          "additionalProperties": false
        },
        "gallery": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "placeholderLabel": {
          "type": "string"
        },
        "customizationItems": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "showDeliveryBlock": {
          "type": "boolean"
        },
        "deliveryText": {
          "type": "string"
        },
        "relatedProductSlugs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "showCustomProjectBlock": {
          "type": "boolean"
        },
        "customProjectTitle": {
          "type": "string"
        },
        "customProjectText": {
          "type": "string"
        },
        "descriptionTextStyle": {
          "type": "object",
          "properties": {
            "fontSize": {
              "type": "string",
              "enum": [
                "small",
                "base",
                "large",
                "xl",
                "2xl"
              ]
            },
            "fontWeight": {
              "type": "string",
              "enum": [
                "normal",
                "medium",
                "semibold",
                "bold"
              ]
            },
            "italic": {
              "type": "boolean"
            },
            "align": {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            "lineHeight": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "relaxed"
              ]
            },
            "color": {
              "type": "string",
              "enum": [
                "primary",
                "secondary",
                "white",
                "accent"
              ]
            }
          },
          "additionalProperties": false
        },
        "descriptionLayout": {
          "type": "object",
          "properties": {
            "width": {
              "type": "string",
              "enum": [
                "narrow",
                "medium",
                "wide",
                "full"
              ]
            },
            "widthPercent": {
              "type": "number",
              "minimum": 30,
              "maximum": 100
            },
            "maxWidth": {
              "type": "number",
              "minimum": 280,
              "maximum": 1200
            },
            "position": {
              "type": "string",
              "enum": [
                "left",
                "center",
                "right"
              ]
            },
            "padding": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "large"
              ]
            },
            "verticalPadding": {
              "type": "string",
              "enum": [
                "compact",
                "normal",
                "large"
              ]
            }
          },
          "additionalProperties": false
        },
        "order": {
          "type": "number"
        },
        "isActive": {
          "type": "boolean"
        },
        "showInCatalog": {
          "type": "boolean"
        },
        "seoTitle": {
          "type": "string"
        },
        "seoDescription": {
          "type": "string"
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "title",
        "slug",
        "productCategorySlug",
        "shortDescription",
        "leadText",
        "priceMode",
        "priceFrom",
        "currency",
        "image",
        "placeholderLabel",
        "order",
        "isActive",
        "showInCatalog",
        "seoTitle",
        "seoDescription"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}